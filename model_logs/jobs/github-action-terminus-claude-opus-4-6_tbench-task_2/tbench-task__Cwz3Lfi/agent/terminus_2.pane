[?2004l     1	package main
     2	
     3	import (
     4		"database/sql"
     5		"log"
     6		"sync"
     7		"time"
     8	)
     9	
    10	type WorkerPool struct {
    11		mu         sync.Mutex
    12		maxWorkers int
    13		active     int
    14		db         *sql.DB
    15		quit       chan struct{}
    16	}
    17	
    18	func NewWorkerPool(max int, db *sql.DB) *WorkerPool {
    19		return &WorkerPool{
    20			maxWorkers: max,
    21			db:         db,
    22			quit:       make(chan struct{}),
    23		}
    24	}
    25	
    26	func (p *WorkerPool) SetMax(n int) {
    27		p.mu.Lock()
    28		defer p.mu.Unlock()
    29		log.Printf("pool: max_workers %d -> %d", p.maxWorkers, n)
    30		p.maxWorkers = n
    31	}
    32	
    33	func (p *WorkerPool) Start() {
    34		go p.poll()
    35	}
    36	
    37	func (p *WorkerPool) Stop() {
    38		close(p.quit)
    39	}
    40	
    41	func (p *WorkerPool) poll() {
    42		ticker := time.NewTicker(500 * time.Millisecond)
    43		defer ticker.Stop()
    44		for {
    45			select {
    46			case <-p.quit:
    47				return
    48			case <-ticker.C:
    49				p.mu.Lock()
    50				slots := p.maxWorkers - p.active
    51				p.mu.Unlock()
    52	
    53				for i := 0; i < slots; i++ {
    54					job, err := p.claimNextPending()
    55					if err != nil {
    56						log.Printf("poll claim error: %v", err)
    57						break
    58					}
    59					if job == nil {
    60						break
    61					}
    62					p.mu.Lock()
    63					p.active++
    64					p.mu.Unlock()
    65	
    66					go func(jobID int) {
    67						defer func() {
    68							p.mu.Lock()
    69							p.active--
    70							p.mu.Unlock()
    71						}()
    72						p.process(jobID)
    73					}(job.id)
    74				}
    75			}
    76		}
    77	}
    78	
    79	type pendingJob struct {
    80		id      int
    81		jobType string
    82	}
    83	
    84	func (p *WorkerPool) claimNextPending() (*pendingJob, error) {
    85		tx, err := p.db.Begin()
    86		if err != nil {
    87			return nil, err
    88		}
    89		defer tx.Rollback() //nolint:errcheck
    90	
    91		var j pendingJob
    92		err = tx.QueryRow(`
    93			SELECT id, type FROM jobs
    94			WHERE status = 'pending'
    95			ORDER BY priority DESC, created_at ASC
    96			LIMIT 1
    97		`).Scan(&j.id, &j.jobType)
    98		if err == sql.ErrNoRows {
    99			return nil, nil
   100		}
   101		if err != nil {
   102			return nil, err
   103		}
   104	
   105		if _, err = tx.Exec(
   106			"UPDATE jobs SET status='running', updated_at=? WHERE id=?",
   107			time.Now(), j.id,
   108		); err != nil {
   109			return nil, err
   110		}
   111		return &j, tx.Commit()
   112	}
   113	
   114	func (p *WorkerPool) process(jobID int) {
   115		time.Sleep(2 * time.Second)
   116	
   117		var status string
   118		if err := p.db.QueryRow("SELECT status FROM jobs WHERE id=?", jobID).Scan(&status); err != nil {
   119			log.Printf("pool: error reading job %d status: %v", jobID, err)
   120			return
   121		}
   122		if status != "running" {
   123			return
   124		}
   125	
   126		if _, err := p.db.Exec(
   127			"UPDATE jobs SET status='completed', updated_at=? WHERE id=?",
   128			time.Now(), jobID,
   129		); err != nil {
   130			log.Printf("pool: error completing job %d: %v", jobID, err)
   131			p.db.Exec( //nolint:errcheck
   132				"UPDATE jobs SET status='failed', updated_at=? WHERE id=?",
   133				time.Now(), jobID,
   134			)
   135		}
   136	}
