[747.067736, "i", "# Verify submit IDs always appear in order 1, 2, 3, ..., N in the log\npython3 -c \"\nimport json\nfor f in ['/tmp/a.json', '/tmp/b.json', '/tmp/d1.json', '/tmp/steady.json', '/tmp/basic_steady_b.json', '/tmp/s2_steady_b.json']:\n    data = json.load(open(f))\n    submits = [e['id'] for e in data['events'] if e['kind'] == 'submit']\n    assert submits == list(range(1, len(submits)+1)), f'{f}: submits not in order'\n    print(f'{f}: submits in order 1..{len(submits)}')\n\"\n"]
