[745.059783, "i", "arena --scenario basic --profile steady --order b_then_a --out /tmp/basic_steady_b.json && python3 -c \"\nimport json\nfrom collections import defaultdict, Counter\ndata = json.load(open('/tmp/basic_steady_b.json'))\nassert data['scenario'] == 'basic'\nassert data['profile'] == 'steady'\nevents = data['events']\nsubmits = [e for e in events if e['kind'] == 'submit']\ncompletes = [e for e in events if e['kind'] == 'complete']\nnotifies = [e for e in events if e['kind'] == 'notify']\nassert len(submits) == len(completes) == len(notifies)\nsubmit_ids = set(e['id'] for e in submits)\nassert submit_ids == set(range(1, len(submits)+1))\nassert len(Counter((e['kind'], e['id']) for e in events)) == len(events)  # no dups\npositions = defaultdict(dict)\nfor i, e in enumerate(events):\n    positions[e['id']][e['kind']] = i\nfor id_, pos in positions.items():\n    assert pos['submit'] < pos['complete'] < pos['notify']\nprint(f'basic/steady/b_then_a: PASS ({len(submits)} ids)')\n\"\n"]
[745.060222, "o", "arena --scenario basic --profile steady --order b_then_a --out /tmp/basic_steady_b.json && python3 -c \"\r\n\u001b[?2004l\r"]
