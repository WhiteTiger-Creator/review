[645.07537, "i", "python3 -c \"\nimport json\ndata = json.load(open('/app/output/report.json'))\nevents = data['events']\n# Check ordering: for each id, submit < complete < notify in position\nfrom collections import defaultdict\npositions = defaultdict(dict)\nfor i, e in enumerate(events):\n    positions[e['id']][e['kind']] = i\nok = True\nfor id_, pos in positions.items():\n    if 'submit' not in pos or 'complete' not in pos or 'notify' not in pos:\n        print(f'ID {id_} missing events: {list(pos.keys())}')\n        ok = False\n        continue\n    if not (pos['submit'] < pos['complete'] < pos['notify']):\n        print(f'ID {id_} ordering wrong: s={pos[\\\"submit\\\"]} c={pos[\\\"complete\\\"]} n={pos[\\\"notify\\\"]}')\n        ok = False\nprint(f'All ordering correct: {ok}')\n\"\n"]
[645.075724, "o", "python3 -c \"\r\n\u001b[?2004l\r\u001b[?2004h> import json\r\n\u001b[?2004l\r"]
[645.075891, "o", "\u001b[?2004h> "]
[645.076859, "o", "data = json.load(open('/app/output/report.json'))\r\n\u001b[?2004l\r"]
[645.079551, "o", "\u001b[?2004h> events = data['events']\r\n\u001b[?2004l\r\u001b[?2004h> # Check ordering: for each id, submit < complete < notify in position\r\n\u001b[?2004l\r\u001b[?2004h> from collections import defaultdict\r\n\u001b[?2004l\r\u001b[?2004h> positions = defaultdict(dict)\r\n\u001b[?2004l\r\u001b[?2004h> for i, e in enumerate(events):\r\n\u001b[?2004l\r\u001b[?2004h>     positions[e['id']][e['kind']] = i\r\n\u001b[?2004l\r\u001b[?2004h> ok = True\r\n\u001b[?2004l\r\u001b[?2004h> for id_, pos in positions.items():\r\n\u001b[?2004l\r\u001b[?2004h>     if 'submit' not in pos or 'complete' not in pos or 'notify' not in pos:\r\n\u001b[?2004l\r\u001b[?2004h>         print(f'ID {id_} missing events: {list(pos.keys())}')\r\n\u001b[?2004l\r"]
[645.079629, "o", "\u001b[?2004h>         ok = False\r\n\u001b[?2004l\r"]
[645.079682, "o", "\u001b[?2004h> "]
[645.07972, "o", "        continue\r\n"]
[645.079767, "o", "\u001b[?2004l\r\u001b[?2004h"]
[645.079785, "o", "> "]
[645.079984, "o", "    if not (pos['submit'] < pos['complete'] < pos['notify']):\r\n\u001b[?2004l\r"]
[645.080008, "o", "\u001b[?2004h"]
[645.080021, "o", "> "]
[645.08035, "o", "        print(f'ID {id_} ordering wrong: s={pos[\\\"submit\\\"]} c={pos[\\\"complete\\\"]} n={pos[\\\"notify\\\"]}')\r\n\u001b[?2004l\r"]
[645.080412, "o", "\u001b[?2004h> "]
[645.080477, "o", "        ok = False\r\n\u001b[?2004l\r"]
[645.080613, "o", "\u001b[?2004h> "]
[645.080817, "o", "print(f'All ordering correct: {ok}')\r\n\u001b[?2004l\r\u001b[?2004h> \"\r\n\u001b[?2004l\r"]
[645.096473, "o", "All ordering correct: True\r\n"]
