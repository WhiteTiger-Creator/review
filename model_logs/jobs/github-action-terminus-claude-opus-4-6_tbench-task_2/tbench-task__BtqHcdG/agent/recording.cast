[492.192993, "o", "#pragma once\r\n\r\n#include \"core/vec_ev.h\"\r\n#include \"runtime/profile.h\"\r\n#include \"runtime/script.h\"\r\n\r\n#include <stdint.h>\r\n\r\n// Writes report.json as described in instruction.md.\r\nint tb_report_write_json(const char *path, tb_scenario scn, tb_profile prof, const tb_vec_ev *evs);\r\n\r\n#pragma once\r\n\r\n#include <stdbool.h>\r\n#include <stdint.h>\r\n\r\ntypedef enum {\r\n  TB_OK = 0,\r\n  TB_ERR_IO = 1,\r\n  TB_ERR_BAD_ARG = 2,\r\n  TB_ERR_CORRUPT = 3,\r\n  TB_ERR_OOM = 4,\r\n} tb_status;\r\n\r\nconst char *tb_status_str(tb_status st);\r\n\r\n\u001b[?2004hroot@34094591dd9d:/app# "]
