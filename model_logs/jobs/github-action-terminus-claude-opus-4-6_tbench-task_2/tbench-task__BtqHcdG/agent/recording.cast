[19.960505, "o", "#include \"runtime/runtime.h\"\r\n\r\n#include \"core/idgen.h\"\r\n#include \"logic/ingest.h\"\r\n#include \"logic/link.h\"\r\n#include \"logic/merge.h\"\r\n#include \"logic/nudge.h\"\r\n#include \"logic/settle.h\"\r\n\r\n#include <stdio.h>\r\n#include <string.h>\r\n\r\ntb_status tb_rt_init(tb_rt *rt, const char *journal_path) {\r\n  if (!rt || !journal_path)\r\n    return TB_ERR_BAD_ARG;\r\n  memset(rt, 0, sizeof(*rt));\r\n\r\n  if (!tb_map_u64_init(&rt->token_to_id, 128))\r\n    return TB_ERR_OOM;\r\n  if (!tb_map_u64_init(&rt->token_done, 128))\r\n    return TB_ERR_OOM;\r\n  if (!tb_q64_init(&rt->in_q, 4096))\r\n    return TB_ERR_OOM;\r\n  if (!tb_q64_init(&rt->done_a, 4096))\r\n    return TB_ERR_OOM;\r\n  if (!tb_q64_init(&rt->done_b, 4096))\r\n    return TB_ERR_OOM;\r\n  if (!tb_q64_init(&rt->notify_q, 4096))\r\n    return TB_ERR_OOM;\r\n  if (!tb_vec_ev_init(&rt->evlog, 2048))\r\n    return TB_ERR_OOM;\r\n\r\n  rt->gen = 1;\r\n  rt->cursor = 1;\r\n"]
[19.960715, "o", "  rt->attached = true;\r\n  rt->journal_path = journal_path;\r\n  return TB_OK;\r\n}\r\n\r\nvoid tb_rt_free(tb_rt *rt) {\r\n  if (!rt)\r\n    return;\r\n  tb_map_u64_free(&rt->token_to_id);\r\n  tb_map_u64_free(&rt->token_done);\r\n  tb_q64_free(&rt->in_q);\r\n  tb_q64_free(&rt->done_a);\r\n  tb_q64_free(&rt->done_b);\r\n  tb_q64_free(&rt->notify_q);\r\n  tb_vec_ev_free(&rt->evlog);\r\n}\r\n\r\nconst tb_vec_ev *tb_rt_events(const tb_rt *rt) { return &rt->evlog; }\r\n\r\nstatic tb_status maybe_detach_attach(tb_rt *rt, const tb_script *sc, uint32_t tick) {\r\n  if (sc->detach_at && tick == sc->detach_at) {\r\n    return tb_link_detach(rt, tick);\r\n  }\r\n  if (sc->detach_at && tick == sc->detach_at + sc->detach_len) {\r\n    return tb_link_attach(rt, tick);\r\n  }\r\n  if (sc->detach2_at && tick == sc->detach2_at) {\r\n    return tb_link_detach(rt, tick);\r\n  }\r\n  if (sc->detach2_at && tick == sc->detach2_at + sc->detach2_len) {\r\n    return tb_link_attach(rt, tick);\r\n  }\r\n  return TB_OK;\r\n}\r\n\r\ntb_status tb_rt_run(tb_rt *rt, tb_scenario scn, tb_profile prof, tb_ord"]
[19.960999, "o", "er ord, uint32_t seed) {\r\n  (void)seed;\r\n  if (!rt)\r\n    return TB_ERR_BAD_ARG;\r\n\r\n  tb_script sc = {0};\r\n  if (!tb_script_for(scn, &sc))\r\n    return TB_ERR_BAD_ARG;\r\n\r\n  tb_stamp last = {0};\r\n  bool found = false;\r\n  tb_status st = journal_load_last(rt->journal_path, &last, &found);\r\n  if (st != TB_OK)\r\n    return st;\r\n  if (found) {\r\n    rt->gen = last.gen + 1;\r\n    rt->cursor = last.cursor;\r\n  }\r\n\r\n  for (uint32_t tick = 0; tick < sc.ticks; tick++) {\r\n    st = maybe_detach_attach(rt, &sc, tick);\r\n    if (st != TB_OK)\r\n      return st;\r\n\r\n    uint32_t submitted = 0;\r\n    st = tb_ingest_tick(rt, prof, tick, &submitted);\r\n    if (st != TB_OK)\r\n      return st;\r\n\r\n    st = tb_settle_tick(rt, tick);\r\n    if (st != TB_OK)\r\n      return st;\r\n\r\n    st = tb_merge_drain(rt, tick, ord);\r\n    if (st != TB_OK)\r\n      return st;\r\n\r\n    st = tb_nudge_drain(rt, tick);\r\n    if (st != TB_OK)\r\n      return st;\r\n  }\r\n\r\n  // Final drain to avoid leaving work in queues.\r\n  for (uint32_t i = 0; i < 16; i++) {\r\n    st = tb_settle"]
[19.961029, "o", "_tick(rt, sc.ticks + i);\r\n    if (st != TB_OK)\r\n      return st;\r\n    st = tb_merge_drain(rt, sc.ticks + i, ord);\r\n    if (st != TB_OK)\r\n      return st;\r\n    st = tb_nudge_drain(rt, sc.ticks + i);\r\n    if (st != TB_OK)\r\n      return st;\r\n  }\r\n\r\n  return TB_OK;\r\n}\r\n\r\n\u001b[?2004hroot@34094591dd9d:/app# "]
