[492.505415, "o", "#include \"tb_err.h\"\r\n\r\nconst char *tb_status_str(tb_status st) {\r\n  switch (st) {\r\n  case TB_OK:\r\n    return \"ok\";\r\n  case TB_ERR_IO:\r\n    return \"io\";\r\n  case TB_ERR_BAD_ARG:\r\n    return \"bad_arg\";\r\n  case TB_ERR_CORRUPT:\r\n    return \"corrupt\";\r\n  case TB_ERR_OOM:\r\n    return \"oom\";\r\n  default:\r\n    return \"unknown\";\r\n  }\r\n}\r\n\r\n"]
