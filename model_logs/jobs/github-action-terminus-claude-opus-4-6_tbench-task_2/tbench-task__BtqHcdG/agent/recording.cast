[701.78774, "i", "python3 -c \"\nimport json\nfrom collections import defaultdict\n\ndef check(path):\n    data = json.load(open(path))\n    events = data['events']\n    positions = defaultdict(dict)\n    for i, e in enumerate(events):\n        positions[e['id']][e['kind']] = i\n    for id_, pos in positions.items():\n        assert 'submit' in pos and 'complete' in pos and 'notify' in pos, f'{path}: ID {id_} missing'\n        assert pos['submit'] < pos['complete'] < pos['notify'], f'{path}: ID {id_} order wrong'\n    # Check at most one per (kind, id)\n    from collections import Counter\n    c = Counter((e['kind'], e['id']) for e in events)\n    for k, v in c.items():\n        assert v == 1, f'{path}: duplicate {k}'\n    print(f'{path}: OK ({len(positions)} ids)')\n\ncheck('/tmp/a.json')  # stress/burst/a_then_b\ncheck('/tmp/b.json')  # stress/burst/b_then_a\ncheck('/tmp/d1.json')  # stress2/burst/a_then_b\ncheck('/tmp/steady.json')  # stress2/steady/a_then_b\n\"\n"]
[701.787971, "o", "python3 -c \"\r\n\u001b[?2004l\r"]
