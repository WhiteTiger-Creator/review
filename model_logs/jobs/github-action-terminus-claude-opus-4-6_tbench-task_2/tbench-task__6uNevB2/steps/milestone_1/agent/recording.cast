[395.208181, "i", "cat > /app/src/db.c << 'EOF'\n#include \"db.h\"\n#include <sqlite3.h>\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <pthread.h>\n\nstatic sqlite3 *db = NULL;\nstatic pthread_mutex_t db_mutex = PTHREAD_MUTEX_INITIALIZER;\n\nstatic char *json_escape(const char *s) {\n    if (!s) return strdup(\"\");\n    size_t len = strlen(s);\n    /* worst case: every char becomes \\uXXXX (6 chars) */\n    char *out = malloc(len * 6 + 1);\n    if (!out) return NULL;\n    char *p = out;\n    for (size_t i = 0; i < len; i++) {\n        unsigned char c = (unsigned char)s[i];\n        switch (c) {\n            case '\"': *p++ = '\\\\'; *p++ = '\"'; break;\n            case '\\\\': *p++ = '\\\\'; *p++ = '\\\\'; break;\n            case '\\n': *p++ = '\\\\'; *p++ = 'n'; break;\n            case '\\r': *p++ = '\\\\'; *p++ = 'r'; break;\n            case '\\t': *p++ = '\\\\'; *p++ = 't'; break;\n            case '\\b': *p++ = '\\\\'; *p++ = 'b'; break;\n            case '\\f': *p++ = '\\\\'; *p++ = 'f'; break;\n            default:\n                if (c < 0x20) {\n                    p += sprintf(p, \"\\\\u%04x\", c);\n                } else {\n                    *p++ = c;\n                }\n                break;\n        }\n    }\n    *p = '\\0';\n    return out;\n}\n\nint init_db(const char *path) {\n    if (sqlite3_open_v2(path, &db,\n            SQLITE_OPEN_READWRITE | SQLITE_OPEN_CREATE | SQLITE_OPEN_FULLMUTEX,\n            NULL) != SQLITE_OK) {\n        fprintf(stderr, \"Cannot open database: %s\\n\", sqlite3_errmsg(db));\n        return -1;\n    }\n\n    char *err_msg = NULL;\n    sqlite3_exec(db, \"PRAGMA journal_mode=WAL;\", NULL, NULL, &err_msg);\n    if (err_msg) { sqlite3_free(err_msg); err_msg = NULL; }\n    sqlite3_exec(db, \"PRAGMA busy_timeout=5000;\", NULL, NULL, &err_msg);\n    if (err_msg) { sqlite3_free(err_msg); err_msg = NULL; }\n\n    const char *sql = \"CREATE TABLE IF NOT EXISTS notes (\"\n                      \"id INTEGER PRIMARY KEY AUTOINCREMENT,\"\n                      \"title TEXT NOT NULL,\"\n                      \"content TEXT DEFAULT ''\"\n                      \");\";\n    if (sqlite3_exec(db, sql, NULL, NULL, &err_msg) != SQLITE_OK) {\n        fprintf(stderr, \"SQL error: %s\\n\", err_msg);\n        sqlite3_free(err_msg);\n        return -1;\n    }\n    return 0;\n}\n\nvoid close_db(void) {\n    if (db)\n        sqlite3_close(db);\n    db = NULL;\n}\n\nint create_note(const char *title, const char *content) {\n    pthread_mutex_lock(&db_mutex);\n    sqlite3_stmt *stmt;\n    const char *sql = \"INSERT INTO notes (title, content) VALUES (?, ?);\";\n    if (sqlite3_prepare_v2(db, sql, -1, &stmt, NULL) != SQLITE_OK) {\n        pthread_mutex_unlock(&db_mutex);\n        return -1;\n    }\n    sqlite3_bind_text(stmt, 1, title, -1, SQLITE_TRANSIENT);\n    sqlite3_bind_text(stmt, 2, content ? content : \"\", -1, SQLITE_TRANSIENT);\n    int rc = sqlite3_step(stmt);\n    sqlite3_finalize(stmt);\n    if (rc != SQLITE_DONE) {\n        pthread_mutex_unlock(&db_mutex);\n        return -1;\n    }\n    int id = (int)sqlite3_last_insert_rowid(db);\n    pthread_mutex_unlock(&db_mutex);\n    return id;\n}\n\nchar *get_all_notes_json(void) {\n    return get_notes_paginated_json(50, 0);\n}\n\nchar *get_notes_paginated_json(int limit, int offset) {\n    pthread_mutex_lock(&db_mutex);\n    sqlite3_stmt *stmt;\n    const char *sql = \"SELECT id, title, content FROM notes ORDER BY id LIMIT ? OFFSET ?;\";\n    if (sqlite3_prepare_v2(db, sql, -1, &stmt, NULL) != SQLITE_OK) {\n        pthread_mutex_unlock(&db_mutex);\n        return strdup(\"[]\");\n    }\n    sqlite3_bind_int(stmt, 1, limit);\n    sqlite3_bind_int(stmt, 2, offset);\n\n    size_t buf_size = 4096;\n    size_t buf_len = 0;\n    char *buf = malloc(buf_size);\n    buf[0] = '[';\n    buf_len = 1;\n    int first = 1;\n\n    while (sqlite3_step(stmt) == SQLITE_ROW) {\n        int id = sqlite3_column_int(stmt, 0);\n        const char *title = (const char *)sqlite3_column_text(stmt, 1);\n        const char *content = (const char *)sqlite3_column_text(stmt, 2);\n        char *etitle = json_escape(title);\n        char *econtent = json_escape(content);\n\n        char item[65536];\n        int item_len = snprintf(item, sizeof(item),\n "]
[395.208315, "i", "           \"%s{\\\"id\\\":%d,\\\"title\\\":\\\"%s\\\",\\\"content\\\":\\\"%s\\\"}\",\n            first ? \"\" : \",\", id, etitle, econtent);\n        free(etitle);\n        free(econtent);\n\n        while (buf_len + item_len + 2 > buf_size) {\n            buf_size *= 2;\n            buf = realloc(buf, buf_size);\n        }\n        memcpy(buf + buf_len, item, item_len);\n        buf_len += item_len;\n        first = 0;\n    }\n    sqlite3_finalize(stmt);\n    pthread_mutex_unlock(&db_mutex);\n\n    if (buf_len + 2 > buf_size) {\n        buf_size = buf_len + 2;\n        buf = realloc(buf, buf_size);\n    }\n    buf[buf_len] = ']';\n    buf[buf_len + 1] = '\\0';\n    return buf;\n}\n\nint get_total_notes_count(void) {\n    pthread_mutex_lock(&db_mutex);\n    sqlite3_stmt *stmt;\n    const char *sql = \"SELECT COUNT(*) FROM notes;\";\n    if (sqlite3_prepare_v2(db, sql, -1, &stmt, NULL) != SQLITE_OK) {\n        pthread_mutex_unlock(&db_mutex);\n        return 0;\n    }\n    int count = 0;\n    if (sqlite3_step(stmt) == SQLITE_ROW) {\n        count = sqlite3_column_int(stmt, 0);\n    }\n    sqlite3_finalize(stmt);\n    pthread_mutex_unlock(&db_mutex);\n    return count;\n}\n\nchar *get_note_json(int id) {\n    pthread_mutex_lock(&db_mutex);\n    sqlite3_stmt *stmt;\n    const char *sql = \"SELECT id, title, content FROM notes WHERE id = ?;\";\n    if (sqlite3_prepare_v2(db, sql, -1, &stmt, NULL) != SQLITE_OK) {\n        pthread_mutex_unlock(&db_mutex);\n        return NULL;\n    }\n    sqlite3_bind_int(stmt, 1, id);\n    char *result = NULL;\n    if (sqlite3_step(stmt) == SQLITE_ROW) {\n        int nid = sqlite3_column_int(stmt, 0);\n        const char *title = (const char *)sqlite3_column_text(stmt, 1);\n        const char *content = (const char *)sqlite3_column_text(stmt, 2);\n        char *etitle = json_escape(title);\n        char *econtent = json_escape(content);\n        size_t rlen = strlen(etitle) + strlen(econtent) + 128;\n        result = malloc(rlen);\n        snprintf(result, rlen, \"{\\\"id\\\":%d,\\\"title\\\":\\\"%s\\\",\\\"content\\\":\\\"%s\\\"}\",\n                 nid, etitle, econtent);\n        free(etitle);\n        free(econtent);\n    }\n    sqlite3_finalize(stmt);\n    pthread_mutex_unlock(&db_mutex);\n    return result;\n}\n\nint update_note(int id, const char *title, const char *content) {\n    pthread_mutex_lock(&db_mutex);\n    sqlite3_stmt *stmt;\n    const char *sql = \"UPDATE notes SET title = ?, content = ? WHERE id = ?;\";\n    if (sqlite3_prepare_v2(db, sql, -1, &stmt, NULL) != SQLITE_OK) {\n        pthread_mutex_unlock(&db_mutex);\n        return -1;\n    }\n    sqlite3_bind_text(stmt, 1, title, -1, SQLITE_TRANSIENT);\n    sqlite3_bind_text(stmt, 2, content ? content : \"\", -1, SQLITE_TRANSIENT);\n    sqlite3_bind_int(stmt, 3, id);\n    int rc = sqlite3_step(stmt);\n    sqlite3_finalize(stmt);\n    if (rc != SQLITE_DONE) {\n        pthread_mutex_unlock(&db_mutex);\n        return -1;\n    }\n    int changes = sqlite3_changes(db);\n    pthread_mutex_unlock(&db_mutex);\n    return changes > 0 ? 0 : -1;\n}\n\nint delete_note(int id) {\n    pthread_mutex_lock(&db_mutex);\n    sqlite3_stmt *stmt;\n    const char *sql = \"DELETE FROM notes WHERE id = ?;\";\n    if (sqlite3_prepare_v2(db, sql, -1, &stmt, NULL) != SQLITE_OK) {\n        pthread_mutex_unlock(&db_mutex);\n        return -1;\n    }\n    sqlite3_bind_int(stmt, 1, id);\n    int rc = sqlite3_step(stmt);\n    sqlite3_finalize(stmt);\n    if (rc != SQLITE_DONE) {\n        pthread_mutex_unlock(&db_mutex);\n        return -1;\n    }\n    int changes = sqlite3_changes(db);\n    pthread_mutex_unlock(&db_mutex);\n    return changes > 0 ? 0 : -1;\n}\n\nint note_exists(int id) {\n    pthread_mutex_lock(&db_mutex);\n    sqlite3_stmt *stmt;\n    const char *sql = \"SELECT 1 FROM notes WHERE id = ?;\";\n    if (sqlite3_prepare_v2(db, sql, -1, &stmt, NULL) != SQLITE_OK) {\n        pthread_mutex_unlock(&db_mutex);\n        return 0;\n    }\n    sqlite3_bind_int(stmt, 1, id);\n    int exists = (sqlite3_step(stmt) == SQLITE_ROW) ? 1 : 0;\n    sqlite3_finalize(stmt);\n    pthread_mutex_unlock(&db_mutex);\n    return exists;\n}\nEOF\n"]
