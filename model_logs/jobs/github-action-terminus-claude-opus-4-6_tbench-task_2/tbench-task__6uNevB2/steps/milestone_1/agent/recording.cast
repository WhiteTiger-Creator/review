[697.72962, "i", "cat > /app/src/routes.c << 'EOF'\n#include \"routes.h\"\n#include \"db.h\"\n#include \"auth.h\"\n#include <microhttpd.h>\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <ctype.h>\n\n#define MAX_BODY_SIZE 65536\n\nstatic enum MHD_Result send_response(struct MHD_Connection *connection,\n    const char *body, unsigned int status_code, const char *total_count) {\n    struct MHD_Response *response = MHD_create_response_from_buffer(\n        strlen(body), (void *)body, MHD_RESPMEM_MUST_COPY);\n    MHD_add_response_header(response, \"Content-Type\", \"application/json\");\n    MHD_add_response_header(response, \"Access-Control-Allow-Origin\", \"*\");\n    MHD_add_response_header(response, \"Access-Control-Allow-Methods\", \"GET, POST, PUT, DELETE, OPTIONS\");\n    MHD_add_response_header(response, \"Access-Control-Allow-Headers\", \"Content-Type, X-API-Key\");\n    if (total_count) {\n        MHD_add_response_header(response, \"X-Total-Count\", total_count);\n    }\n    enum MHD_Result ret = MHD_queue_response(connection, status_code, response);\n    MHD_destroy_response(response);\n    return ret;\n}\n\nstatic enum MHD_Result send_json(struct MHD_Connection *connection,\n    const char *body, unsigned int status_code) {\n    return send_response(connection, body, status_code, NULL);\n}\n\nstatic enum MHD_Result send_options(struct MHD_Connection *connection) {\n    struct MHD_Response *response = MHD_create_response_from_buffer(0, (void *)\"\", MHD_RESPMEM_PERSISTENT);\n    MHD_add_response_header(response, \"Access-Control-Allow-Origin\", \"*\");\n    MHD_add_response_header(response, \"Access-Control-Allow-Methods\", \"GET, POST, PUT, DELETE, OPTIONS\");\n    MHD_add_response_header(response, \"Access-Control-Allow-Headers\", \"Content-Type, X-API-Key\");\n    MHD_add_response_header(response, \"Content-Type\", \"application/json\");\n    enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_OK, response);\n    MHD_destroy_response(response);\n    return ret;\n}\n\nstatic char *json_get_string(const char *json, const char *key) {\n    char search[256];\n    snprintf(search, sizeof(search), \"\\\"%s\\\"\", key);\n    const char *p = strstr(json, search);\n    if (!p) return NULL;\n    p += strlen(search);\n    while (*p && (isspace((unsigned char)*p) || *p == ':')) p++;\n    if (*p == 'n' && strncmp(p, \"null\", 4) == 0) return NULL;\n    if (*p != '\"') return NULL;\n    p++;\n\n    size_t cap = 256;\n    size_t len = 0;\n    char *result = malloc(cap);\n    while (*p && *p != '\"') {\n        if (len + 6 >= cap) {\n            cap *= 2;\n            result = realloc(result, cap);\n        }\n        if (*p == '\\\\') {\n            p++;\n            switch (*p) {\n                case '\"': result[len++] = '\"'; break;\n                case '\\\\': result[len++] = '\\\\'; break;\n                case '/': result[len++] = '/'; break;\n                case 'n': result[len++] = '\\n'; break;\n                case 'r': result[len++] = '\\r'; break;\n                case 't': result[len++] = '\\t'; break;\n                case 'b': result[len++] = '\\b'; break;\n                case 'f': result[len++] = '\\f'; break;\n                case 'u': {\n                    unsigned int cp = 0;\n                    for (int i = 0; i < 4 && p[1]; i++) {\n                        p++;\n                        cp <<= 4;\n                        if (*p >= '0' && *p <= '9') cp |= (*p - '0');\n                        else if (*p >= 'a' && *p <= 'f') cp |= (*p - 'a' + 10);\n                        else if (*p >= 'A' && *p <= 'F') cp |= (*p - 'A' + 10);\n                    }\n                    if (cp < 0x80) {\n                        result[len++] = (char)cp;\n                    } else if (cp < 0x800) {\n                        result[len++] = (char)(0xC0 | (cp >> 6));\n                        result[len++] = (char)(0x80 | (cp & 0x3F));\n                    } else {\n                        result[len++] = (char)(0xE0 | (cp >> 12));\n                        result[len++] = (char)(0x80 | ((cp >> 6) & 0x3F));\n                        result[len++] = (char)(0x80 | (cp & 0x3F));\n                    }\n                    break;\n                }\n                defa"]
[697.729801, "i", "ult: result[len++] = *p; break;\n            }\n        } else {\n            result[len++] = *p;\n        }\n        p++;\n    }\n    result[len] = '\\0';\n    return result;\n}\n\nstatic int title_valid(const char *title) {\n    if (!title) return 0;\n    if (title[0] == '\\0') return 0;\n    return 1;\n}\n\nstatic int parse_id_from_url(const char *url) {\n    const char *p = url + strlen(\"/api/notes/\");\n    if (!*p) return -1;\n    for (const char *c = p; *c; c++) {\n        if (!isdigit((unsigned char)*c)) return -1;\n    }\n    return atoi(p);\n}\n\nenum MHD_Result route_request(struct MHD_Connection *connection, const char *url,\n                              const char *method, const char *upload_data,\n                              size_t *upload_data_size, void **con_cls) {\n\n    /* OPTIONS preflight */\n    if (strcmp(method, \"OPTIONS\") == 0) {\n        return send_options(connection);\n    }\n\n    /* Handle body accumulation for POST/PUT */\n    if (strcmp(method, \"POST\") == 0 || strcmp(method, \"PUT\") == 0) {\n        if (*con_cls == NULL) {\n            struct connection_info *ci = calloc(1, sizeof(struct connection_info));\n            ci->data = NULL;\n            ci->data_size = 0;\n            ci->too_large = 0;\n            *con_cls = ci;\n            return MHD_YES;\n        }\n        struct connection_info *ci = *con_cls;\n        if (*upload_data_size > 0) {\n            if (ci->too_large || ci->data_size + *upload_data_size > MAX_BODY_SIZE) {\n                ci->too_large = 1;\n                *upload_data_size = 0;\n                return MHD_YES;\n            }\n            ci->data = realloc(ci->data, ci->data_size + *upload_data_size + 1);\n            memcpy(ci->data + ci->data_size, upload_data, *upload_data_size);\n            ci->data_size += *upload_data_size;\n            ci->data[ci->data_size] = '\\0';\n            *upload_data_size = 0;\n            return MHD_YES;\n        }\n        /* upload complete, fall through to processing */\n    }\n\n    /* GET /api/notes - list with pagination */\n    if (strcmp(url, \"/api/notes\") == 0 && strcmp(method, \"GET\") == 0) {\n        const char *limit_str = MHD_lookup_connection_value(connection, MHD_GET_ARGUMENT_KIND, \"limit\");\n        const char *offset_str = MHD_lookup_connection_value(connection, MHD_GET_ARGUMENT_KIND, \"offset\");\n        int limit = 50;\n        int offset = 0;\n        if (limit_str) limit = atoi(limit_str);\n        if (offset_str) offset = atoi(offset_str);\n        if (limit <= 0) limit = 50;\n        if (limit > 100) limit = 100;\n        if (offset < 0) offset = 0;\n\n        int total = get_total_notes_count();\n        char total_str[32];\n        snprintf(total_str, sizeof(total_str), \"%d\", total);\n\n        char *json = get_notes_paginated_json(limit, offset);\n        if (!json) json = strdup(\"[]\");\n        enum MHD_Result r = send_response(connection, json, MHD_HTTP_OK, total_str);\n        free(json);\n        return r;\n    }\n\n    /* POST /api/notes - create */\n    if (strcmp(url, \"/api/notes\") == 0 && strcmp(method, \"POST\") == 0) {\n        if (!api_key_valid(connection)) {\n            return send_json(connection, \"{\\\"error\\\":\\\"unauthorized\\\"}\", MHD_HTTP_UNAUTHORIZED);\n        }\n        struct connection_info *ci = *con_cls;\n        if (ci && ci->too_large) {\n            return send_json(connection, \"{\\\"error\\\":\\\"payload too large\\\"}\", 413);\n        }\n        if (!ci || !ci->data || ci->data_size == 0) {\n            return send_json(connection, \"{\\\"error\\\":\\\"title is required\\\"}\", MHD_HTTP_BAD_REQUEST);\n        }\n        char *title = json_get_string(ci->data, \"title\");\n        char *content = json_get_string(ci->data, \"content\");\n        if (!title_valid(title)) {\n            free(title);\n            free(content);\n            return send_json(connection, \"{\\\"error\\\":\\\"title is required\\\"}\", MHD_HTTP_BAD_REQUEST);\n        }\n        int id = create_note(title, content ? content : \"\");\n        if (id < 0) {\n            free(title);\n            free(content);\n            return send_json(connection, \"{\\\"error\\\":\\\"internal error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR);\n        }\n        char *not"]
[697.730374, "o", "cat > /app/src/routes.c << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[697.730408, "i", "e_json = get_note_json(id);\n        if (!note_json) {\n            free(title);\n            free(content);\n            return send_json(connection, \"{\\\"error\\\":\\\"internal error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR);\n        }\n        enum MHD_Result r = send_json(connection, note_json, MHD_HTTP_CREATED);\n        free(note_json);\n        free(title);\n        free(content);\n        return r;\n    }\n\n    /* Routes with /api/notes/{id} */\n    if (strncmp(url, \"/api/notes/\", 11) == 0) {\n        int id = parse_id_from_url(url);\n        if (id < 0) {\n            return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\n        }\n\n        /* GET /api/notes/{id} */\n        if (strcmp(method, \"GET\") == 0) {\n            char *json = get_note_json(id);\n            if (!json) {\n                return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\n            }\n            enum MHD_Result r = send_json(connection, json, MHD_HTTP_OK);\n            free(json);\n            return r;\n        }\n\n        /* PUT /api/notes/{id} */\n        if (strcmp(method, \"PUT\") == 0) {\n            if (!api_key_valid(connection)) {\n                return send_json(connection, \"{\\\"error\\\":\\\"unauthorized\\\"}\", MHD_HTTP_UNAUTHORIZED);\n            }\n            struct connection_info *ci = *con_cls;\n            if (ci && ci->too_large) {\n                return send_json(connection, \"{\\\"error\\\":\\\"payload too large\\\"}\", 413);\n            }\n            if (!ci || !ci->data || ci->data_size == 0) {\n                return send_json(connection, \"{\\\"error\\\":\\\"title is required\\\"}\", MHD_HTTP_BAD_REQUEST);\n            }\n            if (!note_exists(id)) {\n                return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\n            }\n            char *title = json_get_string(ci->data, \"title\");\n            char *content = json_get_string(ci->data, \"content\");\n            if (!title_valid(title)) {\n                free(title);\n                free(content);\n                return send_json(connection, \"{\\\"error\\\":\\\"title is required\\\"}\", MHD_HTTP_BAD_REQUEST);\n            }\n            int rc = update_note(id, title, content ? content : \"\");\n            free(title);\n            free(content);\n            if (rc != 0) {\n                return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\n            }\n            char *json = get_note_json(id);\n            if (!json) {\n                return send_json(connection, \"{\\\"error\\\":\\\"internal error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR);\n            }\n            enum MHD_Result r = send_json(connection, json, MHD_HTTP_OK);\n            free(json);\n            return r;\n        }\n\n        /* DELETE /api/notes/{id} */\n        if (strcmp(method, \"DELETE\") == 0) {\n            if (!api_key_valid(connection)) {\n                return send_json(connection, \"{\\\"error\\\":\\\"unauthorized\\\"}\", MHD_HTTP_UNAUTHORIZED);\n            }\n            int rc = delete_note(id);\n            if (rc != 0) {\n                return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\n            }\n            return send_json(connection, \"{\\\"status\\\":\\\"deleted\\\"}\", MHD_HTTP_OK);\n        }\n    }\n\n    return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\n}\nEOF\n"]
