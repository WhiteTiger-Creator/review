[396.236642, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.236722, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.237252, "o", "/* Simple JSON string extraction - finds \"key\":\"value\" and returns value (unescaped) */\r\n\u001b[?2004l\r"]
[396.237346, "o", "\u001b[?2004h> "]
[396.237907, "o", "static char *json_get_string(const char *json, const char *key) {\r\n\u001b[?2004l\r"]
[396.237947, "o", "\u001b[?2004h"]
[396.238064, "o", "> "]
[396.238206, "o", "    char search[256];\r\n\u001b[?2004l\r\u001b[?2004h"]
[396.238234, "o", "> "]
[396.238507, "o", "    snprintf(search, sizeof(search), \"\\\"%s\\\"\", key);\r\n\u001b[?2004l\r"]
[396.238616, "o", "\u001b[?2004h> "]
[396.238782, "o", "    const char *p = strstr(json, search);\r\n\u001b[?2004l\r"]
[396.238881, "o", "\u001b[?2004h> "]
[396.238986, "o", "    if (!p) return NULL;\r\n\u001b[?2004l\r"]
[396.239059, "o", "\u001b[?2004h> "]
[396.239188, "o", "    p += strlen(search);\r\n\u001b[?2004l\r"]
[396.239289, "o", "\u001b[?2004h"]
[396.239394, "o", "> "]
[396.239534, "o", "    /* skip whitespace and colon */\r\n\u001b[?2004l\r\u001b[?2004h"]
[396.239579, "o", "> "]
[396.239886, "o", "    while (*p && (isspace((unsigned char)*p) || *p == ':')) p++;\r\n\u001b[?2004l\r"]
[396.239916, "o", "\u001b[?2004h> "]
[396.240281, "o", "    if (*p == 'n' && strncmp(p, \"null\", 4) == 0) return NULL;\r\n\u001b[?2004l\r"]
[396.240312, "o", "\u001b[?2004h> "]
[396.240514, "o", "    if (*p != '\"') return NULL;\r\n\u001b[?2004l\r"]
[396.240544, "o", "\u001b[?2004h> "]
[396.240752, "o", "    p++; /* skip opening quote */\r\n\u001b[?2004l\r"]
[396.240875, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[396.240912, "o", "\u001b[?2004h> "]
[396.241198, "o", "    /* Parse the string value with escape handling */\r\n\u001b[?2004l\r"]
[396.241306, "o", "\u001b[?2004h> "]
[396.241421, "o", "    size_t cap = 256;\r\n\u001b[?2004l\r\u001b[?2004h"]
[396.241494, "o", "> "]
[396.24157, "o", "    size_t len = 0;\r\n\u001b[?2004l\r"]
[396.241595, "o", "\u001b[?2004h"]
[396.241615, "o", "> "]
[396.241824, "o", "    char *result = malloc(cap);\r\n\u001b[?2004l\r"]
[396.241893, "o", "\u001b[?2004h> "]
[396.242077, "o", "    while (*p && *p != '\"') {\r\n\u001b[?2004l\r"]
[396.242101, "o", "\u001b[?2004h"]
[396.242121, "o", "> "]
[396.242312, "o", "        if (len + 4 >= cap) {\r\n\u001b[?2004l\r"]
[396.242333, "o", "\u001b[?2004h"]
[396.242354, "o", "> "]
[396.2425, "o", "            cap *= 2;\r\n\u001b[?2004l\r"]
[396.242526, "o", "\u001b[?2004h"]
[396.242547, "o", "> "]
[396.242792, "o", "            result = realloc(result, cap);\r\n\u001b[?2004l\r"]
[396.24282, "o", "\u001b[?2004h"]
[396.242844, "o", "> "]
[396.243031, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.243138, "o", "        if (*p == '\\\\') {\r\n\u001b[?2004l\r"]
[396.243194, "o", "\u001b[?2004h> "]
[396.243305, "o", "            p++;\r\n\u001b[?2004l\r"]
[396.243338, "o", "\u001b[?2004h> "]
[396.243502, "o", "            switch (*p) {\r\n\u001b[?2004l\r"]
[396.243532, "o", "\u001b[?2004h> "]
[396.243864, "o", "                case '\"': result[len++] = '\"'; break;\r\n\u001b[?2004l\r"]
[396.243965, "o", "\u001b[?2004h> "]
[396.244237, "o", "                case '\\\\': result[len++] = '\\\\'; break;\r\n\u001b[?2004l\r"]
[396.244371, "o", "\u001b[?2004h> "]
[396.244593, "o", "                case '/': result[len++] = '/'; break;\r\n\u001b[?2004l\r"]
[396.244635, "o", "\u001b[?2004h> "]
[396.244979, "o", "                case 'n': result[len++] = '\\n'; break;\r\n\u001b[?2004l\r"]
[396.245065, "o", "\u001b[?2004h> "]
[396.245481, "o", "                case 'r': result[len++] = '\\r'; break;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.245704, "o", "                case 't': result[len++] = '\\t'; break;\r\n\u001b[?2004l\r"]
[396.245863, "o", "\u001b[?2004h> "]
[396.246082, "o", "                case 'b': result[len++] = '\\b'; break;\r\n\u001b[?2004l\r"]
[396.246113, "o", "\u001b[?2004h> "]
[396.246431, "o", "                case 'f': result[len++] = '\\f'; break;\r\n\u001b[?2004l\r"]
[396.246552, "o", "\u001b[?2004h> "]
[396.246668, "o", "                case 'u': {\r\n\u001b[?2004l\r"]
[396.246777, "o", "\u001b[?2004h> "]
[396.247109, "o", "                    /* basic \\uXXXX - just store as UTF-8 or raw */\r\n\u001b[?2004l\r"]
[396.247224, "o", "\u001b[?2004h> "]
[396.247401, "o", "                    unsigned int cp = 0;\r\n\u001b[?2004l\r"]
[396.247502, "o", "\u001b[?2004h> "]
[396.247803, "o", "                    for (int i = 0; i < 4 && p[1]; i++) {\r\n\u001b[?2004l\r"]
[396.247907, "o", "\u001b[?2004h> "]
[396.248027, "o", "                        p++;\r\n\u001b[?2004l\r"]
[396.248051, "o", "\u001b[?2004h"]
[396.24807, "o", "> "]
[396.248281, "o", "                        cp <<= 4;\r\n\u001b[?2004l\r"]
[396.248312, "o", "\u001b[?2004h"]
[396.248377, "o", "> "]
[396.248725, "o", "                        if (*p >= '0' && *p <= '9') cp |= (*p - '0');\r\n\u001b[?2004l\r"]
[396.248749, "o", "\u001b[?2004h"]
[396.248768, "o", "> "]
[396.249218, "o", "                        else if (*p >= 'a' && *p <= 'f') cp |= (*p - 'a' + 10);\r\n\u001b[?2004l\r"]
[396.249241, "o", "\u001b[?2004h"]
[396.249259, "o", "> "]
[396.24976, "o", "                        else if (*p >= 'A' && *p <= 'F') cp |= (*p - 'A' + 10);\r\n\u001b[?2004l\r"]
[396.2498, "o", "\u001b[?2004h> "]
[396.24995, "o", "                    }\r\n\u001b[?2004l\r"]
[396.250084, "o", "\u001b[?2004h> "]
[396.250218, "o", "                    if (cp < 0x80) {\r\n\u001b[?2004l\r"]
[396.25024, "o", "\u001b[?2004h"]
[396.250259, "o", "> "]
[396.250548, "o", "                        result[len++] = (char)cp;\r\n\u001b[?2004l\r"]
[396.250578, "o", "\u001b[?2004h> "]
[396.250868, "o", "                    } else if (cp < 0x800) {\r\n\u001b[?2004l\r"]
[396.250896, "o", "\u001b[?2004h> "]
[396.251306, "o", "                        result[len++] = (char)(0xC0 | (cp >> 6));\r\n\u001b[?2004l\r"]
[396.251335, "o", "\u001b[?2004h> "]
[396.251759, "o", "                        result[len++] = (char)(0x80 | (cp & 0x3F));\r\n\u001b[?2004l\r"]
[396.251896, "o", "\u001b[?2004h> "]
[396.251947, "o", "                    } else {\r\n\u001b[?2004l\r"]
[396.251973, "o", "\u001b[?2004h> "]
[396.252406, "o", "                        result[len++] = (char)(0xE0 | (cp >> 12));\r\n\u001b[?2004l\r"]
[396.252493, "o", "\u001b[?2004h> "]
[396.252852, "o", "                        result[len++] = (char)(0x80 | ((cp >> 6) & 0x3F));\r\n\u001b[?2004l\r"]
[396.252883, "o", "\u001b[?2004h> "]
[396.253277, "o", "                        result[len++] = (char)(0x80 | (cp & 0x3F));\r\n\u001b[?2004l\r"]
[396.253308, "o", "\u001b[?2004h> "]
[396.253486, "o", "                    }\r\n\u001b[?2004l\r"]
[396.253519, "o", "\u001b[?2004h> "]
[396.253693, "o", "                    break;\r\n\u001b[?2004l\r"]
[396.253723, "o", "\u001b[?2004h> "]
[396.253854, "o", "                }\r\n\u001b[?2004l\r"]
[396.253878, "o", "\u001b[?2004h"]
[396.253899, "o", "> "]
[396.2542, "o", "                default: result[len++] = *p; break;\r\n\u001b[?2004l\r"]
[396.254222, "o", "\u001b[?2004h"]
[396.254239, "o", "> "]
[396.254337, "o", "            }\r\n\u001b[?2004l\r"]
[396.254363, "o", "\u001b[?2004h"]
[396.254382, "o", "> "]
[396.254518, "o", "        } else {\r\n\u001b[?2004l\r"]
[396.254616, "o", "\u001b[?2004h> "]
[396.254759, "o", "            result[len++] = *p;\r\n\u001b[?2004l\r"]
[396.254789, "o", "\u001b[?2004h> "]
[396.254882, "o", "        }\r\n\u001b[?2004l\r"]
[396.254912, "o", "\u001b[?2004h> "]
[396.255021, "o", "        p++;\r\n\u001b[?2004l\r"]
[396.255051, "o", "\u001b[?2004h> "]
[396.255125, "o", "    }\r\n\u001b[?2004l\r"]
[396.255182, "o", "\u001b[?2004h> "]
[396.255338, "o", "    result[len] = '\\0';\r\n\u001b[?2004l\r"]
[396.255369, "o", "\u001b[?2004h> "]
[396.255499, "o", "    return result;\r\n\u001b[?2004l\r"]
[396.255525, "o", "\u001b[?2004h> "]
[396.255546, "o", "}\r\n\u001b[?2004l\r"]
[396.255569, "o", "\u001b[?2004h"]
[396.255589, "o", "> \r\n\u001b[?2004l\r"]
[396.255611, "o", "\u001b[?2004h"]
[396.255632, "o", "> "]
[396.256051, "o", "/* Check if title is present and non-empty (not just whitespace) */\r\n\u001b[?2004l\r"]
[396.256089, "o", "\u001b[?2004h> "]
[396.256351, "o", "static int title_valid(const char *title) {\r\n\u001b[?2004l\r"]
[396.25638, "o", "\u001b[?2004h> "]
[396.25656, "o", "    if (!title) return 0;\r\n\u001b[?2004l\r"]
[396.256589, "o", "\u001b[?2004h> "]
[396.256763, "o", "    /* Check if entirely empty */\r\n\u001b[?2004l\r"]
[396.256787, "o", "\u001b[?2004h"]
[396.256808, "o", "> "]
[396.257036, "o", "    if (title[0] == '\\0') return 0;\r\n\u001b[?2004l\r"]
[396.25707, "o", "\u001b[?2004h> "]
[396.257175, "o", "    return 1;\r\n\u001b[?2004l\r"]
[396.257203, "o", "\u001b[?2004h> "]
[396.257272, "o", "}\r\n\u001b[?2004l\r\u001b[?2004h"]
[396.257298, "o", "> \r\n\u001b[?2004l\r"]
[396.257341, "o", "\u001b[?2004h"]
[396.257365, "o", "> "]
[396.257651, "o", "static int parse_id_from_url(const char *url) {\r\n\u001b[?2004l\r"]
[396.25773, "o", "\u001b[?2004h"]
[396.257819, "o", "> "]
[396.257917, "o", "    /* url is like /api/notes/123 */\r\n\u001b[?2004l\r"]
[396.257942, "o", "\u001b[?2004h"]
[396.257963, "o", "> "]
[396.258251, "o", "    const char *p = url + strlen(\"/api/notes/\");\r\n\u001b[?2004l\r"]
[396.258273, "o", "\u001b[?2004h"]
[396.258295, "o", "> "]
[396.258449, "o", "    if (!*p) return -1;\r\n\u001b[?2004l\r"]
[396.258472, "o", "\u001b[?2004h"]
[396.258494, "o", "> "]
[396.258689, "o", "    /* check it's all digits */\r\n\u001b[?2004l\r"]
[396.258712, "o", "\u001b[?2004h"]
[396.258733, "o", "> "]
[396.258964, "o", "    for (const char *c = p; *c; c++) {\r\n\u001b[?2004l\r"]
[396.258986, "o", "\u001b[?2004h"]
[396.259003, "o", "> "]
[396.259313, "o", "        if (!isdigit((unsigned char)*c)) return -1;\r\n\u001b[?2004l\r"]
[396.259334, "o", "\u001b[?2004h"]
[396.259352, "o", "> "]
[396.259429, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.259598, "o", "    return atoi(p);\r\n\u001b[?2004l\r\u001b[?2004h"]
[396.259722, "o", "> }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.259828, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.260213, "o", "enum MHD_Result route_request(struct MHD_Connection *connection, const char *url,\r\n\u001b[?2004l\r"]
[396.260239, "o", "\u001b[?2004h> "]
[396.260698, "o", "                              const char *method, const char *upload_data,\r\n\u001b[?2004l\r"]
[396.260798, "o", "\u001b[?2004h> "]
[396.261154, "o", "                              size_t *upload_data_size, void **con_cls) {\r\n\u001b[?2004l\r"]
[396.261187, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[396.261222, "o", "\u001b[?2004h> "]
[396.261425, "o", "    /* OPTIONS preflight */\r\n\u001b[?2004l\r"]
[396.261457, "o", "\u001b[?2004h> "]
[396.261714, "o", "    if (strcmp(method, \"OPTIONS\") == 0) {\r\n\u001b[?2004l\r"]
[396.261744, "o", "\u001b[?2004h> "]
[396.262009, "o", "        return send_options(connection);\r\n\u001b[?2004l\r"]
[396.26204, "o", "\u001b[?2004h> "]
[396.262191, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.262224, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.262474, "o", "    /* Handle body accumulation for POST/PUT */\r\n\u001b[?2004l\r"]
[396.262504, "o", "\u001b[?2004h> "]
[396.262952, "o", "    if (strcmp(method, \"POST\") == 0 || strcmp(method, \"PUT\") == 0) {\r\n\u001b[?2004l\r"]
[396.263094, "o", "\u001b[?2004h> "]
[396.263196, "o", "        if (*con_cls == NULL) {\r\n\u001b[?2004l\r"]
[396.263351, "o", "\u001b[?2004h> "]
[396.263762, "o", "            struct connection_info *ci = calloc(1, sizeof(struct connection_info));\r\n\u001b[?2004l\r"]
[396.263791, "o", "\u001b[?2004h> "]
[396.263989, "o", "            ci->data = NULL;\r\n\u001b[?2004l\r"]
[396.264094, "o", "\u001b[?2004h> "]
[396.264238, "o", "            ci->data_size = 0;\r\n\u001b[?2004l\r"]
[396.264309, "o", "\u001b[?2004h> "]
[396.264467, "o", "            *con_cls = ci;\r\n\u001b[?2004l\r"]
[396.26454, "o", "\u001b[?2004h> "]
[396.264694, "o", "            return MHD_YES;\r\n\u001b[?2004l\r"]
[396.264718, "o", "\u001b[?2004h"]
[396.264737, "o", "> "]
[396.264814, "o", "        }\r\n\u001b[?2004l\r"]
[396.264838, "o", "\u001b[?2004h"]
[396.264856, "o", "> "]
[396.265153, "o", "        struct connection_info *ci = *con_cls;\r\n\u001b[?2004l\r"]
[396.265285, "o", "\u001b[?2004h> "]
[396.265442, "o", "        if (*upload_data_size > 0) {\r\n\u001b[?2004l\r"]
[396.265529, "o", "\u001b[?2004h> "]
[396.26574, "o", "            /* Check body size limit */\r\n\u001b[?2004l\r"]
[396.265882, "o", "\u001b[?2004h> "]
[396.266178, "o", "            if (ci->data_size + *upload_data_size > MAX_BODY_SIZE) {\r\n\u001b[?2004l\r"]
[396.266211, "o", "\u001b[?2004h> "]
