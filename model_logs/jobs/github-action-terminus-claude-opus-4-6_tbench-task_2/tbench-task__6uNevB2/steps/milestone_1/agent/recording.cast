[396.228627, "o", "\u001b[?2004h> "]
[396.229109, "o", "    MHD_add_response_header(response, \"Access-Control-Allow-Headers\", \"Content-Type, X-API-Key\");\r\n\u001b[?2004l\r"]
[396.229185, "o", "\u001b[?2004h> "]
[396.229315, "o", "    if (total_count) {\r\n\u001b[?2004l\r"]
[396.229416, "o", "\u001b[?2004h> "]
[396.229811, "o", "        MHD_add_response_header(response, \"X-Total-Count\", total_count);\r\n\u001b[?2004l\r"]
[396.229909, "o", "\u001b[?2004h> "]
[396.23004, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.230456, "o", "    enum MHD_Result ret = MHD_queue_response(connection, status_code, response);\r\n\u001b[?2004l\r"]
[396.230568, "o", "\u001b[?2004h> "]
[396.230705, "o", "    MHD_destroy_response(response);\r\n\u001b[?2004l\r"]
[396.230806, "o", "\u001b[?2004h> "]
[396.230874, "o", "    return ret;\r\n\u001b[?2004l\r"]
[396.230962, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.231382, "o", "static enum MHD_Result send_json(struct MHD_Connection *connection,\r\n\u001b[?2004l\r"]
[396.231483, "o", "\u001b[?2004h> "]
