[396.23184, "o", "\u001b[?2004h> "]
[396.232127, "o", "    return send_response(connection, body, status_code, NULL);\r\n\u001b[?2004l\r"]
[396.232168, "o", "\u001b[?2004h> "]
[396.232235, "o", "}\r\n\u001b[?2004l\r\u001b[?2004h"]
[396.23232, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.232741, "o", "static enum MHD_Result send_options(struct MHD_Connection *connection) {\r\n\u001b[?2004l\r"]
[396.232811, "o", "\u001b[?2004h> "]
[396.233374, "o", "    struct MHD_Response *response = MHD_create_response_from_buffer(0, (void *)\"\", MHD_RESPMEM_PERSISTENT);\r\n\u001b[?2004l\r"]
[396.233458, "o", "\u001b[?2004h> "]
[396.233862, "o", "    MHD_add_response_header(response, \"Access-Control-Allow-Origin\", \"*\");\r\n\u001b[?2004l\r"]
[396.233947, "o", "\u001b[?2004h> "]
[396.234552, "o", "    MHD_add_response_header(response, \"Access-Control-Allow-Methods\", \"GET, POST, PUT, DELETE, OPTIONS\");\r\n\u001b[?2004l\r"]
[396.234633, "o", "\u001b[?2004h> "]
[396.235126, "o", "    MHD_add_response_header(response, \"Access-Control-Allow-Headers\", \"Content-Type, X-API-Key\");\r\n\u001b[?2004l\r"]
[396.235165, "o", "\u001b[?2004h> "]
[396.235583, "o", "    MHD_add_response_header(response, \"Content-Type\", \"application/json\");\r\n\u001b[?2004l\r"]
[396.235652, "o", "\u001b[?2004h> "]
[396.236122, "o", "    enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_OK, response);\r\n\u001b[?2004l\r"]
[396.236227, "o", "\u001b[?2004h> "]
[396.236385, "o", "    MHD_destroy_response(response);\r\n\u001b[?2004l\r"]
[396.236463, "o", "\u001b[?2004h> "]
