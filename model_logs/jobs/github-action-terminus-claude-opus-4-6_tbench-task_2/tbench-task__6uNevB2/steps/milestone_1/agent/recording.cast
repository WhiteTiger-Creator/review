[395.259132, "o", "int note_exists(int id) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[395.259231, "o", "    pthread_mutex_lock(&db_mutex);\r\n\u001b[?2004l\r"]
[395.259251, "o", "\u001b[?2004h"]
[395.259358, "o", "> "]
[395.259391, "o", "    sqlite3_stmt *stmt;\r\n\u001b[?2004l\r\u001b[?2004h"]
[395.259525, "o", "> "]
[395.259684, "o", "    const char *sql = \"SELECT 1 FROM notes WHERE id = ?;\";\r\n\u001b[?2004l\r\u001b[?2004h> "]
[395.259909, "o", "    if (sqlite3_prepare_v2(db, sql, -1, &stmt, NULL) != SQLITE_OK) {\r\n\u001b[?2004l\r"]
[395.260004, "o", "\u001b[?2004h> "]
[395.260103, "o", "        pthread_mutex_unlock(&db_mutex);\r\n\u001b[?2004l\r"]
[395.260202, "o", "\u001b[?2004h> "]
[395.260267, "o", "        return 0;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[395.260382, "o", "    }\r\n\u001b[?2004l\r"]
[395.260461, "o", "\u001b[?2004h>     sqlite3_bind_int(stmt, 1, id);\r\n"]
[395.26056, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[395.260729, "o", "    int exists = (sqlite3_step(stmt) == SQLITE_ROW) ? 1 : 0;\r\n\u001b[?2004l\r"]
[395.260817, "o", "\u001b[?2004h> "]
[395.260915, "o", "    sqlite3_finalize(stmt);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[395.261037, "o", "    pthread_mutex_unlock(&db_mutex);\r\n\u001b[?2004l\r"]
[395.261065, "o", "\u001b[?2004h> "]
[395.261408, "o", "    return exists;\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[395.26246, "o", "\u001b[?2004hroot@10c43992d5dc:/app# "]
[395.71403, "i", "cat > /app/src/auth.c << 'EOF'\n#include \"auth.h\"\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <ctype.h>\n\nstatic char api_key[256] = {0};\nstatic int key_loaded = 0;\n\nstatic void load_key(void) {\n    if (key_loaded) return;\n    FILE *f = fopen(\"/app/config/api.key\", \"r\");\n    if (!f) {\n        key_loaded = 1;\n        return;\n    }\n    if (fgets(api_key, sizeof(api_key), f)) {\n        /* trim whitespace from both ends */\n        char *start = api_key;\n        while (*start && isspace((unsigned char)*start)) start++;\n        char *end = start + strlen(start) - 1;\n        while (end > start && isspace((unsigned char)*end)) *end-- = '\\0';\n        if (start != api_key) memmove(api_key, start, strlen(start) + 1);\n    }\n    fclose(f);\n    key_loaded = 1;\n}\n\nint api_key_valid(struct MHD_Connection *connection) {\n    load_key();\n    const char *provided = MHD_lookup_connection_value(connection, MHD_HEADER_KIND, \"X-API-Key\");\n    if (!provided || strlen(api_key) == 0) return 0;\n    return strcmp(provided, api_key) == 0 ? 1 : 0;\n}\nEOF\n"]
