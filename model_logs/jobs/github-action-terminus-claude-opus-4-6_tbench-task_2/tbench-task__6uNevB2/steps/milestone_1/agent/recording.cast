[697.745648, "o", "\u001b[?2004h> "]
[697.745762, "o", "    char search[256];\r\n\u001b[?2004l\r"]
[697.745793, "o", "\u001b[?2004h> "]
[697.746141, "o", "    snprintf(search, sizeof(search), \"\\\"%s\\\"\", key);\r\n\u001b[?2004l\r"]
[697.746178, "o", "\u001b[?2004h> "]
[697.746416, "o", "    const char *p = strstr(json, search);\r\n\u001b[?2004l\r"]
[697.746446, "o", "\u001b[?2004h> "]
[697.746615, "o", "    if (!p) return NULL;\r\n\u001b[?2004l\r"]
[697.746646, "o", "\u001b[?2004h> "]
[697.746831, "o", "    p += strlen(search);\r\n\u001b[?2004l\r"]
[697.746969, "o", "\u001b[?2004h> "]
[697.747235, "o", "    while (*p && (isspace((unsigned char)*p) || *p == ':')) p++;\r\n\u001b[?2004l\r"]
[697.747361, "o", "\u001b[?2004h"]
[697.747445, "o", "> "]
[697.747653, "o", "    if (*p == 'n' && strncmp(p, \"null\", 4) == 0) return NULL;\r\n\u001b[?2004l\r"]
[697.747737, "o", "\u001b[?2004h> "]
[697.747891, "o", "    if (*p != '\"') return NULL;\r\n\u001b[?2004l\r"]
