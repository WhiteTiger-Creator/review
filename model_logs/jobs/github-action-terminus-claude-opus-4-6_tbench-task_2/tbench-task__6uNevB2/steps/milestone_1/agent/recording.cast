[697.750414, "o", "\u001b[?2004h"]
[697.750436, "o", "> "]
[697.750727, "o", "                case '\"': result[len++] = '\"'; break;\r\n\u001b[?2004l\r"]
[697.750749, "o", "\u001b[?2004h"]
[697.75077, "o", "> "]
[697.751088, "o", "                case '\\\\': result[len++] = '\\\\'; break;\r\n\u001b[?2004l\r"]
[697.751112, "o", "\u001b[?2004h"]
