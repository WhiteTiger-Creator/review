[16.507198, "o", "\u001b[?2004hroot@10c43992d5dc:/app# "]
[16.793787, "i", "cat /app/src/static.h\n"]
[16.794384, "o", "cat /app/src/static.h\r\n\u001b[?2004l\r"]
