[?2004l[?2004h> /* Simple JSON string extraction - finds "key":"value" and returns value (unescaped) */
[?2004l[?2004h> static char *json_get_string(const char *json, const char *key) {
[?2004l[?2004h>     char search[256];
[?2004l[?2004h>     snprintf(search, sizeof(search), "\"%s\"", key);
[?2004l[?2004h>     const char *p = strstr(json, search);
[?2004l[?2004h>     if (!p) return NULL;
[?2004l[?2004h>     p += strlen(search);
[?2004l[?2004h>     /* skip whitespace and colon */
[?2004l[?2004h>     while (*p && (isspace((unsigned char)*p) || *p == ':')) p++;
[?2004l[?2004h>     if (*p == 'n' && strncmp(p, "null", 4) == 0) return NULL;
[?2004l[?2004h>     if (*p != '"') return NULL;
[?2004l[?2004h>     p++; /* skip opening quote */
[?2004l[?2004h>     
[?2004l[?2004h>     /* Parse the string value with escape handling */
[?2004l[?2004h>     size_t cap = 256;
[?2004l[?2004h>     size_t len = 0;
[?2004l[?2004h>     char *result = malloc(cap);
[?2004l[?2004h>     while (*p && *p != '"') {
[?2004l[?2004h>         if (len + 4 >= cap) {
[?2004l[?2004h>             cap *= 2;
[?2004l[?2004h>             result = realloc(result, cap);
[?2004l[?2004h>         }
[?2004l[?2004h>         if (*p == '\\') {
[?2004l[?2004h>             p++;
[?2004l[?2004h>             switch (*p) {
[?2004l[?2004h>                 case '"': result[len++] = '"'; break;
[?2004l[?2004h>                 case '\\': result[len++] = '\\'; break;
[?2004l[?2004h>                 case '/': result[len++] = '/'; break;
[?2004l[?2004h>                 case 'n': result[len++] = '\n'; break;
[?2004l[?2004h>                 case 'r': result[len++] = '\r'; break;
[?2004l[?2004h>                 case 't': result[len++] = '\t'; break;
[?2004l[?2004h>                 case 'b': result[len++] = '\b'; break;
[?2004l[?2004h>                 case 'f': result[len++] = '\f'; break;
[?2004l[?2004h>                 case 'u': {
[?2004l[?2004h>                     /* basic \uXXXX - just store as UTF-8 or raw */
[?2004l[?2004h>                     unsigned int cp = 0;
[?2004l[?2004h>                     for (int i = 0; i < 4 && p[1]; i++) {
[?2004l[?2004h>                         p++;
[?2004l[?2004h>                         cp <<= 4;
[?2004l[?2004h>                         if (*p >= '0' && *p <= '9') cp |= (*p - '0');
[?2004l[?2004h>                         else if (*p >= 'a' && *p <= 'f') cp |= (*p - 'a' + 10);
[?2004l[?2004h>                         else if (*p >= 'A' && *p <= 'F') cp |= (*p - 'A' + 10);
[?2004l[?2004h>                     }
[?2004l[?2004h>                     if (cp < 0x80) {
[?2004l[?2004h>                         result[len++] = (char)cp;
[?2004l[?2004h>                     } else if (cp < 0x800) {
[?2004l[?2004h>                         result[len++] = (char)(0xC0 | (cp >> 6));
[?2004l[?2004h>                         result[len++] = (char)(0x80 | (cp & 0x3F));
[?2004l[?2004h>                     } else {
[?2004l[?2004h>                         result[len++] = (char)(0xE0 | (cp >> 12));
[?2004l[?2004h>                         result[len++] = (char)(0x80 | ((cp >> 6) & 0x3F));
[?2004l[?2004h>                         result[len++] = (char)(0x80 | (cp & 0x3F));
[?2004l[?2004h>                     }
[?2004l[?2004h>                     break;
[?2004l[?2004h>                 }
[?2004l[?2004h>                 default: result[len++] = *p; break;
