[273.906856, "o", "    // Write checkpoint with pass_epoch\r\n"]
[273.907041, "o", "    fs::create_directories(fs::path(checkpoint_path).parent_path());\r\n    std::ostringstream cp_out;\r\n    cp_out << \"{\\\"schema_version\\\":\" << forge::kSchemaVersion << \",\\\"lane_token\\\":\\\"\" << lane_token_str\r\n           << \"\\\",\\\"pass_epoch\\\":\" << (pass_epoch + 1) << \",\\\"units\\\":[\";\r\n    for (size_t i = 0; i < merged.size(); ++i) {\r\n        if (i) {\r\n            cp_out << ',';\r\n        }\r\n"]
[273.907372, "o", "        cp_out << \"{\\\"name\\\":\\\"\" << merged[i].name << \"\\\",\\\"next_pass\\\":\" << merged[i].next_pass\r\n               << \",\\\"carry_weight\\\":\" << merged[i].carry_weight << \",\\\"carry_drift\\\":\"\r\n               << merged[i].carry_drift << '}';\r\n    }\r\n    cp_out << \"}\\n\";\r\n    std::ofstream cp_file(checkpoint_path, std::ios::binary);\r\n    cp_file << cp_out.str();\r\n\r\n    return 0;\r\n}\r\n"]
