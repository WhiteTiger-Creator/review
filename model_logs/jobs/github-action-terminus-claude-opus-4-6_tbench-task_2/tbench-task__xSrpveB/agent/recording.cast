[72.062742, "o", "#include \"types.h\"\r\n#include <stddef.h>\r\n\r\nunsigned long j2_fold_line(unsigned long seed, const char *line, size_t len) {\r\n    unsigned long h = seed;\r\n    for (size_t i = 0; i < len; ++i) {\r\n        h ^= (unsigned char)line[i];\r\n        h *= 1099511628211UL;\r\n    }\r\n    return h;\r\n}\r\n"]
[72.06302, "o", "\u001b[?2004h"]
[72.063099, "o", "root@cdd56a0b6335:/app# "]
[72.172759, "i", "cat /app/environment/b07/extra_b1.c\n"]
