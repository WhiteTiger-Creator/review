[264.208451, "o", "> "]
[264.208806, "o", "            pass_index = it->second.next_pass;\r\n\u001b[?2004l\r"]
[264.208877, "o", "\u001b[?2004h"]
[264.208946, "o", "> "]
[264.209303, "o", "            cp_carry_weight = it->second.carry_weight;\r\n\u001b[?2004l\r"]
[264.209327, "o", "\u001b[?2004h"]
[264.209519, "o", "> "]
[264.209645, "o", "            has_checkpoint_entry = true;\r\n\u001b[?2004l\r"]
[264.209672, "o", "\u001b[?2004h> "]
[264.209752, "o", "        }"]
[264.209834, "o", "\r\n\u001b[?2004l\r"]
[264.209897, "o", "\u001b[?2004h"]
[264.20997, "o", "> "]
[264.210073, "o", "    }\r\n"]
[264.210136, "o", "\u001b[?2004l\r"]
[264.2102, "o", "\u001b[?2004h"]
[264.210266, "o", "> "]
[264.210322, "o", "\r\n"]
[264.210376, "o", "\u001b[?2004l\r"]
[264.210433, "o", "\u001b[?2004h"]
[264.210499, "o", "> "]
[264.210892, "o", "    if (run.mode == \"resume\" && has_checkpoint_entry) {\r\n\u001b[?2004l\r"]
[264.210969, "o", "\u001b[?2004h> "]
[264.211509, "o", "        run.order_weight = cp_carry_weight + static_cast<int64_t>(order_weight_base) + run.record_bytes;\r\n\u001b[?2004l\r"]
[264.211607, "o", "\u001b[?2004h> "]
[264.211668, "o", "    } else {\r\n\u001b[?2004l\r"]
[264.211688, "o", "\u001b[?2004h> "]
[264.212051, "o", "        // Fresh path: order_weight_base * (order_rank + 1) + record_bytes\r\n\u001b[?2004l\r"]
[264.212069, "o", "\u001b[?2004h"]
[264.212081, "o", "> "]
[264.212723, "o", "        run.order_weight = static_cast<int64_t>(order_weight_base) * (static_cast<int64_t>(order_rank) + 1) + run.record_bytes;\r\n\u001b[?2004l\r"]
[264.212745, "o", "\u001b[?2004h> "]
[264.212804, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[264.21284, "o", "> "]
[264.213, "o", "    run.pass_index = pass_index;\r\n\u001b[?2004l\r"]
[264.213016, "o", "\u001b[?2004h> "]
[264.213215, "o", "    run.row_serial = forge_lane_row_text(run);\r\n\u001b[?2004l\r"]
[264.213329, "o", "\u001b[?2004h> "]
[264.213506, "o", "    run.row_digest = digest_hex(run.row_serial);\r\n\u001b[?2004l\r"]
[264.213547, "o", "\u001b[?2004h> \r\n\u001b[?2004l\rj"]
[264.213574, "o", "\u001b[?2004h> "]
[264.213736, "o", "    std::ostringstream js;\r\n\u001b[?2004l\r"]
[264.213758, "o", "\u001b[?2004h"]
[264.2138, "o", "> "]
[264.214164, "o", "    js << \"{\\\"name\\\":\\\"\" << json_escape(run.name) << \"\\\",\\\"mode\\\":\\\"\" << json_escape(run.mode)\r\n\u001b[?2004l\r"]
[264.214194, "o", "\u001b[?2004h> "]
[264.214629, "o", "       << \"\\\",\\\"pass_index\\\":\" << run.pass_index << \",\\\"manifest_bytes\\\":\" << run.manifest_bytes\r\n\u001b[?2004l\r"]
[264.214668, "o", "\u001b[?2004h"]
[264.214681, "o", "> "]
[264.215189, "o", "       << \",\\\"record_bytes\\\":\" << run.record_bytes << \",\\\"drift_bytes\\\":\" << run.drift_bytes"]
[264.215253, "o", "\r\n"]
[264.215297, "o", "\u001b[?2004l\r"]
[264.215348, "o", "\u001b[?2004h"]
[264.215407, "o", "> "]
[264.216054, "o", "       << \",\\\"order_rank\\\":\" << run.order_rank << \",\\\"order_weight\\\":\" << run.order_weight\r\n"]
[264.216116, "o", "\u001b[?2004l\r"]
[264.216201, "o", "\u001b[?2004h"]
[264.216257, "o", "> "]
[264.216624, "o", "       << \",\\\"row_digest\\\":\\\"\" << run.row_digest << \"\\\"}\";\r\n\u001b[?2004l\r"]
[264.216768, "o", "\u001b[?2004h> "]
[264.216876, "o", "    run.json = js.str();\r\n\u001b[?2004l\r\u001b[?2004h> "]
[264.216926, "o", "    return run;\r\n\u001b[?2004l\r"]
[264.216949, "o", "\u001b[?2004h"]
[264.216959, "o", "> "]
[264.217001, "o", "}\r\n\u001b[?2004l\r\u001b[?2004h"]
[264.217012, "o", "> \r\n\u001b[?2004l\r:"]
[264.217179, "o", "\u001b[?2004h> "]
[264.217242, "o", "}  // namespace forge\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[264.217263, "o", "\u001b[?2004h> "]
[264.217465, "o", "int forge_run_emit(int argc, char **argv) {\r\n\u001b[?2004l\r"]
[264.21756, "o", "\u001b[?2004h> "]
[264.217633, "o", "    if (argc != 4) {\r\n\u001b[?2004l\r"]
[264.217778, "o", "\u001b[?2004h> "]
[264.218041, "o", "        std::cerr << \"usage: forge_emit <manifest-json> <output-json> <units-csv>\\n\";\r\n\u001b[?2004l\r"]
[264.218061, "o", "\u001b[?2004h"]
[264.218081, "o", "> "]
[264.218195, "o", "        return 2;\r\n\u001b[?2004l\r"]
[264.218215, "o", "\u001b[?2004h> "]
[264.218267, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[264.218319, "o", "> "]
[264.21844, "o", "    fs::path manifest_path = argv[1];\r\n\u001b[?2004l\r"]
[264.218456, "o", "\u001b[?2004h"]
[264.218465, "o", "> "]
[264.218661, "o", "    fs::path output_path = argv[2];\r\n\u001b[?2004l\r\u001b[?2004h"]
[264.218679, "o", "> "]
[264.219144, "o", "    std::vector<std::string> requested = forge::split_units_csv(argv[3]);\r\n\u001b[?2004l\r"]
[264.219165, "o", "\u001b[?2004h> "]
[264.219604, "o", "    forge::Manifest manifest = forge::load_manifest(manifest_path);\r\n\u001b[?2004l\r"]
[264.219689, "o", "\u001b[?2004h> "]
[264.219979, "o", "    fs::path manifest_dir = manifest_path.parent_path();\r\n\u001b[?2004l\r"]
[264.220041, "o", "\u001b[?2004h"]
[264.220113, "o", "> \r\n\u001b[?2004l\rr"]
[264.220179, "o", "\u001b[?2004h> "]
[264.220711, "o", "    const char *lane_token = forge_lane_fingerprint(manifest.units.data(), manifest.units.size());\r\n\u001b[?2004l\r"]
[264.22073, "o", "\u001b[?2004h> "]
[264.220996, "o", "    std::string lane_token_str(lane_token);\r\n\u001b[?2004l\r"]
[264.221055, "o", "\u001b[?2004h> "]
[264.223036, "o", "    fs::path checkpoint_path = forge::kCheckpointPath;\r\n\u001b[?2004l\r"]
[264.223068, "o", "\u001b[?2004h> "]
[264.223422, "o", "    int pass_epoch = forge::read_pass_epoch(checkpoint_path);\r\n\u001b[?2004l\r"]
[264.223511, "o", "\u001b[?2004h> "]
[264.223761, "o", "    forge::LaneCheckpoint checkpoint = forge_lane_load_checkpoint(checkpoint_path, lane_token_str);\r\n\u001b[?2004l\r"]
[264.223777, "o", "\u001b[?2004h"]
[264.223828, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[264.223843, "o", "> "]
[264.223983, "o", "    std::vector<const char *> name_ptrs;\r\n\u001b[?2004l\r"]
[264.223999, "o", "\u001b[?2004h"]
[264.224011, "o", "> "]
[264.224173, "o", "    for (const auto &unit : manifest.units) {\r\n\u001b[?2004l\r"]
[264.224269, "o", "\u001b[?2004h> "]
[264.224375, "o", "        name_ptrs.push_back(unit.name.c_str());\r\n\u001b[?2004l\r"]
[264.224389, "o", "\u001b[?2004h> "]
[264.224596, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[264.224735, "o", "    std::map<std::string, forge::UnitSpec> spec_by_name;\r\n\u001b[?2004l\r"]
[264.224752, "o", "\u001b[?2004h"]
[264.224765, "o", "> "]
[264.224913, "o", "    for (const auto &unit : manifest.units) {\r\n\u001b[?2004l\r"]
[264.225016, "o", "\u001b[?2004h> "]
[264.225095, "o", "        spec_by_name[unit.name] = unit;\r\n\u001b[?2004l\r"]
[264.225157, "o", "\u001b[?2004h"]
[264.225214, "o", ">     }\r\n\u001b[?2004l\r"]
[264.225229, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[264.225274, "o", "\u001b[?2004h> "]
[264.225384, "o", "    std::vector<forge::UnitRun> units;\r\n\u001b[?2004l\r"]
[264.225423, "o", "\u001b[?2004h"]
[264.225446, "o", "> "]
[264.225597, "o", "    std::vector<forge::UnitCheckpoint> updated_entries;\r\n\u001b[?2004l\r"]
[264.225613, "o", "\u001b[?2004h"]
[264.225672, "o", "> "]
[264.225864, "o", "    std::vector<std::string> requested_resume;\r\n\u001b[?2004l\r"]
[264.225886, "o", "\u001b[?2004h> "]
[264.226079, "o", "    for (const auto &name : requested) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[264.226186, "o", "        auto it = spec_by_name.find(name);\r\n\u001b[?2004l\r"]
[264.226255, "o", "\u001b[?2004h> "]
[264.226407, "o", "        if (it == spec_by_name.end()) {\r\n\u001b[?2004l\r"]
[264.226432, "o", "\u001b[?2004h> "]
[264.22651, "o", "            continue;\r\n\u001b[?2004l\r"]
[264.226527, "o", "\u001b[?2004h"]
[264.226556, "o", "> "]
[264.226629, "o", "        }\r\n\u001b[?2004l\r"]
[264.226691, "o", "\u001b[?2004h> "]
[264.226854, "o", "        int order_rank = static_cast<int>(std::distance(\r\n\u001b[?2004l\r"]
[264.226921, "o", "\u001b[?2004h"]
[264.226952, "o", "> "]
[264.227015, "o", "            manifest.units.begin(),\r\n\u001b[?2004l\r"]
[264.227031, "o", "\u001b[?2004h"]
[264.227043, "o", "> "]
[264.227312, "o", "            std::find_if(manifest.units.begin(), manifest.units.end(),\r\n\u001b[?2004l\r"]
[264.227377, "o", "\u001b[?2004h> "]
[264.227592, "o", "                         [&](const forge::UnitSpec &u) { return u.name == name; })));\r\n\u001b[?2004l\r"]
[264.227618, "o", "\u001b[?2004h> "]
[264.227745, "o", "        int64_t cw = 0;\r\n\u001b[?2004l\r"]
[264.227786, "o", "\u001b[?2004h> "]
[264.22789, "o", "        if (checkpoint.valid) {"]
[264.227922, "o", "\r\n"]
[264.228003, "o", "\u001b[?2004l\r"]
[264.228056, "o", "\u001b[?2004h"]
[264.228105, "o", "> "]
[264.228355, "o", "            auto cp = checkpoint.units.find(name);\r\n"]
[264.228433, "o", "\u001b[?2004l\r"]
[264.228495, "o", "\u001b[?2004h"]
[264.228561, "o", "> "]
[264.228745, "o", "            if (cp != checkpoint.units.end()) {\r\n\u001b[?2004l\r"]
[264.228776, "o", "\u001b[?2004h> "]
[264.228947, "o", "                cw = cp->second.carry_weight;\r\n\u001b[?2004l\r"]
[264.228997, "o", "\u001b[?2004h"]
[264.23027, "o", ">             }\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>         forge::UnitRun run = forge::analyze_unit(it->second, order_rank, manifest.order_weight_base,\r\n\u001b[?2004l\r\u001b[?2004h>                                                  pass_epoch, manifest_dir, name_ptrs.data(),\r\n\u001b[?2004l\r\u001b[?2004h>                                                  name_ptrs.size(), &checkpoint, cw);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[264.230304, "o", "        units.push_back(run);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[264.23033, "o", "        if (run.mode == \"resume\") {\r\n\u001b[?2004l\r"]
[264.230462, "o", "\u001b[?2004h> "]
[264.230515, "o", "            requested_resume.push_back(name);"]
[264.230613, "o", "\r\n"]
[264.230646, "o", "\u001b[?2004l\r"]
[264.230707, "o", "\u001b[?2004h"]
[264.230774, "o", "> "]
[264.230915, "o", "            forge::UnitCheckpoint entry;\r\n"]
[264.230964, "o", "\u001b[?2004l\r"]
[264.231032, "o", "\u001b[?2004h"]
[264.231087, "o", "> "]
[264.231226, "o", "            entry.name = run.name;\r\n"]
[264.231272, "o", "\u001b[?2004l\r"]
[264.231323, "o", "\u001b[?2004h"]
[264.23138, "o", "> "]
[264.231598, "o", "            entry.next_pass = run.pass_index + 1;\r\n\u001b[?2004l\r"]
[264.23176, "o", "\u001b[?2004h"]
[264.23185, "o", "> "]
[264.231929, "o", "            entry.carry_weight = run.order_weight;\r\n\u001b[?2004l\r"]
[264.231951, "o", "\u001b[?2004h> "]
[264.232124, "o", "            entry.carry_drift = run.drift_bytes;\r\n\u001b[?2004l\r"]
[264.232214, "o", "\u001b[?2004h"]
[264.232295, "o", "> "]
[264.232387, "o", "            updated_entries.push_back(entry);\r\n\u001b[?2004l\r"]
[264.232449, "o", "\u001b[?2004h>         }\r\n"]
[264.232591, "o", "\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[264.232642, "o", "\u001b[?2004h> "]
[264.232861, "o", "    int64_t drift_total = forge_lane_drift_total(units.data(), units.size());\r\n\u001b[?2004l\r"]
[264.232914, "o", "\u001b[?2004h> "]
[264.233189, "o", "    int64_t weight_total = forge_lane_score_total(units.data(), units.size());\r\n\u001b[?2004l\r"]
[264.233264, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[264.233383, "o", "    std::ostringstream serial;\r\n\u001b[?2004l\r"]
[264.233407, "o", "\u001b[?2004h"]
[264.23342, "o", "> "]
[264.233727, "o", "    serial << forge_lane_header_text(forge::kSchemaVersion, manifest.release_id,\r\n\u001b[?2004l\r"]
[264.233753, "o", "\u001b[?2004h> "]
[264.234028, "o", "                                     manifest.order_weight_base, pass_epoch, drift_total,\r\n\u001b[?2004l\r"]
[264.234052, "o", "\u001b[?2004h> "]
[264.234185, "o", "                                     weight_total);\r\n\u001b[?2004l\r"]
[264.234206, "o", "\u001b[?2004h"]
[264.234263, "o", "> "]
[264.234358, "o", "    for (const auto &unit : units) {\r\n\u001b[?2004l\r"]
[264.23443, "o", "\u001b[?2004h> "]
[264.234576, "o", "        serial << '\\n' << unit.row_serial;\r\n\u001b[?2004l\r"]
[264.234598, "o", "\u001b[?2004h"]
[264.234625, "o", "> "]
[264.234755, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[264.234914, "o", "    std::string top_digest = forge::digest_hex(serial.str());\r\n\u001b[?2004l\r"]
[264.234933, "o", "\u001b[?2004h> \r\n"]
[264.235067, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[264.235179, "o", "    fs::create_directories(output_path.parent_path());\r\n\u001b[?2004l\r"]
[264.235261, "o", "\u001b[?2004h> "]
[264.235345, "o", "    std::ostringstream out;\r\n\u001b[?2004l\r"]
[264.235465, "o", "\u001b[?2004h> "]
[264.235705, "o", "    out << \"{\\\"schema_version\\\":\" << forge::kSchemaVersion << \",\\\"release_id\\\":\\\"\"\r\n\u001b[?2004l\r"]
[264.23573, "o", "\u001b[?2004h"]
[264.235742, "o", "> "]
[264.236128, "o", "        << manifest.release_id << \"\\\",\\\"order_weight_base\\\":\" << manifest.order_weight_base"]
[264.236212, "o", "\r\n"]
[264.236269, "o", "\u001b[?2004l\r"]
[264.236354, "o", "\u001b[?2004h"]
[264.236427, "o", "> "]
[264.236659, "o", "        << \",\\\"pass_epoch\\\":\" << pass_epoch << \",\\\"units\\\":[\";\r\n"]
[264.23671, "o", "\u001b[?2004l\r"]
[264.236808, "o", "\u001b[?2004h> "]
[264.236971, "o", "    for (std::size_t i = 0; i < units.size(); ++i) {\r\n\u001b[?2004l\r"]
[264.236998, "o", "\u001b[?2004h"]
[264.237011, "o", "> "]
[264.237119, "o", "        if (i) {\r\n\u001b[?2004l\r"]
[264.23719, "o", "\u001b[?2004h"]
[264.237249, "o", "> "]
[264.23739, "o", "            out << ',';\r\n\u001b[?2004l\r\u001b[?2004h> "]
[264.237414, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[264.237504, "o", "        out << units[i].json;\r\n\u001b[?2004l\r"]
[264.237528, "o", "\u001b[?2004h> "]
[264.237572, "o", "    }"]
[264.239477, "o", "\r\n"]
[264.239575, "o", "\u001b[?2004l\r\u001b[?2004h>     out << \"],\\\"total_drift_bytes\\\":\" << drift_total << \",\\\"order_score\\\":\" << weight_total\r\n\u001b[?2004l\r\u001b[?2004h>         << \",\\\"digest\\\":\\\"\" << top_digest << \"\\\"}\\n\";\r\n\u001b[?2004l\r\u001b[?2004h>     std::ofstream file(output_path, std::ios::binary);\r\n\u001b[?2004l\r\u001b[?2004h>     file << out.str();\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     // Merge checkpoint entries preserving unrelated resume units\r\n\u001b[?2004l\r\u001b[?2004h>     std::vector<forge::UnitCheckpoint> merged =\r\n\u001b[?2004l\r\u001b[?2004h>         forge_lane_merge_checkpoint(checkpoint, updated_entries, requested_resume);\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     // Write checkpoint with pass_epoch\r\n\u001b[?2004l\r\u001b[?2004h> "]
[264.239726, "o", "    fs::create_directories(fs::path(checkpoint_path).parent_path());\r\n\u001b[?2004l\r"]
[264.239817, "o", "\u001b[?2004h> "]
[264.239913, "o", "    std::ostringstream cp_out;\r\n\u001b[?2004l\r"]
[264.239981, "o", "\u001b[?2004h> "]
[264.240358, "o", "    cp_out << \"{\\\"schema_version\\\":\" << forge::kSchemaVersion << \",\\\"lane_token\\\":\\\"\" << lane_token_str\r\n\u001b[?2004l\r"]
[264.240424, "o", "\u001b[?2004h> "]
[264.240677, "o", "           << \"\\\",\\\"pass_epoch\\\":\" << (pass_epoch + 1) << \",\\\"units\\\":[\";\r\n\u001b[?2004l\r"]
[264.24075, "o", "\u001b[?2004h> "]
[264.240908, "o", "    for (size_t i = 0; i < merged.size(); ++i) {\r\n"]
[264.240992, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[264.241052, "o", "        if (i) {"]
