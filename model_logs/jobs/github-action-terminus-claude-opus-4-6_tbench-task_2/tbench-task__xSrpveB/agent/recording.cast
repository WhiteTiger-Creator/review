[264.207369, "o", "\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> UnitRun analyze_unit(const UnitSpec &spec, int order_rank, int order_weight_base, int pass_epoch,\r\n\u001b[?2004l\r\u001b[?2004h>                      const fs::path &manifest_dir, const char *const *names, size_t name_count,\r\n\u001b[?2004l\r\u001b[?2004h>                      const LaneCheckpoint *checkpoint, int64_t carry_weight) {\r\n\u001b[?2004l\r\u001b[?2004h>     (void)carry_weight;\r\n\u001b[?2004l\r\u001b[?2004h>     (void)pass_epoch;\r\n\u001b[?2004l\r\u001b[?2004h>     fs::path record_path = manifest_dir / spec.record;\r\n\u001b[?2004l\r\u001b[?2004h>     UnitRun run{};\r\n\u001b[?2004l\r\u001b[?2004h>     run.name = spec.name;\r\n\u001b[?2004l\r\u001b[?2004h>     run.mode = forge_lane_mode(spec.mode.c_str(), spec.name.c_str(), 0);\r\n\u001b[?2004l\r\u001b[?2004h>     run.manifest_bytes = spec.manifest_bytes;\r\n\u001b[?2004l\r\u001b[?2004h>     run.record_bytes = read_record_bytes(record_path);\r\n\u001b[?2004l\r\u001b[?2004h>     run.drift_bytes = run.record_bytes - static_cast<int64_t>(run.manifest_bytes);\r\n\u001b[?2004l\r\u001b[?2004h>     run.order_rank = order_rank;\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\ri\u001b[?"]
