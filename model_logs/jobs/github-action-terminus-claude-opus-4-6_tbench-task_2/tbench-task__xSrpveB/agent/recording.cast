[357.812849, "i", "python3 -c \"\nimport struct\n\ndef digest(text):\n    h = 1469598103934665603\n    for b in text.encode('utf-8'):\n        h ^= b\n        h = (h * 1099511628211) & 0xffffffffffffffff\n    return format(h, '016x')\n\n# Verify lane token\nlines = sorted([\n    'u_kappa|cold|records/r0.unit|6150|0',\n    'u_alpha|resume|records/r1.unit|4100|0',\n    'u_zeta|resume|records/r2.unit|2050|0'\n])\nprint('lane_token:', digest('\\\\n'.join(lines)))\n\n# Verify first invocation digest\nheader = '1|forge_r07|500|0|0|15300'\nrows = [\n    'u_kappa|6150|6150|0|0|6650',\n    'u_alpha|4100|4100|0|1|5100',\n    'u_zeta|2050|2050|0|2|3550'\n]\nfull = header + '\\\\n' + '\\\\n'.join(rows)\nprint('first digest:', digest(full))\n\n# Verify row_digest for u_kappa\nprint('u_kappa row_digest:', digest('u_kappa|6150|6150|0|0|6650'))\nprint('u_alpha row_digest:', digest('u_alpha|4100|4100|0|1|5100'))\nprint('u_zeta row_digest:', digest('u_zeta|2050|2050|0|2|3550'))\n\"\n"]
