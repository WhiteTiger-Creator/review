[72.520772, "o", "\r\n"]
[72.520941, "o", "\u001b[?2004l\r"]
[72.522112, "o", "#include \"types.h\"\r\n#include <stdlib.h>\r\n\r\nint64_t m14_shadow_carry(int64_t base, int64_t carry) {\r\n    if (carry < 0) {\r\n        return base;\r\n    }\r\n    return base + carry / 2;\r\n}\r\n"]
