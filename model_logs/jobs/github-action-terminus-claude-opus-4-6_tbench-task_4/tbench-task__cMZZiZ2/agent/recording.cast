[342.915395, "o", "        spec.record = pick_string(block, \"record\");\r\n\u001b[?2004l\r"]
[342.915509, "o", "\u001b[?2004h> "]
[342.915828, "o", "        spec.manifest_bytes = pick_int(block, \"manifest_bytes\");\r\n\u001b[?2004l\r"]
[342.915951, "o", "\u001b[?2004h> "]
[342.916222, "o", "        spec.start_pass = pick_int(block, \"start_pass\");\r\n\u001b[?2004l\r"]
[342.916304, "o", "\u001b[?2004h> "]
[342.916488, "o", "        if (!spec.name.empty()) {\r\n\u001b[?2004l\r"]
[342.916548, "o", "\u001b[?2004h> "]
[342.91682, "o", "            manifest.units.push_back(spec);\r\n\u001b[?2004l\r"]
[342.916839, "o", "\u001b[?2004h"]
[342.916864, "o", "> "]
[342.916993, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h"]
[342.917122, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[342.917173, "o", "> "]
[342.917225, "o", "    return manifest;\r\n\u001b[?2004l\r"]
[342.917293, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r"]
[342.917362, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[342.917444, "o", "\u001b[?2004h> "]
[342.917723, "o", "std::string digest_hex(const std::string &text) {\r\n\u001b[?2004l\r"]
[342.917785, "o", "\u001b[?2004h> "]
[342.918127, "o", "    std::uint64_t h = digest_update(kDigestSeed, text);\r\n\u001b[?2004l\r"]
[342.918182, "o", "\u001b[?2004h"]
[342.918235, "o", "> "]
[342.918358, "o", "    std::ostringstream os;\r\n\u001b[?2004l\r"]
[342.918424, "o", "\u001b[?2004h> "]
[342.918889, "o", "    os << std::hex << std::nouppercase << std::setfill('0') << std::setw(16) << h;\r\n\u001b[?2004l\r"]
[342.918911, "o", "\u001b[?2004h"]
[342.918948, "o", "> "]
[342.919075, "o", "    return os.str();\r\n\u001b[?2004l\r"]
[342.919158, "o", "\u001b[?2004h"]
