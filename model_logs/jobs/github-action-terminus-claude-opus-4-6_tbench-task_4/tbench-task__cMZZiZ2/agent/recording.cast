[85.026604, "o", "    }\r\n    return 0;\r\n}\r\n\r\nstd::uint64_t digest_update(std::uint64_t h, const std::string &text) {\r\n    for (unsigned char ch : text) {\r\n        h ^= static_cast<std::uint64_t>(ch);\r\n        h = (h * kDigestStep) & kDigestMask;\r\n    }\r\n    return h;\r\n}\r\n\r\nstd::string json_escape(const std::string &s) {\r\n    std::string out;\r\n    for (char c : s) {\r\n        if (c == '\"' || c == '\\\\') {\r\n            out.push_back('\\\\');\r\n        }\r\n        out.push_back(c);\r\n    }\r\n    return out;\r\n}\r\n\r\n}  // namespace\r\n\r\nstd::vector<std::string> split_units_csv(const std::string &text) {\r\n    std::vector<std::string> out;\r\n    std::string cur;\r\n    for (char ch : text) {\r\n        if (ch == ',') {\r\n            if (!cur.empty()) {\r\n                out.push_back(cur);\r\n            }\r\n            cur.clear();\r\n        } else if (!std::isspace(static_cast<unsigned char>(ch))) {\r\n            cur.push_back(ch);\r\n        }\r\n    }\r\n    if (!cur.empty()) {\r\n        out.push_back(cur);\r\n    }\r\n    return out;\r\n}\r\n\r\nint read_pass_epoch(co"]
