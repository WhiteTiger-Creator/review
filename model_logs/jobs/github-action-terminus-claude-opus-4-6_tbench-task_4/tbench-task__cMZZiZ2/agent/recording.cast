[342.92123, "o", "\u001b[?2004h"]
[342.921245, "o", "> "]
[342.921587, "o", "    fs::path record_path = manifest_dir / spec.record;\r\n\u001b[?2004l\r"]
[342.92162, "o", "\u001b[?2004h"]
[342.921638, "o", "> "]
[342.921768, "o", "    UnitRun run{};\r\n\u001b[?2004l\r"]
[342.921825, "o", "\u001b[?2004h> "]
