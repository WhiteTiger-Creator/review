[237.422704, "o", "extern \"C\" const char *m14_lane_token(const forge::UnitSpec *units, size_t count) {\r\n\u001b[?2004l\r"]
[237.422732, "o", "\u001b[?2004h"]
[237.422744, "o", "> "]
[237.422955, "o", "    static std::string cached;\r\n\u001b[?2004l\r"]
[237.423019, "o", "\u001b[?2004h> "]
[237.423398, "o", "    // Build descriptor lines and sort alphabetically by unit name\r\n\u001b[?2004l\r"]
[237.423492, "o", "\u001b[?2004h> "]
[237.423841, "o", "    std::vector<std::pair<std::string, std::string>> name_desc;\r\n\u001b[?2004l\r"]
[237.423862, "o", "\u001b[?2004h> "]
[237.424052, "o", "    for (size_t i = 0; i < count; ++i) {\r\n\u001b[?2004l\r"]
[237.4241, "o", "\u001b[?2004h> "]
[237.424323, "o", "        name_desc.emplace_back(units[i].name, descriptor_line(units[i]));\r\n\u001b[?2004l\r"]
[237.424345, "o", "\u001b[?2004h"]
[237.424372, "o", "> "]
[237.424461, "o", "    }\r\n\u001b[?2004l\r"]
[237.424542, "o", "\u001b[?2004h> "]
[237.424617, "o", "    std::sort(name_desc.begin(), name_desc.end(),\r\n\u001b[?2004l\r"]
[237.424646, "o", "\u001b[?2004h"]
[237.42466, "o", "> "]
[237.424986, "o", "              [](const std::pair<std::string,std::string> &a, const std::pair<std::string,std::string> &b) {\r\n\u001b[?2004l\r"]
[237.425007, "o", "\u001b[?2004h"]
[237.42504, "o", "> "]
[237.425182, "o", "                  return a.first < b.first;\r\n\u001b[?2004l\r"]
[237.425256, "o", "\u001b[?2004h> "]
[237.425379, "o", "              });\r\n\u001b[?2004l\r\u001b[?2004h> "]
[237.425474, "o", "    std::ostringstream joined;\r\n\u001b[?2004l\r"]
[237.425549, "o", "\u001b[?2004h> "]
[237.4257, "o", "    for (size_t i = 0; i < name_desc.size(); ++i) {\r\n\u001b[?2004l\r"]
[237.42576, "o", "\u001b[?2004h> "]
[237.425812, "o", "        if (i) {\r\n"]
[237.425857, "o", "\u001b[?2004l\r\u001b[?2004h"]
[237.425902, "o", "> "]
[237.425976, "o", "            joined << '\\n';\r\n\u001b[?2004l\r"]
[237.42601, "o", "\u001b[?2004h"]
[237.426051, "o", "> "]
[237.426104, "o", "        }\r\n\u001b[?2004l\r"]
[237.426154, "o", "\u001b[?2004h> "]
[237.426265, "o", "        joined << name_desc[i].second;\r\n"]
[237.426315, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[237.426347, "o", "    }\r\n\u001b[?2004l\r"]
[237.426378, "o", "\u001b[?2004h"]
[237.426398, "o", "> "]
[237.426543, "o", "    cached = digest_hex(joined.str());\r\n\u001b[?2004l\r"]
[237.426594, "o", "\u001b[?2004h"]
[237.426639, "o", "> "]
[237.426719, "o", "    return cached.c_str();\r\n\u001b[?2004l\r\u001b[?2004h"]
[237.426778, "o", "> }"]
[237.426823, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[237.42684, "o", "> "]
[237.427111, "o", "extern \"C\" int m14_checkpoint_valid(const char *on_disk_token, const char *expected_token) {\r\n\u001b[?2004l\r"]
[237.427132, "o", "\u001b[?2004h"]
[237.427146, "o", "> "]
[237.427339, "o", "    if (on_disk_token == nullptr || expected_token == nullptr) {\r\n\u001b[?2004l\r"]
[237.427358, "o", "\u001b[?2004h"]
[237.427406, "o", "> "]
[237.427483, "o", "        return 0;\r\n\u001b[?2004l\r\u001b[?2004h"]
[237.427506, "o", ">     }\r\n"]
[237.427521, "o", "\u001b[?2004l\r"]
[237.427604, "o", "\u001b[?2004h> "]
[237.427821, "o", "    return std::string(on_disk_token) == std::string(expected_token) ? 1 : 0;\r\n\u001b[?2004l\r"]
[237.427877, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r"]
[237.427924, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[237.427973, "o", "\u001b[?2004h> "]
[237.428208, "o", "forge::LaneCheckpoint m14_read_checkpoint(const std::filesystem::path &path,\r\n\u001b[?2004l\r"]
[237.42832, "o", "\u001b[?2004h"]
[237.428386, "o", "> "]
[237.428542, "o", "                                                   const std::string &expected_token) {\r\n\u001b[?2004l\r"]
[237.428608, "o", "\u001b[?2004h"]
[237.428655, "o", "> "]
[237.428759, "o", "    forge::LaneCheckpoint state;\r\n\u001b[?2004l\r"]
[237.428856, "o", "\u001b[?2004h> "]
[237.428932, "o", "    std::ifstream in(path);\r\n\u001b[?2004l\r"]
[237.429011, "o", "\u001b[?2004h> "]
[237.429064, "o", "    if (!in) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[237.429127, "o", "        return state;\r\n\u001b[?2004l\r\u001b[?2004h"]
[237.42915, "o", "> "]
[237.429165, "o", "    }\r\n\u001b[?2004l\r"]
[237.42933, "o", "\u001b[?2004h> "]
[237.429393, "o", "    std::ostringstream buffer;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[237.429468, "o", "    buffer << in.rdbuf();\r\n\u001b[?2004l\r"]
[237.429519, "o", "\u001b[?2004h> "]
[237.429652, "o", "    const std::string doc = buffer.str();\r\n\u001b[?2004l\r"]
[237.429686, "o", "\u001b[?2004h"]
[237.429699, "o", "> "]
[237.429883, "o", "    if (doc.find(\"\\\"schema_version\\\"\") == std::string::npos) {\r\n\u001b[?2004l\r"]
[237.429911, "o", "\u001b[?2004h"]
[237.429923, "o", "> "]
[237.430027, "o", "        return state;\r\n\u001b[?2004l\r\u001b[?2004h"]
[237.430052, "o", "> "]
[237.430146, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[237.43029, "o", "    state.lane_token = pick_string(doc, \"lane_token\");\r\n\u001b[?2004l\r"]
[237.430351, "o", "\u001b[?2004h> "]
[237.430588, "o", "    if (!m14_checkpoint_valid(state.lane_token.c_str(), expected_token.c_str())) {\r\n\u001b[?2004l\r"]
[237.430609, "o", "\u001b[?2004h"]
[237.430663, "o", "> "]
[237.430732, "o", "        return state;\r\n\u001b[?2004l\r"]
[237.43075, "o", "\u001b[?2004h"]
[237.430826, "o", "> "]
[237.430937, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[237.431001, "o", "    size_t units_pos = doc.find(\"\\\"units\\\"\");\r\n\u001b[?2004l\r"]
[237.431088, "o", "\u001b[?2004h"]
[237.431166, "o", "> "]
[237.431243, "o", "    if (units_pos == std::string::npos) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[237.431296, "o", "> "]
[237.431385, "o", "        return state;\r\n\u001b[?2004l\r\u001b[?2004h"]
[237.431458, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[237.431601, "o", "    size_t arr_start = doc.find('[', units_pos);\r\n\u001b[?2004l\r"]
[237.431623, "o", "\u001b[?2004h"]
[237.431681, "o", "> "]
[237.431796, "o", "    size_t arr_end = doc.find(']', arr_start);\r\n\u001b[?2004l\r"]
[237.431854, "o", "\u001b[?2004h> "]
[237.432067, "o", "    if (arr_start == std::string::npos || arr_end == std::string::npos) {\r\n\u001b[?2004l\r"]
[237.432152, "o", "\u001b[?2004h> "]
[237.432275, "o", "        return state;\r\n\u001b[?2004l\r\u001b[?2004h"]
[237.432377, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[237.432545, "o", "    const std::string arr = doc.substr(arr_start, arr_end - arr_start + 1);\r\n\u001b[?2004l\r"]
[237.432637, "o", "\u001b[?2004h> "]
[237.432767, "o", "    for (const auto &block : split_object_blocks(arr)) {\r\n\u001b[?2004l\r"]
[237.432802, "o", "\u001b[?2004h"]
[237.432843, "o", "> "]
[237.432943, "o", "        forge::UnitCheckpoint entry;\r\n\u001b[?2004l\r"]
[237.432991, "o", "\u001b[?2004h> "]
[237.433153, "o", "        entry.name = pick_string(block, \"name\");\r\n\u001b[?2004l\r"]
[237.433248, "o", "\u001b[?2004h> "]
[237.433414, "o", "        entry.next_pass = pick_int(block, \"next_pass\");\r\n\u001b[?2004l\r"]
[237.43345, "o", "\u001b[?2004h"]
[237.433474, "o", "> "]
[237.433657, "o", "        entry.carry_weight = pick_int64(block, \"carry_weight\");\r\n\u001b[?2004l\r"]
[237.433762, "o", "\u001b[?2004h"]
[237.433825, "o", "> "]
[237.43391, "o", "        entry.carry_drift = pick_int64(block, \"carry_drift\");\r\n\u001b[?2004l\r"]
[237.433929, "o", "\u001b[?2004h"]
[237.433943, "o", "> "]
[237.434059, "o", "        if (!entry.name.empty()) {\r\n\u001b[?2004l\r"]
[237.43413, "o", "\u001b[?2004h> "]
[237.434263, "o", "            state.units[entry.name] = entry;\r\n\u001b[?2004l\r"]
[237.434309, "o", "\u001b[?2004h> "]
[237.434349, "o", "        }\r\n\u001b[?2004l\r"]
[237.434381, "o", "\u001b[?2004h> "]
[237.434419, "o", "    }\r\n\u001b[?2004l\r"]
[237.434461, "o", "\u001b[?2004h> "]
[237.434556, "o", "    state.valid = true;\r\n"]
[237.434618, "o", "\u001b[?2004l\r\u001b[?2004h"]
[237.434659, "o", "> "]
[237.434705, "o", "    return state;\r\n\u001b[?2004l\r"]
[237.434827, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r"]
[237.434948, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[237.435043, "o", "std::vector<forge::UnitCheckpoint> m14_merge_entries(\r\n\u001b[?2004l\r"]
[237.435163, "o", "\u001b[?2004h"]
[237.43527, "o", "> "]
[237.435412, "o", "    const forge::LaneCheckpoint &existing, const std::vector<forge::UnitCheckpoint> &updated,\r\n\u001b[?2004l\r"]
[237.435534, "o", "\u001b[?2004h> "]
[237.435653, "o", "    const std::vector<std::string> &requested_resume) {\r\n\u001b[?2004l\r"]
[237.435771, "o", "\u001b[?2004h> "]
[237.43585, "o", "    // Start with existing valid entries\r\n\u001b[?2004l\r"]
[237.435913, "o", "\u001b[?2004h> "]
[237.436085, "o", "    std::map<std::string, forge::UnitCheckpoint> merged;\r\n\u001b[?2004l\r"]
[237.436138, "o", "\u001b[?2004h"]
[237.436241, "o", "> "]
[237.43626, "o", "    if (existing.valid) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[237.436352, "o", "> "]
[237.436472, "o", "        for (const auto &pair : existing.units) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[237.436549, "o", "> "]
[237.436651, "o", "            merged[pair.first] = pair.second;\r\n\u001b[?2004l\r"]
[237.436676, "o", "\u001b[?2004h"]
[237.436689, "o", "> "]
[237.436813, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[237.436877, "o", "\u001b[?2004h> "]
[237.437017, "o", "    // Update with new entries from this invocation\r\n\u001b[?2004l\r"]
[237.437072, "o", "\u001b[?2004h> "]
[237.437201, "o", "    for (const auto &entry : updated) {\r\n\u001b[?2004l\r"]
[237.437283, "o", "\u001b[?2004h> "]
[237.437398, "o", "        merged[entry.name] = entry;\r\n\u001b[?2004l\r"]
[237.437486, "o", "\u001b[?2004h> "]
[237.437541, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[237.437632, "o", "    // Convert to sorted vector\r\n\u001b[?2004l\r"]
[237.43773, "o", "\u001b[?2004h> "]
[237.437819, "o", "    std::vector<forge::UnitCheckpoint> out;\r\n\u001b[?2004l\r"]
[237.437911, "o", "\u001b[?2004h> "]
[237.438002, "o", "    for (const auto &pair : merged) {\r\n\u001b[?2004l\r"]
[237.438073, "o", "\u001b[?2004h"]
[237.438147, "o", "> "]
[237.438236, "o", "        out.push_back(pair.second);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[237.438257, "o", "    }\r\n\u001b[?2004l\r"]
[237.438271, "o", "\u001b[?2004h"]
[237.438283, "o", "> "]
[237.438411, "o", "    std::sort(out.begin(), out.end(),\r\n\u001b[?2004l\r"]
[237.438429, "o", "\u001b[?2004h"]
[237.438537, "o", "> "]
[237.438712, "o", "              [](const forge::UnitCheckpoint &a, const forge::UnitCheckpoint &b) {\r\n\u001b[?2004l\r"]
[237.438735, "o", "\u001b[?2004h"]
[237.438791, "o", "> "]
[237.438894, "o", "                  return a.name < b.name;\r\n\u001b[?2004l\r"]
[237.43896, "o", "\u001b[?2004h> "]
[237.439049, "o", "              });\r\n\u001b[?2004l\r"]
[237.439074, "o", "\u001b[?2004h> "]
[237.43912, "o", "    return out;\r\n\u001b[?2004l\r"]
[237.439135, "o", "\u001b[?2004h"]
[237.439178, "o", "> }\r\n\u001b[?2004l\r"]
[237.439193, "o", "\u001b[?2004h"]
[237.439235, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[237.439271, "o", "> "]
[237.43951, "o", "void m14_write_checkpoint(const std::filesystem::path &path, const char *lane_token,\r\n\u001b[?2004l\r"]
[237.439527, "o", "\u001b[?2004h"]
[237.439538, "o", "> "]
[237.439807, "o", "                                     const std::vector<forge::UnitCheckpoint> &entries) {\r\n\u001b[?2004l\r"]
[237.439822, "o", "\u001b[?2004h"]
[237.439869, "o", "> "]
[237.44005, "o", "    std::filesystem::create_directories(path.parent_path());\r\n\u001b[?2004l\r"]
[237.440139, "o", "\u001b[?2004h> "]
[237.440229, "o", "    std::ostringstream out;\r\n\u001b[?2004l\r\u001b[?2004h"]
[237.440332, "o", "> "]
[237.440765, "o", "    out << \"{\\\"schema_version\\\":\" << forge::kSchemaVersion << \",\\\"lane_token\\\":\\\"\" << lane_token\r\n\u001b[?2004l\r\u001b[?2004h>         << \"\\\",\\\"units\\\":[\";\r\n\u001b[?2004l\r\u001b[?2004h> "]
[237.440878, "o", "    for (size_t i = 0; i < entries.size(); ++i) {\r\n\u001b[?2004l\r"]
[237.44142, "o", "\u001b[?2004h"]
[237.441442, "o", ">         if (i) {\r\n\u001b[?2004l\r\u001b[?2004h>             out << ',';\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>         const auto &entry = entries[i];\r\n\u001b[?2004l\r\u001b[?2004h> "]
[237.442165, "o", "        out << \"{\\\"name\\\":\\\"\" << entry.name << \"\\\",\\\"next_pass\\\":\" << entry.next_pass\r\n\u001b[?2004l\r\u001b[?2004h> "]
[237.442336, "o", "            << \",\\\"carry_weight\\\":\" << entry.carry_weight << \",\\\"carry_drift\\\":\"\r\n\u001b[?2004l\r\u001b[?2004h>             << entry.carry_drift << '}';\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h>     out << \"]}\\n\";\r\n\u001b[?2004l\r\u001b[?2004h"]
[237.442485, "o", "> "]
[237.442546, "o", "    std::ofstream file(path, std::ios::binary);\r\n\u001b[?2004l\r"]
[237.442622, "o", "\u001b[?2004h> "]
[237.442665, "o", "    file << out.str();\r\n\u001b[?2004l\r"]
[237.442681, "o", "\u001b[?2004h"]
[237.442792, "o", "> }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[237.442844, "o", "EOF\r\n\u001b[?2004l\r"]
[237.443971, "o", "\u001b[?2004hroot@071d4af3a22a:/app# "]
[342.868279, "i", "cat > /app/environment/runner/emit_pipeline.cpp << 'ENDOFFILE'\n#include \"emit_pipeline.h\"\n#include \"lane_bridge.h\"\n#include \"scan_bridge.h\"\n#include \"store_bridge.h\"\n#include \"constants.h\"\n#include \"types.h\"\n#include <algorithm>\n#include <cctype>\n#include <filesystem>\n#include <fstream>\n#include <iomanip>\n#include <iostream>\n#include <map>\n#include <sstream>\n#include <stdexcept>\n#include <string>\n#include <vector>\n\nnamespace fs = std::filesystem;\n\nnamespace forge {\n\nconstexpr const char *kCheckpointPath = \"/app/output/forge_checkpoint.json\";\n\nnamespace {\n\nstd::string read_file(const fs::path &path) {\n    std::ifstream in(path, std::ios::binary);\n    if (!in) {\n        throw std::runtime_error(\"could not open fixture\");\n    }\n    std::ostringstream ss;\n    ss << in.rdbuf();\n    return ss.str();\n}\n\nstd::string pick_string(const std::string &block, const std::string &key) {\n    std::string needle = \"\\\"\" + key + \"\\\"\";\n    size_t k = block.find(needle);\n    if (k == std::string::npos) {\n        return \"\";\n    }\n  "]
[342.868426, "i", "  size_t q = block.find('\"', block.find(':', k) + 1);\n    size_t e = block.find('\"', q + 1);\n    if (q == std::string::npos || e == std::string::npos) {\n        return \"\";\n    }\n    return block.substr(q + 1, e - q - 1);\n}\n\nint pick_int(const std::string &block, const std::string &key) {\n    std::string needle = \"\\\"\" + key + \"\\\"\";\n    size_t k = block.find(needle);\n    if (k == std::string::npos) {\n        return 0;\n    }\n    size_t colon = block.find(':', k);\n    if (colon == std::string::npos) {\n        return 0;\n    }\n    size_t start = colon + 1;\n    while (start < block.size() && std::isspace(static_cast<unsigned char>(block[start]))) {\n        ++start;\n    }\n    return std::stoi(block.substr(start));\n}\n\nstd::string extract_array(const std::string &doc, const std::string &key) {\n    std::string needle = \"\\\"\" + key + \"\\\"\";\n    size_t k = doc.find(needle);\n    if (k == std::string::npos) {\n        return \"\";\n    }\n    size_t p = doc.find('[', k);\n    if (p == std::string::npos) {\n        return \"\";\n    }\n "]
[342.868489, "i", "   int depth = 0;\n    size_t start = p;\n    for (size_t i = p; i < doc.size(); ++i) {\n        if (doc[i] == '[') {\n            ++depth;\n        }\n        if (doc[i] == ']') {\n            --depth;\n            if (depth == 0) {\n                return doc.substr(start, i - start + 1);\n            }\n        }\n    }\n    return \"\";\n}\n\nstd::vector<std::string> split_object_blocks(const std::string &array_text) {\n    std::vector<std::string> out;\n    int depth = 0;\n    size_t start = std::string::npos;\n    for (size_t i = 0; i < array_text.size(); ++i) {\n        if (array_text[i] == '{') {\n            if (depth == 0) {\n                start = i;\n            }\n            ++depth;\n        } else if (array_text[i] == '}') {\n            --depth;\n            if (depth == 0 && start != std::string::npos) {\n                out.push_back(array_text.substr(start, i - start + 1));\n                start = std::string::npos;\n            }\n        }\n    }\n    return out;\n}\n\nint64_t read_record_bytes(const fs::path &path) {\n    s"]
