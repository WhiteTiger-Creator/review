[342.922004, "o", "\u001b[?2004h"]
[342.92202, "o", "> "]
[342.922493, "o", "    run.mode = forge_lane_mode(spec.mode.c_str(), spec.name.c_str(), pass_epoch);\r\n\u001b[?2004l\r"]
[342.922523, "o", "\u001b[?2004h"]
[342.922602, "o", "> "]
[342.922843, "o", "    run.manifest_bytes = spec.manifest_bytes;\r\n\u001b[?2004l\r"]
[342.922957, "o", "\u001b[?2004h> "]
[342.923206, "o", "    run.record_bytes = read_record_bytes(record_path);\r\n\u001b[?2004l\r"]
[342.923235, "o", "\u001b[?2004h"]
[342.923255, "o", "> "]
[342.923737, "o", "    run.drift_bytes = run.record_bytes - static_cast<int64_t>(run.manifest_bytes);\r\n\u001b[?2004l\r"]
[342.923885, "o", "\u001b[?2004h> "]
[342.924001, "o", "    run.order_rank = order_rank;\r\n\u001b[?2004l\r"]
[342.924043, "o", "\u001b[?2004h"]
[342.924059, "o", "> \r\n\u001b[?2004l\r"]
[342.924071, "o", "p"]
[342.924185, "o", "\u001b[?2004h> "]
[342.924362, "o", "    int pass_index = spec.start_pass;\r\n\u001b[?2004l\r"]
[342.924503, "o", "\u001b[?2004h> "]
[342.924664, "o", "    bool found_checkpoint_entry = false;\r\n\u001b[?2004l\r"]
[342.924728, "o", "\u001b[?2004h> "]
[342.924929, "o", "    int64_t cp_carry_weight = 0;\r\n\u001b[?2004l\r"]
[342.925016, "o", "\u001b[?2004h> "]
[342.925446, "o", "    if (run.mode == \"resume\" && checkpoint != nullptr && checkpoint->valid) {\r\n\u001b[?2004l\r"]
[342.925503, "o", "\u001b[?2004h> "]
[342.92581, "o", "        auto it = checkpoint->units.find(spec.name);\r\n\u001b[?2004l\r"]
[342.925851, "o", "\u001b[?2004h> "]
[342.926131, "o", "        if (it != checkpoint->units.end()) {\r\n\u001b[?2004l\r"]
[342.926244, "o", "\u001b[?2004h> "]
[342.926461, "o", "            pass_index = it->second.next_pass;\r\n\u001b[?2004l\r"]
[342.926557, "o", "\u001b[?2004h> "]
[342.926844, "o", "            cp_carry_weight = it->second.carry_weight;\r\n\u001b[?2004l\r"]
[342.926905, "o", "\u001b[?2004h"]
[342.927008, "o", "> "]
[342.92716, "o", "            found_checkpoint_entry = true;\r\n\u001b[?2004l\r"]
[342.927278, "o", "\u001b[?2004h> "]
[342.927388, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[342.927503, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[342.92756, "o", "> "]
[342.927854, "o", "    if (run.mode == \"resume\" && found_checkpoint_entry) {\r\n\u001b[?2004l\r"]
[342.927876, "o", "\u001b[?2004h"]
[342.927899, "o", "> "]
[342.928375, "o", "        run.order_weight = cp_carry_weight + static_cast<int64_t>(order_weight_base) + run.record_bytes;\r\n\u001b[?2004l\r"]
[342.928488, "o", "\u001b[?2004h> "]
[342.928594, "o", "    } else {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[342.92868, "o", "        run.order_weight =\r\n\u001b[?2004l\r"]
[342.928702, "o", "\u001b[?2004h"]
[342.928796, "o", "> "]
[342.929338, "o", "            forge_lane_weight(spec.name.c_str(), names, name_count, order_weight_base, run.record_bytes);\r\n\u001b[?2004l\r"]
[342.929393, "o", "\u001b[?2004h> "]
[342.929433, "o", "    }\r\n\u001b[?2004l\r"]
[342.929449, "o", "\u001b[?2004h"]
[342.929463, "o", "> "]
[342.929685, "o", "    run.pass_index = pass_index;\r\n\u001b[?2004l\r"]
[342.929794, "o", "\u001b[?2004h> "]
[342.930021, "o", "    run.row_serial = forge_lane_row_text(run);\r\n\u001b[?2004l\r"]
[342.930072, "o", "\u001b[?2004h> "]
[342.930346, "o", "    run.row_digest = digest_hex(run.row_serial);\r\n\u001b[?2004l\r"]
[342.930482, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[342.930538, "o", "> "]
[342.930694, "o", "    std::ostringstream js;\r\n\u001b[?2004l\r"]
[342.930715, "o", "\u001b[?2004h> "]
[342.931136, "o", "    js << \"{\\\"name\\\":\\\"\" << json_escape(run.name) << \"\\\",\\\"mode\\\":\\\"\" << json_escape(run.mode)\r\n\u001b[?2004l\r"]
[342.931224, "o", "\u001b[?2004h> "]
[342.931764, "o", "       << \"\\\",\\\"pass_index\\\":\" << run.pass_index << \",\\\"manifest_bytes\\\":\" << run.manifest_bytes\r\n\u001b[?2004l\r"]
[342.931784, "o", "\u001b[?2004h"]
[342.931794, "o", "> "]
[342.932402, "o", "       << \",\\\"record_bytes\\\":\" << run.record_bytes << \",\\\"drift_bytes\\\":\" << run.drift_bytes\r\n\u001b[?2004l\r"]
[342.932476, "o", "\u001b[?2004h> "]
[342.932944, "o", "       << \",\\\"order_rank\\\":\" << run.order_rank << \",\\\"order_weight\\\":\" << run.order_weight\r\n\u001b[?2004l\r"]
[342.932997, "o", "\u001b[?2004h> "]
[342.93327, "o", "       << \",\\\"row_digest\\\":\\\"\" << run.row_digest << \"\\\"}\";\r\n\u001b[?2004l\r"]
[342.933355, "o", "\u001b[?2004h> "]
[342.933496, "o", "    run.json = js.str();\r\n\u001b[?2004l\r"]
[342.933579, "o", "\u001b[?2004h> "]
[342.933642, "o", "    return run;\r\n\u001b[?2004l\r"]
