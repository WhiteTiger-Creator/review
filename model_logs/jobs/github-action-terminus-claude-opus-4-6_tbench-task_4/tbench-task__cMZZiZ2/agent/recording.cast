[342.940126, "o", "\u001b[?2004h"]
[342.940178, "o", "> "]
[342.940325, "o", "    std::vector<forge::UnitCheckpoint> updated_entries;\r\n\u001b[?2004l\r"]
[342.940344, "o", "\u001b[?2004h"]
[342.940393, "o", "> "]
[342.940518, "o", "    std::vector<std::string> requested_resume;\r\n\u001b[?2004l\r"]
[342.940537, "o", "\u001b[?2004h"]
[342.940586, "o", "> "]
[342.940696, "o", "    for (const auto &name : requested) {\r\n\u001b[?2004l\r"]
[342.940715, "o", "\u001b[?2004h"]
[342.940765, "o", "> "]
[342.940879, "o", "        auto it = spec_by_name.find(name);\r\n\u001b[?2004l\r"]
[342.940897, "o", "\u001b[?2004h"]
[342.94095, "o", "> "]
[342.941055, "o", "        if (it == spec_by_name.end()) {\r\n\u001b[?2004l\r"]
[342.941074, "o", "\u001b[?2004h"]
[342.941123, "o", "> "]
[342.94118, "o", "            continue;\r\n\u001b[?2004l\r"]
[342.941197, "o", "\u001b[?2004h"]
[342.941258, "o", ">         }\r\n"]
[342.941344, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[342.941504, "o", "        int order_rank = static_cast<int>(std::distance(\r\n\u001b[?2004l\r"]
[342.9416, "o", "\u001b[?2004h> "]
[342.941672, "o", "            manifest.units.begin(),\r\n\u001b[?2004l\r"]
[342.941744, "o", "\u001b[?2004h"]
[342.941788, "o", "> "]
[342.941941, "o", "            std::find_if(manifest.units.begin(), manifest.units.end(),\r\n\u001b[?2004l\r"]
[342.941961, "o", "\u001b[?2004h"]
[342.94199, "o", "> "]
[342.942242, "o", "                         [&](const forge::UnitSpec &u) { return u.name == name; })));\r\n\u001b[?2004l\r"]
[342.942263, "o", "\u001b[?2004h"]
[342.942319, "o", "> "]
[342.942586, "o", "        forge::UnitRun run = forge::analyze_unit(it->second, order_rank, manifest.order_weight_base,\r\n\u001b[?2004l\r"]
[342.942609, "o", "\u001b[?2004h"]
[342.942683, "o", "> "]
[342.942927, "o", "                                                 pass_epoch, manifest_dir, name_ptrs.data(),\r\n\u001b[?2004l\r"]
[342.942986, "o", "\u001b[?2004h"]
[342.943004, "o", "> "]
[342.943245, "o", "                                                 name_ptrs.size(), &checkpoint, 0);\r\n\u001b[?2004l\r"]
[342.943282, "o", "\u001b[?2004h"]
[342.943345, "o", "> "]
[342.943422, "o", "        units.push_back(run);\r\n\u001b[?2004l\r\u001b[?2004h"]
[342.94344, "o", "> "]
[342.943577, "o", "        if (run.mode == \"resume\") {\r\n\u001b[?2004l\r"]
[342.943643, "o", "\u001b[?2004h"]
[342.94369, "o", "> "]
[342.943783, "o", "            requested_resume.push_back(name);\r\n\u001b[?2004l\r"]
[342.943865, "o", "\u001b[?2004h"]
[342.943921, "o", "> "]
[342.943978, "o", "            forge::UnitCheckpoint entry;\r\n\u001b[?2004l\r"]
[342.944032, "o", "\u001b[?2004h> "]
[342.944179, "o", "            entry.name = run.name;\r\n\u001b[?2004l\r\u001b[?2004h"]
[342.944286, "o", "> "]
[342.944401, "o", "            entry.next_pass = run.pass_index + 1;\r\n\u001b[?2004l\r\u001b[?2004h"]
[342.944466, "o", "> "]
[342.944591, "o", "            entry.carry_weight = run.order_weight;\r\n\u001b[?2004l\r"]
[342.944696, "o", "\u001b[?2004h> "]
[342.944828, "o", "            entry.carry_drift = run.drift_bytes;\r\n\u001b[?2004l\r\u001b[?2004h"]
[342.944909, "o", "> "]
[342.945007, "o", "            updated_entries.push_back(entry);\r\n\u001b[?2004l\r"]
[342.94503, "o", "\u001b[?2004h"]
[342.945045, "o", "> "]
[342.945136, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[342.945156, "o", "    }\r\n\u001b[?2004l\r"]
[342.94522, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[342.945238, "o", "\u001b[?2004h> "]
[342.945501, "o", "    int64_t drift_total = forge_lane_drift_total(units.data(), units.size());\r\n\u001b[?2004l\r"]
[342.945603, "o", "\u001b[?2004h"]
[342.945681, "o", "> "]
[342.945825, "o", "    int64_t weight_total = forge_lane_score_total(units.data(), units.size());\r\n\u001b[?2004l\r"]
[342.945889, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[342.946013, "o", "\u001b[?2004h> "]
[342.946073, "o", "    std::ostringstream serial;\r\n"]
[342.946185, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[342.946373, "o", "    serial << forge_lane_header_text(forge::kSchemaVersion, manifest.release_id,\r\n\u001b[?2004l\r"]
[342.946434, "o", "\u001b[?2004h> "]
[342.946703, "o", "                                     manifest.order_weight_base, pass_epoch, drift_total,\r\n\u001b[?2004l\r"]
[342.946796, "o", "\u001b[?2004h> "]
[342.946934, "o", "                                     weight_total);\r\n\u001b[?2004l\r"]
[342.946955, "o", "\u001b[?2004h"]
[342.946969, "o", "> "]
[342.947107, "o", "    for (const auto &unit : units) {\r\n\u001b[?2004l\r"]
[342.947168, "o", "\u001b[?2004h> "]
[342.947297, "o", "        serial << '\\n' << unit.row_serial;\r\n\u001b[?2004l\r"]
[342.947344, "o", "\u001b[?2004h> "]
[342.947388, "o", "    }\r\n\u001b[?2004l\r"]
[342.947404, "o", "\u001b[?2004h"]
[342.94742, "o", "> "]
[342.947617, "o", "    std::string top_digest = forge::digest_hex(serial.str());\r\n\u001b[?2004l\r"]
[342.947636, "o", "\u001b[?2004h"]
[342.94769, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[342.947707, "o", "> "]
[342.947882, "o", "    fs::create_directories(output_path.parent_path());\r\n\u001b[?2004l\r"]
[342.947901, "o", "\u001b[?2004h"]
[342.947913, "o", "> "]
[342.948023, "o", "    std::ostringstream out;\r\n\u001b[?2004l\r"]
[342.948046, "o", "\u001b[?2004h"]
[342.9481, "o", "> "]
[342.948323, "o", "    out << \"{\\\"schema_version\\\":\" << forge::kSchemaVersion << \",\\\"release_id\\\":\\\"\"\r\n\u001b[?2004l\r"]
[342.948338, "o", "\u001b[?2004h"]
[342.948354, "o", "> "]
[342.948634, "o", "        << manifest.release_id << \"\\\",\\\"order_weight_base\\\":\" << manifest.order_weight_base\r\n\u001b[?2004l\r"]
[342.948652, "o", "\u001b[?2004h"]
[342.948704, "o", "> "]
[342.948872, "o", "        << \",\\\"pass_epoch\\\":\" << pass_epoch << \",\\\"units\\\":[\";\r\n\u001b[?2004l\r"]
[342.948891, "o", "\u001b[?2004h"]
[342.94898, "o", "> "]
[342.949095, "o", "    for (std::size_t i = 0; i < units.size(); ++i) {\r\n\u001b[?2004l\r"]
[342.949147, "o", "\u001b[?2004h"]
[342.949167, "o", "> "]
[342.949246, "o", "        if (i) {\r\n\u001b[?2004l\r"]
[342.949266, "o", "\u001b[?2004h> "]
[342.949351, "o", "            out << ',';\r\n\u001b[?2004l\r"]
[342.949409, "o", "\u001b[?2004h"]
[342.949438, "o", ">         }\r\n\u001b[?2004l\r"]
[342.949464, "o", "\u001b[?2004h"]
[342.949482, "o", "> "]
[342.9496, "o", "        out << units[i].json;\r\n\u001b[?2004l\r"]
[342.949647, "o", "\u001b[?2004h"]
[342.949666, "o", ">     }\r\n"]
[342.949682, "o", "\u001b[?2004l\r"]
[342.949726, "o", "\u001b[?2004h"]
[342.949746, "o", "> "]
[342.950014, "o", "    out << \"],\\\"total_drift_bytes\\\":\" << drift_total << \",\\\"order_score\\\":\" << weight_total\r\n\u001b[?2004l\r"]
[342.95008, "o", "\u001b[?2004h> "]
[342.95023, "o", "        << \",\\\"digest\\\":\\\"\" << top_digest << \"\\\"}\\n\";\r\n\u001b[?2004l\r"]
[342.950268, "o", "\u001b[?2004h"]
[342.950287, "o", "> "]
[342.950454, "o", "    std::ofstream file(output_path, std::ios::binary);\r\n\u001b[?2004l\r"]
[342.950509, "o", "\u001b[?2004h"]
[342.950526, "o", "> "]
[342.950616, "o", "    file << out.str();\r\n\u001b[?2004l\r"]
[342.950683, "o", "\u001b[?2004h> "]
[342.95077, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[342.950905, "o", "    // Merge checkpoint: preserve existing entries, update with new\r\n\u001b[?2004l\r"]
[342.950953, "o", "\u001b[?2004h"]
[342.950973, "o", "> "]
[342.95112, "o", "    std::vector<forge::UnitCheckpoint> merged =\r\n\u001b[?2004l\r"]
[342.951161, "o", "\u001b[?2004h"]
[342.951178, "o", "> "]
[342.951428, "o", "        forge_lane_merge_checkpoint(checkpoint, updated_entries, requested_resume);\r\n\u001b[?2004l\r"]
[342.951514, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[342.951533, "o", "\u001b[?2004h> "]
[342.951667, "o", "    // Write checkpoint with pass_epoch\r\n\u001b[?2004l\r"]
[342.951729, "o", "\u001b[?2004h"]
[342.951755, "o", "> "]
[342.9519, "o", "    fs::create_directories(checkpoint_path.parent_path());\r\n\u001b[?2004l\r"]
[342.951949, "o", "\u001b[?2004h> "]
[342.952063, "o", "    std::ostringstream cp_out;\r\n\u001b[?2004l\r"]
[342.952082, "o", "\u001b[?2004h"]
[342.952096, "o", "> "]
[342.952397, "o", "    cp_out << \"{\\\"schema_version\\\":\" << forge::kSchemaVersion << \",\\\"lane_token\\\":\\\"\" << lane_token\r\n\u001b[?2004l\r"]
[342.952483, "o", "\u001b[?2004h> "]
[342.952682, "o", "           << \"\\\",\\\"pass_epoch\\\":\" << (pass_epoch + 1) << \",\\\"units\\\":[\";\r\n\u001b[?2004l\r"]
[342.952701, "o", "\u001b[?2004h"]
[342.952711, "o", "> "]
[342.952881, "o", "    for (size_t i = 0; i < merged.size(); ++i) {\r\n\u001b[?2004l\r"]
[342.952899, "o", "\u001b[?2004h"]
[342.952911, "o", "> "]
[342.952993, "o", "        if (i) {\r\n\u001b[?2004l\r"]
[342.953043, "o", "\u001b[?2004h> "]
[342.953142, "o", "            cp_out << ',';\r\n\u001b[?2004l\r"]
[342.95316, "o", "\u001b[?2004h"]
[342.953174, "o", "> "]
[342.953234, "o", "        }\r\n\u001b[?2004l\r"]
[342.953251, "o", "\u001b[?2004h"]
[342.953264, "o", "> "]
[342.953569, "o", "        cp_out << \"{\\\"name\\\":\\\"\" << merged[i].name << \"\\\",\\\"next_pass\\\":\" << merged[i].next_pass\r\n\u001b[?2004l\r"]
[342.953711, "o", "\u001b[?2004h> "]
[342.953894, "o", "               << \",\\\"carry_weight\\\":\" << merged[i].carry_weight << \",\\\"carry_drift\\\":\"\r\n\u001b[?2004l\r"]
[342.953974, "o", "\u001b[?2004h"]
[342.953999, "o", "> "]
[342.954096, "o", "               << merged[i].carry_drift << '}';\r\n\u001b[?2004l\r"]
[342.954114, "o", "\u001b[?2004h"]
[342.95418, "o", "> "]
[342.954215, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[342.954289, "o", "    cp_out << \"]}\\n\";\r\n\u001b[?2004l\r"]
[342.954316, "o", "\u001b[?2004h> "]
[342.954509, "o", "    std::ofstream cp_file(checkpoint_path, std::ios::binary);\r\n\u001b[?2004l\r"]
[342.95453, "o", "\u001b[?2004h"]
[342.954543, "o", "> "]
[342.954659, "o", "    cp_file << cp_out.str();\r\n\u001b[?2004l\r"]
[342.954681, "o", "\u001b[?2004h"]
[342.954766, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[342.9548, "o", "    return 0;\r\n\u001b[?2004l\r"]
[342.954883, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h"]
[342.954905, "o", "> "]
[342.954947, "o", "ENDOFFILE\r\n\u001b[?2004l\r"]
