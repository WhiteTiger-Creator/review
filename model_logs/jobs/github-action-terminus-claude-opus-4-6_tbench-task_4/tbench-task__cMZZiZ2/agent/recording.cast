[237.394646, "i", "cat > /app/environment/m14/lane_store.cpp << 'EOF'\n#include \"constants.h\"\n#include \"m14_api.h\"\n#include \"types.h\"\n#include <algorithm>\n#include <cctype>\n#include <fstream>\n#include <sstream>\n#include <stdexcept>\n#include <string>\n#include <vector>\n\nnamespace {\n\nstd::uint64_t digest_update(std::uint64_t h, const std::string &text) {\n    for (unsigned char ch : text) {\n        h ^= static_cast<std::uint64_t>(ch);\n        h = (h * forge::kDigestStep) & forge::kDigestMask;\n    }\n    return h;\n}\n\nstd::string digest_hex(const std::string &text) {\n    std::uint64_t h = digest_update(forge::kDigestSeed, text);\n    std::ostringstream os;\n    os << std::hex << std::nouppercase;\n    os.width(16);\n    os.fill('0');\n    os << h;\n    return os.str();\n}\n\nstd::string descriptor_line(const forge::UnitSpec &unit) {\n    std::ostringstream os;\n    os << unit.name << '|' << unit.mode << '|' << unit.record << '|' << unit.manifest_bytes << '|'\n       << unit.start_pass;\n    return os.str();\n}\n\nstd::string pick_string(const std::str"]
[237.394943, "i", "ing &block, const std::string &key) {\n    std::string needle = \"\\\"\" + key + \"\\\"\";\n    size_t k = block.find(needle);\n    if (k == std::string::npos) {\n        return \"\";\n    }\n    size_t q = block.find('\"', block.find(':', k) + 1);\n    size_t e = block.find('\"', q + 1);\n    return block.substr(q + 1, e - q - 1);\n}\n\nint pick_int(const std::string &block, const std::string &key) {\n    std::string needle = \"\\\"\" + key + \"\\\"\";\n    size_t k = block.find(needle);\n    if (k == std::string::npos) {\n        return 0;\n    }\n    size_t p = block.find(':', k) + 1;\n    while (p < block.size() && !std::isdigit(static_cast<unsigned char>(block[p])) && block[p] != '-') {\n        ++p;\n    }\n    size_t e = p;\n    if (e < block.size() && block[e] == '-') ++e;\n    while (e < block.size() && std::isdigit(static_cast<unsigned char>(block[e]))) {\n        ++e;\n    }\n    return std::stoi(block.substr(p, e - p));\n}\n\nint64_t pick_int64(const std::string &block, const std::string &key) {\n    std::string needle = \"\\\"\" + key + \"\\\"\";\n    si"]
[237.395027, "o", "cat > /app/environment/m14/lane_store.cpp << 'EOF'\r\n\u001b[?2004l\r"]
[237.395081, "i", "ze_t k = block.find(needle);\n    if (k == std::string::npos) {\n        return 0;\n    }\n    size_t p = block.find(':', k) + 1;\n    while (p < block.size() && !std::isdigit(static_cast<unsigned char>(block[p])) && block[p] != '-') {\n        ++p;\n    }\n    size_t e = p;\n    if (e < block.size() && block[e] == '-') ++e;\n    while (e < block.size() && std::isdigit(static_cast<unsigned char>(block[e]))) {\n        ++e;\n    }\n    return std::stoll(block.substr(p, e - p));\n}\n\nstd::vector<std::string> split_object_blocks(const std::string &array_text) {\n    std::vector<std::string> out;\n    int depth = 0;\n    size_t start = std::string::npos;\n    for (size_t i = 0; i < array_text.size(); ++i) {\n        if (array_text[i] == '{') {\n            if (depth == 0) {\n                start = i;\n            }\n            ++depth;\n        } else if (array_text[i] == '}') {\n            --depth;\n            if (depth == 0 && start != std::string::npos) {\n                out.push_back(array_text.substr(start, i - start + 1));\n      "]
[237.3951, "o", "\u001b[?2004h> "]
[237.395143, "i", "          start = std::string::npos;\n            }\n        }\n    }\n    return out;\n}\n\n}  // namespace\n\nextern \"C\" const char *m14_lane_token(const forge::UnitSpec *units, size_t count) {\n    static std::string cached;\n    // Build descriptor lines and sort alphabetically by unit name\n    std::vector<std::pair<std::string, std::string>> name_desc;\n    for (size_t i = 0; i < count; ++i) {\n        name_desc.emplace_back(units[i].name, descriptor_line(units[i]));\n    }\n    std::sort(name_desc.begin(), name_desc.end(),\n              [](const std::pair<std::string,std::string> &a, const std::pair<std::string,std::string> &b) {\n                  return a.first < b.first;\n              });\n    std::ostringstream joined;\n    for (size_t i = 0; i < name_desc.size(); ++i) {\n        if (i) {\n            joined << '\\n';\n        }\n        joined << name_desc[i].second;\n    }\n    cached = digest_hex(joined.str());\n    return cached.c_str();\n}\n\nextern \"C\" int m14_checkpoint_valid(const char *on_disk_token, const char *expect"]
