[342.938169, "o", "\u001b[?2004h"]
[342.938222, "o", "> "]
[342.938501, "o", "    forge::LaneCheckpoint checkpoint = forge_lane_load_checkpoint(checkpoint_path, lane_token);\r\n\u001b[?2004l\r"]
[342.938523, "o", "\u001b[?2004h"]
[342.938588, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[342.938723, "o", "    std::vector<const char *> name_ptrs;\r\n\u001b[?2004l\r"]
[342.938772, "o", "\u001b[?2004h> "]
[342.938913, "o", "    for (const auto &unit : manifest.units) {\r\n\u001b[?2004l\r"]
[342.938934, "o", "\u001b[?2004h"]
[342.938986, "o", "> "]
[342.93911, "o", "        name_ptrs.push_back(unit.name.c_str());\r\n\u001b[?2004l\r"]
[342.93913, "o", "\u001b[?2004h"]
[342.939144, "o", "> "]
[342.939204, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[342.939221, "o", "> \r\n\u001b[?2004l\r"]
[342.939277, "o", "\u001b[?2004h> "]
[342.939457, "o", "    std::map<std::string, forge::UnitSpec> spec_by_name;\r\n\u001b[?2004l\r"]
[342.939475, "o", "\u001b[?2004h"]
[342.939486, "o", "> "]
[342.93964, "o", "    for (const auto &unit : manifest.units) {\r\n\u001b[?2004l\r"]
[342.93966, "o", "\u001b[?2004h"]
[342.939709, "o", "> "]
[342.939814, "o", "        spec_by_name[unit.name] = unit;\r\n\u001b[?2004l\r"]
[342.939833, "o", "\u001b[?2004h"]
[342.939883, "o", ">     }\r\n\u001b[?2004l\r"]
[342.939929, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
