[342.933994, "o", "\u001b[?2004h"]
[342.934087, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[342.934255, "o", "int forge_run_emit(int argc, char **argv) {\r\n\u001b[?2004l\r"]
[342.934274, "o", "\u001b[?2004h"]
[342.934335, "o", "> "]
[342.934398, "o", "    if (argc != 4) {\r\n\u001b[?2004l\r"]
[342.934481, "o", "\u001b[?2004h> "]
[342.934922, "o", "        std::cerr << \"usage: forge_emit <manifest-json> <output-json> <units-csv>\\n\";\r\n\u001b[?2004l\r"]
[342.935043, "o", "\u001b[?2004h> "]
[342.935091, "o", "        return 2;\r\n\u001b[?2004l\r"]
[342.935186, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[342.935246, "o", "\u001b[?2004h> "]
[342.935456, "o", "    fs::path manifest_path = argv[1];\r\n\u001b[?2004l\r"]
[342.935565, "o", "\u001b[?2004h> "]
[342.935724, "o", "    fs::path output_path = argv[2];\r\n\u001b[?2004l\r"]
[342.935832, "o", "\u001b[?2004h> "]
[342.936202, "o", "    std::vector<std::string> requested = forge::split_units_csv(argv[3]);\r\n\u001b[?2004l\r"]
[342.936311, "o", "\u001b[?2004h> "]
[342.936644, "o", "    forge::Manifest manifest = forge::load_manifest(manifest_path);\r\n\u001b[?2004l\r"]
[342.936752, "o", "\u001b[?2004h> "]
[342.937016, "o", "    fs::path manifest_dir = manifest_path.parent_path();\r\n\u001b[?2004l\r"]
[342.937123, "o", "\u001b[?2004h> \r\n\u001b[?2004l\rt\u001b[?2004h> "]
[342.937478, "o", "    const char *lane_token_raw = forge_lane_fingerprint(manifest.units.data(), manifest.units.size());\r\n\u001b[?2004l\r"]
[342.937606, "o", "\u001b[?2004h> "]
[342.937688, "o", "    std::string lane_token(lane_token_raw);\r\n\u001b[?2004l\r"]
[342.937756, "o", "\u001b[?2004h> "]
[342.937912, "o", "    fs::path checkpoint_path = forge::kCheckpointPath;\r\n\u001b[?2004l\r"]
