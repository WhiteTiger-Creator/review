[173.701277, "o", "#include \"types.h\"\r\n#include <string.h>\r\n\r\nint b07_line_has_key(const char *line, size_t len, const char *key) {\r\n    size_t key_len = strlen(key);\r\n    if (len < key_len) {\r\n        return 0;\r\n    }\r\n    for (size_t i = 0; i + key_len <= len; ++i) {\r\n        if (strncmp(line + i, key, key_len) == 0) {\r\n            return 1;\r\n        }\r\n    }\r\n    return 0;\r\n}\r\n"]
