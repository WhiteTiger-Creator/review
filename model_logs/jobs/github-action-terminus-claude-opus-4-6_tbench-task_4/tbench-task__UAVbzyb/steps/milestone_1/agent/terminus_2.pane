[?2004lvar API_BASE = '/api/notes';
var API_KEY = 'tb3_notes_api_secret_2026';
var editingId = null;

function fetchNotes() {
  fetch(API_BASE).then(function(res) {
    return res.json();
  }).then(function(notes) {
    var list = document.getElementById('notes-list');
    list.innerHTML = '';
    for (var i = 0; i < notes.length; i++) {
      (function(note) {
        var div = document.createElement('div');
        div.className = 'note-item';
        div.setAttribute('data-id', note.id);

        var titleEl = document.createElement('strong');
        titleEl.textContent = note.title;
        div.appendChild(titleEl);

        var contentEl = document.createElement('span');
        contentEl.textContent = note.content || '';
        div.appendChild(contentEl);

        var editBtn = document.createElement('button');
        editBtn.className = 'edit-btn';
        editBtn.textContent = 'Edit';
        editBtn.setAttribute('data-id', String(note.id));
        editBtn.setAttribute('data-title', note.title || '');
        editBtn.setAttribute('data-content', note.content || '');
        editBtn.addEventListener('click', function() {
          editingId = note.id;
          document.getElementById('note-title').value = note.title || '';
          document.getElementById('note-content').value = note.content || '';
        });
        div.appendChild(editBtn);

        var deleteBtn = document.createElement('button');
        deleteBtn.className = 'delete-btn';
        deleteBtn.textContent = 'Delete';
        deleteBtn.setAttribute('data-id', String(note.id));
        deleteBtn.addEventListener('click', function() {
          fetch(API_BASE + '/' + note.id, {
            method: 'DELETE',
            headers: {
              'Content-Type': 'application/json',
              'X-API-Key': API_KEY
            }
          }).then(function() {
            editingId = null;
            document.getElementById('note-title').value = '';
            document.getElementById('note-content').value = '';
            fetchNotes();
          });
        });
        div.appendChild(deleteBtn);

        list.appendChild(div);
      })(notes[i]);
    }
  });
}

var form = document.getElementById('note-form');
form.addEventListener('submit', function(e) {
  e.preventDefault();
  var title = document.getElementById('note-title').value.trim();
  var content = document.getElementById('note-content').value.trim();

  if (editingId !== null) {
    fetch(API_BASE + '/' + editingId, {
      method: 'PUT',
      headers: {
        'Content-Type': 'application/json',
        'X-API-Key': API_KEY
      },
      body: JSON.stringify({ title: title, content: content })
    }).then(function() {
      editingId = null;
      document.getElementById('note-title').value = '';
      document.getElementById('note-content').value = '';
      fetchNotes();
    });
  } else {
    fetch(API_BASE, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-API-Key': API_KEY
      },
      body: JSON.stringify({ title: title, content: content })
    }).then(function() {
      editingId = null;
      document.getElementById('note-title').value = '';
      document.getElementById('note-content').value = '';
      fetchNotes();
    });
  }
});

fetchNotes();
