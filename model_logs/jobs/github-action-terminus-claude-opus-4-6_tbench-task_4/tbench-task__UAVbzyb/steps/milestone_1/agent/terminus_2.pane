[?2004hroot@1ebded0d6da5:/app# cat /app/src/main.c
[?2004l#include <microhttpd.h>
#include <stdio.h>
#include <string.h>
#include <stdlib.h>
#include <signal.h>
#include <sys/stat.h>
#include <strings.h>
#include <unistd.h>
#include "routes.h"
#include "db.h"

#define PORT 8080
#define WWW_DIR "/app/www"

static struct MHD_Daemon *daemon_handle = NULL;

static void handle_signal(int sig) {
    (void)sig;
    if (daemon_handle) MHD_stop_daemon(daemon_handle);
    close_db();
    exit(0);
}

static const char *get_content_type(const char *path) {
    const char *ext = strrchr(path, '.');
    if (!ext) return "application/octet-stream";
    if (strcmp(ext, ".html") == 0) return "text/html";
    if (strcmp(ext, ".css") == 0) return "text/css";
    if (strcmp(ext, ".js") == 0) return "application/javascript";
    return "application/octet-stream";
}

/* Check if a character at position is a dot - either literal or percent-encoded */
static int is_dot(const char *p, int *advance) {
    if (*p == '.') {
        *advance = 1;
        return 1;
    }
    if (*p == '%' && p[1] && p[2]) {
        if ((p[1] == '2') && (p[2] == 'e' || p[2] == 'E')) {
            *advance = 3;
            return 1;
        }
    }
    return 0;
}

/* Check if the URL contains any form of ".." including percent-encoded variants */
static int url_has_dotdot(const char *url) {
    const char *p = url;
    while (*p) {
        int adv1 = 0, adv2 = 0;
        if (is_dot(p, &adv1) && is_dot(p + adv1, &adv2)) {
            return 1;
        }
        p++;
    }
    return 0;
}

static enum MHD_Result serve_static_file(struct MHD_Connection *connection,
    const char *url) {
    if (url_has_dotdot(url)) {
        struct MHD_Response *r = MHD_create_response_from_buffer(
            9, (void *)"Forbidden", MHD_RESPMEM_PERSISTENT);
        enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_FORBIDDEN, r);
        MHD_destroy_response(r);
        return ret;
    }

    char filepath[512];
    const char *path = strcmp(url, "/") == 0 ? "/index.html" : url;
    snprintf(filepath, sizeof(filepath), "%s%s", WWW_DIR, path);

    struct stat st;
    if (stat(filepath, &st) != 0) return MHD_NO;

    FILE *f = fopen(filepath, "rb");
    if (!f) return MHD_NO;

    char *buf = malloc(st.st_size);
    fread(buf, 1, st.st_size, f);
    fclose(f);

    struct MHD_Response *response = MHD_create_response_from_buffer(
        st.st_size, buf, MHD_RESPMEM_MUST_FREE);
    MHD_add_response_header(response, "Content-Type", get_content_type(filepath));
    enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_OK, response);
    MHD_destroy_response(response);
    return ret;
}

static void request_completed(void *cls, struct MHD_Connection *connection,
    void **con_cls, enum MHD_RequestTerminationCode toe) {
    (void)cls; (void)connection; (void)toe;
    if (con_cls && *con_cls) {
        struct connection_info *ci = *con_cls;
        if (ci->data) free(ci->data);
        free(ci);
        *con_cls = NULL;
    }
}

static enum MHD_Result handle_request(void *cls,
    struct MHD_Connection *connection,
    const char *url, const char *method,
    const char *version,
    const char *upload_data, size_t *upload_data_size,
    void **con_cls) {
    (void)cls; (void)version;

    if (strncmp(url, "/api/", 5) == 0) {
        return route_request(connection, url, method, upload_data,
                             upload_data_size, con_cls);
    }

    if (strcmp(method, "GET") == 0) {
        enum MHD_Result ret = serve_static_file(connection, url);
        if (ret == MHD_YES) return ret;
    }

    struct MHD_Response *response = MHD_create_response_from_buffer(
        9, (void *)"Not Found", MHD_RESPMEM_PERSISTENT);
    enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_NOT_FOUND, response);
    MHD_destroy_response(response);
    return ret;
}

int main(void) {
    signal(SIGINT, handle_signal);
    signal(SIGTERM, handle_signal);

    mkdir("/app/data", 0755);

    if (init_db("/app/data/notes.db") != 0) {
        fprintf(stderr, "Failed to initialize database\n");
        return 1;
    }

    daemon_handle = MHD_start_daemon(
        MHD_USE_THREAD_PER_CONNECTION,
        PORT,
        NULL, NULL,
        &handle_request, NULL,
        MHD_OPTION_NOTIFY_COMPLETED, &request_completed, NULL,
        MHD_OPTION_END
    );

    if (!daemon_handle) {
        fprintf(stderr, "Failed to start server\n");
        return 1;
    }

    printf("Server running on port %d\n", PORT);
    while (1) pause();
    return 0;
}
[?2004hroot@1ebded0d6da5:/app# cat /app/src/routes.c
[?2004l#include "routes.h"
#include "db.h"
#include <microhttpd.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

static enum MHD_Result send_json(struct MHD_Connection *connection,
                                  const char *body, unsigned int status_code) {
    struct MHD_Response *response = MHD_create_response_from_buffer(
        strlen(body), (void *)body, MHD_RESPMEM_MUST_COPY);
    MHD_add_response_header(response, "Content-Type", "application/json");
    MHD_add_response_header(response, "Access-Control-Allow-Origin", "*");
    MHD_add_response_header(response, "Access-Control-Allow-Methods",
                            "GET, POST, PUT, DELETE, OPTIONS");
    MHD_add_response_header(response, "Access-Control-Allow-Headers",
                            "Content-Type, X-API-Key");
    enum MHD_Result ret = MHD_queue_response(connection, status_code, response);
    MHD_destroy_response(response);
    return ret;
}

static enum MHD_Result send_json_total(struct MHD_Connection *connection,
                                       const char *body, unsigned int status_code,
                                       int total) {
    struct MHD_Response *response = MHD_create_response_from_buffer(
        strlen(body), (void *)body, MHD_RESPMEM_MUST_COPY);
    MHD_add_response_header(response, "Content-Type", "application/json");
    MHD_add_response_header(response, "Access-Control-Allow-Origin", "*");
    MHD_add_response_header(response, "Access-Control-Allow-Methods",
                            "GET, POST, PUT, DELETE, OPTIONS");
    MHD_add_response_header(response, "Access-Control-Allow-Headers",
                            "Content-Type, X-API-Key");
    char count_str[32];
    snprintf(count_str, sizeof(count_str), "%d", total);
    MHD_add_response_header(response, "X-Total-Count", count_str);
    enum MHD_Result ret = MHD_queue_response(connection, status_code, response);
    MHD_destroy_response(response);
    return ret;
}

enum MHD_Result route_request(struct MHD_Connection *connection, const char *url,
                              const char *method, const char *upload_data,
                              size_t *upload_data_size, void **con_cls) {
    (void)upload_data;
    (void)upload_data_size;
    (void)con_cls;

    if (strcmp(method, "OPTIONS") == 0)
        return send_json(connection, "", MHD_HTTP_OK);

    if (strcmp(url, "/api/notes") == 0 && strcmp(method, "GET") == 0) {
        int total = get_total_notes_count();
        char *json = get_notes_paginated_json(50, 0);
        if (!json)
            return send_json_total(connection, "[]", MHD_HTTP_OK, total);
        enum MHD_Result r = send_json_total(connection, json, MHD_HTTP_OK, total);
        free(json);
        return r;
    }

    return send_json(connection, "{\"error\":\"not found\"}", MHD_HTTP_NOT_FOUND);
}
