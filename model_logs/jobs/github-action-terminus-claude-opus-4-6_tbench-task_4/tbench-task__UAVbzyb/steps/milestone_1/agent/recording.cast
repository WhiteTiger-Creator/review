[372.681287, "o", "\u001b[?2004h> "]
[372.681467, "o", "    /* check all digits */\r\n\u001b[?2004l\r"]
[372.681497, "o", "\u001b[?2004h> "]
[372.681636, "o", "    const char *s = p;\r\n\u001b[?2004l\r"]
[372.681664, "o", "\u001b[?2004h> "]
