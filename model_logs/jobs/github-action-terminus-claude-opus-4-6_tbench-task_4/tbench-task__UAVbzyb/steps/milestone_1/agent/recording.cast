[372.678248, "o", "/* Check if title is present and non-empty (after trimming) */\r\n\u001b[?2004l\r"]
[372.678403, "o", "\u001b[?2004h> "]
[372.678571, "o", "static int title_valid(const char *title) {\r\n\u001b[?2004l\r"]
[372.678602, "o", "\u001b[?2004h> "]
[372.678771, "o", "    if (!title) return 0;\r\n\u001b[?2004l\r"]
[372.678802, "o", "\u001b[?2004h> "]
[372.67901, "o", "    /* Check if all whitespace */\r\n\u001b[?2004l\r"]
[372.679043, "o", "\u001b[?2004h> "]
[372.679214, "o", "    const char *p = title;\r\n\u001b[?2004l\r"]
[372.679245, "o", "\u001b[?2004h> "]
[372.679354, "o", "    while (*p) {\r\n\u001b[?2004l\r"]
[372.679377, "o", "\u001b[?2004h> "]
[372.679678, "o", "        if (!isspace((unsigned char)*p)) return 1;\r\n\u001b[?2004l\r"]
[372.679716, "o", "\u001b[?2004h> "]
[372.679826, "o", "        p++;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[372.679856, "o", "    }\r\n\u001b[?2004l\r"]
[372.679921, "o", "\u001b[?2004h> "]
[372.68016, "o", "    return 0; /* empty or all whitespace */\r\n\u001b[?2004l\r"]
[372.680187, "o", "\u001b[?2004h> "]
[372.680208, "o", "}\r\n\u001b[?2004l\r"]
