[372.666201, "o", "\u001b[?2004h"]
[372.666218, "o", "> "]
[372.666428, "o", "    p += strlen(search);\r\n\u001b[?2004l\r"]
[372.66646, "o", "\u001b[?2004h> "]
[372.666678, "o", "    /* skip whitespace and colon */\r\n\u001b[?2004l\r"]
[372.666706, "o", "\u001b[?2004h> "]
