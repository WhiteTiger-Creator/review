[845.106358, "o", "\r\n\u001b[?2004l\r"]
[845.108937, "o", "#include <microhttpd.h>\r\n#include <stdio.h>\r\n#include <string.h>\r\n#include <stdlib.h>\r\n#include <signal.h>\r\n#include <sys/stat.h>\r\n#include <strings.h>\r\n#include <unistd.h>\r\n#include \"routes.h\"\r\n#include \"db.h\"\r\n\r\n#define PORT 8080\r\n#define WWW_DIR \"/app/www\"\r\n\r\nstatic struct MHD_Daemon *daemon_handle = NULL;\r\n\r\nstatic void handle_signal(int sig) {\r\n    (void)sig;\r\n    if (daemon_handle) MHD_stop_daemon(daemon_handle);\r\n    close_db();\r\n    exit(0);\r\n}\r\n\r\nstatic const char *get_content_type(const char *path) {\r\n    const char *ext = strrchr(path, '.');\r\n    if (!ext) return \"application/octet-stream\";\r\n    if (strcmp(ext, \".html\") == 0) return \"text/html\";\r\n    if (strcmp(ext, \".css\") == 0) return \"text/css\";\r\n    if (strcmp(ext, \".js\") == 0) return \"application/javascript\";\r\n    return \"application/octet-stream\";\r\n}\r\n\r\n/* Check if a character at position is a dot - either literal or percent-encoded */\r\nstatic int is_dot(const char *p, int *advance) {\r\n    if (*p == '.') {\r\n        *advance = 1;\r\n        return 1;\r\n    }\r\n    if (*p == '%' && p[1] && p[2]) {\r\n        if ((p[1] == '2') && (p[2] == 'e' || p[2] == 'E')) {\r\n            *advance = 3;\r\n            return 1;\r\n        }\r\n    }\r\n    return 0;\r\n}\r\n\r\n/* Check if the URL contains any form of \"..\" including percent-encoded variants */\r\nstatic int url_has_dotdot(const char *url) {\r\n    const char *p = url;\r\n    while (*p) {\r\n        int adv1 = 0, adv2 = 0;\r\n        if (is_dot(p, &adv1) && is_dot(p + adv1, &adv2)) {\r\n            return 1;\r\n        }\r\n        p++;\r\n    }\r\n    return 0;\r\n}\r\n\r\nstatic enum MHD_Result serve_static_file(struct MHD_Connection *connection,\r\n    const char *url) {\r\n    if (url_has_dotdot(url)) {\r\n        struct MHD_Response *r = MHD_create_response_from_buffer(\r\n            9, (void *)\"Forbidden\", MHD_RESPMEM_PERSISTENT);\r\n        enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_FORBIDDEN, r);\r\n        MHD_destroy_response(r);\r\n        return ret;\r\n    }\r\n\r\n    char filepath[512];\r\n    const char *path = strcmp(url, \"/\") == 0 ? \"/index.html\" : url;\r\n    snprintf(filepath, sizeof(filepath), \"%s%s\", WWW_DIR, path);\r\n\r\n    struct stat st;\r\n"]
[845.109467, "o", "    if (stat(filepath, &st) != 0) return MHD_NO;\r\n\r\n    FILE *f = fopen(filepath, \"rb\");\r\n    if (!f) return MHD_NO;\r\n\r\n    char *buf = malloc(st.st_size);\r\n    fread(buf, 1, st.st_size, f);\r\n    fclose(f);\r\n\r\n    struct MHD_Response *response = MHD_create_response_from_buffer(\r\n        st.st_size, buf, MHD_RESPMEM_MUST_FREE);\r\n    MHD_add_response_header(response, \"Content-Type\", get_content_type(filepath));\r\n    enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_OK, response);\r\n    MHD_destroy_response(response);\r\n    return ret;\r\n}\r\n\r\nstatic void request_completed(void *cls, struct MHD_Connection *connection,\r\n    void **con_cls, enum MHD_RequestTerminationCode toe) {\r\n    (void)cls; (void)connection; (void)toe;\r\n    if (con_cls && *con_cls) {\r\n        struct connection_info *ci = *con_cls;\r\n        if (ci->data) free(ci->data);\r\n        free(ci);\r\n        *con_cls = NULL;\r\n    }\r\n}\r\n\r\nstatic enum MHD_Result handle_request(void *cls,\r\n    struct MHD_Connection *connection,\r\n    const char *url, const char *method,\r\n    const char *version,\r\n    const char *upload_data, size_t *upload_data_size,\r\n    void **con_cls) {\r\n    (void)cls; (void)version;\r\n\r\n    if (strncmp(url, \"/api/\", 5) == 0) {\r\n        return route_request(connection, url, method, upload_data,\r\n                             upload_data_size, con_cls);\r\n    }\r\n\r\n    if (strcmp(method, \"GET\") == 0) {\r\n        enum MHD_Result ret = serve_static_file(connection, url);\r\n        if (ret == MHD_YES) return ret;\r\n    }\r\n\r\n    struct MHD_Response *response = MHD_create_response_from_buffer(\r\n        9, (void *)\"Not Found\", MHD_RESPMEM_PERSISTENT);\r\n    enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_NOT_FOUND, response);\r\n    MHD_destroy_response(response);\r\n    return ret;\r\n}\r\n\r\nint main(void) {\r\n    signal(SIGINT, handle_signal);\r\n    signal(SIGTERM, handle_signal);\r\n\r\n    mkdir(\"/app/data\", 0755);\r\n\r\n    if (init_db(\"/app/data/notes.db\") != 0) {\r\n        fprintf(stderr, \"Failed to initialize database\\n\");\r\n        return 1;\r\n    }\r\n\r\n    daemon_handle = MHD_start_daemon(\r\n        MHD_USE_THREAD_PER_CONNECTION,\r\n        PORT,\r\n        NULL, NULL,\r\n        &handle_request, NULL,\r\n        MHD_OPTION_NOTIFY_COMPLETED, &request_completed, NULL,\r\n        MHD_OPTION_END\r\n    );\r\n\r\n    if (!daemon_handle) {\r\n        fprintf(stderr, \"Failed to start server\\n\");\r\n        return 1;\r\n    }\r\n\r\n    printf(\"Server running on port %d\\n\", PORT);\r\n    while (1) pause();\r\n    return 0;\r\n}\r\n\u001b[?2004hroot@1ebded0d6da5:/app# "]
