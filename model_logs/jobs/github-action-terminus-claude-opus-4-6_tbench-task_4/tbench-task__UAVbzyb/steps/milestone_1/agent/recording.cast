[125.074452, "o", "\u001b[?2004h"]
[125.074471, "o", "> "]
[125.074556, "o", "    char count_str[32];\r\n\u001b[?2004l\r"]
[125.074618, "o", "\u001b[?2004h"]
[125.074675, "o", "> "]
[125.074807, "o", "    snprintf(count_str, sizeof(count_str), \"%d\", total);\r\n\u001b[?2004l\r"]
[125.074837, "o", "\u001b[?2004h"]
[125.074857, "o", "> "]
[125.075064, "o", "    MHD_add_response_header(response, \"X-Total-Count\", count_str);\r\n\u001b[?2004l\r"]
[125.075089, "o", "\u001b[?2004h"]
[125.07511, "o", "> "]
[125.075349, "o", "    enum MHD_Result ret = MHD_queue_response(connection, status_code, response);\r\n\u001b[?2004l\r"]
[125.075376, "o", "\u001b[?2004h> "]
