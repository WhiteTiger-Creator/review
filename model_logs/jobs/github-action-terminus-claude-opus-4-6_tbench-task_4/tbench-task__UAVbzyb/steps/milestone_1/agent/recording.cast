[897.626159, "o", "cat /app/src/auth.c\r\n\u001b[?2004l\r"]
[897.629131, "o", "#include \"auth.h\"\r\n#include <stdio.h>\r\n#include <stdlib.h>\r\n#include <string.h>\r\n#include <ctype.h>\r\n\r\nstatic char api_key[256] = {0};\r\nstatic int key_loaded = 0;\r\n\r\nstatic void load_key(void) {\r\n    if (key_loaded) return;\r\n    FILE *f = fopen(\"/app/config/api.key\", \"r\");\r\n    if (!f) {\r\n        key_loaded = 1;\r\n        return;\r\n    }\r\n    if (fgets(api_key, sizeof(api_key), f)) {\r\n        /* trim whitespace */\r\n        char *end = api_key + strlen(api_key) - 1;\r\n        while (end >= api_key && isspace((unsigned char)*end)) {\r\n            *end = '\\0';\r\n            end--;\r\n        }\r\n        char *start = api_key;\r\n        while (*start && isspace((unsigned char)*start)) start++;\r\n        if (start != api_key) memmove(api_key, start, strlen(start) + 1);\r\n    }\r\n    fclose(f);\r\n    key_loaded = 1;\r\n}\r\n\r\nint api_key_valid(struct MHD_Connection *connection) {\r\n    load_key();\r\n    const char *provided = MHD_lookup_connection_value(connection, MHD_HEADER_KIND, \"X-API-Key\");\r\n    if (!provided || strcmp(provided, api_key) != 0) {\r\n        return 0;\r\n    }\r\n    return 1;\r\n}\r\n\u001b[?2004hroot@1ebded0d6da5:/app# "]
[916.703075, "i", "cat > /app/www/app.js << 'EOF'\nvar API_BASE = '/api/notes';\nvar API_KEY = 'tb3_notes_api_secret_2026';\nvar editingId = null;\n\nfunction fetchNotes() {\n  fetch(API_BASE).then(function(res) {\n    return res.json();\n  }).then(function(notes) {\n    var list = document.getElementById('notes-list');\n    list.innerHTML = '';\n    for (var i = 0; i < notes.length; i++) {\n      (function(note) {\n        var div = document.createElement('div');\n        div.className = 'note-item';\n        div.setAttribute('data-id', note.id);\n\n        var titleEl = document.createElement('strong');\n        titleEl.textContent = note.title;\n        div.appendChild(titleEl);\n\n        var contentEl = document.createElement('span');\n        contentEl.textContent = note.content || '';\n        div.appendChild(contentEl);\n\n        var editBtn = document.createElement('button');\n        editBtn.className = 'edit-btn';\n        editBtn.textContent = 'Edit';\n        editBtn.setAttribute('data-id', String(note.id));\n        editBtn.setAttribute('data-title', note.title || '');\n        editBtn.setAttribute('data-content', note.content || '');\n        editBtn.addEventListener('click', function() {\n          editingId = note.id;\n          document.getElementById('note-title').value = note.title || '';\n          document.getElementById('note-content').value = note.content || '';\n        });\n        div.appendChild(editBtn);\n\n        var deleteBtn = document.createElement('button');\n        deleteBtn.className = 'delete-btn';\n        deleteBtn.textContent = 'Delete';\n        deleteBtn.setAttribute('data-id', String(note.id));\n        deleteBtn.addEventListener('click', function() {\n          fetch(API_BASE + '/' + note.id, {\n            method: 'DELETE',\n            headers: {\n              'Content-Type': 'application/json',\n              'X-API-Key': API_KEY\n            }\n          }).then(function() {\n            editingId = null;\n            document.getElementById('note-title').value = '';\n            document.getElementById('note-content').value = '';\n            fetchNotes();\n          });\n        });\n        div.appendChild(deleteBtn);\n\n        list.appendChild(div);\n      })(notes[i]);\n    }\n  });\n}\n\nvar form = document.getElementById('note-form');\nform.addEventListener('submit', function(e) {\n  e.preventDefault();\n  var title = document.getElementById('note-title').value.trim();\n  var content = document.getElementById('note-content').value.trim();\n\n  if (editingId !== null) {\n    fetch(API_BASE + '/' + editingId, {\n      method: 'PUT',\n      headers: {\n        'Content-Type': 'application/json',\n        'X-API-Key': API_KEY\n      },\n      body: JSON.stringify({ title: title, content: content })\n    }).then(function() {\n      editingId = null;\n      document.getElementById('note-title').value = '';\n      document.getElementById('note-content').value = '';\n      fetchNotes();\n    });\n  } else {\n    fetch(API_BASE, {\n      method: 'POST',\n      headers: {\n        'Content-Type': 'application/json',\n        'X-API-Key': API_KEY\n      },\n      body: JSON.stringify({ title: title, content: content })\n    }).then(function() {\n      editingId = null;\n      document.getElementById('note-title').value = '';\n      document.getElementById('note-content').value = '';\n      fetchNotes();\n    });\n  }\n});\n\nfetchNotes();\nEOF\n"]
