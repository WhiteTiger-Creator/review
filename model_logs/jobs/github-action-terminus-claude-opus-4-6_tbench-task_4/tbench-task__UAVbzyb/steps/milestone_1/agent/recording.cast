[124.768662, "o", "\u001b[?2004h> "]
[124.768839, "o", "/* Check if the URL contains any form of \"..\" including percent-encoded variants */\r\n\u001b[?2004l\r"]
[124.768917, "o", "\u001b[?2004h> "]
[124.769053, "o", "static int url_has_dotdot(const char *url) {\r\n\u001b[?2004l\r"]
[124.769124, "o", "\u001b[?2004h> "]
[124.769213, "o", "    const char *p = url;\r\n\u001b[?2004l\r"]
[124.769244, "o", "\u001b[?2004h> "]
[124.769314, "o", "    while (*p) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[124.769342, "o", "> "]
[124.769446, "o", "        int adv1 = 0, adv2 = 0;\r\n\u001b[?2004l\r"]
[124.76947, "o", "\u001b[?2004h"]
[124.769487, "o", "> "]
[124.769685, "o", "        if (is_dot(p, &adv1) && is_dot(p + adv1, &adv2)) {\r\n\u001b[?2004l\r"]
[124.769755, "o", "\u001b[?2004h> "]
[124.769829, "o", "            return 1;\r\n\u001b[?2004l\r"]
[124.769858, "o", "\u001b[?2004h> "]
[124.770018, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[124.770134, "o", "        p++;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[124.770226, "o", ">     return 0;\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n"]
[124.770259, "o", "\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[124.770316, "o", "\u001b[?2004h"]
[124.770438, "o", "> "]
[124.770602, "o", "static enum MHD_Result serve_static_file(struct MHD_Connection *connection,\r\n\u001b[?2004l\r"]
[124.770744, "o", "\u001b[?2004h> "]
[124.770852, "o", "    const char *url) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[124.770943, "o", "    if (url_has_dotdot(url)) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[124.771014, "o", "> "]
[124.771134, "o", "        struct MHD_Response *r = MHD_create_response_from_buffer(\r\n\u001b[?2004l\r"]
[124.771168, "o", "\u001b[?2004h> "]
[124.771369, "o", "            9, (void *)\"Forbidden\", MHD_RESPMEM_PERSISTENT);\r\n\u001b[?2004l\r"]
[124.7714, "o", "\u001b[?2004h> "]
[124.771662, "o", "        enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_FORBIDDEN, r);\r\n\u001b[?2004l\r"]
[124.771691, "o", "\u001b[?2004h"]
[124.771715, "o", "> "]
[124.771841, "o", "        MHD_destroy_response(r);\r\n\u001b[?2004l\r"]
[124.771922, "o", "\u001b[?2004h> "]
[124.771957, "o", "        return ret;\r\n\u001b[?2004l\r"]
[124.771979, "o", "\u001b[?2004h> "]
[124.772107, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[124.772158, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[124.77228, "o", "    char filepath[512];\r\n\u001b[?2004l\r"]
[124.772329, "o", "\u001b[?2004h> "]
[124.772488, "o", "    const char *path = strcmp(url, \"/\") == 0 ? \"/index.html\" : url;\r\n\u001b[?2004l\r"]
[124.77256, "o", "\u001b[?2004h> "]
[124.772725, "o", "    snprintf(filepath, sizeof(filepath), \"%s%s\", WWW_DIR, path);\r\n\u001b[?2004l\r"]
[124.772811, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[124.772892, "o", "\u001b[?2004h> "]
[124.772969, "o", "    struct stat st;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[124.77311, "o", "    if (stat(filepath, &st) != 0) return MHD_NO;\r\n\u001b[?2004l\r"]
[124.773143, "o", "\u001b[?2004h> "]
[124.77317, "o", "\r\n\u001b[?2004l\r"]
[124.773196, "o", "\u001b[?2004h> "]
[124.773344, "o", "    FILE *f = fopen(filepath, \"rb\");\r\n\u001b[?2004l\r"]
[124.773377, "o", "\u001b[?2004h> "]
[124.773479, "o", "    if (!f) return MHD_NO;\r\n\u001b[?2004l\r"]
[124.773503, "o", "\u001b[?2004h> "]
[124.773527, "o", "\r\n\u001b[?2004l\r"]
[124.773613, "o", "\u001b[?2004h> "]
[124.773703, "o", "    char *buf = malloc(st.st_size);\r\n\u001b[?2004l\r"]
[124.773734, "o", "\u001b[?2004h> "]
[124.773862, "o", "    fread(buf, 1, st.st_size, f);\r\n\u001b[?2004l\r"]
[124.774017, "o", "\u001b[?2004h> "]
[124.774055, "o", "    fclose(f);\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[124.774289, "o", "    struct MHD_Response *response = MHD_create_response_from_buffer(\r\n\u001b[?2004l\r"]
[124.774321, "o", "\u001b[?2004h> "]
[124.774476, "o", "        st.st_size, buf, MHD_RESPMEM_MUST_FREE);\r\n\u001b[?2004l\r"]
[124.774504, "o", "\u001b[?2004h> "]
[124.774764, "o", "    MHD_add_response_header(response, \"Content-Type\", get_content_type(filepath));\r\n\u001b[?2004l\r"]
[124.774879, "o", "\u001b[?2004h> "]
[124.775055, "o", "    enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_OK, response);\r\n\u001b[?2004l\r"]
[124.775163, "o", "\u001b[?2004h> "]
[124.775297, "o", "    MHD_destroy_response(response);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[124.775436, "o", "    return ret;\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[124.775564, "o", "\u001b[?2004h> "]
[124.775737, "o", "static void request_completed(void *cls, struct MHD_Connection *connection,\r\n\u001b[?2004l\r"]
[124.775851, "o", "\u001b[?2004h> "]
[124.775977, "o", "    void **con_cls, enum MHD_RequestTerminationCode toe) {\r\n\u001b[?2004l\r"]
[124.776067, "o", "\u001b[?2004h> "]
[124.776166, "o", "    (void)cls; (void)connection; (void)toe;\r\n\u001b[?2004l\r"]
[124.776231, "o", "\u001b[?2004h> "]
[124.776317, "o", "    if (con_cls && *con_cls) {\r\n\u001b[?2004l\r"]
[124.776394, "o", "\u001b[?2004h> "]
[124.776522, "o", "        struct connection_info *ci = *con_cls;\r\n\u001b[?2004l\r"]
[124.776553, "o", "\u001b[?2004h> "]
[124.776693, "o", "        if (ci->data) free(ci->data);\r\n\u001b[?2004l\r"]
[124.776725, "o", "\u001b[?2004h> "]
[124.776811, "o", "        free(ci);\r\n\u001b[?2004l\r"]
[124.776841, "o", "\u001b[?2004h> "]
[124.776944, "o", "        *con_cls = NULL;\r\n\u001b[?2004l\r"]
[124.776972, "o", "\u001b[?2004h"]
[124.776994, "o", "> "]
[124.777157, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[124.77725, "o", "}\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[124.777361, "o", "static enum MHD_Result handle_request(void *cls,\r\n\u001b[?2004l\r"]
[124.777434, "o", "\u001b[?2004h> "]
[124.777526, "o", "    struct MHD_Connection *connection,\r\n\u001b[?2004l\r"]
[124.777579, "o", "\u001b[?2004h> "]
[124.777708, "o", "    const char *url, const char *method,\r\n\u001b[?2004l\r"]
[124.777785, "o", "\u001b[?2004h> "]
[124.77787, "o", "    const char *version,\r\n\u001b[?2004l\r\u001b[?2004h"]
[124.777946, "o", "> "]
[124.778066, "o", "    const char *upload_data, size_t *upload_data_size,\r\n\u001b[?2004l\r"]
[124.778098, "o", "\u001b[?2004h> "]
[124.778282, "o", "    void **con_cls) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[124.778367, "o", "    (void)cls; (void)version;\r\n\u001b[?2004l\r\u001b[?2004h"]
[124.778446, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[124.778522, "o", "> "]
[124.778601, "o", "    if (strncmp(url, \"/api/\", 5) == 0) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[124.778806, "o", "        return route_request(connection, url, method, upload_data,\r\n\u001b[?2004l\r"]
[124.778923, "o", "\u001b[?2004h> "]
[124.779015, "o", "                             upload_data_size, con_cls);\r\n\u001b[?2004l\r"]
[124.779116, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[124.779196, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[124.779312, "o", "    if (strcmp(method, \"GET\") == 0) {\r\n\u001b[?2004l\r"]
[124.779382, "o", "\u001b[?2004h> "]
[124.779571, "o", "        enum MHD_Result ret = serve_static_file(connection, url);\r\n\u001b[?2004l\r"]
[124.779599, "o", "\u001b[?2004h"]
[124.77962, "o", "> "]
[124.779745, "o", "        if (ret == MHD_YES) return ret;\r\n\u001b[?2004l\r"]
[124.779771, "o", "\u001b[?2004h"]
[124.77979, "o", "> "]
[124.779811, "o", "    }\r\n\u001b[?2004l\r"]
[124.779831, "o", "\u001b[?2004h"]
[124.779851, "o", "> \r\n\u001b[?2004l\r"]
[124.779873, "o", "\u001b[?2004h"]
[124.779897, "o", "> "]
[124.780129, "o", "    struct MHD_Response *response = MHD_create_response_from_buffer(\r\n\u001b[?2004l\r"]
[124.780156, "o", "\u001b[?2004h> "]
[124.780337, "o", "        9, (void *)\"Not Found\", MHD_RESPMEM_PERSISTENT);\r\n\u001b[?2004l\r"]
[124.780361, "o", "\u001b[?2004h"]
[124.780384, "o", "> "]
[124.780638, "o", "    enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_NOT_FOUND, response);\r\n\u001b[?2004l\r"]
[124.780666, "o", "\u001b[?2004h"]
[124.780688, "o", "> "]
[124.780804, "o", "    MHD_destroy_response(response);\r\n\u001b[?2004l\r"]
[124.780829, "o", "\u001b[?2004h"]
[124.78085, "o", "> "]
[124.78101, "o", "    return ret;\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h"]
[124.781116, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[124.781212, "o", "> int main(void) {\r\n\u001b[?2004l\r"]
[124.78129, "o", "\u001b[?2004h> "]
[124.781385, "o", "    signal(SIGINT, handle_signal);\r\n\u001b[?2004l\r\u001b[?2004h"]
[124.781465, "o", "> "]
[124.781563, "o", "    signal(SIGTERM, handle_signal);\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[124.781698, "o", "> "]
[124.781734, "o", "    mkdir(\"/app/data\", 0755);\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[124.781813, "o", "> "]
[124.781928, "o", "    if (init_db(\"/app/data/notes.db\") != 0) {\r\n\u001b[?2004l\r"]
[124.78201, "o", "\u001b[?2004h> "]
[124.78217, "o", "        fprintf(stderr, \"Failed to initialize database\\n\");\r\n\u001b[?2004l\r"]
[124.782383, "o", "\u001b[?2004h> "]
[124.782501, "o", "        return 1;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[124.782577, "o", "\u001b[?2004h> "]
[124.782637, "o", "    daemon_handle = MHD_start_daemon(\r\n\u001b[?2004l\r"]
[124.782719, "o", "\u001b[?2004h> "]
[124.782822, "o", "        MHD_USE_THREAD_PER_CONNECTION,\r\n\u001b[?2004l\r"]
[124.782857, "o", "\u001b[?2004h> "]
[124.782936, "o", "        PORT,\r\n\u001b[?2004l\r\u001b[?2004h"]
[124.782966, "o", "> "]
[124.783043, "o", "        NULL, NULL,\r\n\u001b[?2004l\r"]
[124.783128, "o", "\u001b[?2004h> "]
[124.783196, "o", "        &handle_request, NULL,\r\n\u001b[?2004l\r"]
[124.78324, "o", "\u001b[?2004h> "]
[124.78342, "o", "        MHD_OPTION_NOTIFY_COMPLETED, &request_completed, NULL,\r\n\u001b[?2004l\r"]
[124.783492, "o", "\u001b[?2004h> "]
[124.78362, "o", "        MHD_OPTION_END\r\n\u001b[?2004l\r\u001b[?2004h"]
[124.783717, "o", ">     );\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[124.783826, "o", "    if (!daemon_handle) {\r\n\u001b[?2004l\r"]
[124.783953, "o", "\u001b[?2004h> "]
[124.784101, "o", "        fprintf(stderr, \"Failed to start server\\n\");\r\n\u001b[?2004l\r"]
[124.78418, "o", "\u001b[?2004h>         return 1;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[124.78425, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[124.784341, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[124.784474, "o", "    printf(\"Server running on port %d\\n\", PORT);\r\n\u001b[?2004l\r"]
[124.784567, "o", "\u001b[?2004h>     while (1) pause();\r\n"]
[124.784649, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[124.784745, "o", "    return 0;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[124.784844, "o", "}\r\n\u001b[?2004l\r\u001b[?2004h> MAINEOF\r\n\u001b[?2004l\r"]
[124.785951, "o", "\u001b[?2004hroot@1ebded0d6da5:/app# "]
[125.066231, "i", "cat > /app/src/routes.c << 'ROUTESEOF'\n#include \"routes.h\"\n#include \"db.h\"\n#include <microhttpd.h>\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n\nstatic enum MHD_Result send_json(struct MHD_Connection *connection,\n                                  const char *body, unsigned int status_code) {\n    struct MHD_Response *response = MHD_create_response_from_buffer(\n        strlen(body), (void *)body, MHD_RESPMEM_MUST_COPY);\n    MHD_add_response_header(response, \"Content-Type\", \"application/json\");\n    MHD_add_response_header(response, \"Access-Control-Allow-Origin\", \"*\");\n    MHD_add_response_header(response, \"Access-Control-Allow-Methods\",\n                            \"GET, POST, PUT, DELETE, OPTIONS\");\n    MHD_add_response_header(response, \"Access-Control-Allow-Headers\",\n                            \"Content-Type, X-API-Key\");\n    enum MHD_Result ret = MHD_queue_response(connection, status_code, response);\n    MHD_destroy_response(response);\n    return ret;\n}\n\nstatic enum MHD_Result send_json_total(struct MHD_Connection *connection,\n                                       const char *body, unsigned int status_code,\n                                       int total) {\n    struct MHD_Response *response = MHD_create_response_from_buffer(\n        strlen(body), (void *)body, MHD_RESPMEM_MUST_COPY);\n    MHD_add_response_header(response, \"Content-Type\", \"application/json\");\n    MHD_add_response_header(response, \"Access-Control-Allow-Origin\", \"*\");\n    MHD_add_response_header(response, \"Access-Control-Allow-Methods\",\n                            \"GET, POST, PUT, DELETE, OPTIONS\");\n    MHD_add_response_header(response, \"Access-Control-Allow-Headers\",\n                            \"Content-Type, X-API-Key\");\n    char count_str[32];\n    snprintf(count_str, sizeof(count_str), \"%d\", total);\n    MHD_add_response_header(response, \"X-Total-Count\", count_str);\n    enum MHD_Result ret = MHD_queue_response(connection, status_code, response);\n    MHD_destroy_response(response);\n    return ret;\n}\n\nenum MHD_Result route_request(struct MHD_Connection *connection, const char *url,\n                              const char *method, const char *upload_data,\n                              size_t *upload_data_size, void **con_cls) {\n    (void)upload_data;\n    (void)upload_data_size;\n    (void)con_cls;\n\n    if (strcmp(method, \"OPTIONS\") == 0)\n        return send_json(connection, \"\", MHD_HTTP_OK);\n\n    if (strcmp(url, \"/api/notes\") == 0 && strcmp(method, \"GET\") == 0) {\n        int total = get_total_notes_count();\n        char *json = get_notes_paginated_json(50, 0);\n        if (!json)\n            return send_json_total(connection, \"[]\", MHD_HTTP_OK, total);\n        enum MHD_Result r = send_json_total(connection, json, MHD_HTTP_OK, total);\n        free(json);\n        return r;\n    }\n\n    return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\n}\nROUTESEOF\n"]
