     8	)
     9	
    10	var (
    11		ErrNotFound = errors.New("not found")
    12		ErrConflict = errors.New("conflict")
    13	)
    14	
    15	type Service struct {
    16		db   *sql.DB
    17		pool *WorkerPool
    18	}
    19	
    20	func NewService(db *sql.DB, pool *WorkerPool) *Service {
    21		return &Service{db: db, pool: pool}
    22	}
    23	
    24	func (s *Service) CreateJob(req CreateJobRequest) (*Job, error) {
    25		if req.Type == "" {
    26			return nil, fmt.Errorf("type is required")
    27		}
    28		res, err := s.db.Exec(
    29			"INSERT INTO jobs (job_type, payload, priority) VALUES (?, ?, ?)",
    30			req.Type, req.Payload, req.Priority,
    31		)
    32		if err != nil {
    33			return nil, fmt.Errorf("insert job: %w", err)
    34		}
    35		id, _ := res.LastInsertId()
    36		return s.GetJob(int(id))
    37	}
    38	
    39	func (s *Service) GetJob(id int) (*Job, error) {
    40		var j Job
    41		var workerID sql.NullInt64
    42		var workerName sql.NullString
    43	
    44		err := s.db.QueryRow(`
    45			SELECT j.id, j.type, j.payload, j.status, j.priority,
    46			       j.created_at, j.updated_at, j.worker_id, w.name
    47			FROM jobs j
    48			LEFT JOIN workers w ON j.worker_id = w.id
    49			WHERE j.id = ?
    50		`, id).Scan(
    51			&j.ID, &j.Type, &j.Payload, &j.Status, &j.Priority,
    52			&j.CreatedAt, &j.UpdatedAt, &workerID, &workerName,
    53		)
    54		if errors.Is(err, sql.ErrNoRows) {
    55			return nil, ErrNotFound
    56		}
    57		if err != nil {
    58			return nil, err
    59		}
    60		if workerID.Valid {
    61			wid := int(workerID.Int64)
    62			j.WorkerID = &wid
    63		}
    64		j.WorkerName = workerName.String
    65		return &j, nil
    66	}
    67	
    68	func (s *Service) ListJobs(status string) ([]Job, error) {
    69		var (
    70			rows *sql.Rows
    71			err  error
    72		)
    73		if status == "" {
    74			rows, err = s.db.Query(`
    75				SELECT id, type, payload, status, priority, created_at, updated_at, worker_id
    76				FROM jobs ORDER BY priority DESC, created_at ASC
    77			`)
    78		} else {
    79			rows, err = s.db.Query(`
    80				SELECT id, type, payload, status, priority, created_at, updated_at, worker_id
    81				FROM jobs WHERE status = ? ORDER BY priority DESC, created_at ASC
    82			`, status)
    83		}
    84		if err != nil {
    85			return nil, err
    86		}
    87		defer rows.Close()
    88	
    89		var jobs []Job
    90		for rows.Next() {
    91			var j Job
    92			var workerID sql.NullInt64
    93			if err := rows.Scan(
    94				&j.ID, &j.Type, &j.Payload, &j.Status, &j.Priority,
    95				&j.CreatedAt, &j.UpdatedAt, &workerID,
    96			); err != nil {
    97				return nil, err
    98			}
    99			if workerID.Valid {
   100				wid := int(workerID.Int64)
   101				j.WorkerID = &wid
   102			}
   103			jobs = append(jobs, j)
   104		}
   105		return jobs, rows.Err()
   106	}
   107	
   108	func (s *Service) CancelJob(id int) (*Job, error) {
   109		job, err := s.GetJob(id)
   110		if err != nil {
   111			return nil, err
   112		}
   113		if job.Status != "pending" {
   114			return nil, fmt.Errorf("%w: job status is %q", ErrConflict, job.Status)
   115		}
   116		if _, err := s.db.Exec(
   117			"UPDATE jobs SET status='cancelled', updated_at=? WHERE id=?",
   118			time.Now(), id,
   119		); err != nil {
   120			return nil, err
   121		}
   122		return s.GetJob(id)
   123	}
   124	
   125	func (s *Service) CompleteJob(id int) (*Job, error) {
   126		job, err := s.GetJob(id)
   127		if err != nil {
   128			return nil, err
   129		}
   130		if job.Status != "running" {
   131			return nil, fmt.Errorf("%w: job must be running to complete, got %q", ErrConflict, job.Status)
   132		}
   133		if _, err := s.db.Exec(
   134			"UPDATE jobs SET status='completed', updated_at=? WHERE id=?",
   135			time.Now(), id,
   136		); err != nil {
   137			return nil, err
   138		}
   139		return s.GetJob(id)
   140	}
   141	
   142	func (s *Service) FailJob(id int) (*Job, error) {
   143		job, err := s.GetJob(id)
   144		if err != nil {
   145			return nil, err
   146		}
   147		if job.Status != "running" {
   148			return nil, fmt.Errorf("%w: job must be running to fail, got %q", ErrConflict, job.Status)
   149		}
   150		if _, err := s.db.Exec(
   151			"UPDATE jobs SET status='failed', updated_at=? WHERE id=?",
   152			time.Now(), id,
   153		); err != nil {
   154			return nil, err
   155		}
   156		return s.GetJob(id)
   157	}
   158	
   159	func (s *Service) RegisterWorker(name string) (*Worker, error) {
   160		if name == "" {
   161			return nil, fmt.Errorf("name is required")
   162		}
   163		res, err := s.db.Exec("INSERT INTO workers (name) VALUES (?)", name)
   164		if err != nil {
   165			return nil, fmt.Errorf("insert worker: %w", err)
   166		}
   167		id, _ := res.LastInsertId()
   168		return s.GetWorker(int(id))
   169	}
   170	
   171	func (s *Service) GetWorker(id int) (*Worker, error) {
   172		var w Worker
   173		err := s.db.QueryRow(
   174			"SELECT id, name, status, registered_at FROM workers WHERE id=?", id,
   175		).Scan(&w.ID, &w.Name, &w.Status, &w.RegisteredAt)
   176		if errors.Is(err, sql.ErrNoRows) {
   177			return nil, ErrNotFound
   178		}
   179		return &w, err
   180	}
   181	
   182	func (s *Service) ListWorkers() ([]Worker, error) {
   183		rows, err := s.db.Query("SELECT id, name, status, registered_at FROM workers ORDER BY id")
   184		if err != nil {
   185			return nil, err
   186		}
   187		defer rows.Close()
   188	
   189		var workers []Worker
   190		for rows.Next() {
   191			var w Worker
   192			if err := rows.Scan(&w.ID, &w.Name, &w.Status, &w.RegisteredAt); err != nil {
   193				return nil, err
   194			}
   195			workers = append(workers, w)
   196		}
   197		return workers, rows.Err()
   198	}
   199	
   200	func (s *Service) GetStats() (*QueueStats, error) {
   201		stats := &QueueStats{}
   202		rows, err := s.db.Query("SELECT status, COUNT(*) FROM jobs GROUP BY status")
   203		if err != nil {
   204			return nil, err
   205		}
   206		defer rows.Close()
   207		for rows.Next() {
   208			var status string
   209			var count int
   210			if err := rows.Scan(&status, &count); err != nil {
   211				return nil, err
   212			}
   213			switch status {
   214			case "pending":
   215				stats.Pending = count
   216			case "running":
   217				stats.Running = count
   218			case "completed":
   219				stats.Completed = count
   220			case "failed":
   221				stats.Failed = count
   222			case "cancelled":
   223				stats.Cancelled = count
   224			}
   225		}
   226		return stats, rows.Err()
   227	}
[?2004hroot@971fdf94be36:/app# cat -n /app/worker.go
[?2004l     1	package main
     2	
     3	import (
     4		"database/sql"
     5		"log"
     6		"sync"
     7		"time"
     8	)
     9	
    10	type WorkerPool struct {
    11		mu         sync.Mutex
    12		maxWorkers int
    13		active     int
    14		db         *sql.DB
    15		quit       chan struct{}
    16	}
    17	
    18	func NewWorkerPool(max int, db *sql.DB) *WorkerPool {
    19		return &WorkerPool{
    20			maxWorkers: max,
    21			db:         db,
    22			quit:       make(chan struct{}),
    23		}
    24	}
    25	
    26	func (p *WorkerPool) SetMax(n int) {
    27		p.mu.Lock()
    28		defer p.mu.Unlock()
    29		log.Printf("pool: max_workers %d -> %d", p.maxWorkers, n)
    30		p.maxWorkers = n
    31	}
    32	
    33	func (p *WorkerPool) Start() {
    34		go p.poll()
    35	}
    36	
    37	func (p *WorkerPool) Stop() {
    38		close(p.quit)
    39	}
    40	
    41	func (p *WorkerPool) poll() {
    42		ticker := time.NewTicker(500 * time.Millisecond)
    43		defer ticker.Stop()
    44		for {
    45			select {
    46			case <-p.quit:
    47				return
    48			case <-ticker.C:
    49				p.mu.Lock()
    50				slots := p.maxWorkers - p.active
    51				p.mu.Unlock()
    52	
    53				for i := 0; i < slots; i++ {
    54					job, err := p.claimNextPending()
    55					if err != nil {
    56						log.Printf("poll claim error: %v", err)
    57						break
    58					}
    59					if job == nil {
    60						break
    61					}
    62					p.mu.Lock()
    63					p.active++
    64					p.mu.Unlock()
    65	
    66					go func(jobID int) {
    67						defer func() {
    68							p.mu.Lock()
    69							p.active--
    70							p.mu.Unlock()
    71						}()
    72						p.process(jobID)
    73					}(job.id)
    74				}
    75			}
    76		}
    77	}
    78	
    79	type pendingJob struct {
    80		id      int
    81		jobType string
    82	}
    83	
    84	func (p *WorkerPool) claimNextPending() (*pendingJob, error) {
    85		tx, err := p.db.Begin()
    86		if err != nil {
    87			return nil, err
    88		}
    89		defer tx.Rollback() //nolint:errcheck
    90	
    91		var j pendingJob
    92		err = tx.QueryRow(`
    93			SELECT id, type FROM jobs
    94			WHERE status = 'pending'
    95			ORDER BY priority DESC, created_at ASC
    96			LIMIT 1
    97		`).Scan(&j.id, &j.jobType)
    98		if err == sql.ErrNoRows {
    99			return nil, nil
   100		}
   101		if err != nil {
   102			return nil, err
   103		}
   104	
   105		if _, err = tx.Exec(
   106			"UPDATE jobs SET status='running', updated_at=? WHERE id=?",
   107			time.Now(), j.id,
   108		); err != nil {
   109			return nil, err
   110		}
   111		return &j, tx.Commit()
   112	}
   113	
   114	func (p *WorkerPool) process(jobID int) {
   115		time.Sleep(2 * time.Second)
   116	
   117		var status string
   118		if err := p.db.QueryRow("SELECT status FROM jobs WHERE id=?", jobID).Scan(&status); err != nil {
   119			log.Printf("pool: error reading job %d status: %v", jobID, err)
   120			return
   121		}
   122		if status != "running" {
   123			return
   124		}
   125	
   126		if _, err := p.db.Exec(
