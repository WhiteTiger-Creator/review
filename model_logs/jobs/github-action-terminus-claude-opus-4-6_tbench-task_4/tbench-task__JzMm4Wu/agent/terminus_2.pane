  src/logic/ingest.c \
  src/logic/settle.c \
  src/logic/nudge.c \
  src/logic/merge.c \
  src/logic/link.c

$(OUT): $(SRC) include/*.h include/runtime/*.h include/core/*.h include/io/*.h include/logic/*.h
	mkdir -p $(BIN_DIR)
	$(CC) $(CFLAGS) -o $@ $(SRC) $(LDFLAGS)

.PHONY: all clean
all: $(OUT)

clean:
	rm -f $(OUT)
