[398.214048, "i", "cat /app/output/report.json | python3 -c \"\nimport json, sys\ndata = json.load(sys.stdin)\nevents = data['events']\nprint(f'Total events: {len(events)}')\nsubmits = [e for e in events if e['kind'] == 'submit']\ncompletes = [e for e in events if e['kind'] == 'complete']\nnotifies = [e for e in events if e['kind'] == 'notify']\nprint(f'Submits: {len(submits)}, Completes: {len(completes)}, Notifies: {len(notifies)}')\nids_s = [e['id'] for e in submits]\nids_c = [e['id'] for e in completes]\nids_n = [e['id'] for e in notifies]\nprint(f'Submit ids: {ids_s[:10]}...')\nprint(f'Submit ids contiguous 1..N: {ids_s == list(range(1, len(ids_s)+1))}')\nprint(f'Complete covers all submits: {set(ids_c) == set(ids_s)}')\nprint(f'Notify covers all submits: {set(ids_n) == set(ids_s)}')\nprint(f'No dup completes: {len(ids_c) == len(set(ids_c))}')\nprint(f'No dup notifies: {len(ids_n) == len(set(ids_n))}')\n# Check ordering: submit before complete before notify for each id\nfirst_submit = {}\nfirst_complete = {}\nfirst_notify = {}\nfor i, e in enumer"]
[398.214201, "o", "cat /app/output/report.json | python3 -c \"\r\n\u001b[?2004l\r"]
[398.215403, "i", "ate(events):\n    if e['kind'] == 'submit' and e['id'] not in first_submit:\n        first_submit[e['id']] = i\n    elif e['kind'] == 'complete' and e['id'] not in first_complete:\n        first_complete[e['id']] = i\n    elif e['kind'] == 'notify' and e['id'] not in first_notify:\n        first_notify[e['id']] = i\norder_ok = all(first_submit[i] < first_complete[i] < first_notify[i] for i in ids_s)\nprint(f'Order invariant (submit < complete < notify): {order_ok}')\nprint(f'Events per id = 3: {len(events) == 3 * len(submits)}')\n\"\n"]
[398.215766, "o", "ate(events):\r\n    if e['kind'] == 'submit' and e['id'] not in first_submit:\r\n        first_submit[e['id']] = i\r\n    elif e['kind'] == 'complete' and e['id'] not in first_complete:\r\n        first_complete[e['id']] = i\r\n    elif e['kind'] == 'notify' and e['id'] not in first_notify:\r\n        first_notify[e['id']] = i\r\norder_ok = all(first_submit[i] < first_complete[i] < first_notify[i] for i in ids_s)\r\nprint(f'Order invariant (submit < complete < notify): {order_ok}')\r\nprint(f'Events per id = 3: {len(events) == 3 * len(submits)}')\r\n\"\r\n"]
