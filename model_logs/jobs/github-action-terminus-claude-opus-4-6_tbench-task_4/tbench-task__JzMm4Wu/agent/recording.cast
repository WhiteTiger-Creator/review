[475.383314, "i", "# Verify interleaving in basic burst too\npython3 << 'PYEOF'\nimport json\ndata = json.load(open('/app/output/report.json'))\nevents = data['events']\n# Check that completes are spread throughout, not all at end\ncomplete_positions = [i for i,e in enumerate(events) if e['kind']=='complete']\nsubmit_positions = [i for i,e in enumerate(events) if e['kind']=='submit']\nprint(f'Complete positions spread: min={min(complete_positions)}, max={max(complete_positions)}')\nprint(f'Submit positions spread: min={min(submit_positions)}, max={max(submit_positions)}')\n# Completes should not all be after all submits\nprint(f'First complete before last submit: {min(complete_positions) < max(submit_positions)}')\nPYEOF\n"]
