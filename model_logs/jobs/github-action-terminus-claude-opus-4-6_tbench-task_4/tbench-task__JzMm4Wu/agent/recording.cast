[612.605806, "o", "root@f9af61a5cd30:/app# "]
[612.606179, "o", "arena --scenario stress2 --profile burst --order a_then_b --out /app/output/report.json && echo 'SUCCESS'\r\n\u001b[?2004l\r"]
[612.607281, "o", "SUCCESS\r\n"]
[612.607366, "o", "\u001b[?2004hroot@f9af61a5cd30:/app# "]
