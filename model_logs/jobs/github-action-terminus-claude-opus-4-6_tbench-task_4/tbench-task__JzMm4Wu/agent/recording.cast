[522.054695, "i", "python3 << 'PYEOF'\nimport json, subprocess, os\n\ndef validate(scenario, profile, order):\n    path = f'/app/output/test_{scenario}_{profile}_{order}.json'\n    if os.path.exists(path):\n        os.remove(path)\n    r = subprocess.run(['arena', '--scenario', scenario, '--profile', profile, '--order', order, '--out', path], capture_output=True)\n    if r.returncode != 0:\n        return f'FAIL: exit {r.returncode}'\n    data = json.load(open(path))\n    events = data['events']\n    submits = [e for e in events if e['kind'] == 'submit']\n    completes = [e for e in events if e['kind'] == 'complete']\n    notifies = [e for e in events if e['kind'] == 'notify']\n    ids_s = [e['id'] for e in submits]\n    ids_c = [e['id'] for e in completes]\n    ids_n = [e['id'] for e in notifies]\n    \n    # Contiguous 1..N\n    if ids_s != list(range(1, len(ids_s)+1)):\n        return 'FAIL: not contiguous'\n    # Coverage\n    if set(ids_c) != set(ids_s):\n        return 'FAIL: complete coverage'\n    if set(ids_n) != set(ids_s):\n        return 'FA"]
[522.054748, "o", "python3 << 'PYEOF'\r\n"]
[522.054819, "i", "IL: notify coverage'\n    # No duplicates\n    if len(ids_c) != len(set(ids_c)):\n        return 'FAIL: dup completes'\n    if len(ids_n) != len(set(ids_n)):\n        return 'FAIL: dup notifies'\n    # At most one row per (kind, id)\n    pairs = [(e['kind'], e['id']) for e in events]\n    if len(pairs) != len(set(pairs)):\n        return 'FAIL: dup (kind,id) pairs'\n    # Exactly 3*N events\n    if len(events) != 3 * len(submits):\n        return 'FAIL: event count'\n    # Order\n    first_s, first_c, first_n = {}, {}, {}\n    for i, e in enumerate(events):\n        eid = e['id']\n        if e['kind'] == 'submit' and eid not in first_s: first_s[eid] = i\n        elif e['kind'] == 'complete' and eid not in first_c: first_c[eid] = i\n        elif e['kind'] == 'notify' and eid not in first_n: first_n[eid] = i\n    if not all(first_s[i] < first_c[i] < first_n[i] for i in ids_s):\n        return 'FAIL: ordering'\n    # Interleaving\n    cp = [i for i,e in enumerate(events) if e['kind']=='complete']\n    sp = [i for i,e in enumerate(event"]
[522.054936, "o", "\u001b[?2004l\r"]
[522.054949, "i", "s) if e['kind']=='submit']\n    if not (min(cp) < max(sp)):\n        return 'FAIL: not interleaved'\n    return f'OK ({len(submits)} submits)'\n\nfor scn in ['basic', 'stress', 'stress2']:\n    for prof in ['burst', 'steady']:\n        for order in ['a_then_b', 'b_then_a']:\n            result = validate(scn, prof, order)\n            print(f'{scn:8s} {prof:8s} {order:10s}: {result}')\nPYEOF\n"]
[522.055043, "o", "s) if e['kind']=='submit']\r\n    if not (min(cp) < max(sp)):\r\n        return 'FAIL: not interleaved'\r\n    return f'OK ({len(submits)} submits)'\r\n\r\nfor scn in ['basic', 'stress', 'stress2']:\r\n    for prof in ['burst', 'steady']:\r\n        for order in ['a_then_b', 'b_then_a']:\r\n            result = validate(scn, prof, order)\r\n            print(f'{scn:8s} {prof:8s} {order:10s}: {result}')\r\nPYEOF\r\n\u001b[?2004h"]
