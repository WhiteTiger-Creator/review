[473.362448, "i", "arena --scenario stress2 --profile steady --order a_then_b --out /app/output/stress2_steady_ab.json && python3 << 'PYEOF'\nimport json\ndata = json.load(open('/app/output/stress2_steady_ab.json'))\nevents = data['events']\nsubmits = [e for e in events if e['kind'] == 'submit']\ncompletes = [e for e in events if e['kind'] == 'complete']\nnotifies = [e for e in events if e['kind'] == 'notify']\nids_s = [e['id'] for e in submits]\nids_c = [e['id'] for e in completes]\nids_n = [e['id'] for e in notifies]\nprint(f'Submits: {len(submits)}, Completes: {len(completes)}, Notifies: {len(notifies)}')\nprint(f'Contiguous 1..N: {ids_s == list(range(1, len(ids_s)+1))}')\nprint(f'Complete covers all: {set(ids_c) == set(ids_s)}')\nprint(f'Notify covers all: {set(ids_n) == set(ids_s)}')\nprint(f'No dup C: {len(ids_c) == len(set(ids_c))}')\nprint(f'No dup N: {len(ids_n) == len(set(ids_n))}')\nfirst_s, first_c, first_n = {}, {}, {}\nfor i, e in enumerate(events):\n    eid = e['id']\n    if e['kind'] == 'submit' and eid not in first_s: first_s[eid"]
[473.36256, "i", "] = i\n    elif e['kind'] == 'complete' and eid not in first_c: first_c[eid] = i\n    elif e['kind'] == 'notify' and eid not in first_n: first_n[eid] = i\norder_ok = all(first_s[i] < first_c[i] < first_n[i] for i in ids_s)\nprint(f'Order OK: {order_ok}')\nprint(f'3 events per id: {len(events) == 3 * len(submits)}')\n# Check interleaving\nfirst_complete_idx = next(i for i,e in enumerate(events) if e['kind']=='complete')\nlast_submit_idx = len(events) - 1 - next(i for i,e in enumerate(reversed(events)) if e['kind']=='submit')\nprint(f'First complete at idx {first_complete_idx}, last submit at idx {last_submit_idx}')\nprint(f'Interleaved (completes before last submit): {first_complete_idx < last_submit_idx}')\nPYEOF\n"]
