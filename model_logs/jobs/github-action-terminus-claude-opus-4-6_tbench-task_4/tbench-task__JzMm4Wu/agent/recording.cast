[474.374666, "i", "# Test that steady profile output differs from burst\npython3 << 'PYEOF'\nimport json\nburst = json.load(open('/app/output/stress2_burst_ab.json'))\nsteady = json.load(open('/app/output/stress2_steady_ab.json'))\nprint(f\"Different profile different events: {burst['events'] != steady['events']}\")\nprint(f\"Different submit counts (burst vs steady): {sum(1 for e in burst['events'] if e['kind']=='submit')} vs {sum(1 for e in steady['events'] if e['kind']=='submit')}\")\nPYEOF\n"]
[474.375209, "o", "# Test that steady profile output differs from burst\r\n\u001b[?2004l\r"]
[474.375267, "o", "\u001b[?2004h"]
