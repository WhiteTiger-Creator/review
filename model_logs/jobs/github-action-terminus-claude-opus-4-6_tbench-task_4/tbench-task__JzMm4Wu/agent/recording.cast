[227.523677, "o", "cat /app/include/core/vec_ev.h /app/src/core/vec_ev.c\r\n\u001b[?2004l\r"]
[227.52449, "o", "#pragma once\r\n\r\n#include \"core/ev.h\"\r\n\r\n#include <stdbool.h>\r\n#include <stddef.h>\r\n\r\ntypedef struct {\r\n  tb_event *v;\r\n  size_t len;\r\n  size_t cap;\r\n} tb_vec_ev;\r\n\r\nbool tb_vec_ev_init(tb_vec_ev *a, size_t cap);\r\nvoid tb_vec_ev_free(tb_vec_ev *a);\r\nbool tb_vec_ev_push(tb_vec_ev *a, tb_event ev);\r\nvoid tb_vec_ev_clear(tb_vec_ev *a);\r\n\r\n"]
[227.524595, "o", "#include \"core/vec_ev.h\"\r\n\r\n#include <stdlib.h>\r\n\r\nbool tb_vec_ev_init(tb_vec_ev *a, size_t cap) {\r\n  if (!a)\r\n    return false;\r\n  if (cap == 0)\r\n    cap = 16;\r\n  a->v = (tb_event *)malloc(sizeof(tb_event) * cap);\r\n  if (!a->v)\r\n    return false;\r\n  a->len = 0;\r\n  a->cap = cap;\r\n  return true;\r\n}\r\n\r\nvoid tb_vec_ev_free(tb_vec_ev *a) {\r\n  if (!a)\r\n    return;\r\n  free(a->v);\r\n  a->v = NULL;\r\n  a->len = 0;\r\n  a->cap = 0;\r\n}\r\n\r\nbool tb_vec_ev_push(tb_vec_ev *a, tb_event ev) {\r\n  if (!a || !a->v)\r\n    return false;\r\n  if (a->len == a->cap) {\r\n    size_t ncap = a->cap * 2;\r\n    tb_event *nv = (tb_event *)realloc(a->v, ncap * sizeof(tb_event));\r\n    if (!nv)\r\n      return false;\r\n    a->v = nv;\r\n    a->cap = ncap;\r\n  }\r\n  a->v[a->len++] = ev;\r\n  return true;\r\n}\r\n\r\nvoid tb_vec_ev_clear(tb_vec_ev *a) {\r\n  if (!a)\r\n    return;\r\n  a->len = 0;\r\n}\r\n\r\n"]
