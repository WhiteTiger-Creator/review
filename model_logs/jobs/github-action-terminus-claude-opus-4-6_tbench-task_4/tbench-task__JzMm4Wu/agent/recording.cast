[12.645688, "o", "CC ?= cc\r\nCFLAGS ?= -O2 -g -std=c11 -Wall -Wextra -Wshadow -Wconversion -Iinclude\r\nLDFLAGS ?=\r\n\r\nBIN_DIR := /usr/local/bin\r\nOUT := $(BIN_DIR)/arena\r\n\r\nSRC := \\\r\n  src/main.c \\\r\n  src/cli.c \\\r\n  src/tb_err.c \\\r\n  src/report.c \\\r\n  src/runtime/runtime.c \\\r\n  src/runtime/profile.c \\\r\n  src/runtime/script.c \\\r\n  src/core/idgen.c \\\r\n  src/core/queue.c \\\r\n  src/core/map_u64.c \\\r\n  src/core/vec_u64.c \\\r\n  src/core/vec_ev.c \\\r\n  src/io/fs.c \\\r\n  src/io/journal.c \\\r\n  src/logic/ingest.c \\\r\n  src/logic/settle.c \\\r\n  src/logic/nudge.c \\\r\n  src/logic/merge.c \\\r\n  src/logic/link.c\r\n\r\n$(OUT): $(SRC) include/*.h include/runtime/*.h include/core/*.h include/io/*.h include/logic/*.h\r\n\tmkdir -p $(BIN_DIR)\r\n\t$(CC) $(CFLAGS) -o $@ $(SRC) $(LDFLAGS)\r\n\r\n.PHONY: all clean\r\nall: $(OUT)\r\n\r\nclean:\r\n\trm -f $(OUT)\r\n\u001b[?2004hroot@f9af61a5cd30:/app# "]
