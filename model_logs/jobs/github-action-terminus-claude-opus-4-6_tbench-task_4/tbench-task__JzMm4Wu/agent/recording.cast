[541.995839, "i", "python3 << 'PYEOF'\nimport json\n\n# Verify order matters for each scenario+profile combo\nfor scn in ['basic', 'stress', 'stress2']:\n    for prof in ['burst', 'steady']:\n        ab = json.load(open(f'/app/output/test_{scn}_{prof}_a_then_b.json'))\n        ba = json.load(open(f'/app/output/test_{scn}_{prof}_b_then_a.json'))\n        ab_evs = ab['events']\n        ba_evs = ba['events']\n        same = ab_evs == ba_evs\n        print(f'{scn:8s} {prof:8s}: sequences differ={not same}')\nPYEOF\n"]
