[?2004l#!/usr/bin/env bash
# Wipes the database so the server starts fresh with seed data on next boot.
set -euo pipefail
DB_PATH="${DB_PATH:-/opt/jobqueue/jobs.db}"
rm -f "$DB_PATH" "$DB_PATH-wal" "$DB_PATH-shm"
echo "Database reset: $DB_PATH"
#!/usr/bin/env bash
# Build and run the server locally.
set -euo pipefail
cd "$(dirname "$0")/.."
CGO_ENABLED=1 go build -o jobqueue .
DB_PATH="${DB_PATH:-/opt/jobqueue/jobs.db}" PORT="${PORT:-8080}" ./jobqueue
