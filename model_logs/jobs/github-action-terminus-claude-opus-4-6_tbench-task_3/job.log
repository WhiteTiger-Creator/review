in [\'a_then_b\', \'b_then_a\']:\n            path = f\'/app/output/full_{scn}_{prof}_{order}.json\'\n            result = run_and_check(scn, prof, order, path)\n            print(f\'{scn:8s} {prof:6s} {order:10s}: {result}\')\n"\n'] min_timeout_sec: 5.0 max_timeout_sec: 180.0
