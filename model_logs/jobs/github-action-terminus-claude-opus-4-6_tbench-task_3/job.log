Sending keys: ['cat > /tmp/fix_service.py << \'PYEOF\'\nwith open(\'/app/service.go\', \'r\') as f:\n    lines = f.readlines()\n\ncontent = \'\'.join(lines)\n\n# Fix query 1 - no status filter\ncontent = content.replace(\n    """SELECT id, type, payload, status, priority, created_at, updated_at, worker_id\n                        FROM jobs ORDER BY priority DESC, created_at ASC""",\n    """SELECT j.id, j.type, j.payload, j.status, j.priority, j.created_at, j.updated_at, j.worker_id, COALESCE(w.name, \'\')\n                        FROM jobs j LEFT JOIN workers w ON j.worker_id = w.id ORDER BY j.priority DESC, j.created_at ASC"""\n)\n\n# Fix query 2 - with status filter\ncontent = content.replace(\n    """SELECT id, type, payload, status, priority, created_at, updated_at, worker_id\n                        FROM jobs WHERE status = ? ORDER BY priority DESC, created_at ASC""",\n    """SELECT j.id, j.type, j.payload, j.status, j.priority, j.created_at, j.updated_at, j.worker_id, COALESCE(w.name, \'\')\n                        FROM jobs j LEFT JOIN workers w ON j.worker_id = w.id WHERE j.status = ? ORDER BY j.priority DESC, j.created_at ASC"""\n)\n\n# Fix the scan to include workerName\ncontent = content.replace(\n    """var j Job\n                var workerID sql.NullInt64\n                if err := rows.Scan(\n                        &j.ID, &j.Type, &j.Payload, &j.Status, &j.Priority,\n                        &j.CreatedAt, &j.UpdatedAt, &workerID,\n                ); err != nil {\n                        return nil, err\n                }\n                if workerID.Valid {\n                        wid := int(workerID.Int64)\n                        j.WorkerID = &wid\n                }\n                jobs = append(jobs, j)""",\n    """var j Job\n                var workerID sql.NullInt64\n                var workerName string\n                if err := rows.Scan(\n                        &j.ID, &j.Type, &j.Payload, &j.Status, &j.Priority,\n                        &j.CreatedAt, &j.UpdatedAt, &workerID, &workerName,\n                ); err != nil {\n                        return nil, err\n                }\n                if workerID.Valid {\n                        wid := int(workerID.Int64)\n                        j.WorkerID = &wid\n                }\n                j.WorkerName = workerName\n                jobs = append(jobs, j)"""\n)\n\nwith open(\'/app/service.go\', \'w\') as f:\n    f.write(content)\n\nprint("Done")\nPYEOF\npython3 /tmp/fix_service.py\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
