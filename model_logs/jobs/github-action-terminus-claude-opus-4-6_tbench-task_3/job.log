alloc\'d string or NULL. */\nstatic char *json_get_string(const char *json, const char *key) {\n    /* Look for "key" */\n    char search[256];\n    snprintf(search, sizeof(search), "\\"%s\\"", key);\n    const char *pos = strstr(json, search);\n    if (!pos) return NULL;\n    pos += strlen(search);\n    /* Skip whitespace and colon */\n    while (*pos && (isspace((unsigned char)*pos) || *pos == \':\')) pos++;\n    if (*pos == \'\\0\') return NULL;\n    if (*pos == \'n\' && strncmp(pos, "null", 4) == 0) return NULL;\n    if (*pos != \'"\') return NULL;\n    pos++; /* skip opening quote */\n    \n    /* Parse the string value handling escapes */\n    size_t buf_size = 1024;\n    char *buf = malloc(buf_size);\n    size_t buf_len = 0;\n    \n    while (*pos && *pos != \'"\') {\n        if (buf_len + 8 >= buf_size) {\n            buf_size *= 2;\n            buf = realloc(buf, buf_size);\n        }\n        if (*pos == \'\\\\\') {\n            pos++;\n            switch (*pos) {\n                case \'"\': buf[buf_len++] = \'"\'; break;\n                case \'\\\\\': buf[buf_len++] = \'\\\\\'; break;\n                case \'/\': buf[buf_len++] = \'/\'; break;\n                case \'n\': buf[buf_len++] = \'\\n\'; break;\n                case \'r\': buf[buf_len++] = \'\\r\'; break;\n                case \'t\': buf[buf_len++] = \'\\t\'; break;\n                case \'b\': buf[buf_len++] = \'\\b\'; break;\n                case \'f\': buf[buf_len++] = \'\\f\'; break;\n                case \'u\': {\n                    /* Basic \\uXXXX handling - just pass through as UTF-8 for ASCII range */\n                    if (pos[1] && pos[2] && pos[3] && pos[4]) {\n                        unsigned int cp = 0;\n                        sscanf(pos + 1, "%4x", &cp);\n                        if (cp < 0x80) {\n                            buf[buf_len++] = (char)cp;\n                        } else if (cp < 0x800) {\n                            buf[buf_len++] = (char)(0xC0 | (cp >> 6));\n   