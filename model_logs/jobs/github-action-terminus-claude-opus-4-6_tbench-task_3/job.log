not found\\"}", MHD_HTTP_NOT_FOUND);\n    }\n    enum MHD_Result r = send_json(connection, json, MHD_HTTP_OK);\n    free(json);\n    return r;\n}\n\nstatic enum MHD_Result handle_post_note(struct MHD_Connection *connection, const char *body) {\n    if (!body || strlen(body) == 0) {\n        return send_json(connection, "{\\"error\\":\\"title is required\\"}", MHD_HTTP_BAD_REQUEST);\n    }\n    \n    char *title = json_get_string(body, "title");\n    \n    if (!title || strlen(title) == 0) {\n        if (title) free(title);\n        return send_json(connection, "{\\"error\\":\\"title is required\\"}", MHD_HTTP_BAD_REQUEST);\n    }\n    \n    int all_space = 1;\n    for (size_t i = 0; i < strlen(title); i++) {\n        if (!isspace((unsigned char)title[i])) { all_space = 0; break; }\n    }\n    if (all_space) {\n        free(title);\n        return send_json(connection, "{\\"error\\":\\"title is required\\"}", MHD_HTTP_BAD_REQUEST);\n    }\n    \n    char *content = json_get_string(body, "content");\n    if (!content) content = strdup("");\n    \n    int id = create_note(title, content);\n    if (id < 0) {\n        free(title);\n        free(content);\n        return send_json(connection, "{\\"error\\":\\"internal error\\"}", MHD_HTTP_INTERNAL_SERVER_ERROR);\n    }\n    \n    char *note_json = get_note_json(id);\n    if (!note_json) {\n        free(title);\n        free(content);\n        return send_json(connection, "{\\"error\\":\\"internal error\\"}", MHD_HTTP_INTERNAL_SERVER_ERROR);\n    }\n    \n    enum MHD_Result r = send_json(connection, note_json, MHD_HTTP_CREATED);\n    free(note_json);\n    free(title);\n    free(content);\n    return r;\n}\n\nstatic enum MHD_Result handle_put_note(struct MHD_Connection *connection, int id, const char *body) {\n    if (!body || strlen(body) == 0) {\n        return send_json(connection, "{\\"error\\":\\"title is required\\"}", MHD_HTTP_BAD_REQUEST);\n    }\n    \n    char *title = json_get_string(body, "title");\n    \n    if (!title || strlen(title) == 0) {\n        if (title) free(title);\n        return send_json(connection, "{\\"error\\":\\"title is required\\"}", MHD_HTTP_BAD_REQUEST);\n    }\n    \n    int all_space = 1;\n    for (size_t i = 0; i < strlen(title); i++) {\n        if (!isspace((unsigned char)title[i])) { all_space = 0; break; }\n    }\n    if (all_space) {\n        free(title);\n        return send_json(connection, "{\\"error\\":\\"title is required\\"}", MHD_HTTP_BAD_REQUEST);\n    }\n    \n    char *content = json_get_string(body, "content");\n    if (!content) content = strdup("");\n    \n    int result = update_note(id, title, content);\n    free(title);\n    free(content);\n    \n    if (result == 0) {\n        return send_json(connection, "{\\"error\\":\\"not found\\"}", MHD_HTTP_NOT_FOUND);\n    }\n    if (result < 0) {\n        return send_json(connection, "{\\"error\\":\\"internal error\\"}", MHD_HTTP_INTERNAL_SERVER_ERROR);\n    }\n    \n    char *note_json = get_note_json(id);\n    if (!note_json) {\n        return send_json(connection, "{\\"error\\":\\"internal error\\"}", MHD_HTTP_INTERNAL_SERVER_ERROR);\n    }\n    enum MHD_Result r = send_json(connection, note_json, MHD_HTTP_OK);\n    free(note_json);\n    return r;\n}\n\nstatic enum MHD_Result handle_delete_note(struct MHD_Connection *connection, int id) {\n    int result = delete_note(id);\n    if (result == 0) {\n        return send_json(connection, "{\\"error\\":\\"not found\\"}", MHD_HTTP_NOT_FOUND);\n    }\n    return send_json(connection, "{\\"status\\":\\"deleted\\"}", MHD_HTTP_OK);\n}\n\nenum MHD_Result route_request(struct MHD_Connection *connection, const char *url,\n                              const char *method, const char *upload_data,\n                              size_t *upload_data_size, void **con_cls) {\n    \n    /* OPTIONS preflight */\n    if (strcmp(method, "OPTIONS") == 0) {\n        return send_options(connection);\n    }\n    \n    /* For POST/PUT/DELETE, we need to accum