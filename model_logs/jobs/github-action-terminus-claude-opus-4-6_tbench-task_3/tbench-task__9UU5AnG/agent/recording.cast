[359.055291, "o", "> "]
[359.0555, "o", "        << \",\\\"pass_epoch\\\":\" << pass_epoch << \",\\\"units\\\":[\";\r\n\u001b[?2004l\r"]
[359.055522, "o", "\u001b[?2004h"]
[359.05558, "o", "> "]
[359.055729, "o", "    for (std::size_t i = 0; i < units.size(); ++i) {\r\n\u001b[?2004l\r"]
