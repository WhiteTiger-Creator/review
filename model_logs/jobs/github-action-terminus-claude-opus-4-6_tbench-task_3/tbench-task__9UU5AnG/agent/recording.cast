[359.039299, "o", "}  // namespace forge\r\n\u001b[?2004l\r"]
[359.039374, "o", "\u001b[?2004h"]
[359.039422, "o", "> \r\n\u001b[?2004l\r:\u001b[?2004h> "]
[359.03962, "o", "int forge_run_emit(int argc, char **argv) {\r\n\u001b[?2004l\r"]
[359.039639, "o", "\u001b[?2004h"]
[359.039649, "o", "> "]
[359.039763, "o", "    if (argc != 4) {\r\n\u001b[?2004l\r"]
[359.039782, "o", "\u001b[?2004h> "]
[359.040199, "o", "        std::cerr << \"usage: forge_emit <manifest-json> <output-json> <units-csv>\\n\";\r\n\u001b[?2004l\r"]
[359.040227, "o", "\u001b[?2004h> "]
[359.040357, "o", "        return 2;\r\n\u001b[?2004l\r"]
[359.040444, "o", "\u001b[?2004h> "]
[359.040462, "o", "    }\r\n\u001b[?2004l\r"]
[359.040533, "o", "\u001b[?2004h> "]
[359.040725, "o", "    fs::path manifest_path = argv[1];\r\n\u001b[?2004l\r"]
[359.040822, "o", "\u001b[?2004h"]
[359.040845, "o", "> "]
[359.041006, "o", "    fs::path output_path = argv[2];\r\n\u001b[?2004l\r"]
[359.041038, "o", "\u001b[?2004h"]
[359.04117, "o", "> "]
[359.041482, "o", "    std::vector<std::string> requested = forge::split_units_csv(argv[3]);\r\n\u001b[?2004l\r"]
[359.041591, "o", "\u001b[?2004h> "]
[359.041941, "o", "    forge::Manifest manifest = forge::load_manifest(manifest_path);\r\n\u001b[?2004l\r"]
[359.042017, "o", "\u001b[?2004h> "]
[359.042305, "o", "    fs::path manifest_dir = manifest_path.parent_path();\r\n\u001b[?2004l\r"]
[359.042391, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[359.042926, "o", "    const char *lane_token = forge_lane_fingerprint(manifest.units.data(), manifest.units.size());\r\n\u001b[?2004l\r"]
[359.043016, "o", "\u001b[?2004h> "]
[359.043295, "o", "    fs::path checkpoint_path = forge::kCheckpointPath;\r\n\u001b[?2004l\r"]
[359.043375, "o", "\u001b[?2004h> "]
[359.043704, "o", "    int pass_epoch = forge::read_pass_epoch(checkpoint_path);\r\n\u001b[?2004l\r"]
[359.04372, "o", "\u001b[?2004h"]
[359.043865, "o", "> "]
[359.044063, "o", "    forge::LaneCheckpoint checkpoint = forge_lane_load_checkpoint(checkpoint_path, lane_token);\r\n\u001b[?2004l\r"]
[359.044126, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[359.0442, "o", "> "]
[359.044284, "o", "    std::vector<const char *> name_ptrs;\r\n\u001b[?2004l\r"]
[359.044386, "o", "\u001b[?2004h> "]
[359.044486, "o", "    for (const auto &unit : manifest.units) {\r\n\u001b[?2004l\r"]
[359.044508, "o", "\u001b[?2004h"]
[359.044589, "o", "> "]
[359.044693, "o", "        name_ptrs.push_back(unit.name.c_str());\r\n\u001b[?2004l\r"]
[359.044744, "o", "\u001b[?2004h> "]
[359.044763, "o", "    }\r\n\u001b[?2004l\r"]
[359.044816, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[359.044865, "o", "\u001b[?2004h> "]
[359.04504, "o", "    std::map<std::string, forge::UnitSpec> spec_by_name;\r\n\u001b[?2004l\r"]
[359.045088, "o", "\u001b[?2004h> "]
[359.045231, "o", "    for (const auto &unit : manifest.units) {\r\n\u001b[?2004l\r"]
[359.045285, "o", "\u001b[?2004h> "]
[359.045415, "o", "        spec_by_name[unit.name] = unit;\r\n\u001b[?2004l\r"]
[359.045438, "o", "\u001b[?2004h"]
[359.045449, "o", "> "]
[359.045484, "o", "    }\r\n"]
[359.045597, "o", "\u001b[?2004l\r"]
[359.045619, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[359.045747, "o", "    std::vector<forge::UnitRun> units;\r\n\u001b[?2004l\r"]
[359.045764, "o", "\u001b[?2004h"]
[359.045841, "o", "> "]
[359.045968, "o", "    std::vector<forge::UnitCheckpoint> updated_entries;\r\n\u001b[?2004l\r"]
[359.045985, "o", "\u001b[?2004h"]
[359.046032, "o", "> "]
[359.046165, "o", "    std::vector<std::string> requested_resume;\r\n\u001b[?2004l\r"]
[359.046216, "o", "\u001b[?2004h> "]
[359.046348, "o", "    for (const auto &name : requested) {\r\n\u001b[?2004l\r"]
[359.046417, "o", "\u001b[?2004h> "]
[359.046535, "o", "        auto it = spec_by_name.find(name);\r\n\u001b[?2004l\r"]
[359.046602, "o", "\u001b[?2004h> "]
[359.046708, "o", "        if (it == spec_by_name.end()) {\r\n\u001b[?2004l\r"]
[359.046755, "o", "\u001b[?2004h> "]
[359.04684, "o", "            continue;\r\n\u001b[?2004l\r"]
[359.046887, "o", "\u001b[?2004h> "]
[359.046934, "o", "        }\r\n\u001b[?2004l\r"]
[359.046952, "o", "\u001b[?2004h"]
[359.046963, "o", "> "]
[359.04715, "o", "        int order_rank = static_cast<int>(std::distance(\r\n\u001b[?2004l\r"]
[359.047169, "o", "\u001b[?2004h"]
[359.047222, "o", "> "]
[359.047315, "o", "            manifest.units.begin(),\r\n\u001b[?2004l\r"]
[359.047362, "o", "\u001b[?2004h> "]
[359.047577, "o", "            std::find_if(manifest.units.begin(), manifest.units.end(),\r\n\u001b[?2004l\r"]
[359.047621, "o", "\u001b[?2004h> "]
[359.047879, "o", "                         [&](const forge::UnitSpec &u) { return u.name == name; })));\r\n\u001b[?2004l\r"]
[359.047926, "o", "\u001b[?2004h> "]
[359.048037, "o", "        int64_t carry_weight = 0;\r\n\u001b[?2004l\r"]
[359.048057, "o", "\u001b[?2004h"]
[359.04807, "o", "> "]
[359.048188, "o", "        if (checkpoint.valid) {\r\n\u001b[?2004l\r"]
[359.048208, "o", "\u001b[?2004h"]
[359.04826, "o", "> "]
[359.048413, "o", "            auto cp = checkpoint.units.find(name);\r\n\u001b[?2004l\r"]
[359.048433, "o", "\u001b[?2004h"]
[359.04849, "o", "> "]
[359.048612, "o", "            if (cp != checkpoint.units.end()) {\r\n\u001b[?2004l\r"]
[359.04866, "o", "\u001b[?2004h> "]
[359.048834, "o", "                carry_weight = cp->second.carry_weight;\r\n\u001b[?2004l\r"]
[359.048882, "o", "\u001b[?2004h> "]
[359.048943, "o", "            }\r\n\u001b[?2004l\r"]
[359.048959, "o", "\u001b[?2004h"]
[359.048973, "o", "> "]
[359.049047, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h"]
[359.049175, "o", "> "]
[359.049383, "o", "        forge::UnitRun run = forge::analyze_unit(it->second, order_rank, manifest.order_weight_base,\r\n\u001b[?2004l\r"]
[359.049445, "o", "\u001b[?2004h"]
[359.049468, "o", "> "]
[359.049719, "o", "                                                 pass_epoch, manifest_dir, name_ptrs.data(),\r\n\u001b[?2004l\r"]
[359.049769, "o", "\u001b[?2004h> "]
[359.050069, "o", "                                                 name_ptrs.size(), &checkpoint, carry_weight);\r\n\u001b[?2004l\r"]
[359.050092, "o", "\u001b[?2004h"]
[359.050106, "o", "> "]
[359.050223, "o", "        units.push_back(run);\r\n\u001b[?2004l\r"]
[359.050273, "o", "\u001b[?2004h> "]
[359.050427, "o", "        if (std::string(run.mode) == \"resume\") {\r\n\u001b[?2004l\r"]
[359.050473, "o", "\u001b[?2004h> "]
[359.050619, "o", "            requested_resume.push_back(name);\r\n\u001b[?2004l\r"]
[359.050666, "o", "\u001b[?2004h> "]
[359.050797, "o", "            forge::UnitCheckpoint entry;\r\n\u001b[?2004l\r"]
[359.050845, "o", "\u001b[?2004h> "]
[359.050963, "o", "            entry.name = run.name;\r\n\u001b[?2004l\r"]
[359.051009, "o", "\u001b[?2004h> "]
[359.051166, "o", "            entry.next_pass = run.pass_index + 1;\r\n\u001b[?2004l\r"]
[359.051212, "o", "\u001b[?2004h> "]
[359.051373, "o", "            entry.carry_weight = run.order_weight;\r\n\u001b[?2004l\r"]
[359.05142, "o", "\u001b[?2004h> "]
[359.051574, "o", "            entry.carry_drift = run.drift_bytes;\r\n\u001b[?2004l\r"]
[359.051622, "o", "\u001b[?2004h> "]
[359.051767, "o", "            updated_entries.push_back(entry);\r\n\u001b[?2004l\r"]
[359.051817, "o", "\u001b[?2004h> "]
[359.051866, "o", "        }\r\n\u001b[?2004l\r"]
[359.051938, "o", "\u001b[?2004h> "]
[359.051963, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[359.052013, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[359.052032, "o", "> "]
[359.052269, "o", "    int64_t drift_total = forge_lane_drift_total(units.data(), units.size());\r\n\u001b[?2004l\r"]
[359.052317, "o", "\u001b[?2004h> "]
[359.052568, "o", "    int64_t weight_total = forge_lane_score_total(units.data(), units.size());\r\n\u001b[?2004l\r"]
[359.052589, "o", "\u001b[?2004h"]
[359.05265, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[359.052759, "o", "    std::ostringstream serial;\r\n\u001b[?2004l\r"]
[359.052812, "o", "\u001b[?2004h> "]
[359.053045, "o", "    serial << forge_lane_header_text(forge::kSchemaVersion, manifest.release_id,\r\n\u001b[?2004l\r"]
[359.053094, "o", "\u001b[?2004h> "]
[359.053359, "o", "                                     manifest.order_weight_base, pass_epoch, drift_total,\r\n\u001b[?2004l\r"]
[359.053378, "o", "\u001b[?2004h"]
[359.053392, "o", "> "]
[359.053564, "o", "                                     weight_total);\r\n\u001b[?2004l\r"]
[359.053583, "o", "\u001b[?2004h"]
[359.053633, "o", "> "]
[359.053738, "o", "    for (const auto &unit : units) {\r\n\u001b[?2004l\r"]
[359.053758, "o", "\u001b[?2004h"]
[359.053812, "o", "> "]
[359.053923, "o", "        serial << '\\n' << unit.row_serial;\r\n\u001b[?2004l\r"]
[359.053943, "o", "\u001b[?2004h"]
[359.053956, "o", "> "]
[359.054017, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[359.054034, "o", "> "]
[359.05423, "o", "    std::string top_digest = forge::digest_hex(serial.str());\r\n\u001b[?2004l\r"]
