[359.03086, "o", "\u001b[?2004h"]
[359.030924, "o", "> "]
[359.031396, "o", "    if (std::string(run.mode) == \"resume\" && checkpoint != nullptr && checkpoint->valid) {\r\n\u001b[?2004l\r"]
[359.031431, "o", "\u001b[?2004h"]
[359.031541, "o", "> "]
[359.031755, "o", "        auto it = checkpoint->units.find(spec.name);\r\n\u001b[?2004l\r"]
[359.031818, "o", "\u001b[?2004h"]
[359.031834, "o", "> "]
[359.032061, "o", "        if (it != checkpoint->units.end()) {\r\n\u001b[?2004l\r"]
[359.032176, "o", "\u001b[?2004h"]
[359.032205, "o", "> "]
