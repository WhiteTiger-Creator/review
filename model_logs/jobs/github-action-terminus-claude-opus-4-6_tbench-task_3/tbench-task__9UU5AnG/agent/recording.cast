[359.028527, "o", "\u001b[?2004h"]
[359.028572, "o", "> "]
[359.028811, "o", "    run.manifest_bytes = spec.manifest_bytes;\r\n\u001b[?2004l\r"]
[359.028857, "o", "\u001b[?2004h"]
[359.028879, "o", "> "]
[359.029198, "o", "    run.record_bytes = read_record_bytes(record_path);\r\n\u001b[?2004l\r"]
[359.029224, "o", "\u001b[?2004h"]
[359.029234, "o", "> "]
[359.029728, "o", "    run.drift_bytes = run.record_bytes - static_cast<int64_t>(run.manifest_bytes);\r\n\u001b[?2004l\r"]
[359.029756, "o", "\u001b[?2004h> "]
[359.029958, "o", "    run.order_rank = order_rank;\r\n\u001b[?2004l\r"]
[359.03001, "o", "\u001b[?2004h> \r\n"]
