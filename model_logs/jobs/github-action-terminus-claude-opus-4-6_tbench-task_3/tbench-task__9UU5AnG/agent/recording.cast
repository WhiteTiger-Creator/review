[262.995225, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.995495, "o", "extern \"C\" int m14_checkpoint_valid(const char *on_disk_token, const char *expected_token) {\r\n\u001b[?2004l\r"]
[262.995563, "o", "\u001b[?2004h> "]
[262.995754, "o", "    if (on_disk_token == nullptr || expected_token == nullptr) {\r\n\u001b[?2004l\r"]
[262.995816, "o", "\u001b[?2004h> "]
[262.995915, "o", "        return 0;\r\n\u001b[?2004l\r\u001b[?2004h"]
[262.995937, "o", ">     }\r\n"]
[262.99595, "o", "\u001b[?2004l\r"]
[262.996019, "o", "\u001b[?2004h> "]
[262.996227, "o", "    return std::string(on_disk_token) == std::string(expected_token) ? 1 : 0;\r\n\u001b[?2004l\r"]
[262.996281, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r"]
[262.996332, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[262.996408, "o", "\u001b[?2004h> "]
[262.996646, "o", "forge::LaneCheckpoint m14_read_checkpoint(const std::filesystem::path &path,\r\n\u001b[?2004l\r"]
[262.996715, "o", "\u001b[?2004h> "]
[262.996969, "o", "                                                   const std::string &expected_token) {\r\n\u001b[?2004l\r"]
[262.997024, "o", "\u001b[?2004h> "]
[262.997128, "o", "    forge::LaneCheckpoint state;\r\n\u001b[?2004l\r"]
[262.997207, "o", "\u001b[?2004h> "]
[262.997295, "o", "    std::ifstream in(path);\r\n\u001b[?2004l\r"]
[262.997349, "o", "\u001b[?2004h> "]
[262.997431, "o", "    if (!in) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.997497, "o", "        return state;\r\n\u001b[?2004l\r"]
[262.997517, "o", "\u001b[?2004h"]
[262.997527, "o", "> "]
[262.997593, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[262.997611, "o", "> "]
[262.997728, "o", "    std::ostringstream buffer;\r\n\u001b[?2004l\r"]
[262.997772, "o", "\u001b[?2004h> "]
[262.997862, "o", "    buffer << in.rdbuf();\r\n\u001b[?2004l\r"]
[262.997907, "o", "\u001b[?2004h"]
[262.997926, "o", "> "]
[262.998047, "o", "    const std::string doc = buffer.str();\r\n\u001b[?2004l\r"]
[262.998101, "o", "\u001b[?2004h> "]
[262.998296, "o", "    if (doc.find(\"\\\"schema_version\\\"\") == std::string::npos) {\r\n\u001b[?2004l\r"]
[262.998357, "o", "\u001b[?2004h> "]
[262.998446, "o", "        return state;\r\n\u001b[?2004l\r\u001b[?2004h"]
[262.998491, "o", "> "]
[262.998514, "o", "    }\r\n\u001b[?2004l\r"]
[262.998571, "o", "\u001b[?2004h> "]
[262.998721, "o", "    state.lane_token = pick_string(doc, \"lane_token\");\r\n\u001b[?2004l\r"]
[262.99877, "o", "\u001b[?2004h> "]
[262.999018, "o", "    if (!m14_checkpoint_valid(state.lane_token.c_str(), expected_token.c_str())) {\r\n\u001b[?2004l\r"]
[262.999068, "o", "\u001b[?2004h> "]
[262.999142, "o", "        return state;\r\n\u001b[?2004l\r"]
[262.999208, "o", "\u001b[?2004h> "]
[262.999228, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[262.999278, "o", "> "]
[262.999412, "o", "    size_t units_pos = doc.find(\"\\\"units\\\"\");\r\n\u001b[?2004l\r"]
[262.999442, "o", "\u001b[?2004h"]
[262.999455, "o", "> "]
[262.999604, "o", "    if (units_pos == std::string::npos) {\r\n\u001b[?2004l\r"]
[262.999627, "o", "\u001b[?2004h"]
[262.999639, "o", "> "]
[262.999727, "o", "        return state;\r\n\u001b[?2004l\r"]
[262.999802, "o", "\u001b[?2004h"]
[262.999863, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[262.999881, "o", "> "]
[263.000024, "o", "    size_t arr_start = doc.find('[', units_pos);\r\n\u001b[?2004l\r"]
[263.000047, "o", "\u001b[?2004h"]
[263.000062, "o", "> "]
[263.000223, "o", "    size_t arr_end = doc.find(']', arr_start);\r\n\u001b[?2004l\r"]
[263.00028, "o", "\u001b[?2004h> "]
[263.000508, "o", "    if (arr_start == std::string::npos || arr_end == std::string::npos) {\r\n\u001b[?2004l\r"]
[263.000614, "o", "\u001b[?2004h> "]
[263.000675, "o", "        return state;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[263.000747, "o", "    }"]
[263.000805, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[263.000995, "o", "    const std::string arr = doc.substr(arr_start, arr_end - arr_start + 1);\r\n\u001b[?2004l\r"]
[263.001061, "o", "\u001b[?2004h> "]
[263.001221, "o", "    for (const auto &block : split_object_blocks(arr)) {\r\n\u001b[?2004l\r"]
[263.001289, "o", "\u001b[?2004h> "]
[263.001393, "o", "        forge::UnitCheckpoint entry;\r\n\u001b[?2004l\r"]
[263.001412, "o", "\u001b[?2004h"]
[263.001441, "o", "> "]
[263.001583, "o", "        entry.name = pick_string(block, \"name\");\r\n\u001b[?2004l\r"]
[263.001652, "o", "\u001b[?2004h> "]
[263.001809, "o", "        entry.next_pass = pick_int(block, \"next_pass\");\r\n\u001b[?2004l\r"]
[263.001867, "o", "\u001b[?2004h> "]
[263.002064, "o", "        entry.carry_weight = pick_int64(block, \"carry_weight\");\r\n\u001b[?2004l\r"]
[263.002089, "o", "\u001b[?2004h"]
[263.002186, "o", "> "]
[263.002317, "o", "        entry.carry_drift = pick_int64(block, \"carry_drift\");\r\n\u001b[?2004l\r"]
[263.002339, "o", "\u001b[?2004h"]
[263.002376, "o", "> "]
[263.002491, "o", "        if (!entry.name.empty()) {\r\n\u001b[?2004l\r"]
[263.002519, "o", "\u001b[?2004h"]
[263.002538, "o", "> "]
[263.002692, "o", "            state.units[entry.name] = entry;\r\n\u001b[?2004l\r"]
[263.002715, "o", "\u001b[?2004h"]
[263.002727, "o", "> "]
[263.002789, "o", "        }\r\n\u001b[?2004l\r"]
[263.002803, "o", "\u001b[?2004h"]
[263.002814, "o", "> "]
[263.002834, "o", "    }\r\n"]
[263.002845, "o", "\u001b[?2004l\r"]
[263.002865, "o", "\u001b[?2004h"]
[263.002877, "o", "> "]
[263.002991, "o", "    state.valid = true;\r\n\u001b[?2004l\r\u001b[?2004h"]
[263.003009, "o", "> "]
[263.003079, "o", "    return state;\r\n\u001b[?2004l\r"]
[263.003122, "o", "\u001b[?2004h> "]
[263.003137, "o", "}\r\n\u001b[?2004l\r"]
[263.003178, "o", "\u001b[?2004h> "]
[263.003192, "o", "\r\n\u001b[?2004l\r"]
[263.003232, "o", "\u001b[?2004h> "]
[263.003411, "o", "std::vector<forge::UnitCheckpoint> m14_merge_entries(\r\n\u001b[?2004l\r"]
[263.003492, "o", "\u001b[?2004h> "]
[263.003751, "o", "    const forge::LaneCheckpoint &existing, const std::vector<forge::UnitCheckpoint> &updated,\r\n\u001b[?2004l\r"]
[263.003772, "o", "\u001b[?2004h"]
[263.003788, "o", "> "]
[263.003969, "o", "    const std::vector<std::string> &requested_resume) {\r\n\u001b[?2004l\r"]
[263.00402, "o", "\u001b[?2004h> "]
[263.004166, "o", "    // Start with existing checkpoint entries\r\n\u001b[?2004l\r"]
[263.004257, "o", "\u001b[?2004h> "]
[263.004411, "o", "    std::map<std::string, forge::UnitCheckpoint> merged;\r\n\u001b[?2004l\r"]
[263.004493, "o", "\u001b[?2004h> "]
[263.004563, "o", "    if (existing.valid) {\r\n\u001b[?2004l\r"]
[263.004585, "o", "\u001b[?2004h"]
[263.004606, "o", "> "]
[263.004748, "o", "        for (const auto &pair : existing.units) {\r\n\u001b[?2004l\r"]
[263.004822, "o", "\u001b[?2004h"]
[263.004881, "o", "> "]
[263.004948, "o", "            merged[pair.first] = pair.second;\r\n\u001b[?2004l\r"]
[263.005013, "o", "\u001b[?2004h"]
[263.005113, "o", ">         }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[263.00517, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[263.005275, "o", "    // Overwrite with updated entries\r\n\u001b[?2004l\r"]
[263.005297, "o", "\u001b[?2004h"]
[263.005317, "o", "> "]
[263.005432, "o", "    for (const auto &entry : updated) {\r\n\u001b[?2004l\r"]
[263.005544, "o", "\u001b[?2004h> "]
[263.005602, "o", "        merged[entry.name] = entry;\r\n\u001b[?2004l\r\u001b[?2004h"]
[263.005664, "o", "> "]
[263.005725, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[263.005742, "o", "> "]
[263.005837, "o", "    // Convert to sorted vector\r\n\u001b[?2004l\r"]
[263.005889, "o", "\u001b[?2004h> "]
[263.006022, "o", "    std::vector<forge::UnitCheckpoint> out;\r\n\u001b[?2004l\r"]
[263.006087, "o", "\u001b[?2004h> "]
[263.006203, "o", "    for (const auto &pair : merged) {\r\n\u001b[?2004l\r"]
[263.006228, "o", "\u001b[?2004h> "]
[263.006366, "o", "        out.push_back(pair.second);\r\n\u001b[?2004l\r"]
[263.00646, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[263.006517, "o", "> "]
[263.006616, "o", "    std::sort(out.begin(), out.end(),\r\n\u001b[?2004l\r"]
[263.006684, "o", "\u001b[?2004h> "]
[263.006912, "o", "              [](const forge::UnitCheckpoint &a, const forge::UnitCheckpoint &b) {\r\n\u001b[?2004l\r"]
[263.006967, "o", "\u001b[?2004h> "]
[263.007119, "o", "                  return a.name < b.name;\r\n\u001b[?2004l\r"]
[263.00719, "o", "\u001b[?2004h> "]
[263.007251, "o", "              });\r\n\u001b[?2004l\r\u001b[?2004h"]
[263.007321, "o", "> "]
[263.007367, "o", "    return out;\r\n\u001b[?2004l\r"]
[263.007421, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r"]
[263.00747, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[263.007511, "o", "\u001b[?2004h> "]
[263.007777, "o", "void m14_write_checkpoint(const std::filesystem::path &path, const char *lane_token,\r\n\u001b[?2004l\r"]
[263.007793, "o", "\u001b[?2004h"]
[263.00785, "o", "> "]
[263.008109, "o", "                                     const std::vector<forge::UnitCheckpoint> &entries) {\r\n\u001b[?2004l\r"]
[263.008138, "o", "\u001b[?2004h"]
[263.008161, "o", "> "]
[263.008371, "o", "    std::filesystem::create_directories(path.parent_path());\r\n\u001b[?2004l\r"]
[263.008403, "o", "\u001b[?2004h"]
[263.008417, "o", "> "]
[263.00853, "o", "    std::ostringstream out;\r\n\u001b[?2004l\r"]
[263.008649, "o", "\u001b[?2004h> "]
[263.008894, "o", "    out << \"{\\\"schema_version\\\":\" << forge::kSchemaVersion << \",\\\"lane_token\\\":\\\"\" << lane_token\r\n\u001b[?2004l\r"]
[263.008949, "o", "\u001b[?2004h> "]
[263.009039, "o", "        << \"\\\",\\\"units\\\":[\";\r\n\u001b[?2004l\r"]
[263.0091, "o", "\u001b[?2004h> "]
[263.009269, "o", "    for (size_t i = 0; i < entries.size(); ++i) {\r\n\u001b[?2004l\r"]
[263.009332, "o", "\u001b[?2004h> "]
[263.009376, "o", "        if (i) {\r\n\u001b[?2004l\r"]
[263.009396, "o", "\u001b[?2004h"]
[263.009418, "o", "> "]
[263.009526, "o", "            out << ',';\r\n\u001b[?2004l\r"]
[263.009546, "o", "\u001b[?2004h> "]
[263.009631, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[263.009772, "o", "        const auto &entry = entries[i];\r\n\u001b[?2004l\r"]
[263.009802, "o", "\u001b[?2004h"]
[263.009825, "o", "> "]
[263.010088, "o", "        out << \"{\\\"name\\\":\\\"\" << entry.name << \"\\\",\\\"next_pass\\\":\" << entry.next_pass\r\n\u001b[?2004l\r"]
[263.010114, "o", "\u001b[?2004h"]
[263.010126, "o", "> "]
[263.010389, "o", "            << \",\\\"carry_weight\\\":\" << entry.carry_weight << \",\\\"carry_drift\\\":\"\r\n\u001b[?2004l\r"]
[263.010418, "o", "\u001b[?2004h"]
[263.010469, "o", "> "]
[263.010582, "o", "            << entry.carry_drift << '}';\r\n\u001b[?2004l\r"]
[263.010606, "o", "\u001b[?2004h"]
[263.010618, "o", "> "]
[263.010673, "o", "    }\r\n\u001b[?2004l\r"]
[263.010696, "o", "\u001b[?2004h> "]
[263.010792, "o", "    out << \"]}\\n\";\r\n\u001b[?2004l\r\u001b[?2004h"]
[263.010813, "o", "> "]
[263.010989, "o", "    std::ofstream file(path, std::ios::binary);\r\n\u001b[?2004l\r"]
[263.01107, "o", "\u001b[?2004h> "]
[263.011126, "o", "    file << out.str();\r\n\u001b[?2004l\r"]
[263.011151, "o", "\u001b[?2004h> "]
[263.011223, "o", "}\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n"]
[263.011249, "o", "\u001b[?2004l\r"]
[263.012312, "o", "\u001b[?2004hroot@ba860eb2c572:/app# "]
[277.630342, "i", "head -5 /app/environment/m14/lane_store.cpp\n"]
[277.630523, "o", "head -5 /app/environment/m14/lane_store.cpp"]
[277.630589, "o", "\r\n\u001b[?2004l\r"]
[277.632016, "o", "#include \"constants.h\"\r\n#include \"m14_api.h\"\r\n#include \"types.h\"\r\n#include <algorithm>\r\n#include <cctype>\r\n"]
[277.632236, "o", "\u001b[?2004h"]
[277.632384, "o", "root@ba860eb2c572:/app# "]
[277.754262, "i", "tail -5 /app/environment/m14/lane_store.cpp\n"]
[277.754484, "o", "tail -5 /app/environment/m14/lane_store.cpp\r\n\u001b[?2004l\r"]
[277.755916, "o", "    }\r\n    out << \"]}\\n\";\r\n"]
[277.756032, "o", "    std::ofstream file(path, std::ios::binary);\r\n    file << out.str();\r\n}\r\n"]
[277.756334, "o", "\u001b[?2004h"]
[277.756382, "o", "root@ba860eb2c572:/app# "]
[277.878639, "i", "wc -l /app/environment/m14/lane_store.cpp\n"]
[277.879709, "o", "wc -l /app/environment/m14/lane_store.cpp\r\n\u001b[?2004l\r"]
[277.879805, "o", "224 /app/environment/m14/lane_store.cpp\r\n"]
[277.880089, "o", "\u001b[?2004h"]
[277.880632, "o", "root@ba860eb2c572:/app# "]
[358.97812, "i", "cat > /app/environment/runner/emit_pipeline.cpp << 'ENDOFFILE'\n#include \"emit_pipeline.h\"\n#include \"lane_bridge.h\"\n#include \"scan_bridge.h\"\n#include \"store_bridge.h\"\n#include \"constants.h\"\n#include \"types.h\"\n#include <algorithm>\n#include <cctype>\n#include <filesystem>\n#include <fstream>\n#include <iomanip>\n#include <iostream>\n#include <map>\n#include <sstream>\n#include <stdexcept>\n#include <string>\n#include <vector>\n\nnamespace fs = std::filesystem;\n\nnamespace forge {\n\nconstexpr const char *kCheckpointPath = \"/app/output/forge_checkpoint.json\";\n\nnamespace {\n\nstd::string read_file(const fs::path &path) {\n    std::ifstream in(path, std::ios::binary);\n    if (!in) {\n        throw std::runtime_error(\"could not open fixture\");\n    }\n    std::ostringstream ss;\n    ss << in.rdbuf();\n    return ss.str();\n}\n\nstd::string pick_string(const std::string &block, const std::string &key) {\n    std::string needle = \"\\\"\" + key + \"\\\"\";\n    size_t k = block.find(needle);\n    if (k == std::string::npos) {\n        return \"\";\n    }\n  "]
[358.978717, "i", "  size_t q = block.find('\"', block.find(':', k) + 1);\n    size_t e = block.find('\"', q + 1);\n    if (q == std::string::npos || e == std::string::npos) {\n        return \"\";\n    }\n    return block.substr(q + 1, e - q - 1);\n}\n\nint pick_int(const std::string &block, const std::string &key) {\n    std::string needle = \"\\\"\" + key + \"\\\"\";\n    size_t k = block.find(needle);\n    if (k == std::string::npos) {\n        return 0;\n    }\n    size_t colon = block.find(':', k);\n    if (colon == std::string::npos) {\n        return 0;\n    }\n    size_t start = colon + 1;\n    while (start < block.size() && std::isspace(static_cast<unsigned char>(block[start]))) {\n        ++start;\n    }\n    return std::stoi(block.substr(start));\n}\n\nstd::string extract_array(const std::string &doc, const std::string &key) {\n    std::string needle = \"\\\"\" + key + \"\\\"\";\n    size_t k = doc.find(needle);\n    if (k == std::string::npos) {\n        return \"\";\n    }\n    size_t p = doc.find('[', k);\n    if (p == std::string::npos) {\n        return \"\";\n    }\n "]
[358.982344, "o", "cat > /app/environment/runner/emit_pipeline.cpp << 'ENDOFFILE'\r\n\u001b[?2004l\r\u001b[?2004h> #include \"emit_pipeline.h\"\r\n\u001b[?2004l\r\u001b[?2004h> #include \"lane_bridge.h\"\r\n\u001b[?2004l\r\u001b[?2004h> #include \"scan_bridge.h\"\r\n\u001b[?2004l\r\u001b[?2004h> #include \"store_bridge.h\"\r\n\u001b[?2004l\r\u001b[?2004h> #include \"constants.h\"\r\n\u001b[?2004l\r\u001b[?2004h> #include \"types.h\"\r\n\u001b[?2004l\r\u001b[?2004h> #include <algorithm>\r\n\u001b[?2004l\r\u001b[?2004h> #include <cctype>\r\n\u001b[?2004l\r\u001b[?2004h> #include <filesystem>\r\n\u001b[?2004l\r\u001b[?2004h> #include <fstream>\r\n\u001b[?2004l\r\u001b[?2004h> #include <iomanip>\r\n\u001b[?2004l\r\u001b[?2004h> #include <iostream>\r\n\u001b[?2004l\r\u001b[?2004h> #include <map>\r\n\u001b[?2004l\r\u001b[?2004h> #include <sstream>\r\n\u001b[?2004l\r\u001b[?2004h> #include <stdexcept>\r\n\u001b[?2004l\r\u001b[?2004h> #include <string>\r\n\u001b[?2004l\r\u001b[?2004h> #include <vector>\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> namespace fs = std::filesystem;\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> namespace forge {\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> constexpr const char *kCheckpointPath = \"/app/output/forge_checkpoint.json\";\r\n\u001b[?2004l\r\u001b[?200"]
