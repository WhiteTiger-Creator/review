[359.024174, "o", "std::string digest_hex(const std::string &text) {\r\n\u001b[?2004l\r"]
[359.024232, "o", "\u001b[?2004h> "]
[359.024541, "o", "    std::uint64_t h = digest_update(kDigestSeed, text);\r\n\u001b[?2004l\r"]
[359.02456, "o", "\u001b[?2004h"]
[359.024571, "o", "> "]
[359.024758, "o", "    std::ostringstream os;\r\n\u001b[?2004l\r"]
[359.024818, "o", "\u001b[?2004h> "]
[359.0253, "o", "    os << std::hex << std::nouppercase << std::setfill('0') << std::setw(16) << h;\r\n\u001b[?2004l\r"]
[359.025361, "o", "\u001b[?2004h> "]
[359.02547, "o", "    return os.str();\r\n\u001b[?2004l\r"]
[359.025514, "o", "\u001b[?2004h> "]
[359.025533, "o", "}\r\n\u001b[?2004l\r"]
[359.025587, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r "]
[359.025606, "o", "\u001b[?2004h"]
[359.025652, "o", "> "]
[359.026225, "o", "UnitRun analyze_unit(const UnitSpec &spec, int order_rank, int order_weight_base, int pass_epoch,\r\n\u001b[?2004l\r"]
