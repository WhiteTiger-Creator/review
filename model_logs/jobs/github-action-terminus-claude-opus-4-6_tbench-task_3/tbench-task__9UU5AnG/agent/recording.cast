[114.019526, "o", "#include \"types.h\"\r\n#include <vector>\r\n\r\nnamespace forge {\r\n\r\nint64_t f12_abs_drift(int64_t drift);\r\n\r\nint64_t f12_drift_total(const std::vector<UnitRun> &units) {\r\n    int64_t total = 0;\r\n    for (const auto &unit : units) {\r\n        total += unit.drift_bytes;\r\n    }\r\n    return total;\r\n}\r\n\r\n}\r\n"]
