[359.027277, "o", "\u001b[?2004h> "]
[359.027614, "o", "    fs::path record_path = manifest_dir / spec.record;\r\n\u001b[?2004l\r"]
[359.027634, "o", "\u001b[?2004h"]
[359.027645, "o", "> "]
[359.027772, "o", "    UnitRun run{};\r\n\u001b[?2004l\r"]
