[359.033442, "o", "> "]
[359.03371, "o", "    if (std::string(run.mode) == \"resume\" && has_checkpoint_entry) {\r\n\u001b[?2004l\r"]
[359.03373, "o", "\u001b[?2004h"]
[359.033742, "o", "> "]
[359.034274, "o", "        run.order_weight = seeded_weight + static_cast<int64_t>(order_weight_base) + run.record_bytes;\r\n\u001b[?2004l\r"]
[359.034364, "o", "\u001b[?2004h> "]
[359.034437, "o", "    } else {\r\n\u001b[?2004l\r\u001b[?2004h"]
[359.034506, "o", "> "]
[359.034615, "o", "        run.order_weight =\r\n\u001b[?2004l\r"]
[359.034685, "o", "\u001b[?2004h> "]
[359.035126, "o", "            forge_lane_weight(spec.name.c_str(), names, name_count, order_weight_base, run.record_bytes);\r\n\u001b[?2004l\r"]
[359.035205, "o", "\u001b[?2004h> "]
[359.035272, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[359.03545, "o", "    run.pass_index = pass_index;\r\n\u001b[?2004l\r"]
[359.035519, "o", "\u001b[?2004h> "]
[359.03573, "o", "    run.row_serial = forge_lane_row_text(run);\r\n\u001b[?2004l\r"]
[359.035751, "o", "\u001b[?2004h"]
[359.03578, "o", "> "]
[359.036016, "o", "    run.row_digest = digest_hex(run.row_serial);\r\n\u001b[?2004l\r"]
[359.036041, "o", "\u001b[?2004h"]
[359.036066, "o", "> \r\n\u001b[?2004l\r"]
[359.036094, "o", "\u001b[?2004h"]
[359.036104, "o", "> "]
[359.036277, "o", "    std::ostringstream js;\r\n\u001b[?2004l\r"]
[359.036295, "o", "\u001b[?2004h"]
[359.036401, "o", "> "]
[359.036897, "o", "    js << \"{\\\"name\\\":\\\"\" << json_escape(run.name) << \"\\\",\\\"mode\\\":\\\"\" << json_escape(run.mode)\r\n\u001b[?2004l\r"]
[359.036915, "o", "\u001b[?2004h"]
[359.03703, "o", "> "]
[359.03735, "o", "       << \"\\\",\\\"pass_index\\\":\" << run.pass_index << \",\\\"manifest_bytes\\\":\" << run.manifest_bytes\r\n\u001b[?2004l\r"]
[359.037365, "o", "\u001b[?2004h"]
[359.037404, "o", "> "]
[359.037841, "o", "       << \",\\\"record_bytes\\\":\" << run.record_bytes << \",\\\"drift_bytes\\\":\" << run.drift_bytes\r\n\u001b[?2004l\r"]
[359.037867, "o", "\u001b[?2004h"]
[359.03788, "o", "> "]
[359.038314, "o", "       << \",\\\"order_rank\\\":\" << run.order_rank << \",\\\"order_weight\\\":\" << run.order_weight\r\n\u001b[?2004l\r"]
[359.038337, "o", "\u001b[?2004h"]
[359.038349, "o", "> "]
[359.038651, "o", "       << \",\\\"row_digest\\\":\\\"\" << run.row_digest << \"\\\"}\";\r\n\u001b[?2004l\r"]
[359.038672, "o", "\u001b[?2004h"]
[359.038684, "o", "> "]
[359.03885, "o", "    run.json = js.str();\r\n\u001b[?2004l\r"]
[359.038873, "o", "\u001b[?2004h"]
[359.038933, "o", "> "]
[359.038988, "o", "    return run;\r\n\u001b[?2004l\r"]
[359.039025, "o", "\u001b[?2004h"]
[359.039072, "o", "> "]
[359.039089, "o", "}\r\n\u001b[?2004l\r\u001b[?2004h"]
