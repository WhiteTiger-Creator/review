[361.384327, "i", "python3 -c \"\nimport json\nwith open('/app/output/report.json') as f:\n    data = json.load(f)\nevents = data['events']\nsubmits = [e for e in events if e['kind'] == 'submit']\ncompletes = [e for e in events if e['kind'] == 'complete']\nnotifies = [e for e in events if e['kind'] == 'notify']\nprint(f'Submits: {len(submits)}, Completes: {len(completes)}, Notifies: {len(notifies)}')\nsubmit_ids = [e['id'] for e in submits]\ncomplete_ids = [e['id'] for e in completes]\nnotify_ids = [e['id'] for e in notifies]\nprint(f'Submit IDs range: {min(submit_ids)}-{max(submit_ids)}')\nprint(f'Submit IDs contiguous: {submit_ids == list(range(1, max(submit_ids)+1))}')\nprint(f'Complete covers all: {set(complete_ids) == set(submit_ids)}')\nprint(f'Notify covers all: {set(notify_ids) == set(submit_ids)}')\nprint(f'No dup completes: {len(complete_ids) == len(set(complete_ids))}')\nprint(f'No dup notifies: {len(notify_ids) == len(set(notify_ids))}')\n# Check ordering: for each id, submit < complete < notify\nfor sid in submit_ids:\n    si = next(i "]
