[391.667331, "i", "python3 -c \"\nimport json\nwith open('/app/output/stress_a.json') as f:\n    a = json.load(f)\nwith open('/app/output/stress_b.json') as f:\n    b = json.load(f)\na_ids = set(e['id'] for e in a['events'] if e['kind']=='complete')\nb_ids = set(e['id'] for e in b['events'] if e['kind']=='complete')\nprint(f'Same ID coverage: {a_ids == b_ids}')\na_seq = [(e['kind'], e['id']) for e in a['events']]\nb_seq = [(e['kind'], e['id']) for e in b['events']]\nprint(f'Different sequence: {a_seq != b_seq}')\n\"\n"]
[391.668318, "o", "python3 -c \"\r\n\u001b[?2004l\r\u001b[?2004h> import json\r\n\u001b[?2004l\r\u001b[?2004h> with open('/app/output/stress_a.json') as f:\r\n\u001b[?2004l\r\u001b[?2004h>     a = json.load(f)\r\n\u001b[?2004l\r\u001b[?2004h> with open('/app/output/stress_b.json') as f:\r\n\u001b[?2004l\r\u001b[?2004h>     b = json.load(f)\r\n\u001b[?2004l\r\u001b[?2004h> "]
