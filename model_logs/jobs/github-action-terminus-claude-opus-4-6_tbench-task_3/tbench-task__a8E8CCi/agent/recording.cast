[417.292222, "i", "python3 -c \"\nimport json\n# Check tick-driven interleaving: completes should not all be at the end\nwith open('/app/output/stress_a.json') as f:\n    data = json.load(f)\nevents = data['events']\nn = len(events)\n# Check that submits and completes are interleaved (not all submits first then all completes)\nsubmit_positions = [i for i,e in enumerate(events) if e['kind']=='submit']\ncomplete_positions = [i for i,e in enumerate(events) if e['kind']=='complete']\nmax_submit_pos = max(submit_positions)\nmin_complete_pos = min(complete_positions)\nprint(f'First complete at position {min_complete_pos}, last submit at position {max_submit_pos}')\nprint(f'Interleaved: {min_complete_pos < max_submit_pos}')\n# Check submits and completes not all bunched\nthird = n // 3\nmid_completes = [p for p in complete_positions if third <= p <= 2*third]\nprint(f'Completes in middle third: {len(mid_completes)} (should be > 0)')\n\"\n"]
