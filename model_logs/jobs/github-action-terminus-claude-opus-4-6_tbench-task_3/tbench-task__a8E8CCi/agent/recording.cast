[391.669855, "o", "\u001b[?2004h> print(f'Same ID coverage: {a_ids == b_ids}')\r\n\u001b[?2004l\r\u001b[?2004h> a_seq = [(e['kind'], e['id']) for e in a['events']]\r\n\u001b[?2004l\r\u001b[?2004h> b_seq = [(e['kind'], e['id']) for e in b['events']]\r\n\u001b[?2004l\r\u001b[?2004h> print(f'Different sequence: {a_seq != b_seq}')\r\n\u001b[?2004l\r\u001b[?2004h> \"\r\n\u001b[?2004l\r"]
