[378.296015, "i", "python3 -c \"\nimport json\n\ndef check(path):\n    with open(path) as f:\n        data = json.load(f)\n    events = data['events']\n    submits = [e for e in events if e['kind'] == 'submit']\n    completes = [e for e in events if e['kind'] == 'complete']\n    notifies = [e for e in events if e['kind'] == 'notify']\n    submit_ids = [e['id'] for e in submits]\n    complete_ids = [e['id'] for e in completes]\n    notify_ids = [e['id'] for e in notifies]\n    ok = True\n    if submit_ids != list(range(1, max(submit_ids)+1)):\n        print(f'  FAIL: submit IDs not contiguous')\n        ok = False\n    if set(complete_ids) != set(submit_ids):\n        print(f'  FAIL: complete IDs mismatch')\n        ok = False\n    if set(notify_ids) != set(submit_ids):\n        print(f'  FAIL: notify IDs mismatch ({len(notify_ids)} vs {len(submit_ids)})')\n        missing = set(submit_ids) - set(notify_ids)\n        if missing:\n            print(f'    missing notifies: {sorted(missing)[:10]}...')\n        ok = False\n    if len(complete_ids) != len(set("]
[378.296074, "i", "complete_ids)):\n        print(f'  FAIL: duplicate completes')\n        ok = False\n    if len(notify_ids) != len(set(notify_ids)):\n        print(f'  FAIL: duplicate notifies')\n        ok = False\n    # Check ordering\n    for sid in submit_ids:\n        si = next(i for i,e in enumerate(events) if e['kind']=='submit' and e['id']==sid)\n        ci = next(i for i,e in enumerate(events) if e['kind']=='complete' and e['id']==sid)\n        ni = next(i for i,e in enumerate(events) if e['kind']=='notify' and e['id']==sid)\n        if not (si < ci < ni):\n            print(f'  FAIL: ORDER VIOLATION id={sid}')\n            ok = False\n            break\n    if ok:\n        print(f'  OK: {len(submits)} submits, {len(completes)} completes, {len(notifies)} notifies')\n    return ok\n\nfor p in ['stress_a', 'stress_b', 'stress2_a']:\n    path = f'/app/output/{p}.json'\n    print(f'{p}:')\n    check(path)\n\"\n"]
