[343.775678, "i", "cat > /app/src/logic/link.c << 'EOF'\n#include \"logic/link.h\"\n\n#include \"io/journal.h\"\n\n#include <string.h>\n\ntb_status tb_link_detach(tb_rt *rt, uint32_t tick) {\n  (void)tick;\n  if (!rt)\n    return TB_ERR_BAD_ARG;\n  if (!rt->attached)\n    return TB_OK;\n\n  rt->attached = false;\n\n  tb_stamp s = {.gen = rt->gen, .cursor = rt->cursor};\n  tb_status st = journal_append_stamp(rt->journal_path, s);\n  if (st != TB_OK)\n    return st;\n\n  // Do NOT clear notify_q; items accumulate for delivery on reattach.\n  return TB_OK;\n}\n\ntb_status tb_link_attach(tb_rt *rt, uint32_t tick) {\n  (void)tick;\n  if (!rt)\n    return TB_ERR_BAD_ARG;\n  if (rt->attached)\n    return TB_OK;\n\n  tb_stamp last = {0};\n  bool found = false;\n  tb_status st = journal_load_last(rt->journal_path, &last, &found);\n  if (st != TB_OK)\n    return st;\n  if (found) {\n    rt->gen = last.gen + 1;\n    // Do NOT reset cursor; it has advanced during detach.\n  }\n\n  rt->attached = true;\n  return TB_OK;\n}\nEOF\n"]
[343.777458, "o", "cat > /app/src/logic/link.c << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> #include \"logic/link.h\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> #include \"io/journal.h\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> #include <string.h>\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> tb_status tb_link_detach(tb_rt *rt, uint32_t tick) {\r\n\u001b[?2004l\r\u001b[?2004h>   (void)tick;\r\n\u001b[?2004l\r\u001b[?2004h>   if (!rt)\r\n\u001b[?2004l\r\u001b[?2004h>     return TB_ERR_BAD_ARG;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[343.777596, "o", "  if (!rt->attached)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[343.777721, "o", "    return TB_OK;\r\n\u001b[?2004l\r"]
[343.777791, "o", "\u001b[?2004h> "]
[343.777835, "o", "\r\n"]
