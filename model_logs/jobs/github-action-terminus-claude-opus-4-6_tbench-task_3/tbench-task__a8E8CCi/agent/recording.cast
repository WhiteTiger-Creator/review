[416.795584, "i", "python3 -c \"\nimport json\n\ndef load_seq(path):\n    with open(path) as f:\n        data = json.load(f)\n    return [(e['kind'], e['id']) for e in data['events']]\n\npairs = [\n    ('basic_burst_a', '/app/output/report.json'),\n    ('basic_steady_a', '/app/output/basic_steady.json'),\n    ('stress_burst_a', '/app/output/stress_a.json'),\n    ('stress2_steady_b', '/app/output/stress2_steady_b.json'),\n]\nseqs = {}\nfor name, path in pairs:\n    seqs[name] = load_seq(path)\n\n# All different\nnames = list(seqs.keys())\nfor i in range(len(names)):\n    for j in range(i+1, len(names)):\n        same = seqs[names[i]] == seqs[names[j]]\n        if same:\n            print(f'FAIL: {names[i]} == {names[j]}')\n        else:\n            print(f'OK: {names[i]} != {names[j]}')\n\"\n"]
[416.795836, "o", "python3 -c \""]
