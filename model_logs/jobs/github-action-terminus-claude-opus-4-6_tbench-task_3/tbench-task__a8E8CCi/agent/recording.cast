[54.879104, "i", "cat /app/src/runtime/profile.c\n"]
[54.879474, "o", "cat /app/src/runtime/profile.c\r\n\u001b[?2004l\r"]
[54.880275, "o", "#include \"runtime/profile.h\"\r\n\r\n#include <string.h>\r\n\r\ntb_profile tb_profile_parse(const char *s) {\r\n  if (!s)\r\n    return 0;\r\n  if (strcmp(s, \"burst\") == 0)\r\n    return TB_PROFILE_BURST;\r\n  if (strcmp(s, \"steady\") == 0)\r\n    return TB_PROFILE_STEADY;\r\n  return 0;\r\n}\r\n\r\nconst char *tb_profile_str(tb_profile p) {\r\n  switch (p) {\r\n  case TB_PROFILE_BURST:\r\n    return \"burst\";\r\n  case TB_PROFILE_STEADY:\r\n    return \"steady\";\r\n  default:\r\n    return \"unknown\";\r\n  }\r\n}\r\n\r\nuint32_t tb_profile_should_submit(tb_profile p, uint32_t tick) {\r\n  switch (p) {\r\n  case TB_PROFILE_BURST:\r\n    return tick < 10 ? 3 : (tick < 20 ? 2 : 1);\r\n  case TB_PROFILE_STEADY:\r\n    return (tick % 3) == 0 ? 1 : 0;\r\n  default:\r\n    return 0;\r\n  }\r\n}\r\n\r\n"]
[54.88054, "o", "\u001b[?2004hroot@0af9d3038c81:/app# "]
[55.178895, "i", "cat /app/include/runtime/profile.h\n"]
[55.179094, "o", "cat /app/include/runtime/profile.h\r\n\u001b[?2004l\r"]
[55.18012, "o", "#pragma once\r\n\r\n#include <stdint.h>\r\n\r\ntypedef enum {\r\n  TB_PROFILE_BURST = 1,\r\n  TB_PROFILE_STEADY = 2,\r\n} tb_profile;\r\n\r\ntb_profile tb_profile_parse(const char *s);\r\nconst char *tb_profile_str(tb_profile p);\r\n\r\n// Deterministic submission cadence.\r\nuint32_t tb_profile_should_submit(tb_profile p, uint32_t tick);\r\n\r\n"]
[55.180838, "o", "\u001b[?2004hroot@0af9d3038c81:/app# "]
[55.475659, "i", "cat /app/src/report.c\n"]
[55.475936, "o", "cat /app/src/report.c\r\n\u001b[?2004l\r"]
[55.477239, "o", "#include \"report.h\"\r\n\r\n#include <stdio.h>\r\n\r\nstatic const char *kind_str(tb_ev_kind k) {\r\n  switch (k) {\r\n  case TB_EV_SUBMIT:\r\n    return \"submit\";\r\n  case TB_EV_DONE:\r\n    return \"complete\";\r\n  case TB_EV_POKE:\r\n    return \"notify\";\r\n  default:\r\n    return \"unknown\";\r\n  }\r\n}\r\n\r\nint tb_report_write_json(const char *path, tb_scenario scn, tb_profile prof, const tb_vec_ev *evs) {\r\n  FILE *f = fopen(path, \"wb\");\r\n  if (!f)\r\n    return 1;\r\n\r\n  fprintf(f, \"{\\n\");\r\n  fprintf(f, \"  \\\"scenario\\\": \\\"%s\\\",\\n\", tb_scenario_str(scn));\r\n  fprintf(f, \"  \\\"profile\\\": \\\"%s\\\",\\n\", tb_profile_str(prof));\r\n  fprintf(f, \"  \\\"events\\\": [\\n\");\r\n  for (size_t i = 0; i < evs->len; i++) {\r\n    const tb_event *ev = &evs->v[i];\r\n    fprintf(f, \"    {\\\"kind\\\": \\\"%s\\\", \\\"id\\\": %u}%s\\n\", kind_str(ev->kind), ev->id,\r\n            (i + 1 == evs->len) ? \"\" : \",\");\r\n  }\r\n  fprintf(f, \"  ]\\n\");\r\n  fprintf(f, \"}\\n\");\r\n  fclose(f);\r\n  return 0;\r\n}\r\n\r\n\u001b[?2004hroot@0af9d3038c81:/app# "]
[55.786961, "i", "cat /app/include/report.h\n"]
[55.787142, "o", "cat /app/include/report.h"]
[55.787263, "o", "\r\n\u001b[?2004l\r"]
[55.788084, "o", "#pragma once\r\n\r\n#include \"core/vec_ev.h\"\r\n#include \"runtime/profile.h\"\r\n#include \"runtime/script.h\"\r\n\r\n#include <stdint.h>\r\n\r\n// Writes report.json as described in instruction.md.\r\nint tb_report_write_json(const char *path, tb_scenario scn, tb_profile prof, const tb_vec_ev *evs);\r\n\r\n"]
