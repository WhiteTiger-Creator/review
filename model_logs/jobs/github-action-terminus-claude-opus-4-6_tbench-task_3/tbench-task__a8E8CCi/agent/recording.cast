[481.371995, "i", "cat > /app/src/logic/nudge.c << 'EOF'\n#include \"logic/nudge.h\"\n\n#include \"core/ev.h\"\n\ntb_status tb_nudge_drain(tb_rt *rt, uint32_t tick) {\n  (void)tick;\n  if (!rt)\n    return TB_ERR_BAD_ARG;\n\n  // Only deliver notifications while attached.\n  if (!rt->attached)\n    return TB_OK;\n\n  // Drain the notify_q: emit notify for merged items, re-queue pending ones.\n  size_t n = rt->notify_q.len;\n  for (size_t i = 0; i < n; i++) {\n    uint64_t token = 0;\n    if (!tb_q64_pop(&rt->notify_q, &token))\n      break;\n\n    uint64_t key = (uint32_t)token;\n    if (!tb_map_u64_has(&rt->token_done, key)) {\n      // Not yet merged; re-queue for a future tick.\n      if (!tb_q64_push(&rt->notify_q, token))\n        return TB_ERR_CORRUPT;\n      continue;\n    }\n    uint64_t id64 = 0;\n    if (!tb_map_u64_get(&rt->token_to_id, token, &id64))\n      continue;\n    tb_event ev = {.kind = TB_EV_POKE, .id = (uint32_t)id64};\n    (void)tb_vec_ev_push(&rt->evlog, ev);\n  }\n  return TB_OK;\n}\nEOF\n"]
