[166.060236, "o", "#pragma once\r\n\r\n#include <stdint.h>\r\n\r\ntypedef enum {\r\n  TB_EV_SUBMIT = 1,\r\n  TB_EV_DONE = 2,\r\n  TB_EV_POKE = 3,\r\n} tb_ev_kind;\r\n\r\ntypedef struct {\r\n  tb_ev_kind kind;\r\n  uint32_t id;\r\n} tb_event;\r\n\r\n"]
