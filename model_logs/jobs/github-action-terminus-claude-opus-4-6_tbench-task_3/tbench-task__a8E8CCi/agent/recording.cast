[483.668129, "i", "python3 -c \"\nimport json, subprocess, os\n\ndef run_and_check(scenario, profile, order, path):\n    os.makedirs(os.path.dirname(path), exist_ok=True)\n    if os.path.exists(path):\n        os.remove(path)\n    r = subprocess.run(['arena', '--scenario', scenario, '--profile', profile, '--order', order, '--out', path], capture_output=True)\n    if r.returncode != 0:\n        return f'FAIL: exit {r.returncode}: {r.stderr.decode()[:100]}'\n    with open(path) as f:\n        data = json.load(f)\n    events = data['events']\n    submits = [e for e in events if e['kind'] == 'submit']\n    completes = [e for e in events if e['kind'] == 'complete']\n    notifies = [e for e in events if e['kind'] == 'notify']\n    if not submits:\n        return 'FAIL: no submits'\n    submit_ids = [e['id'] for e in submits]\n    complete_ids = [e['id'] for e in completes]\n    notify_ids = [e['id'] for e in notifies]\n    if submit_ids != list(range(1, max(submit_ids)+1)):\n        return f'FAIL: non-contiguous submit IDs'\n    if set(complete_ids) != set("]
[483.674627, "i", "submit_ids):\n        return f'FAIL: complete IDs mismatch'\n    if set(notify_ids) != set(submit_ids):\n        return f'FAIL: notify IDs mismatch'\n    if len(complete_ids) != len(set(complete_ids)):\n        return f'FAIL: dup completes'\n    if len(notify_ids) != len(set(notify_ids)):\n        return f'FAIL: dup notifies'\n    for sid in submit_ids:\n        si = next(i for i,e in enumerate(events) if e['kind']=='submit' and e['id']==sid)\n        ci = next(i for i,e in enumerate(events) if e['kind']=='complete' and e['id']==sid)\n        ni = next(i for i,e in enumerate(events) if e['kind']=='notify' and e['id']==sid)\n        if not (si < ci < ni):\n            return f'FAIL: order violation id={sid}'\n    return f'OK ({len(submits)} items)'\n\nfor scn in ['basic', 'stress', 'stress2']:\n    for prof in ['burst', 'steady']:\n        for order in ['a_then_b', 'b_then_a']:\n            path = f'/app/output/full_{scn}_{prof}_{order}.json'\n            result = run_and_check(scn, prof, order, path)\n            print(f'{scn:8s}"]
