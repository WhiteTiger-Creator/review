[552.134981, "o", "\u001b[?2004h"]
[552.135003, "o", "> "]
[552.135141, "o", "    int offset = 0;\r\n\u001b[?2004l\r"]
[552.135165, "o", "\u001b[?2004h"]
[552.135188, "o", "> "]
[552.135218, "o", "    \r\n\u001b[?2004l\r"]
[552.135317, "o", "\u001b[?2004h> "]
[552.135886, "o", "    const char *limit_str = MHD_lookup_connection_value(connection, MHD_GET_ARGUMENT_KIND, \"limit\");\r\n\u001b[?2004l\r\u001b[?2004h"]
[552.135929, "o", "> "]
[552.136491, "o", "    const char *offset_str = MHD_lookup_connection_value(connection, MHD_GET_ARGUMENT_KIND, \"offset\");\r\n\u001b[?2004l\r"]
[552.13659, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h"]
[552.136688, "o", "> "]
[552.136773, "o", "    if (limit_str) {\r\n\u001b[?2004l\r"]
[552.136838, "o", "\u001b[?2004h> "]
[552.137022, "o", "        limit = atoi(limit_str);\r\n\u001b[?2004l\r"]
[552.137155, "o", "\u001b[?2004h> "]
