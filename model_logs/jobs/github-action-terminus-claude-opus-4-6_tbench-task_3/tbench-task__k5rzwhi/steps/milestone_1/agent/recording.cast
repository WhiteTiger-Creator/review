[299.556126, "i", " 0) {\n        return send_json(connection, \"{\\\"error\\\":\\\"title is required\\\"}\", MHD_HTTP_BAD_REQUEST);\n    }\n    \n    char *title = json_get_string(body, \"title\");\n    \n    /* Title must be present and non-empty */\n    if (!title || strlen(title) == 0) {\n        if (title) free(title);\n        return send_json(connection, \"{\\\"error\\\":\\\"title is required\\\"}\", MHD_HTTP_BAD_REQUEST);\n    }\n    \n    /* Check if title is only whitespace */\n    int all_space = 1;\n    for (size_t i = 0; i < strlen(title); i++) {\n        if (!isspace((unsigned char)title[i])) { all_space = 0; break; }\n    }\n    if (all_space) {\n        free(title);\n        return send_json(connection, \"{\\\"error\\\":\\\"title is required\\\"}\", MHD_HTTP_BAD_REQUEST);\n    }\n    \n    char *content = json_get_string(body, \"content\");\n    if (!content) content = strdup(\"\");\n    \n    int result = update_note(id, title, content);\n    free(title);\n    free(content);\n    \n    if (result == 0) {\n        return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\n    }\n    if (result < 0) {\n        return send_json(connection, \"{\\\"error\\\":\\\"internal error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR);\n    }\n    \n    char *note_json = get_note_json(id);\n    if (!note_json) {\n        return send_json(connection, \"{\\\"error\\\":\\\"internal error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR);\n    }\n    enum MHD_Result r = send_json(connection, note_json, MHD_HTTP_OK);\n    free(note_json);\n    return r;\n}\n\nstatic enum MHD_Result handle_delete_note(struct MHD_Connection *connection, int id) {\n    int result = delete_note(id);\n    if (result == 0) {\n        return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\n    }\n    return send_json(connection, \"{\\\"status\\\":\\\"deleted\\\"}\", MHD_HTTP_OK);\n}\n\nenum MHD_Result route_request(struct MHD_Connection *connection, const char *url,\n                              const char *method, const char *upload_data,\n                              size_t *upload_data_size, void **con_cls) {\n    \n    /* OPTIONS preflight */\n    if (strcmp(method, \"OPTIONS\") == 0) {\n        return send_options(connection);\n    }\n    \n    /* For POST/PUT/DELETE, we need to accumulate body data */\n    if (strcmp(method, \"POST\") == 0 || strcmp(method, \"PUT\") == 0 || strcmp(method, \"DELETE\") == 0) {\n        if (*con_cls == NULL) {\n            /* First call - allocate connection info */\n            struct connection_info *ci = calloc(1, sizeof(struct connection_info));\n            ci->data = NULL;\n            ci->data_size = 0;\n            *con_cls = ci;\n            return MHD_YES;\n        }\n        \n        struct connection_info *ci = *con_cls;\n        \n        if (*upload_data_size > 0) {\n            /* Check body size limit */\n            if (ci->data_size + *upload_data_size > MAX_BODY_SIZE) {\n                *upload_data_size = 0;\n                return send_json(connection, \"{\\\"error\\\":\\\"body too large\\\"}\", 413);\n            }\n            /* Accumulate data */\n            ci->data = realloc(ci->data, ci->data_size + *upload_data_size + 1);\n            memcpy(ci->data + ci->data_size, upload_data, *upload_data_size);\n            ci->data_size += *upload_data_size;\n            ci->data[ci->data_size] = '\\0';\n            *upload_data_size = 0;\n            return MHD_YES;\n        }\n        \n        /* All data received - process the request */\n        /* Check auth for mutating requests */\n        if (!api_key_valid(connection)) {\n            return send_json(connection, \"{\\\"error\\\":\\\"unauthorized\\\"}\", MHD_HTTP_UNAUTHORIZED);\n        }\n        \n        /* Check body size */\n        if (ci->data_size > MAX_BODY_SIZE) {\n            return send_json(connection, \"{\\\"error\\\":\\\"body too large\\\"}\", 413);\n        }\n        \n        /* Route to appropriate handler */\n        if (strcmp(url, \"/api/notes\") == 0 && strcmp(method, \"POST\") == 0) {\n            return handle_post_note(connection, ci->data);\n        }\n        \n        /* Extract ID for /api/notes/{id} routes */\n        int id = extract_note_id(url);\n        if (id < 0) {\n            return send_json(conne"]
[299.556374, "i", "ction, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\n        }\n        \n        if (strcmp(method, \"PUT\") == 0) {\n            return handle_put_note(connection, id, ci->data);\n        }\n        if (strcmp(method, \"DELETE\") == 0) {\n            return handle_delete_note(connection, id);\n        }\n        \n        return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\n    }\n    \n    /* GET requests */\n    if (strcmp(method, \"GET\") == 0) {\n        if (strcmp(url, \"/api/notes\") == 0) {\n            return handle_get_notes(connection);\n        }\n        \n        int id = extract_note_id(url);\n        if (id >= 0) {\n            return handle_get_note(connection, id);\n        }\n        \n        return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\n    }\n    \n    return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\n}\nEOF\n"]
