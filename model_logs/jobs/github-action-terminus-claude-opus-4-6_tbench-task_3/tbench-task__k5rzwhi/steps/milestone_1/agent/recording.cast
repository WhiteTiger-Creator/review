[552.142181, "o", "\u001b[?2004h> "]
[552.142244, "o", "    if (!json) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[552.142765, "o", "        return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\r\n\u001b[?2004l\r"]
[552.142854, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[552.142898, "o", "\u001b[?2004h> "]
[552.143301, "o", "    enum MHD_Result r = send_json(connection, json, MHD_HTTP_OK);\r\n\u001b[?2004l\r"]
[552.143366, "o", "\u001b[?2004h> "]
