[552.146317, "o", "> "]
[552.146919, "o", "        return send_json(connection, \"{\\\"error\\\":\\\"title is required\\\"}\", MHD_HTTP_BAD_REQUEST);\r\n\u001b[?2004l\r"]
[552.146945, "o", "\u001b[?2004h> "]
[552.147008, "o", "    }\r\n\u001b[?2004l\r"]
[552.147037, "o", "\u001b[?2004h> "]
