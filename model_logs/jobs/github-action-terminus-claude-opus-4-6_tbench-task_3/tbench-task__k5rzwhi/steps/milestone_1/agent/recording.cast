[16.940412, "o", "cat /app/www/index.html\r\n\u001b[?2004l\r"]
[16.941961, "o", "<!DOCTYPE html>\r\n<html lang=\"en\">\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>Notes App</title>\r\n    <link rel=\"stylesheet\" href=\"/style.css\">\r\n</head>\r\n<body>\r\n    <div class=\"container\">\r\n        <h1>Notes</h1>\r\n        <form id=\"note-form\">\r\n            <input type=\"text\" id=\"note-title\" placeholder=\"Title\" required>\r\n            <textarea id=\"note-content\" placeholder=\"Content\"></textarea>\r\n            <button type=\"submit\" id=\"btn-submit\">Save</button>\r\n        </form>\r\n        <div id=\"notes-list\"></div>\r\n    </div>\r\n    <script src=\"/app.js\"></script>\r\n</body>\r\n</html>\r\n"]
[16.942156, "o", "\u001b[?2004h"]
