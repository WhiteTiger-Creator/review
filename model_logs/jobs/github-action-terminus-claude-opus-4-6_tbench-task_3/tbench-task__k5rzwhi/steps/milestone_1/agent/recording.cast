[299.107249, "i", "cat > /app/src/db.c << 'EOF'\n#include \"db.h\"\n#include <sqlite3.h>\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <pthread.h>\n\nstatic sqlite3 *db = NULL;\nstatic pthread_mutex_t db_mutex = PTHREAD_MUTEX_INITIALIZER;\n\n/* Escape a string for JSON output. Caller must free result. */\nstatic char *json_escape(const char *s) {\n    if (!s) return strdup(\"\");\n    size_t len = strlen(s);\n    /* Worst case: every char becomes \\uXXXX (6 chars) */\n    char *out = malloc(len * 6 + 1);\n    if (!out) return strdup(\"\");\n    char *p = out;\n    for (size_t i = 0; i < len; i++) {\n        unsigned char c = (unsigned char)s[i];\n        switch (c) {\n            case '\"':  *p++ = '\\\\'; *p++ = '\"'; break;\n            case '\\\\': *p++ = '\\\\'; *p++ = '\\\\'; break;\n            case '\\n': *p++ = '\\\\'; *p++ = 'n'; break;\n            case '\\r': *p++ = '\\\\'; *p++ = 'r'; break;\n            case '\\t': *p++ = '\\\\'; *p++ = 't'; break;\n            case '\\b': *p++ = '\\\\'; *p++ = 'b'; break;\n            case '\\f': *p++ = '\\\\'; *p++ = 'f'; break;\n            default:\n                if (c < 0x20) {\n                    p += sprintf(p, \"\\\\u%04x\", c);\n                } else {\n                    *p++ = c;\n                }\n                break;\n        }\n    }\n    *p = '\\0';\n    return out;\n}\n\nint init_db(const char *path) {\n    int rc = sqlite3_open_v2(path, &db,\n        SQLITE_OPEN_READWRITE | SQLITE_OPEN_CREATE | SQLITE_OPEN_FULLMUTEX,\n        NULL);\n    if (rc != SQLITE_OK) {\n        fprintf(stderr, \"Cannot open database: %s\\n\", sqlite3_errmsg(db));\n        return -1;\n    }\n\n    /* Enable WAL mode for concurrency */\n    sqlite3_exec(db, \"PRAGMA journal_mode=WAL;\", NULL, NULL, NULL);\n    /* Set busy timeout to 5 seconds */\n    sqlite3_busy_timeout(db, 5000);\n\n    const char *sql = \"CREATE TABLE IF NOT EXISTS notes (\"\n                      \"id INTEGER PRIMARY KEY AUTOINCREMENT,\"\n                      \"title TEXT NOT NULL,\"\n                      \"content TEXT NOT NULL DEFAULT ''\"\n                      \");\";\n    char *err_msg = NULL;\n    if (sqlite3_exec(db, sql, NULL, NULL, &err_msg) != SQLITE_OK) {\n        fprintf(stderr, \"SQL error: %s\\n\", err_msg);\n        sqlite3_free(err_msg);\n        return -1;\n    }\n    return 0;\n}\n\nvoid close_db(void) {\n    if (db) sqlite3_close(db);\n    db = NULL;\n}\n\nint create_note(const char *title, const char *content) {\n    if (!content) content = \"\";\n    pthread_mutex_lock(&db_mutex);\n    sqlite3_stmt *stmt;\n    const char *sql = \"INSERT INTO notes (title, content) VALUES (?, ?);\";\n    int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);\n    if (rc != SQLITE_OK) {\n        pthread_mutex_unlock(&db_mutex);\n        return -1;\n    }\n    sqlite3_bind_text(stmt, 1, title, -1, SQLITE_TRANSIENT);\n    sqlite3_bind_text(stmt, 2, content, -1, SQLITE_TRANSIENT);\n    rc = sqlite3_step(stmt);\n    sqlite3_finalize(stmt);\n    if (rc != SQLITE_DONE) {\n        pthread_mutex_unlock(&db_mutex);\n        return -1;\n    }\n    int id = (int)sqlite3_last_insert_rowid(db);\n    pthread_mutex_unlock(&db_mutex);\n    return id;\n}\n\nchar *get_note_json(int id) {\n    pthread_mutex_lock(&db_mutex);\n    sqlite3_stmt *stmt;\n    const char *sql = \"SELECT id, title, content FROM notes WHERE id = ?;\";\n    int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);\n    if (rc != SQLITE_OK) {\n        pthread_mutex_unlock(&db_mutex);\n        return NULL;\n    }\n    sqlite3_bind_int(stmt, 1, id);\n    rc = sqlite3_step(stmt);\n    if (rc != SQLITE_ROW) {\n        sqlite3_finalize(stmt);\n        pthread_mutex_unlock(&db_mutex);\n        return NULL;\n    }\n    int nid = sqlite3_column_int(stmt, 0);\n    const char *title = (const char *)sqlite3_column_text(stmt, 1);\n    const char *content = (const char *)sqlite3_column_text(stmt, 2);\n    char *esc_title = json_escape(title);\n    char *esc_content = json_escape(content);\n    size_t buf_size = strlen(esc_title) + strlen(esc_content) + 100;\n    char *json = malloc(buf_size);\n    snprintf(json, buf_size, \"{\\\"id\\\":%d,\\\"title\\\":\\\"%s\\\",\\\"content\\\":\\\"%s\\\"}\",\n             nid, esc_title, esc_content);\n    free(esc_title);\n"]
[299.107434, "i", "    free(esc_content);\n    sqlite3_finalize(stmt);\n    pthread_mutex_unlock(&db_mutex);\n    return json;\n}\n\nchar *get_notes_paginated_json(int limit, int offset) {\n    pthread_mutex_lock(&db_mutex);\n    sqlite3_stmt *stmt;\n    const char *sql = \"SELECT id, title, content FROM notes ORDER BY id LIMIT ? OFFSET ?;\";\n    int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);\n    if (rc != SQLITE_OK) {\n        pthread_mutex_unlock(&db_mutex);\n        return strdup(\"[]\");\n    }\n    sqlite3_bind_int(stmt, 1, limit);\n    sqlite3_bind_int(stmt, 2, offset);\n\n    /* Build JSON array */\n    size_t buf_size = 4096;\n    size_t buf_used = 0;\n    char *buf = malloc(buf_size);\n    buf[0] = '[';\n    buf_used = 1;\n    int first = 1;\n\n    while ((rc = sqlite3_step(stmt)) == SQLITE_ROW) {\n        int nid = sqlite3_column_int(stmt, 0);\n        const char *title = (const char *)sqlite3_column_text(stmt, 1);\n        const char *content = (const char *)sqlite3_column_text(stmt, 2);\n        char *esc_title = json_escape(title);\n        char *esc_content = json_escape(content);\n        \n        size_t entry_size = strlen(esc_title) + strlen(esc_content) + 100;\n        while (buf_used + entry_size + 10 > buf_size) {\n            buf_size *= 2;\n            buf = realloc(buf, buf_size);\n        }\n        if (!first) { buf[buf_used++] = ','; }\n        first = 0;\n        buf_used += snprintf(buf + buf_used, buf_size - buf_used,\n            \"{\\\"id\\\":%d,\\\"title\\\":\\\"%s\\\",\\\"content\\\":\\\"%s\\\"}\",\n            nid, esc_title, esc_content);\n        free(esc_title);\n        free(esc_content);\n    }\n    sqlite3_finalize(stmt);\n    pthread_mutex_unlock(&db_mutex);\n\n    if (buf_used + 2 > buf_size) {\n        buf_size = buf_used + 2;\n        buf = realloc(buf, buf_size);\n    }\n    buf[buf_used++] = ']';\n    buf[buf_used] = '\\0';\n    return buf;\n}\n\nint get_total_notes_count(void) {\n    pthread_mutex_lock(&db_mutex);\n    sqlite3_stmt *stmt;\n    const char *sql = \"SELECT COUNT(*) FROM notes;\";\n    int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);\n    if (rc != SQLITE_OK) {\n        pthread_mutex_unlock(&db_mutex);\n        return 0;\n    }\n    rc = sqlite3_step(stmt);\n    int count = 0;\n    if (rc == SQLITE_ROW) {\n        count = sqlite3_column_int(stmt, 0);\n    }\n    sqlite3_finalize(stmt);\n    pthread_mutex_unlock(&db_mutex);\n    return count;\n}\n\nint note_exists(int id) {\n    pthread_mutex_lock(&db_mutex);\n    sqlite3_stmt *stmt;\n    const char *sql = \"SELECT 1 FROM notes WHERE id = ?;\";\n    int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);\n    if (rc != SQLITE_OK) {\n        pthread_mutex_unlock(&db_mutex);\n        return 0;\n    }\n    sqlite3_bind_int(stmt, 1, id);\n    rc = sqlite3_step(stmt);\n    int exists = (rc == SQLITE_ROW) ? 1 : 0;\n    sqlite3_finalize(stmt);\n    pthread_mutex_unlock(&db_mutex);\n    return exists;\n}\n\nint update_note(int id, const char *title, const char *content) {\n    if (!content) content = \"\";\n    pthread_mutex_lock(&db_mutex);\n    /* Check existence first */\n    sqlite3_stmt *stmt;\n    const char *check_sql = \"SELECT 1 FROM notes WHERE id = ?;\";\n    int rc = sqlite3_prepare_v2(db, check_sql, -1, &stmt, NULL);\n    if (rc != SQLITE_OK) {\n        pthread_mutex_unlock(&db_mutex);\n        return -1;\n    }\n    sqlite3_bind_int(stmt, 1, id);\n    rc = sqlite3_step(stmt);\n    sqlite3_finalize(stmt);\n    if (rc != SQLITE_ROW) {\n        pthread_mutex_unlock(&db_mutex);\n        return 0; /* not found */\n    }\n\n    const char *sql = \"UPDATE notes SET title = ?, content = ? WHERE id = ?;\";\n    rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);\n    if (rc != SQLITE_OK) {\n        pthread_mutex_unlock(&db_mutex);\n        return -1;\n    }\n    sqlite3_bind_text(stmt, 1, title, -1, SQLITE_TRANSIENT);\n    sqlite3_bind_text(stmt, 2, content, -1, SQLITE_TRANSIENT);\n    sqlite3_bind_int(stmt, 3, id);\n    rc = sqlite3_step(stmt);\n    sqlite3_finalize(stmt);\n    pthread_mutex_unlock(&db_mutex);\n    return (rc == SQLITE_DONE) ? 1 : -1;\n}\n\nint delete_note(int id) {\n    pthread_mutex_lock(&db_mutex);\n    /* Check existence first */\n    sqlite3_stmt *stmt;\n    con"]
