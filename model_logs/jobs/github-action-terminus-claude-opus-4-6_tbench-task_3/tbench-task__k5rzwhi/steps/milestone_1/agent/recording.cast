[552.1141, "o", "/* Simple JSON string value extractor. Returns malloc'd string or NULL. */\r\n\u001b[?2004l\r"]
[552.114167, "o", "\u001b[?2004h> "]
[552.114586, "o", "static char *json_get_string(const char *json, const char *key) {\r\n\u001b[?2004l\r"]
[552.114651, "o", "\u001b[?2004h> "]
[552.114773, "o", "    char search[256];\r\n\u001b[?2004l\r"]
[552.114837, "o", "\u001b[?2004h> "]
[552.115132, "o", "    snprintf(search, sizeof(search), \"\\\"%s\\\"\", key);\r\n\u001b[?2004l\r"]
[552.115165, "o", "\u001b[?2004h> "]
[552.115441, "o", "    const char *pos = strstr(json, search);\r\n\u001b[?2004l\r"]
[552.115469, "o", "\u001b[?2004h> "]
[552.115647, "o", "    if (!pos) return NULL;\r\n\u001b[?2004l\r"]
[552.115705, "o", "\u001b[?2004h> "]
[552.115848, "o", "    pos += strlen(search);\r\n\u001b[?2004l\r"]
[552.115892, "o", "\u001b[?2004h> "]
[552.116315, "o", "    while (*pos && (isspace((unsigned char)*pos) || *pos == ':')) pos++;\r\n\u001b[?2004l\r"]
[552.116434, "o", "\u001b[?2004h> "]
[552.116585, "o", "    if (*pos == '\\0') return NULL;\r\n\u001b[?2004l\r"]
[552.116616, "o", "\u001b[?2004h> "]
[552.117022, "o", "    if (*pos == 'n' && strncmp(pos, \"null\", 4) == 0) return NULL;\r\n\u001b[?2004l\r"]
[552.117052, "o", "\u001b[?2004h> "]
[552.117296, "o", "    if (*pos != '\"') return NULL;\r\n\u001b[?2004l\r"]
[552.117332, "o", "\u001b[?2004h> "]
[552.117438, "o", "    pos++;\r\n\u001b[?2004l\r"]
[552.117471, "o", "\u001b[?2004h> "]
[552.117553, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[552.117733, "o", "    size_t buf_size = 1024;\r\n\u001b[?2004l\r"]
[552.117805, "o", "\u001b[?2004h> "]
[552.117989, "o", "    char *buf = malloc(buf_size);\r\n\u001b[?2004l\r"]
[552.118066, "o", "\u001b[?2004h> "]
[552.118209, "o", "    size_t buf_len = 0;\r\n\u001b[?2004l\r"]
[552.118318, "o", "\u001b[?2004h>     \r\n"]
[552.118367, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[552.118558, "o", "    while (*pos && *pos != '\"') {\r\n\u001b[?2004l\r"]
[552.118656, "o", "\u001b[?2004h> "]
[552.118837, "o", "        if (buf_len + 8 >= buf_size) {\r\n\u001b[?2004l\r"]
[552.118926, "o", "\u001b[?2004h> "]
[552.119061, "o", "            buf_size *= 2;\r\n\u001b[?2004l\r"]
[552.119121, "o", "\u001b[?2004h> "]
[552.11936, "o", "            buf = realloc(buf, buf_size);\r\n\u001b[?2004l\r"]
[552.119392, "o", "\u001b[?2004h> "]
[552.11951, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[552.119713, "o", "        if (*pos == '\\\\') {\r\n\u001b[?2004l\r"]
[552.119745, "o", "\u001b[?2004h> "]
[552.119957, "o", "            pos++;\r\n\u001b[?2004l\r"]
[552.120041, "o", "\u001b[?2004h> "]
[552.120111, "o", "            switch (*pos) {\r\n\u001b[?2004l\r"]
[552.120193, "o", "\u001b[?2004h> "]
[552.12046, "o", "                case '\"': buf[buf_len++] = '\"'; break;\r\n\u001b[?2004l\r"]
[552.120557, "o", "\u001b[?2004h> "]
[552.120847, "o", "                case '\\\\': buf[buf_len++] = '\\\\'; break;\r\n\u001b[?2004l\r"]
[552.12093, "o", "\u001b[?2004h> "]
[552.121246, "o", "                case '/': buf[buf_len++] = '/'; break;\r\n\u001b[?2004l\r"]
[552.121332, "o", "\u001b[?2004h> "]
[552.121627, "o", "                case 'n': buf[buf_len++] = '\\n'; break;\r\n\u001b[?2004l\r"]
[552.121708, "o", "\u001b[?2004h> "]
[552.121996, "o", "                case 'r': buf[buf_len++] = '\\r'; break;\r\n\u001b[?2004l\r"]
[552.122106, "o", "\u001b[?2004h> "]
[552.122385, "o", "                case 't': buf[buf_len++] = '\\t'; break;\r\n\u001b[?2004l\r"]
[552.122409, "o", "\u001b[?2004h"]
[552.122427, "o", "> "]
[552.122779, "o", "                case 'b': buf[buf_len++] = '\\b'; break;\r\n\u001b[?2004l\r"]
[552.122886, "o", "\u001b[?2004h> "]
[552.12318, "o", "                case 'f': buf[buf_len++] = '\\f'; break;\r\n\u001b[?2004l\r"]
[552.12328, "o", "\u001b[?2004h> "]
[552.123379, "o", "                case 'u': {\r\n\u001b[?2004l\r"]
[552.123475, "o", "\u001b[?2004h> "]
[552.123829, "o", "                    if (pos[1] && pos[2] && pos[3] && pos[4]) {\r\n\u001b[?2004l\r"]
[552.123947, "o", "\u001b[?2004h> "]
[552.124178, "o", "                        unsigned int cp = 0;\r\n\u001b[?2004l\r"]
[552.124296, "o", "\u001b[?2004h> "]
[552.124542, "o", "                        sscanf(pos + 1, \"%4x\", &cp);\r\n\u001b[?2004l\r"]
[552.124637, "o", "\u001b[?2004h> "]
[552.124857, "o", "                        if (cp < 0x80) {\r\n\u001b[?2004l\r"]
[552.124951, "o", "\u001b[?2004h> "]
[552.125267, "o", "                            buf[buf_len++] = (char)cp;\r\n\u001b[?2004l\r"]
[552.125378, "o", "\u001b[?2004h> "]
[552.125619, "o", "                        } else if (cp < 0x800) {\r\n\u001b[?2004l\r"]
[552.125733, "o", "\u001b[?2004h> "]
[552.12608, "o", "                            buf[buf_len++] = (char)(0xC0 | (cp >> 6));\r\n\u001b[?2004l\r"]
[552.126111, "o", "\u001b[?2004h> "]
[552.126585, "o", "                            buf[buf_len++] = (char)(0x80 | (cp & 0x3F));\r\n\u001b[?2004l\r"]
[552.126614, "o", "\u001b[?2004h> "]
[552.126831, "o", "                        } else {\r\n\u001b[?2004l\r"]
[552.126862, "o", "\u001b[?2004h> "]
[552.127333, "o", "                            buf[buf_len++] = (char)(0xE0 | (cp >> 12));\r\n\u001b[?2004l\r"]
[552.127363, "o", "\u001b[?2004h> "]
[552.127818, "o", "                            buf[buf_len++] = (char)(0x80 | ((cp >> 6) & 0x3F));\r\n\u001b[?2004l\r"]
[552.127848, "o", "\u001b[?2004h> "]
[552.128287, "o", "                            buf[buf_len++] = (char)(0x80 | (cp & 0x3F));\r\n\u001b[?2004l\r"]
[552.128315, "o", "\u001b[?2004h> "]
[552.128503, "o", "                        }\r\n\u001b[?2004l\r"]
[552.128535, "o", "\u001b[?2004h> "]
[552.128763, "o", "                        pos += 4;\r\n\u001b[?2004l\r"]
[552.128792, "o", "\u001b[?2004h> "]
[552.128958, "o", "                    }\r\n\u001b[?2004l\r"]
[552.128988, "o", "\u001b[?2004h> "]
[552.129189, "o", "                    break;\r\n\u001b[?2004l\r"]
[552.129216, "o", "\u001b[?2004h> "]
[552.129352, "o", "                }\r\n\u001b[?2004l\r"]
[552.12938, "o", "\u001b[?2004h> "]
[552.129711, "o", "                default: buf[buf_len++] = *pos; break;\r\n\u001b[?2004l\r"]
[552.129738, "o", "\u001b[?2004h> "]
[552.129868, "o", "            }\r\n\u001b[?2004l\r"]
[552.129897, "o", "\u001b[?2004h> "]
[552.130057, "o", "        } else {\r\n\u001b[?2004l\r\u001b[?2004h"]
[552.130085, "o", "> "]
[552.130284, "o", "            buf[buf_len++] = *pos;\r\n\u001b[?2004l\r"]
[552.130308, "o", "\u001b[?2004h"]
[552.130329, "o", "> "]
[552.130413, "o", "        }\r\n\u001b[?2004l\r"]
[552.130441, "o", "\u001b[?2004h> "]
[552.13055, "o", "        pos++;\r\n\u001b[?2004l\r"]
[552.130574, "o", "\u001b[?2004h"]
[552.130592, "o", "> "]
[552.130672, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[552.13084, "o", "    buf[buf_len] = '\\0';\r\n\u001b[?2004l\r"]
[552.130912, "o", "\u001b[?2004h> "]
[552.130988, "o", "    return buf;\r\n\u001b[?2004l\r"]
