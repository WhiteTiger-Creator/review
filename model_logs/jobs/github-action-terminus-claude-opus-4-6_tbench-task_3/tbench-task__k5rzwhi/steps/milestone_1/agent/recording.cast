[195.598841, "o", "#ifndef NOTES_H\r\n#define NOTES_H\r\n\r\n#define NOTES_LISTEN_PORT 8080\r\n\r\n#endif\r\n\u001b[?2004hroot@1b06f1f3df22:/app# "]
[298.972444, "i", "cat > /app/src/db.h << 'EOF'\n#ifndef DB_H\n#define DB_H\n\nint init_db(const char *path);\nvoid close_db(void);\n\n/* Returns the new row id, or -1 on error */\nint create_note(const char *title, const char *content);\n\n/* Returns malloc'd JSON string for a single note, or NULL if not found */\nchar *get_note_json(int id);\n\n/* Returns malloc'd JSON array string for paginated notes */\nchar *get_notes_paginated_json(int limit, int offset);\n\n/* Returns total count of notes */\nint get_total_notes_count(void);\n\n/* Returns 1 if note exists, 0 otherwise */\nint note_exists(int id);\n\n/* Update note; returns 1 on success, 0 if not found, -1 on error */\nint update_note(int id, const char *title, const char *content);\n\n/* Delete note; returns 1 on success, 0 if not found */\nint delete_note(int id);\n\n#endif\nEOF\n"]
