[552.141219, "o", "\u001b[?2004h"]
[552.141286, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[552.141766, "o", "static enum MHD_Result handle_get_note(struct MHD_Connection *connection, int id) {\r\n\u001b[?2004l\r"]
[552.141805, "o", "\u001b[?2004h> "]
