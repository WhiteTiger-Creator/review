[552.143664, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r"]
[552.143721, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[552.143757, "o", "\u001b[?2004h> "]
[552.144314, "o", "static enum MHD_Result handle_post_note(struct MHD_Connection *connection, const char *body) {\r\n\u001b[?2004l\r"]
[552.14443, "o", "\u001b[?2004h> "]
[552.144598, "o", "    if (!body || strlen(body) == 0) {\r\n\u001b[?2004l\r"]
[552.144664, "o", "\u001b[?2004h> "]
[552.145186, "o", "        return send_json(connection, \"{\\\"error\\\":\\\"title is required\\\"}\", MHD_HTTP_BAD_REQUEST);\r\n\u001b[?2004l\r"]
[552.145299, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[552.145326, "o", "    \r\n\u001b[?2004l\r"]
[552.145347, "o", "\u001b[?2004h"]
[552.14537, "o", "> "]
[552.145685, "o", "    char *title = json_get_string(body, \"title\");\r\n\u001b[?2004l\r"]
[552.145712, "o", "\u001b[?2004h> "]
[552.145822, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[552.14602, "o", "    if (!title || strlen(title) == 0) {\r\n\u001b[?2004l\r"]
[552.146044, "o", "\u001b[?2004h"]
