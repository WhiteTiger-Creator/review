[299.576903, "o", "                case 'n': buf[buf_len++] = '\\n'; break;\r\n\u001b[?2004l\r"]
[299.576987, "o", "\u001b[?2004h> "]
[299.577303, "o", "                case 'r': buf[buf_len++] = '\\r'; break;\r\n\u001b[?2004l\r"]
[299.577407, "o", "\u001b[?2004h> "]
[299.577661, "o", "                case 't': buf[buf_len++] = '\\t'; break;\r\n\u001b[?2004l\r"]
[299.577761, "o", "\u001b[?2004h> "]
[299.578069, "o", "                case 'b': buf[buf_len++] = '\\b'; break;\r\n\u001b[?2004l\r"]
[299.578102, "o", "\u001b[?2004h> "]
[299.578461, "o", "                case 'f': buf[buf_len++] = '\\f'; break;\r\n\u001b[?2004l\r"]
[299.578496, "o", "\u001b[?2004h> "]
[299.578631, "o", "                case 'u': {\r\n\u001b[?2004l\r"]
[299.578784, "o", "\u001b[?2004h> "]
[299.57924, "o", "                    /* Basic \\uXXXX handling - just pass through as UTF-8 for ASCII range */\r\n\u001b[?2004l\r"]
[299.579348, "o", "\u001b[?2004h> "]
[299.579644, "o", "                    if (pos[1] && pos[2] && pos[3] && pos[4]) {\r\n\u001b[?2004l\r"]
[299.57975, "o", "\u001b[?2004h"]
[299.579789, "o", "> "]
[299.579976, "o", "                        unsigned int cp = 0;\r\n\u001b[?2004l\r"]
[299.58005, "o", "\u001b[?2004h> "]
[299.580313, "o", "                        sscanf(pos + 1, \"%4x\", &cp);\r\n\u001b[?2004l\r"]
[299.580347, "o", "\u001b[?2004h> "]
[299.580634, "o", "                        if (cp < 0x80) {\r\n\u001b[?2004l\r"]
[299.580727, "o", "\u001b[?2004h> "]
[299.581004, "o", "                            buf[buf_len++] = (char)cp;\r\n\u001b[?2004l\r"]
[299.581096, "o", "\u001b[?2004h> "]
[299.581343, "o", "                        } else if (cp < 0x800) {\r\n\u001b[?2004l\r"]
[299.581416, "o", "\u001b[?2004h> "]
[299.581787, "o", "                            buf[buf_len++] = (char)(0xC0 | (cp >> 6));\r\n\u001b[?2004l\r"]
[299.581861, "o", "\u001b[?2004h> "]
[299.582242, "o", "                            buf[buf_len++] = (char)(0x80 | (cp & 0x3F));\r\n\u001b[?2004l\r"]
[299.582375, "o", "\u001b[?2004h> "]
[299.582515, "o", "                        } else {\r\n\u001b[?2004l\r"]
[299.582611, "o", "\u001b[?2004h> "]
[299.582971, "o", "                            buf[buf_len++] = (char)(0xE0 | (cp >> 12));\r\n\u001b[?2004l\r"]
[299.583067, "o", "\u001b[?2004h> "]
[299.583517, "o", "                            buf[buf_len++] = (char)(0x80 | ((cp >> 6) & 0x3F));\r\n\u001b[?2004l\r"]
[299.583582, "o", "\u001b[?2004h> "]
[299.584002, "o", "                            buf[buf_len++] = (char)(0x80 | (cp & 0x3F));\r\n\u001b[?2004l\r"]
[299.584035, "o", "\u001b[?2004h> "]
[299.584191, "o", "                        }\r\n\u001b[?2004l\r"]
[299.584219, "o", "\u001b[?2004h> "]
[299.584441, "o", "                        pos += 4;\r\n\u001b[?2004l\r"]
[299.584468, "o", "\u001b[?2004h> "]
[299.584624, "o", "                    }\r\n\u001b[?2004l\r"]
[299.584651, "o", "\u001b[?2004h> "]
[299.584836, "o", "                    break;\r\n\u001b[?2004l\r"]
[299.584868, "o", "\u001b[?2004h"]
[299.584961, "o", "> "]
[299.585045, "o", "                }\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.585075, "o", "> "]
[299.585401, "o", "                default: buf[buf_len++] = *pos; break;\r\n\u001b[?2004l\r"]
[299.585426, "o", "\u001b[?2004h"]
[299.585477, "o", "> "]
[299.585563, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.5856, "o", "> "]
[299.585736, "o", "        } else {\r\n\u001b[?2004l\r"]
[299.585845, "o", "\u001b[?2004h> "]
[299.585974, "o", "            buf[buf_len++] = *pos;\r\n\u001b[?2004l\r"]
[299.586002, "o", "\u001b[?2004h> "]
[299.586115, "o", "        }\r\n\u001b[?2004l\r"]
[299.586184, "o", "\u001b[?2004h> "]
[299.586268, "o", "        pos++;\r\n\u001b[?2004l\r"]
[299.586389, "o", "\u001b[?2004h> "]
[299.586418, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.586553, "o", "    buf[buf_len] = '\\0';\r\n\u001b[?2004l\r"]
[299.586664, "o", "\u001b[?2004h> "]
[299.586771, "o", "    return buf;\r\n\u001b[?2004l\r"]
[299.586828, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r}"]
[299.586917, "o", "\u001b[?2004h> "]
[299.587298, "o", "/* Check if a key exists in JSON (even if value is empty string) */\r\n\u001b[?2004l\r"]
[299.587342, "o", "\u001b[?2004h> "]
[299.587703, "o", "static int json_has_key(const char *json, const char *key) {\r\n\u001b[?2004l\r"]
[299.587814, "o", "\u001b[?2004h> "]
[299.587955, "o", "    char search[256];\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.588261, "o", "    snprintf(search, sizeof(search), \"\\\"%s\\\"\", key);\r\n\u001b[?2004l\r"]
[299.588448, "o", "\u001b[?2004h> "]
[299.588587, "o", "    return strstr(json, search) != NULL;\r\n\u001b[?2004l\r"]
[299.588714, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[299.588826, "o", "\u001b[?2004h> "]
[299.589064, "o", "/* Extract note ID from URL like /api/notes/123 */\r\n\u001b[?2004l\r"]
[299.589155, "o", "\u001b[?2004h> "]
[299.589399, "o", "static int extract_note_id(const char *url) {\r\n\u001b[?2004l\r"]
[299.589508, "o", "\u001b[?2004h> "]
[299.589712, "o", "    const char *prefix = \"/api/notes/\";\r\n\u001b[?2004l\r"]
[299.58974, "o", "\u001b[?2004h> "]
[299.590132, "o", "    if (strncmp(url, prefix, strlen(prefix)) != 0) return -1;\r\n\u001b[?2004l\r"]
[299.590158, "o", "\u001b[?2004h> "]
[299.59045, "o", "    const char *id_str = url + strlen(prefix);\r\n\u001b[?2004l\r"]
[299.590604, "o", "\u001b[?2004h> "]
[299.590715, "o", "    if (*id_str == '\\0') return -1;\r\n\u001b[?2004l\r"]
[299.590787, "o", "\u001b[?2004h> "]
[299.590947, "o", "    /* Check it's all digits */\r\n\u001b[?2004l\r"]
[299.590975, "o", "\u001b[?2004h> "]
[299.591266, "o", "    for (const char *p = id_str; *p; p++) {\r\n\u001b[?2004l\r"]
[299.591292, "o", "\u001b[?2004h> "]
[299.591607, "o", "        if (!isdigit((unsigned char)*p)) return -1;\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.591646, "o", "> "]
[299.591678, "o", "    }\r\n\u001b[?2004l\r"]
[299.591763, "o", "\u001b[?2004h> "]
[299.592024, "o", "    return atoi(id_str);\r\n\u001b[?2004l\r"]
[299.592117, "o", "\u001b[?2004h> }"]
[299.592235, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[299.592286, "o", "> "]
[299.592671, "o", "static enum MHD_Result handle_get_notes(struct MHD_Connection *connection) {\r\n\u001b[?2004l\r"]
[299.592709, "o", "\u001b[?2004h> "]
[299.59302, "o", "    /* Parse limit and offset from query params */\r\n\u001b[?2004l\r"]
[299.593046, "o", "\u001b[?2004h> "]
[299.593198, "o", "    int limit = 50;\r\n\u001b[?2004l\r"]
[299.593227, "o", "\u001b[?2004h> "]
[299.593373, "o", "    int offset = 0;\r\n\u001b[?2004l\r"]
[299.593401, "o", "\u001b[?2004h> "]
[299.593494, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.594122, "o", "    const char *limit_str = MHD_lookup_connection_value(connection, MHD_GET_ARGUMENT_KIND, \"limit\");\r\n\u001b[?2004l\r"]
[299.59415, "o", "\u001b[?2004h> "]
[299.59473, "o", "    const char *offset_str = MHD_lookup_connection_value(connection, MHD_GET_ARGUMENT_KIND, \"offset\");\r\n\u001b[?2004l\r"]
[299.594763, "o", "\u001b[?2004h"]
[299.594799, "o", "> "]
[299.594855, "o", "    \r\n\u001b[?2004l\r"]
[299.594893, "o", "\u001b[?2004h> "]
[299.59511, "o", "    if (limit_str) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.595271, "o", "        limit = atoi(limit_str);\r\n\u001b[?2004l\r"]
[299.59542, "o", "\u001b[?2004h> "]
[299.595556, "o", "        if (limit <= 0) limit = 50;\r\n\u001b[?2004l\r"]
[299.595728, "o", "\u001b[?2004h> "]
[299.595845, "o", "        if (limit > 100) limit = 100;\r\n\u001b[?2004l\r"]
[299.595889, "o", "\u001b[?2004h"]
[299.595911, "o", "> "]
[299.595932, "o", "    }\r\n\u001b[?2004l\r"]
[299.596033, "o", "\u001b[?2004h> "]
[299.596136, "o", "    if (offset_str) {\r\n\u001b[?2004l\r"]
[299.596188, "o", "\u001b[?2004h> "]
[299.596409, "o", "        offset = atoi(offset_str);\r\n\u001b[?2004l\r"]
[299.596497, "o", "\u001b[?2004h> "]
[299.596721, "o", "        if (offset < 0) offset = 0;\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.596867, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n"]
[299.596966, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[299.597206, "o", "    int total = get_total_notes_count();\r\n\u001b[?2004l\r"]
[299.597234, "o", "\u001b[?2004h> "]
[299.597586, "o", "    char *json = get_notes_paginated_json(limit, offset);\r\n\u001b[?2004l\r"]
[299.597613, "o", "\u001b[?2004h> "]
[299.59784, "o", "    if (!json) json = strdup(\"[]\");\r\n\u001b[?2004l\r"]
[299.597869, "o", "\u001b[?2004h> "]
[299.597945, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[299.597969, "o", "> "]
[299.598134, "o", "    char total_str[32];\r\n\u001b[?2004l\r"]
[299.598164, "o", "\u001b[?2004h> "]
[299.5985, "o", "    snprintf(total_str, sizeof(total_str), \"%d\", total);\r\n\u001b[?2004l\r"]
[299.598599, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h"]
[299.598681, "o", "> "]
[299.599038, "o", "    enum MHD_Result r = send_response(connection, json, MHD_HTTP_OK, total_str);\r\n\u001b[?2004l\r"]
[299.599104, "o", "\u001b[?2004h> "]
[299.599163, "o", "    free(json);\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.599194, "o", "> "]
[299.599266, "o", "    return r;\r\n\u001b[?2004l\r"]
[299.599295, "o", "\u001b[?2004h> }\r\n"]
[299.59932, "o", "\u001b[?2004l\r"]
[299.599346, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[299.599444, "o", "\u001b[?2004h> "]
[299.599757, "o", "static enum MHD_Result handle_get_note(struct MHD_Connection *connection, int id) {\r\n\u001b[?2004l\r"]
[299.599784, "o", "\u001b[?2004h> "]
[299.599978, "o", "    char *json = get_note_json(id);\r\n\u001b[?2004l\r"]
[299.600096, "o", "\u001b[?2004h>     if (!json) {\r\n\u001b[?2004l\r"]
[299.600151, "o", "\u001b[?2004h> "]
[299.600583, "o", "        return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\r\n\u001b[?2004l\r"]
[299.600618, "o", "\u001b[?2004h> "]
[299.600677, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.600699, "o", "> "]
[299.60106, "o", "    enum MHD_Result r = send_json(connection, json, MHD_HTTP_OK);\r\n\u001b[?2004l\r"]
[299.601152, "o", "\u001b[?2004h> "]
[299.601212, "o", "    free(json);\r\n\u001b[?2004l\r"]
[299.601235, "o", "\u001b[?2004h"]
[299.601253, "o", "> "]
[299.601367, "o", "    return r;\r\n\u001b[?2004l\r"]
[299.60139, "o", "\u001b[?2004h"]
[299.601409, "o", "> "]
[299.601431, "o", "}\r\n\u001b[?2004l\r"]
[299.60152, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[299.601545, "o", "> "]
[299.602063, "o", "static enum MHD_Result handle_post_note(struct MHD_Connection *connection, const char *body) {\r\n\u001b[?2004l\r"]
[299.602149, "o", "\u001b[?2004h> "]
[299.60234, "o", "    if (!body || strlen(body) == 0) {\r\n\u001b[?2004l\r"]
[299.602476, "o", "\u001b[?2004h"]
[299.602598, "o", "> "]
[299.602935, "o", "        return send_json(connection, \"{\\\"error\\\":\\\"title is required\\\"}\", MHD_HTTP_BAD_REQUEST);\r\n\u001b[?2004l\r"]
[299.602964, "o", "\u001b[?2004h"]
[299.602985, "o", "> "]
[299.603082, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[299.603108, "o", "\u001b[?2004h> "]
[299.603455, "o", "    char *title = json_get_string(body, \"title\");\r\n\u001b[?2004l\r"]
[299.603488, "o", "\u001b[?2004h> "]
[299.603554, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.603847, "o", "    /* Title must be present and non-empty */\r\n\u001b[?2004l\r"]
[299.603947, "o", "\u001b[?2004h> "]
[299.604184, "o", "    if (!title || strlen(title) == 0) {\r\n\u001b[?2004l\r"]
[299.604264, "o", "\u001b[?2004h> "]
[299.60444, "o", "        if (title) free(title);\r\n\u001b[?2004l\r"]
[299.60457, "o", "\u001b[?2004h> "]
[299.60504, "o", "        return send_json(connection, \"{\\\"error\\\":\\\"title is required\\\"}\", MHD_HTTP_BAD_REQUEST);\r\n\u001b[?2004l\r"]
[299.605197, "o", "\u001b[?2004h> "]
[299.60531, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.605555, "o", "    /* Check if title is only whitespace */\r\n\u001b[?2004l\r"]
[299.605622, "o", "\u001b[?2004h> "]
[299.605764, "o", "    int all_space = 1;\r\n\u001b[?2004l\r"]
[299.605793, "o", "\u001b[?2004h> "]
[299.606085, "o", "    for (size_t i = 0; i < strlen(title); i++) {\r\n\u001b[?2004l\r"]
[299.606121, "o", "\u001b[?2004h> "]
[299.606519, "o", "        if (!isspace((unsigned char)title[i])) { all_space = 0; break; }\r\n\u001b[?2004l\r"]
[299.606562, "o", "\u001b[?2004h> "]
[299.606589, "o", "    }\r\n\u001b[?2004l\r"]
[299.606783, "o", "\u001b[?2004h>     if (all_space) {\r\n\u001b[?2004l\r"]
[299.606916, "o", "\u001b[?2004h> "]
[299.607057, "o", "        free(title);\r\n\u001b[?2004l\r"]
[299.607157, "o", "\u001b[?2004h> "]
[299.607558, "o", "        return send_json(connection, \"{\\\"error\\\":\\\"title is required\\\"}\", MHD_HTTP_BAD_REQUEST);\r\n\u001b[?2004l\r"]
[299.607633, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[299.60766, "o", "\u001b[?2004h> "]
[299.607684, "o", "    \r\n\u001b[?2004l\r"]
[299.607708, "o", "\u001b[?2004h"]
[299.60773, "o", "> "]
[299.608004, "o", "    char *content = json_get_string(body, \"content\");\r\n\u001b[?2004l\r"]
[299.608033, "o", "\u001b[?2004h> "]
[299.608248, "o", "    if (!content) content = strdup(\"\");\r\n\u001b[?2004l\r"]
[299.608433, "o", "\u001b[?2004h> "]
[299.608514, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.608631, "o", "    int id = create_note(title, content);\r\n\u001b[?2004l\r"]
[299.60867, "o", "\u001b[?2004h> "]
[299.608816, "o", "    if (id < 0) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.608914, "o", "> "]
[299.608988, "o", "        free(title);\r\n\u001b[?2004l\r"]
[299.609064, "o", "\u001b[?2004h"]
[299.609096, "o", "> "]
[299.609218, "o", "        free(content);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.609706, "o", "        return send_json(connection, \"{\\\"error\\\":\\\"internal error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR);\r\n\u001b[?2004l\r"]
[299.609785, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.609852, "o", ">     \r\n\u001b[?2004l\r"]
[299.609916, "o", "\u001b[?2004h> "]
[299.610115, "o", "    /* Return the created note */\r\n\u001b[?2004l\r"]
[299.610144, "o", "\u001b[?2004h"]
[299.610199, "o", "> "]
[299.610421, "o", "    char *note_json = get_note_json(id);\r\n\u001b[?2004l\r"]
[299.610481, "o", "\u001b[?2004h> "]
[299.610598, "o", "    if (!note_json) {\r\n\u001b[?2004l\r"]
[299.610625, "o", "\u001b[?2004h"]
[299.610644, "o", "> "]
[299.610788, "o", "        free(title);\r\n\u001b[?2004l\r"]
[299.610874, "o", "\u001b[?2004h> "]
[299.610986, "o", "        free(content);\r\n\u001b[?2004l\r"]
[299.611013, "o", "\u001b[?2004h> "]
[299.611597, "o", "        return send_json(connection, \"{\\\"error\\\":\\\"internal error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR);\r\n\u001b[?2004l\r"]
[299.611748, "o", "\u001b[?2004h> "]
[299.611861, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.612277, "o", "    enum MHD_Result r = send_json(connection, note_json, MHD_HTTP_CREATED);\r\n\u001b[?2004l\r"]
[299.612379, "o", "\u001b[?2004h"]
[299.612504, "o", ">     free(note_json);\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.612605, "o", "> "]
[299.612638, "o", "    free(title);\r\n\u001b[?2004l\r"]
[299.612659, "o", "\u001b[?2004h"]
[299.612683, "o", "> "]
[299.612847, "o", "    free(content);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.612942, "o", "    return r;\r\n\u001b[?2004l\r"]
[299.612964, "o", "\u001b[?2004h"]
[299.612986, "o", "> }"]
[299.613003, "o", "\r\n\u001b[?2004l\r"]
[299.613019, "o", "\u001b[?2004h"]
[299.613171, "o", "> \r\n\u001b[?2004l\rx\u001b[?2004h> "]
[299.613676, "o", "static enum MHD_Result handle_put_note(struct MHD_Connection *connection, int id, const char *body) {\r\n\u001b[?2004l\r"]
[299.613807, "o", "\u001b[?2004h> "]
[299.613984, "o", "    if (!body || strlen(body) == 0) {\r\n\u001b[?2004l\r"]
[299.61407, "o", "\u001b[?2004h> "]
[299.614577, "o", "        return send_json(connection, \"{\\\"error\\\":\\\"title is required\\\"}\", MHD_HTTP_BAD_REQUEST);\r\n\u001b[?2004l\r"]
[299.614717, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.614863, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.615117, "o", "    char *title = json_get_string(body, \"title\");\r\n\u001b[?2004l\r"]
[299.615264, "o", "\u001b[?2004h>     "]
[299.615376, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.615552, "o", "    /* Title must be present and non-empty */\r\n\u001b[?2004l\r"]
[299.615725, "o", "\u001b[?2004h> "]
[299.615888, "o", "    if (!title || strlen(title) == 0) {\r\n\u001b[?2004l\r"]
[299.616034, "o", "\u001b[?2004h> "]
[299.616187, "o", "        if (title) free(title);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.616726, "o", "        return send_json(connection, \"{\\\"error\\\":\\\"title is required\\\"}\", MHD_HTTP_BAD_REQUEST);\r\n\u001b[?2004l\r"]
[299.616756, "o", "\u001b[?2004h> "]
[299.616838, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.616861, "o", "> "]
[299.616929, "o", "    \r\n\u001b[?2004l\r"]
[299.616956, "o", "\u001b[?2004h> "]
[299.617232, "o", "    /* Check if title is only whitespace */\r\n\u001b[?2004l\r"]
[299.61726, "o", "\u001b[?2004h> "]
[299.617427, "o", "    int all_space = 1;\r\n\u001b[?2004l\r"]
[299.617457, "o", "\u001b[?2004h> "]
[299.617752, "o", "    for (size_t i = 0; i < strlen(title); i++) {\r\n\u001b[?2004l\r"]
[299.617782, "o", "\u001b[?2004h> "]
[299.618211, "o", "        if (!isspace((unsigned char)title[i])) { all_space = 0; break; }\r\n\u001b[?2004l\r"]
[299.618239, "o", "\u001b[?2004h> "]
[299.618319, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.618342, "o", "> "]
[299.618491, "o", "    if (all_space) {\r\n\u001b[?2004l\r"]
[299.61852, "o", "\u001b[?2004h> "]
[299.618676, "o", "        free(title);\r\n\u001b[?2004l\r"]
[299.618706, "o", "\u001b[?2004h> "]
[299.619266, "o", "        return send_json(connection, \"{\\\"error\\\":\\\"title is required\\\"}\", MHD_HTTP_BAD_REQUEST);\r\n\u001b[?2004l\r"]
[299.619295, "o", "\u001b[?2004h> "]
[299.61938, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.619404, "o", "> "]
[299.619431, "o", "    \r\n\u001b[?2004l\r"]
[299.619608, "o", "\u001b[?2004h> "]
[299.619806, "o", "    char *content = json_get_string(body, \"content\");\r\n\u001b[?2004l\r"]
[299.619832, "o", "\u001b[?2004h> "]
[299.620094, "o", "    if (!content) content = strdup(\"\");\r\n\u001b[?2004l\r"]
[299.620125, "o", "\u001b[?2004h> "]
[299.620196, "o", "    \r\n\u001b[?2004l\r"]
[299.620223, "o", "\u001b[?2004h> "]
[299.620527, "o", "    int result = update_note(id, title, content);\r\n\u001b[?2004l\r"]
[299.620555, "o", "\u001b[?2004h> "]
[299.620671, "o", "    free(title);\r\n\u001b[?2004l\r"]
[299.620702, "o", "\u001b[?2004h"]
[299.620727, "o", "> "]
[299.620816, "o", "    free(content);\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.620841, "o", "> "]
[299.620866, "o", "    \r\n\u001b[?2004l\r"]
[299.620954, "o", "\u001b[?2004h> "]
[299.621013, "o", "    if (result == 0) {\r\n\u001b[?2004l\r"]
[299.62104, "o", "\u001b[?2004h"]
[299.621064, "o", "> "]
[299.621344, "o", "        return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\r\n\u001b[?2004l\r"]
[299.621375, "o", "\u001b[?2004h> "]
[299.62145, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.621565, "o", "> "]
[299.621603, "o", "    if (result < 0) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.621922, "o", "        return send_json(connection, \"{\\\"error\\\":\\\"internal error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR);\r\n\u001b[?2004l\r"]
[299.621953, "o", "\u001b[?2004h> "]
[299.622031, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.622055, "o", ">     \r\n"]
[299.622079, "o", "\u001b[?2004l\r"]
[299.622184, "o", "\u001b[?2004h> "]
[299.622292, "o", "    char *note_json = get_note_json(id);\r\n\u001b[?2004l\r"]
[299.622322, "o", "\u001b[?2004h> "]
[299.622427, "o", "    if (!note_json) {\r\n\u001b[?2004l\r"]
[299.622459, "o", "\u001b[?2004h"]
[299.62248, "o", "> "]
[299.622798, "o", "        return send_json(connection, \"{\\\"error\\\":\\\"internal error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR);\r\n\u001b[?2004l\r"]
[299.622889, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.622922, "o", "> "]
[299.623147, "o", "    enum MHD_Result r = send_json(connection, note_json, MHD_HTTP_OK);\r\n\u001b[?2004l\r"]
[299.623178, "o", "\u001b[?2004h> "]
[299.62328, "o", "    free(note_json);\r\n\u001b[?2004l\r"]
[299.623312, "o", "\u001b[?2004h"]
[299.623337, "o", "> "]
[299.623422, "o", "    return r;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.623449, "o", "}\r\n\u001b[?2004l\r"]
[299.623468, "o", "\u001b[?2004h"]
[299.623496, "o", "> \r\n\u001b[?2004l\r"]
[299.623602, "o", "\u001b[?2004h> "]
[299.623825, "o", "static enum MHD_Result handle_delete_note(struct MHD_Connection *connection, int id) {\r\n\u001b[?2004l\r"]
[299.623912, "o", "\u001b[?2004h> "]
[299.62402, "o", "    int result = delete_note(id);\r\n\u001b[?2004l\r"]
[299.624138, "o", "\u001b[?2004h>     if (result == 0) {\r\n\u001b[?2004l\r"]
[299.624219, "o", "\u001b[?2004h> "]
[299.624454, "o", "        return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\r\n\u001b[?2004l\r"]
[299.624529, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[299.624572, "o", "\u001b[?2004h> "]
[299.624809, "o", "    return send_json(connection, \"{\\\"status\\\":\\\"deleted\\\"}\", MHD_HTTP_OK);\r\n\u001b[?2004l\r"]
[299.624844, "o", "\u001b[?2004h> }\r\n"]
[299.624871, "o", "\u001b[?2004l\r"]
[299.6249, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[299.625027, "o", "\u001b[?2004h> "]
[299.625238, "o", "enum MHD_Result route_request(struct MHD_Connection *connection, const char *url,\r\n\u001b[?2004l\r"]
[299.625269, "o", "\u001b[?2004h> "]
[299.625519, "o", "                              const char *method, const char *upload_data,\r\n\u001b[?2004l\r"]
[299.62555, "o", "\u001b[?2004h> "]
[299.625811, "o", "                              size_t *upload_data_size, void **con_cls) {\r\n\u001b[?2004l\r"]
[299.625846, "o", "\u001b[?2004h> "]
[299.625872, "o", "    \r\n\u001b[?2004l\r"]
[299.625897, "o", "\u001b[?2004h"]
[299.625923, "o", "> "]
[299.626049, "o", "    /* OPTIONS preflight */\r\n\u001b[?2004l\r"]
[299.626081, "o", "\u001b[?2004h> "]
[299.626234, "o", "    if (strcmp(method, \"OPTIONS\") == 0) {\r\n\u001b[?2004l\r"]
[299.626265, "o", "\u001b[?2004h"]
[299.626289, "o", "> "]
[299.626431, "o", "        return send_options(connection);\r\n\u001b[?2004l\r"]
[299.626462, "o", "\u001b[?2004h> "]
[299.626537, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.626566, "o", ">     \r\n"]
[299.626587, "o", "\u001b[?2004l\r"]
[299.626613, "o", "\u001b[?2004h"]
[299.626637, "o", "> "]
[299.626851, "o", "    /* For POST/PUT/DELETE, we need to accumulate body data */\r\n\u001b[?2004l\r"]
[299.626887, "o", "\u001b[?2004h> "]
[299.627208, "o", "    if (strcmp(method, \"POST\") == 0 || strcmp(method, \"PUT\") == 0 || strcmp(method, \"DELETE\") == 0) {\r\n\u001b[?2004l\r"]
[299.627236, "o", "\u001b[?2004h> "]
[299.627369, "o", "        if (*con_cls == NULL) {\r\n\u001b[?2004l\r"]
[299.627398, "o", "\u001b[?2004h"]
[299.627421, "o", "> "]
[299.627607, "o", "            /* First call - allocate connection info */\r\n\u001b[?2004l\r"]
[299.627638, "o", "\u001b[?2004h> "]
[299.627927, "o", "            struct connection_info *ci = calloc(1, sizeof(struct connection_info));\r\n\u001b[?2004l\r"]
[299.627962, "o", "\u001b[?2004h> "]
[299.628082, "o", "            ci->data = NULL;\r\n\u001b[?2004l\r"]
[299.628113, "o", "\u001b[?2004h> "]
[299.62824, "o", "            ci->data_size = 0;\r\n\u001b[?2004l\r"]
[299.628305, "o", "\u001b[?2004h> "]
[299.628402, "o", "            *con_cls = ci;\r\n\u001b[?2004l\r"]
[299.62843, "o", "\u001b[?2004h"]
[299.628454, "o", "> "]
[299.628563, "o", "            return MHD_YES;\r\n\u001b[?2004l\r"]
[299.628591, "o", "\u001b[?2004h> "]
[299.628667, "o", "        }\r\n\u001b[?2004l\r"]
[299.628695, "o", "\u001b[?2004h> "]
[299.628768, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h"]
[299.628796, "o", "> "]
[299.628952, "o", "        struct connection_info *ci = *con_cls;\r\n\u001b[?2004l\r"]
[299.628983, "o", "\u001b[?2004h> "]
[299.629056, "o", "        \r\n\u001b[?2004l\r"]
[299.629084, "o", "\u001b[?2004h> "]
[299.629226, "o", "        if (*upload_data_size > 0) {\r\n\u001b[?2004l\r"]
[299.629334, "o", "\u001b[?2004h> "]
[299.629418, "o", "            /* Check body size limit */\r\n\u001b[?2004l\r"]
[299.629445, "o", "\u001b[?2004h"]
[299.629469, "o", "> "]
[299.62969, "o", "            if (ci->data_size + *upload_data_size > MAX_BODY_SIZE) {\r\n\u001b[?2004l\r"]
[299.629719, "o", "\u001b[?2004h"]
[299.629742, "o", "> "]
[299.629879, "o", "                *upload_data_size = 0;\r\n\u001b[?2004l\r"]
[299.629908, "o", "\u001b[?2004h"]
[299.629929, "o", "> "]
[299.630211, "o", "                return send_json(connection, \"{\\\"error\\\":\\\"body too large\\\"}\", 413);\r\n\u001b[?2004l\r"]
[299.630338, "o", "\u001b[?2004h>             }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.630452, "o", "            /* Accumulate data */\r\n\u001b[?2004l\r"]
[299.630569, "o", "\u001b[?2004h> "]
[299.630754, "o", "            ci->data = realloc(ci->data, ci->data_size + *upload_data_size + 1);\r\n\u001b[?2004l\r"]
[299.630864, "o", "\u001b[?2004h> "]
[299.631044, "o", "            memcpy(ci->data + ci->data_size, upload_data, *upload_data_size);\r\n\u001b[?2004l\r"]
[299.631173, "o", "\u001b[?2004h> "]
[299.63126, "o", "            ci->data_size += *upload_data_size;\r\n\u001b[?2004l\r"]
[299.631302, "o", "\u001b[?2004h> "]
[299.631458, "o", "            ci->data[ci->data_size] = '\\0';\r\n\u001b[?2004l\r"]
[299.631561, "o", "\u001b[?2004h> "]
[299.631655, "o", "            *upload_data_size = 0;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.631763, "o", "            return MHD_YES;\r\n\u001b[?2004l\r"]
[299.63185, "o", "\u001b[?2004h> "]
[299.631948, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r"]
[299.63205, "o", "\u001b[?2004h> "]
[299.632174, "o", "        /* All data received - process the request */\r\n\u001b[?2004l\r"]
[299.632296, "o", "\u001b[?2004h> "]
[299.632374, "o", "        /* Check auth for mutating requests */\r\n\u001b[?2004l\r"]
[299.632407, "o", "\u001b[?2004h"]
[299.632433, "o", "> "]
[299.632582, "o", "        if (!api_key_valid(connection)) {\r\n\u001b[?2004l\r"]
[299.63261, "o", "\u001b[?2004h> "]
[299.632922, "o", "            return send_json(connection, \"{\\\"error\\\":\\\"unauthorized\\\"}\", MHD_HTTP_UNAUTHORIZED);\r\n\u001b[?2004l\r"]
[299.632951, "o", "\u001b[?2004h"]
[299.632975, "o", "> "]
[299.633066, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.633095, "o", "        \r\n\u001b[?2004l\r"]
[299.633126, "o", "\u001b[?2004h"]
[299.633153, "o", "> "]
[299.633276, "o", "        /* Check body size */\r\n\u001b[?2004l\r"]
[299.633382, "o", "\u001b[?2004h> "]
[299.633555, "o", "        if (ci->data_size > MAX_BODY_SIZE) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.633782, "o", "            return send_json(connection, \"{\\\"error\\\":\\\"body too large\\\"}\", 413);\r\n\u001b[?2004l\r"]
[299.633812, "o", "\u001b[?2004h> "]
[299.633935, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.634019, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.634137, "o", "        /* Route to appropriate handler */\r\n\u001b[?2004l\r"]
[299.634169, "o", "\u001b[?2004h> "]
[299.634424, "o", "        if (strcmp(url, \"/api/notes\") == 0 && strcmp(method, \"POST\") == 0) {\r\n\u001b[?2004l\r"]
[299.634456, "o", "\u001b[?2004h> "]
[299.635924, "o", "            return handle_post_note(connection, ci->data);\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h>         /* Extract ID for /api/notes/{id} routes */\r\n\u001b[?2004l\r\u001b[?2004h>         int id = extract_note_id(url);\r\n\u001b[?2004l\r\u001b[?2004h>         if (id < 0) {\r\n\u001b[?2004l\r\u001b[?2004h>             return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n"]
[299.63596, "o", "\u001b[?2004l\r\u001b[?2004h"]
[299.635982, "o", "> "]
[299.636004, "o", "        \r\n"]
[299.636041, "o", "\u001b[?2004l\r"]
[299.636073, "o", "\u001b[?2004h> "]
[299.636228, "o", "        if (strcmp(method, \"PUT\") == 0) {\r\n\u001b[?2004l\r"]
[299.636251, "o", "\u001b[?2004h"]
[299.636293, "o", "> "]
[299.636847, "o", "            return handle_put_note(connection, id, ci->data);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.63693, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h>         if (strcmp(method, \"DELETE\") == 0) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.637127, "o", "            return handle_delete_note(connection, id);\r\n\u001b[?2004l\r"]
[299.637395, "o", "\u001b[?2004h"]
[299.63743, "o", ">         }\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.637737, "o", "        return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\r\n\u001b[?2004l\r"]
[299.637787, "o", "\u001b[?2004h> "]
[299.637837, "o", "    }\r\n\u001b[?2004l\r"]
[299.63788, "o", "\u001b[?2004h> "]
[299.637909, "o", "    \r\n\u001b[?2004l\r"]
[299.63796, "o", "\u001b[?2004h> "]
[299.638063, "o", "    /* GET requests */\r\n\u001b[?2004l\r"]
[299.638099, "o", "\u001b[?2004h"]
[299.63814, "o", "> "]
[299.638281, "o", "    if (strcmp(method, \"GET\") == 0) {\r\n\u001b[?2004l\r"]
[299.638328, "o", "\u001b[?2004h> "]
[299.638531, "o", "        if (strcmp(url, \"/api/notes\") == 0) {\r\n\u001b[?2004l\r"]
[299.638577, "o", "\u001b[?2004h> "]
[299.638793, "o", "            return handle_get_notes(connection);\r\n\u001b[?2004l\r"]
[299.638841, "o", "\u001b[?2004h> "]
[299.638907, "o", "        }\r\n\u001b[?2004l\r"]
[299.638929, "o", "\u001b[?2004h"]
[299.638968, "o", "> "]
[299.639012, "o", "        \r\n\u001b[?2004l\r"]
[299.639047, "o", "\u001b[?2004h> "]
[299.639217, "o", "        int id = extract_note_id(url);\r\n\u001b[?2004l\r"]
[299.639264, "o", "\u001b[?2004h"]
[299.639297, "o", "> "]
[299.639369, "o", "        if (id >= 0) {\r\n\u001b[?2004l\r"]
[299.639415, "o", "\u001b[?2004h"]
[299.639445, "o", "> "]
[299.639643, "o", "            return handle_get_note(connection, id);\r\n\u001b[?2004l\r"]
[299.639692, "o", "\u001b[?2004h> "]
[299.639743, "o", "        }\r\n\u001b[?2004l\r"]
[299.639789, "o", "\u001b[?2004h"]
[299.639822, "o", "> "]
[299.63988, "o", "        \r\n\u001b[?2004l\r"]
[299.639927, "o", "\u001b[?2004h> "]
[299.640247, "o", "        return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\r\n\u001b[?2004l\r"]
[299.640296, "o", "\u001b[?2004h> "]
