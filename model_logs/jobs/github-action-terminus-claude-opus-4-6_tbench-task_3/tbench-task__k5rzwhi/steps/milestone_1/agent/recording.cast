[552.1374, "o", "\u001b[?2004h> "]
[552.137606, "o", "        if (limit > 100) limit = 100;\r\n\u001b[?2004l\r"]
[552.137703, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[552.137794, "o", "\u001b[?2004h> "]
