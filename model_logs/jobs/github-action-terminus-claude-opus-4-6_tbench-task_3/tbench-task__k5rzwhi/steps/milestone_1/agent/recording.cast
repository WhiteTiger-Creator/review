[552.110739, "o", "\u001b[?2004h"]
[552.110757, "o", "> "]
[552.111419, "o", "    MHD_add_response_header(response, \"Access-Control-Allow-Methods\", \"GET, POST, PUT, DELETE, OPTIONS\");\r\n\u001b[?2004l\r"]
