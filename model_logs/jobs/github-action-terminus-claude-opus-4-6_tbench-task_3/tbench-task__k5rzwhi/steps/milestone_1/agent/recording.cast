[195.354979, "o", "CC = gcc\r\nCFLAGS = -Wall -Wextra -Isrc -Iinclude\r\nLDFLAGS = -lmicrohttpd -lsqlite3\r\n\r\nSOURCES = src/main.c src/routes.c src/db.c\r\nTARGET = notes_server\r\n\r\n$(TARGET): $(SOURCES)\r\n\t$(CC) $(CFLAGS) -o $(TARGET) $(SOURCES) $(LDFLAGS)\r\n\r\nclean:\r\n\trm -f $(TARGET)\r\n"]
