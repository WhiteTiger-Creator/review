[721.53816, "o", "\u001b[?2004hroot@1b06f1f3df22:/app# "]
[740.417859, "i", "cat > /app/www/app.js << 'EOF'\nvar API = '/api/notes';\nvar API_KEY = 'tb3_notes_api_secret_2026';\nvar editingId = null;\n\nfunction fetchNotes() {\n  fetch(API).then(function(res) {\n    return res.json();\n  }).then(function(notes) {\n    var list = document.getElementById('notes-list');\n    list.innerHTML = '';\n    notes.forEach(function(note) {\n      var div = document.createElement('div');\n      div.className = 'note-card';\n      div.setAttribute('data-id', note.id);\n\n      var title = document.createElement('h3');\n      title.textContent = note.title;\n      div.appendChild(title);\n\n      var content = document.createElement('p');\n      content.textContent = note.content;\n      div.appendChild(content);\n\n      var editBtn = document.createElement('button');\n      editBtn.className = 'edit-btn';\n      editBtn.textContent = 'Edit';\n      editBtn.setAttribute('data-id', note.id);\n      editBtn.setAttribute('data-title', note.title);\n      editBtn.setAttribute('data-content', note.content);\n      editBtn.addEventListener('click', function() {\n        var id = editBtn.getAttribute('data-id');\n        var t = editBtn.getAttribute('data-title');\n        var c = editBtn.getAttribute('data-content');\n        editingId = id;\n        document.getElementById('note-title').value = t;\n        document.getElementById('note-content').value = c;\n      });\n      div.appendChild(editBtn);\n\n      var deleteBtn = document.createElement('button');\n      deleteBtn.className = 'delete-btn';\n      deleteBtn.textContent = 'Delete';\n      deleteBtn.setAttribute('data-id', note.id);\n      deleteBtn.addEventListener('click', function() {\n        var id = deleteBtn.getAttribute('data-id');\n        fetch(API + '/' + id, {\n          method: 'DELETE',\n          headers: {\n            'Content-Type': 'application/json',\n            'X-API-Key': API_KEY\n          }\n        }).then(function() {\n          if (editingId == id) {\n            editingId = null;\n            document.getElementById('note-title').value = '';\n            document.getElementById('note-content').value = '';\n          }\n          fetchNotes();\n        });\n      });\n      div.appendChild(deleteBtn);\n\n      list.appendChild(div);\n    });\n  });\n}\n\ndocument.getElementById('note-form').addEventListener('submit', function(e) {\n  e.preventDefault();\n  var title = document.getElementById('note-title').value;\n  var content = document.getElementById('note-content').value;\n\n  if (editingId !== null) {\n    fetch(API + '/' + editingId, {\n      method: 'PUT',\n      headers: {\n        'Content-Type': 'application/json',\n        'X-API-Key': API_KEY\n      },\n      body: JSON.stringify({ title: title, content: content })\n    }).then(function() {\n      editingId = null;\n      document.getElementById('note-title').value = '';\n      document.getElementById('note-content').value = '';\n      fetchNotes();\n    });\n  } else {\n    fetch(API, {\n      method: 'POST',\n      headers: {\n        'Content-Type': 'application/json',\n        'X-API-Key': API_KEY\n      },\n      body: JSON.stringify({ title: title, content: content })\n    }).then(function() {\n      editingId = null;\n      document.getElementById('note-title').value = '';\n      document.getElementById('note-content').value = '';\n      fetchNotes();\n    });\n  }\n});\n\nfetchNotes();\nEOF\n"]
