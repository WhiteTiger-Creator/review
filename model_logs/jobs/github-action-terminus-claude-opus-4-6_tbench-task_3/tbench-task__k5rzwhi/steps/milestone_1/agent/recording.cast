[552.131473, "o", "/* Extract note ID from URL like /api/notes/123 */\r\n\u001b[?2004l\r"]
[552.131502, "o", "\u001b[?2004h> "]
[552.131807, "o", "static int extract_note_id(const char *url) {\r\n\u001b[?2004l\r"]
[552.131831, "o", "\u001b[?2004h"]
[552.13185, "o", "> "]
[552.132122, "o", "    const char *prefix = \"/api/notes/\";\r\n\u001b[?2004l\r"]
[552.132145, "o", "\u001b[?2004h"]
[552.132166, "o", "> "]
[552.132559, "o", "    if (strncmp(url, prefix, strlen(prefix)) != 0) return -1;\r\n\u001b[?2004l\r"]
[552.132583, "o", "\u001b[?2004h"]
[552.132602, "o", "> "]
[552.132901, "o", "    const char *id_str = url + strlen(prefix);\r\n\u001b[?2004l\r"]
[552.132925, "o", "\u001b[?2004h"]
[552.132943, "o", "> "]
[552.133181, "o", "    if (*id_str == '\\0') return -1;\r\n\u001b[?2004l\r"]
[552.133205, "o", "\u001b[?2004h"]
[552.133222, "o", "> "]
[552.133506, "o", "    for (const char *p = id_str; *p; p++) {\r\n\u001b[?2004l\r"]
[552.13353, "o", "\u001b[?2004h"]
[552.133552, "o", "> "]
[552.133878, "o", "        if (!isdigit((unsigned char)*p)) return -1;\r\n\u001b[?2004l\r"]
[552.133902, "o", "\u001b[?2004h"]
[552.133919, "o", "> "]
[552.133999, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[552.134023, "o", "> "]
[552.134177, "o", "    return atoi(id_str);\r\n\u001b[?2004l\r"]
[552.134286, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\rO"]
[552.134314, "o", "\u001b[?2004h> "]
[552.134799, "o", "static enum MHD_Result handle_get_notes(struct MHD_Connection *connection) {\r\n\u001b[?2004l\r"]
[552.13483, "o", "\u001b[?2004h> "]
