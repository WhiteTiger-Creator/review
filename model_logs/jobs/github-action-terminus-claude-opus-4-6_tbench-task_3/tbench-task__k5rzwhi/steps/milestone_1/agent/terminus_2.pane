[?2004l[?2004h>     const char *pos = strstr(json, search);
[?2004l[?2004h>     if (!pos) return NULL;
[?2004l[?2004h>     pos += strlen(search);
[?2004l[?2004h>     while (*pos && (isspace((unsigned char)*pos) || *pos == ':')) pos++;
[?2004l[?2004h>     if (*pos == '\0') return NULL;
[?2004l[?2004h>     if (*pos == 'n' && strncmp(pos, "null", 4) == 0) return NULL;
[?2004l[?2004h>     if (*pos != '"') return NULL;
[?2004l[?2004h>     pos++;
[?2004l[?2004h>     
[?2004l[?2004h>     size_t buf_size = 1024;
[?2004l[?2004h>     char *buf = malloc(buf_size);
[?2004l[?2004h>     size_t buf_len = 0;
[?2004l[?2004h>     
[?2004l[?2004h>     while (*pos && *pos != '"') {
[?2004l[?2004h>         if (buf_len + 8 >= buf_size) {
[?2004l[?2004h>             buf_size *= 2;
[?2004l[?2004h>             buf = realloc(buf, buf_size);
[?2004l[?2004h>         }
[?2004l[?2004h>         if (*pos == '\\') {
[?2004l[?2004h>             pos++;
[?2004l[?2004h>             switch (*pos) {
[?2004l[?2004h>                 case '"': buf[buf_len++] = '"'; break;
[?2004l[?2004h>                 case '\\': buf[buf_len++] = '\\'; break;
[?2004l[?2004h>                 case '/': buf[buf_len++] = '/'; break;
[?2004l[?2004h>                 case 'n': buf[buf_len++] = '\n'; break;
[?2004l[?2004h>                 case 'r': buf[buf_len++] = '\r'; break;
[?2004l[?2004h>                 case 't': buf[buf_len++] = '\t'; break;
[?2004l[?2004h>                 case 'b': buf[buf_len++] = '\b'; break;
[?2004l[?2004h>                 case 'f': buf[buf_len++] = '\f'; break;
[?2004l[?2004h>                 case 'u': {
[?2004l[?2004h>                     if (pos[1] && pos[2] && pos[3] && pos[4]) {
[?2004l[?2004h>                         unsigned int cp = 0;
[?2004l[?2004h>                         sscanf(pos + 1, "%4x", &cp);
[?2004l[?2004h>                         if (cp < 0x80) {
[?2004l[?2004h>                             buf[buf_len++] = (char)cp;
[?2004l[?2004h>                         } else if (cp < 0x800) {
[?2004l[?2004h>                             buf[buf_len++] = (char)(0xC0 | (cp >> 6));
[?2004l[?2004h>                             buf[buf_len++] = (char)(0x80 | (cp & 0x3F));
[?2004l[?2004h>                         } else {
[?2004l[?2004h>                             buf[buf_len++] = (char)(0xE0 | (cp >> 12));
[?2004l[?2004h>                             buf[buf_len++] = (char)(0x80 | ((cp >> 6) & 0x3F));
[?2004l[?2004h>                             buf[buf_len++] = (char)(0x80 | (cp & 0x3F));
[?2004l[?2004h>                         }
[?2004l[?2004h>                         pos += 4;
[?2004l[?2004h>                     }
[?2004l[?2004h>                     break;
[?2004l[?2004h>                 }
[?2004l[?2004h>                 default: buf[buf_len++] = *pos; break;
[?2004l[?2004h>             }
[?2004l[?2004h>         } else {
[?2004l[?2004h>             buf[buf_len++] = *pos;
[?2004l[?2004h>         }
[?2004l[?2004h>         pos++;
[?2004l[?2004h>     }
[?2004l[?2004h>     buf[buf_len] = '\0';
[?2004l[?2004h>     return buf;
[?2004l[?2004h> }
