[?2004l[?2004h> static enum MHD_Result handle_get_notes(struct MHD_Connection *connection) {
[?2004l[?2004h>     /* Parse limit and offset from query params */
[?2004l[?2004h>     int limit = 50;
[?2004l[?2004h>     int offset = 0;
[?2004l[?2004h>     
[?2004l[?2004h>     const char *limit_str = MHD_lookup_connection_value(connection, MHD_GET_ARGUMENT_KIND, "limit");
[?2004l[?2004h>     const char *offset_str = MHD_lookup_connection_value(connection, MHD_GET_ARGUMENT_KIND, "offset");
[?2004l[?2004h>     
[?2004l[?2004h>     if (limit_str) {
[?2004l[?2004h>         limit = atoi(limit_str);
[?2004l[?2004h>         if (limit <= 0) limit = 50;
[?2004l[?2004h>         if (limit > 100) limit = 100;
[?2004l[?2004h>     }
[?2004l[?2004h>     if (offset_str) {
[?2004l[?2004h>         offset = atoi(offset_str);
[?2004l[?2004h>         if (offset < 0) offset = 0;
[?2004l[?2004h>     }
[?2004l[?2004h>     
[?2004l[?2004h>     int total = get_total_notes_count();
[?2004l[?2004h>     char *json = get_notes_paginated_json(limit, offset);
[?2004l[?2004h>     if (!json) json = strdup("[]");
[?2004l[?2004h>     
[?2004l[?2004h>     char total_str[32];
[?2004l[?2004h>     snprintf(total_str, sizeof(total_str), "%d", total);
[?2004l[?2004h>     
[?2004l[?2004h>     enum MHD_Result r = send_response(connection, json, MHD_HTTP_OK, total_str);
[?2004l[?2004h>     free(json);
[?2004l[?2004h>     return r;
[?2004l[?2004h> }
