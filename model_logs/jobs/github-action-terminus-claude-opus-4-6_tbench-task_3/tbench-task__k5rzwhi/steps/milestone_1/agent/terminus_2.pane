[?2004lvar API = '/api/notes';
var API_KEY = 'tb3_notes_api_secret_2026';
var editingId = null;

function fetchNotes() {
  fetch(API).then(function(res) {
    return res.json();
  }).then(function(notes) {
    var list = document.getElementById('notes-list');
    list.innerHTML = '';
    notes.forEach(function(note) {
      var div = document.createElement('div');
      div.className = 'note-card';
      div.setAttribute('data-id', note.id);

      var title = document.createElement('h3');
      title.textContent = note.title;
      div.appendChild(title);

      var content = document.createElement('p');
      content.textContent = note.content;
      div.appendChild(content);

      var editBtn = document.createElement('button');
      editBtn.className = 'edit-btn';
      editBtn.textContent = 'Edit';
      editBtn.setAttribute('data-id', note.id);
      editBtn.setAttribute('data-title', note.title);
      editBtn.setAttribute('data-content', note.content);
      editBtn.addEventListener('click', function() {
        var id = editBtn.getAttribute('data-id');
        var t = editBtn.getAttribute('data-title');
        var c = editBtn.getAttribute('data-content');
        editingId = id;
        document.getElementById('note-title').value = t;
        document.getElementById('note-content').value = c;
      });
      div.appendChild(editBtn);

      var deleteBtn = document.createElement('button');
      deleteBtn.className = 'delete-btn';
      deleteBtn.textContent = 'Delete';
      deleteBtn.setAttribute('data-id', note.id);
      deleteBtn.addEventListener('click', function() {
        var id = deleteBtn.getAttribute('data-id');
        fetch(API + '/' + id, {
          method: 'DELETE',
          headers: {
            'Content-Type': 'application/json',
            'X-API-Key': API_KEY
          }
        }).then(function() {
          if (editingId == id) {
            editingId = null;
            document.getElementById('note-title').value = '';
            document.getElementById('note-content').value = '';
          }
          fetchNotes();
        });
      });
      div.appendChild(deleteBtn);

      list.appendChild(div);
    });
  });
}

document.getElementById('note-form').addEventListener('submit', function(e) {
  e.preventDefault();
  var title = document.getElementById('note-title').value;
  var content = document.getElementById('note-content').value;

  if (editingId !== null) {
    fetch(API + '/' + editingId, {
      method: 'PUT',
      headers: {
        'Content-Type': 'application/json',
        'X-API-Key': API_KEY
      },
      body: JSON.stringify({ title: title, content: content })
    }).then(function() {
      editingId = null;
      document.getElementById('note-title').value = '';
      document.getElementById('note-content').value = '';
      fetchNotes();
    });
  } else {
    fetch(API, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-API-Key': API_KEY
      },
      body: JSON.stringify({ title: title, content: content })
    }).then(function() {
      editingId = null;
      document.getElementById('note-title').value = '';
      document.getElementById('note-content').value = '';
      fetchNotes();
    });
  }
});

fetchNotes();
