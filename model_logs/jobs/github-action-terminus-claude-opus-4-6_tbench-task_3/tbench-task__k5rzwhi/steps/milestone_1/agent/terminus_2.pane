[?2004l[?2004h> static void load_api_key(void) {
[?2004l[?2004h>     if (key_loaded) return;
[?2004l[?2004h>     FILE *f = fopen("/app/config/api.key", "r");
[?2004l[?2004h>     if (!f) {
[?2004l[?2004h>         key_loaded = 1;
[?2004l[?2004h>         return;
[?2004l[?2004h>     }
[?2004l[?2004h>     if (fgets(api_key, sizeof(api_key), f)) {
[?2004l[?2004h>         /* Trim whitespace from both ends */
[?2004l[?2004h>         char *end = api_key + strlen(api_key) - 1;
[?2004l[?2004h>         while (end >= api_key && isspace((unsigned char)*end)) *end-- = '\0';
[?2004l[?2004h>         char *start = api_key;
[?2004l[?2004h>         while (*start && isspace((unsigned char)*start)) start++;
[?2004l[?2004h>         if (start != api_key) memmove(api_key, start, strlen(start) + 1);
[?2004l[?2004h>     }
[?2004l[?2004h>     fclose(f);
[?2004l[?2004h>     key_loaded = 1;
[?2004l[?2004h> }
