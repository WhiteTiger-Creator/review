[?2004l[?2004h> /* Extract note ID from URL like /api/notes/123 */
[?2004l[?2004h> static int extract_note_id(const char *url) {
[?2004l[?2004h>     const char *prefix = "/api/notes/";
[?2004l[?2004h>     if (strncmp(url, prefix, strlen(prefix)) != 0) return -1;
[?2004l[?2004h>     const char *id_str = url + strlen(prefix);
[?2004l[?2004h>     if (*id_str == '\0') return -1;
[?2004l[?2004h>     /* Check it's all digits */
[?2004l[?2004h>     for (const char *p = id_str; *p; p++) {
[?2004l[?2004h>         if (!isdigit((unsigned char)*p)) return -1;
[?2004l[?2004h>     }
[?2004l[?2004h>     return atoi(id_str);
[?2004l[?2004h> }
