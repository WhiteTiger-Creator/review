[?2004l[?2004h> static enum MHD_Result handle_post_note(struct MHD_Connection *connection, const char *body) {
[?2004l[?2004h>     if (!body || strlen(body) == 0) {
[?2004l[?2004h>         return send_json(connection, "{\"error\":\"title is required\"}", MHD_HTTP_BAD_REQUEST);
[?2004l[?2004h>     }
[?2004l[?2004h>     
[?2004l[?2004h>     char *title = json_get_string(body, "title");
[?2004l[?2004h>     
[?2004l[?2004h>     /* Title must be present and non-empty */
[?2004l[?2004h>     if (!title || strlen(title) == 0) {
[?2004l[?2004h>         if (title) free(title);
[?2004l[?2004h>         return send_json(connection, "{\"error\":\"title is required\"}", MHD_HTTP_BAD_REQUEST);
[?2004l[?2004h>     }
[?2004l[?2004h>     
[?2004l[?2004h>     /* Check if title is only whitespace */
[?2004l[?2004h>     int all_space = 1;
[?2004l[?2004h>     for (size_t i = 0; i < strlen(title); i++) {
[?2004l[?2004h>         if (!isspace((unsigned char)title[i])) { all_space = 0; break; }
[?2004l[?2004h>     }
[?2004l[?2004h>     if (all_space) {
[?2004l[?2004h>         free(title);
[?2004l[?2004h>         return send_json(connection, "{\"error\":\"title is required\"}", MHD_HTTP_BAD_REQUEST);
[?2004l[?2004h>     }
[?2004l[?2004h>     
[?2004l[?2004h>     char *content = json_get_string(body, "content");
[?2004l[?2004h>     if (!content) content = strdup("");
[?2004l[?2004h>     
[?2004l[?2004h>     int id = create_note(title, content);
[?2004l[?2004h>     if (id < 0) {
[?2004l[?2004h>         free(title);
[?2004l[?2004h>         free(content);
[?2004l[?2004h>         return send_json(connection, "{\"error\":\"internal error\"}", MHD_HTTP_INTERNAL_SERVER_ERROR);
[?2004l[?2004h>     }
