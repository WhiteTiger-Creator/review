[?2004l[?2004h> static enum MHD_Result handle_get_note(struct MHD_Connection *connection, int id) {
[?2004l[?2004h>     char *json = get_note_json(id);
[?2004l[?2004h>     if (!json) {
[?2004l[?2004h>         return send_json(connection, "{\"error\":\"not found\"}", MHD_HTTP_NOT_FOUND);
[?2004l[?2004h>     }
[?2004l[?2004h>     enum MHD_Result r = send_json(connection, json, MHD_HTTP_OK);
