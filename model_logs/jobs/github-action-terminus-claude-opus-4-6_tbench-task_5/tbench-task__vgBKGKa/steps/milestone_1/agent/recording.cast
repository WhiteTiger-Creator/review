[296.639558, "o", "\u001b[?2004h"]
[296.639579, "o", "> "]
[296.639755, "o", "int note_exists(int id) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[296.639844, "o", "    pthread_mutex_lock(&db_mutex);\r\n\u001b[?2004l\r"]
[296.639946, "o", "\u001b[?2004h"]
[296.639993, "o", ">     sqlite3_stmt *stmt;\r\n\u001b[?2004l\r"]
[296.640103, "o", "\u001b[?2004h> "]
[296.640232, "o", "    const char *sql = \"SELECT 1 FROM notes WHERE id = ?;\";\r\n\u001b[?2004l\r"]
[296.640268, "o", "\u001b[?2004h> "]
[296.640425, "o", "    int exists = 0;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[296.640607, "o", "    if (sqlite3_prepare_v2(db, sql, -1, &stmt, NULL) == SQLITE_OK) {\r\n\u001b[?2004l\r"]
[296.640632, "o", "\u001b[?2004h"]
[296.640657, "o", "> "]
[296.640796, "o", "        sqlite3_bind_int(stmt, 1, id);\r\n\u001b[?2004l\r"]
[296.640823, "o", "\u001b[?2004h"]
[296.640845, "o", "> "]
[296.641042, "o", "        if (sqlite3_step(stmt) == SQLITE_ROW) {\r\n\u001b[?2004l\r"]
[296.641072, "o", "\u001b[?2004h> "]
[296.641165, "o", "            exists = 1;\r\n\u001b[?2004l\r"]
[296.641194, "o", "\u001b[?2004h> "]
[296.641336, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[296.641419, "o", "        sqlite3_finalize(stmt);\r\n\u001b[?2004l\r"]
[296.641515, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[296.641592, "o", "\u001b[?2004h> "]
[296.64168, "o", "    pthread_mutex_unlock(&db_mutex);\r\n\u001b[?2004l\r"]
[296.641749, "o", "\u001b[?2004h> "]
[296.64183, "o", "    return exists;\r\n\u001b[?2004l\r"]
[296.641934, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h"]
