[296.589807, "i", "cat > /app/src/db.c << 'EOF'\n#include \"db.h\"\n#include <sqlite3.h>\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <pthread.h>\n\nstatic sqlite3 *db = NULL;\nstatic pthread_mutex_t db_mutex = PTHREAD_MUTEX_INITIALIZER;\n\nint init_db(const char *path) {\n    if (sqlite3_open_v2(path, &db,\n            SQLITE_OPEN_READWRITE | SQLITE_OPEN_CREATE | SQLITE_OPEN_FULLMUTEX,\n            NULL) != SQLITE_OK) {\n        fprintf(stderr, \"Cannot open database: %s\\n\", sqlite3_errmsg(db));\n        return -1;\n    }\n\n    sqlite3_busy_timeout(db, 5000);\n\n    char *err_msg = NULL;\n    if (sqlite3_exec(db, \"PRAGMA journal_mode=WAL;\", NULL, NULL, &err_msg) != SQLITE_OK) {\n        fprintf(stderr, \"WAL error: %s\\n\", err_msg);\n        sqlite3_free(err_msg);\n    }\n\n    const char *sql = \"CREATE TABLE IF NOT EXISTS notes (\"\n                      \"id INTEGER PRIMARY KEY AUTOINCREMENT,\"\n                      \"title TEXT NOT NULL,\"\n                      \"content TEXT DEFAULT ''\"\n                      \");\";\n    if (sqlite3_exec(db, sql, NULL, NULL, &err_msg) != SQLITE_OK) {\n        fprintf(stderr, \"SQL error: %s\\n\", err_msg);\n        sqlite3_free(err_msg);\n        return -1;\n    }\n    return 0;\n}\n\nvoid close_db(void) {\n    if (db)\n        sqlite3_close(db);\n    db = NULL;\n}\n\nstatic char *escape_json_string(const char *str) {\n    if (!str) return strdup(\"\");\n    size_t len = strlen(str);\n    /* Worst case: every char needs escaping (6 chars for \\uXXXX) */\n    char *out = malloc(len * 6 + 1);\n    if (!out) return NULL;\n    size_t j = 0;\n    for (size_t i = 0; i < len; i++) {\n        unsigned char c = (unsigned char)str[i];\n        switch (c) {\n            case '\"':  out[j++]='\\\\'; out[j++]='\"'; break;\n            case '\\\\': out[j++]='\\\\'; out[j++]='\\\\'; break;\n            case '\\b': out[j++]='\\\\'; out[j++]='b'; break;\n            case '\\f': out[j++]='\\\\'; out[j++]='f'; break;\n            case '\\n': out[j++]='\\\\'; out[j++]='n'; break;\n            case '\\r': out[j++]='\\\\'; out[j++]='r'; break;\n            case '\\t': out[j++]='\\\\'; out[j++]='t'; break;\n            default:\n                if (c < 0x20) {\n                    j += sprintf(out + j, \"\\\\u%04x\", c);\n                } else {\n                    out[j++] = c;\n                }\n                break;\n        }\n    }\n    out[j] = '\\0';\n    return out;\n}\n\nint create_note(const char *title, const char *content) {\n    pthread_mutex_lock(&db_mutex);\n    sqlite3_stmt *stmt;\n    const char *sql = \"INSERT INTO notes (title, content) VALUES (?, ?);\";\n    if (sqlite3_prepare_v2(db, sql, -1, &stmt, NULL) != SQLITE_OK) {\n        pthread_mutex_unlock(&db_mutex);\n        return -1;\n    }\n    sqlite3_bind_text(stmt, 1, title, -1, SQLITE_STATIC);\n    sqlite3_bind_text(stmt, 2, content ? content : \"\", -1, SQLITE_STATIC);\n    int rc = sqlite3_step(stmt);\n    int id = -1;\n    if (rc == SQLITE_DONE) {\n        id = (int)sqlite3_last_insert_rowid(db);\n    }\n    sqlite3_finalize(stmt);\n    pthread_mutex_unlock(&db_mutex);\n    return id;\n}\n\nchar *get_all_notes_json(void) {\n    return get_notes_paginated_json(50, 0);\n}\n\nchar *get_notes_paginated_json(int limit, int offset) {\n    pthread_mutex_lock(&db_mutex);\n    sqlite3_stmt *stmt;\n    const char *sql = \"SELECT id, title, content FROM notes ORDER BY id LIMIT ? OFFSET ?;\";\n    if (sqlite3_prepare_v2(db, sql, -1, &stmt, NULL) != SQLITE_OK) {\n        pthread_mutex_unlock(&db_mutex);\n        return strdup(\"[]\");\n    }\n    sqlite3_bind_int(stmt, 1, limit);\n    sqlite3_bind_int(stmt, 2, offset);\n\n    size_t buf_size = 4096;\n    size_t buf_len = 0;\n    char *buf = malloc(buf_size);\n    buf[buf_len++] = '[';\n\n    int first = 1;\n    while (sqlite3_step(stmt) == SQLITE_ROW) {\n        int id = sqlite3_column_int(stmt, 0);\n        const char *title = (const char *)sqlite3_column_text(stmt, 1);\n        const char *content = (const char *)sqlite3_column_text(stmt, 2);\n        char *etitle = escape_json_string(title);\n        char *econtent = escape_json_string(content);\n\n        char item[65536];\n        int item_len = snprintf(item, sizeof(item),\n            \"%s{\\\"id\\\":%"]
[296.589961, "i", "d,\\\"title\\\":\\\"%s\\\",\\\"content\\\":\\\"%s\\\"}\",\n            first ? \"\" : \",\", id, etitle, econtent);\n        free(etitle);\n        free(econtent);\n\n        while (buf_len + item_len + 2 > buf_size) {\n            buf_size *= 2;\n            buf = realloc(buf, buf_size);\n        }\n        memcpy(buf + buf_len, item, item_len);\n        buf_len += item_len;\n        first = 0;\n    }\n    sqlite3_finalize(stmt);\n    pthread_mutex_unlock(&db_mutex);\n\n    if (buf_len + 2 > buf_size) {\n        buf_size = buf_len + 2;\n        buf = realloc(buf, buf_size);\n    }\n    buf[buf_len++] = ']';\n    buf[buf_len] = '\\0';\n    return buf;\n}\n\nint get_total_notes_count(void) {\n    pthread_mutex_lock(&db_mutex);\n    sqlite3_stmt *stmt;\n    const char *sql = \"SELECT COUNT(*) FROM notes;\";\n    int count = 0;\n    if (sqlite3_prepare_v2(db, sql, -1, &stmt, NULL) == SQLITE_OK) {\n        if (sqlite3_step(stmt) == SQLITE_ROW) {\n            count = sqlite3_column_int(stmt, 0);\n        }\n        sqlite3_finalize(stmt);\n    }\n    pthread_mutex_unlock(&db_mutex);\n    return count;\n}\n\nchar *get_note_json(int id) {\n    pthread_mutex_lock(&db_mutex);\n    sqlite3_stmt *stmt;\n    const char *sql = \"SELECT id, title, content FROM notes WHERE id = ?;\";\n    if (sqlite3_prepare_v2(db, sql, -1, &stmt, NULL) != SQLITE_OK) {\n        pthread_mutex_unlock(&db_mutex);\n        return NULL;\n    }\n    sqlite3_bind_int(stmt, 1, id);\n    char *result = NULL;\n    if (sqlite3_step(stmt) == SQLITE_ROW) {\n        int nid = sqlite3_column_int(stmt, 0);\n        const char *title = (const char *)sqlite3_column_text(stmt, 1);\n        const char *content = (const char *)sqlite3_column_text(stmt, 2);\n        char *etitle = escape_json_string(title);\n        char *econtent = escape_json_string(content);\n        size_t needed = strlen(etitle) + strlen(econtent) + 128;\n        result = malloc(needed);\n        snprintf(result, needed, \"{\\\"id\\\":%d,\\\"title\\\":\\\"%s\\\",\\\"content\\\":\\\"%s\\\"}\",\n                 nid, etitle, econtent);\n        free(etitle);\n        free(econtent);\n    }\n    sqlite3_finalize(stmt);\n    pthread_mutex_unlock(&db_mutex);\n    return result;\n}\n\nint update_note(int id, const char *title, const char *content) {\n    pthread_mutex_lock(&db_mutex);\n    sqlite3_stmt *stmt;\n    const char *sql = \"UPDATE notes SET title = ?, content = ? WHERE id = ?;\";\n    if (sqlite3_prepare_v2(db, sql, -1, &stmt, NULL) != SQLITE_OK) {\n        pthread_mutex_unlock(&db_mutex);\n        return -1;\n    }\n    sqlite3_bind_text(stmt, 1, title, -1, SQLITE_STATIC);\n    sqlite3_bind_text(stmt, 2, content ? content : \"\", -1, SQLITE_STATIC);\n    sqlite3_bind_int(stmt, 3, id);\n    int rc = sqlite3_step(stmt);\n    sqlite3_finalize(stmt);\n    int changes = sqlite3_changes(db);\n    pthread_mutex_unlock(&db_mutex);\n    if (rc != SQLITE_DONE) return -1;\n    return changes > 0 ? 0 : 1; /* 0=updated, 1=not found */\n}\n\nint delete_note(int id) {\n    pthread_mutex_lock(&db_mutex);\n    sqlite3_stmt *stmt;\n    const char *sql = \"DELETE FROM notes WHERE id = ?;\";\n    if (sqlite3_prepare_v2(db, sql, -1, &stmt, NULL) != SQLITE_OK) {\n        pthread_mutex_unlock(&db_mutex);\n        return -1;\n    }\n    sqlite3_bind_int(stmt, 1, id);\n    int rc = sqlite3_step(stmt);\n    sqlite3_finalize(stmt);\n    int changes = sqlite3_changes(db);\n    pthread_mutex_unlock(&db_mutex);\n    if (rc != SQLITE_DONE) return -1;\n    return changes > 0 ? 0 : 1; /* 0=deleted, 1=not found */\n}\n\nint note_exists(int id) {\n    pthread_mutex_lock(&db_mutex);\n    sqlite3_stmt *stmt;\n    const char *sql = \"SELECT 1 FROM notes WHERE id = ?;\";\n    int exists = 0;\n    if (sqlite3_prepare_v2(db, sql, -1, &stmt, NULL) == SQLITE_OK) {\n        sqlite3_bind_int(stmt, 1, id);\n        if (sqlite3_step(stmt) == SQLITE_ROW) {\n            exists = 1;\n        }\n        sqlite3_finalize(stmt);\n    }\n    pthread_mutex_unlock(&db_mutex);\n    return exists;\n}\nEOF\n"]
