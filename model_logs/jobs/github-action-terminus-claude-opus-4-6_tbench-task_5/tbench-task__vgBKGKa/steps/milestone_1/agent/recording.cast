[481.854526, "o", "[2]   Done                    curl -s -X POST http://localhost:8080/api/notes -H 'Content-Type: application/json' -H 'X-API-Key: tb3_notes_api_secret_2026' -d \"{\\\"title\\\":\\\"Concurrent $i\\\",\\\"content\\\":\\\"Body $i\\\"}\"\r\n[3]   Done                    curl -s -X POST http://localhost:8080/api/notes -H 'Content-Type: application/json' -H 'X-API-Key: tb3_notes_api_secret_2026' -d \"{\\\"title\\\":\\\"Concurrent $i\\\",\\\"content\\\":\\\"Body $i\\\"}\"\r\n[4]   Done                    curl -s -X POST http://localhost:8080/api/notes -H 'Content-Type: application/json' -H 'X-API-Key: tb3_notes_api_secret_2026' -d \"{\\\"title\\\":\\\"Concurrent $i\\\",\\\"content\\\":\\\"Body $i\\\"}\"\r\n[5]   Done                    curl -s -X POST http://localhost:8080/api/notes -H 'Content-Type: application/json' -H 'X-API-Key: tb3_notes_api_secret_2026' -d \"{\\\"title\\\":\\\"Concurrent $i\\\",\\\"content\\\":\\\"Body $i\\\"}\"\r\n[6]   Done                    curl -s -X POST http://localhost:8080/api/notes -H 'Content-Type: application/json' -H 'X-API-Key: tb3_notes_api_secret_2026' -d \"{\\\"title\\\":\\\"Concurrent $i\\\",\\\"content\\\":\\\"Body $i\\\"}\"\r\n[7]   Done                    curl -s -X POST http://localhost:8080/api/notes -H 'Content-Type: application/json' -H 'X-API-Key: tb3_notes_api_secret_2026' -d \"{\\\"title\\\":\\\"Concurrent $i\\\",\\\"content\\\":\\\"Body $i\\\"}\"\r\n[8]   Done                    curl -s -X POST http://localhost:8080/api/notes -H 'Content-Type: application/json' -H 'X-API-Key: tb3_notes_api_secret_2026' -d \"{\\\"title\\\":\\\"Concurrent $i\\\",\\\"content\\\":\\\"Body $i\\\"}\"\r\n[9]   Done                    curl -s -X POST http://localhost:8080/api/notes -H 'Content-Type: application/json' -H 'X-API-Key: tb3_notes_api_secret_2026' -d \"{\\\"title\\\":\\\"Concurrent $i\\\",\\\"content\\\":\\\"Body $i\\\"}\"\r\n[10]   Done                    curl -s -X POST http://localhost:8080/api/notes -H 'Content-Type: application/json' -H 'X-API-Key: tb3_notes_api_secret_2026' -d \"{\\\"title\\\":\\\"Concurrent $i\\\",\\\"content\\\":\\\"Body $i\\\"}\"\r\n[11]   Done                    curl -s -X POST http://localhost:8080/api/notes -H 'Content-Type: application/json' -H 'X-API-Key: tb3_notes_api_secret_2026' -d \"{\\\"title\\\":\\\"Concurrent $i\\\",\\\"content\\\":\\\"Body $i\\\"}\"\r\n[12]   Done                    curl -s -X POST http://localhost:8080/api/notes -H 'Content-Type: application/json' -H 'X-API-Key: tb3_notes_api_secret_2026' -d \"{\\\"title\\\":\\\"Concurrent $i\\\",\\\"content\\\":\\\"Body $i\\\"}\"\r\n[13]   Done                    curl -s -X POST http://localhost:8080/api/notes -H 'Content-Type: application/json' -H 'X-API-Key: tb3_notes_api_secret_2026' -d \"{\\\"title\\\":\\\"Concurrent $i\\\",\\\"content\\\":\\\"Body $i\\\"}\"\r\n[14]   Done                    curl -s -X POST http://localhost:8080/api/notes -H 'Content-Type: application/json' -H 'X-API-Key: tb3_notes_api_secret_2026' -d \"{\\\"title\\\":\\\"Concurrent $i\\\",\\\"content\\\":\\\"Body $i\\\"}\"\r\n[15]-  Done                    curl -s -X POST http://localhost:8080/api/notes -H 'Content-Type: application/json' -H 'X-API-Key: tb3_notes_api_secret_2026' -d \"{\\\"title\\\":\\\"Concurrent $i\\\",\\\"content\\\":\\\"Body $i\\\"}\"\r\n[16]+  Done                    curl -s -X POST http://localhost:8080/api/notes -H 'Content-Type: application/json' -H 'X-API-Key: tb3_notes_api_secret_2026' -d \"{\\\"title\\\":\\\"Concurrent $i\\\",\\\"content\\\":\\\"Body $i\\\"}\"\r\n\u001b[?2004hroot@78f42a19e0d4:/app# "]
