[298.094265, "i", "cat > /app/src/routes.c << 'EOF'\n#include \"routes.h\"\n#include \"db.h\"\n#include \"auth.h\"\n#include <microhttpd.h>\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <ctype.h>\n#include \"common.h\"\n\n#define MAX_BODY NOTES_MAX_BODY_BYTES\n\nstatic enum MHD_Result send_json_response(struct MHD_Connection *connection,\n    const char *json, unsigned int status_code, int total_count) {\n    size_t len = json ? strlen(json) : 0;\n    struct MHD_Response *response = MHD_create_response_from_buffer(\n        len, (void *)json, MHD_RESPMEM_MUST_COPY);\n    MHD_add_response_header(response, \"Content-Type\", \"application/json\");\n    MHD_add_response_header(response, \"Access-Control-Allow-Origin\", \"*\");\n    MHD_add_response_header(response, \"Access-Control-Allow-Methods\",\n                            \"GET, POST, PUT, DELETE, OPTIONS\");\n    MHD_add_response_header(response, \"Access-Control-Allow-Headers\",\n                            \"Content-Type, X-API-Key\");\n    if (total_count >= 0) {\n        char total_str[32];\n        snprintf(total_str, sizeof(total_str), \"%d\", total_count);\n        MHD_add_response_header(response, \"X-Total-Count\", total_str);\n    }\n    enum MHD_Result ret = MHD_queue_response(connection, status_code, response);\n    MHD_destroy_response(response);\n    return ret;\n}\n\nstatic enum MHD_Result send_json(struct MHD_Connection *connection,\n    const char *json, unsigned int status_code) {\n    return send_json_response(connection, json, status_code, -1);\n}\n\n/* Simple JSON string value extractor - handles escape sequences */\nstatic char *json_get_string(const char *json, const char *key) {\n    char search[256];\n    snprintf(search, sizeof(search), \"\\\"%s\\\"\", key);\n    const char *p = strstr(json, search);\n    if (!p) return NULL;\n    p += strlen(search);\n    /* skip whitespace and colon */\n    while (*p && (*p == ' ' || *p == '\\t' || *p == '\\n' || *p == '\\r')) p++;\n    if (*p != ':') return NULL;\n    p++;\n    while (*p && (*p == ' ' || *p == '\\t' || *p == '\\n' || *p == '\\r')) p++;\n    if (*p == 'n' && strncmp(p, \"null\", 4) == 0) return NULL;\n    if (*p != '\"') return NULL;\n    p++; /* skip opening quote */\n\n    /* Parse the string value with escape handling */\n    size_t buf_size = 1024;\n    char *result = malloc(buf_size);\n    size_t j = 0;\n    while (*p && *p != '\"') {\n        if (j + 8 >= buf_size) {\n            buf_size *= 2;\n            result = realloc(result, buf_size);\n        }\n        if (*p == '\\\\') {\n            p++;\n            switch (*p) {\n                case '\"': result[j++] = '\"'; break;\n                case '\\\\': result[j++] = '\\\\'; break;\n                case '/': result[j++] = '/'; break;\n                case 'b': result[j++] = '\\b'; break;\n                case 'f': result[j++] = '\\f'; break;\n                case 'n': result[j++] = '\\n'; break;\n                case 'r': result[j++] = '\\r'; break;\n                case 't': result[j++] = '\\t'; break;\n                case 'u': {\n                    /* Parse 4 hex digits - store as UTF-8 */\n                    unsigned int codepoint = 0;\n                    for (int i = 0; i < 4 && p[1]; i++) {\n                        p++;\n                        codepoint <<= 4;\n                        if (*p >= '0' && *p <= '9') codepoint |= *p - '0';\n                        else if (*p >= 'a' && *p <= 'f') codepoint |= *p - 'a' + 10;\n                        else if (*p >= 'A' && *p <= 'F') codepoint |= *p - 'A' + 10;\n                    }\n                    if (codepoint < 0x80) {\n                        result[j++] = (char)codepoint;\n                    } else if (codepoint < 0x800) {\n                        result[j++] = (char)(0xC0 | (codepoint >> 6));\n                        result[j++] = (char)(0x80 | (codepoint & 0x3F));\n                    } else {\n                        result[j++] = (char)(0xE0 | (codepoint >> 12));\n                        result[j++] = (char)(0x80 | ((codepoint >> 6) & 0x3F));\n                        result[j++] = (char)(0x80 | (codepoint & 0x3F));\n                    }\n                    break;\n                }\n                defa"]
[298.094419, "i", "ult: result[j++] = *p; break;\n            }\n        } else {\n            result[j++] = *p;\n        }\n        p++;\n    }\n    result[j] = '\\0';\n    return result;\n}\n\n/* Check if key exists in JSON (even if value is empty string) */\nstatic int json_has_key(const char *json, const char *key) {\n    char search[256];\n    snprintf(search, sizeof(search), \"\\\"%s\\\"\", key);\n    return strstr(json, search) != NULL;\n}\n\nstatic int parse_id_from_url(const char *url) {\n    /* url is like /api/notes/123 */\n    const char *p = url + strlen(\"/api/notes/\");\n    if (*p == '\\0') return -1;\n    /* Check all chars are digits */\n    for (const char *c = p; *c; c++) {\n        if (!isdigit((unsigned char)*c)) return -1;\n    }\n    return atoi(p);\n}\n\nenum MHD_Result route_request(struct MHD_Connection *connection, const char *url,\n                              const char *method, const char *upload_data,\n                              size_t *upload_data_size, void **con_cls) {\n\n    /* Handle connection data accumulation for POST/PUT */\n    if (*con_cls == NULL) {\n        struct connection_info *ci = calloc(1, sizeof(struct connection_info));\n        if (!ci) return MHD_NO;\n        ci->data = NULL;\n        ci->data_size = 0;\n        *con_cls = ci;\n        return MHD_YES; /* Wait for data */\n    }\n\n    struct connection_info *ci = *con_cls;\n\n    /* Accumulate upload data */\n    if (*upload_data_size > 0) {\n        /* Check body size limit */\n        if (ci->data_size + *upload_data_size > MAX_BODY) {\n            *upload_data_size = 0;\n            ci->data_size = MAX_BODY + 1; /* Mark as too large */\n            return MHD_YES;\n        }\n        char *new_data = realloc(ci->data, ci->data_size + *upload_data_size + 1);\n        if (!new_data) return MHD_NO;\n        memcpy(new_data + ci->data_size, upload_data, *upload_data_size);\n        ci->data_size += *upload_data_size;\n        new_data[ci->data_size] = '\\0';\n        ci->data = new_data;\n        *upload_data_size = 0;\n        return MHD_YES;\n    }\n\n    /* All data received, process the request */\n\n    /* OPTIONS preflight */\n    if (strcmp(method, \"OPTIONS\") == 0) {\n        return send_json(connection, \"\", MHD_HTTP_NO_CONTENT);\n    }\n\n    /* Check body size exceeded */\n    if (ci->data_size > MAX_BODY) {\n        return send_json(connection, \"{\\\"error\\\":\\\"body too large\\\"}\", MHD_HTTP_PAYLOAD_TOO_LARGE);\n    }\n\n    /* Route: GET /api/notes */\n    if (strcmp(url, \"/api/notes\") == 0 && strcmp(method, \"GET\") == 0) {\n        const char *limit_str = MHD_lookup_connection_value(connection, MHD_GET_ARGUMENT_KIND, \"limit\");\n        const char *offset_str = MHD_lookup_connection_value(connection, MHD_GET_ARGUMENT_KIND, \"offset\");\n        int limit = NOTES_DEFAULT_PAGE_SIZE;\n        int offset = 0;\n        if (limit_str) limit = atoi(limit_str);\n        if (offset_str) offset = atoi(offset_str);\n        if (limit <= 0) limit = NOTES_DEFAULT_PAGE_SIZE;\n        if (limit > NOTES_MAX_PAGE_SIZE) limit = NOTES_MAX_PAGE_SIZE;\n        if (offset < 0) offset = 0;\n\n        int total = get_total_notes_count();\n        char *json = get_notes_paginated_json(limit, offset);\n        if (!json) json = strdup(\"[]\");\n        enum MHD_Result r = send_json_response(connection, json, MHD_HTTP_OK, total);\n        free(json);\n        return r;\n    }\n\n    /* Route: POST /api/notes */\n    if (strcmp(url, \"/api/notes\") == 0 && strcmp(method, \"POST\") == 0) {\n        if (!api_key_valid(connection)) {\n            return send_json(connection, \"{\\\"error\\\":\\\"unauthorized\\\"}\", MHD_HTTP_UNAUTHORIZED);\n        }\n        if (!ci->data || ci->data_size == 0) {\n            return send_json(connection, \"{\\\"error\\\":\\\"title is required\\\"}\", MHD_HTTP_BAD_REQUEST);\n        }\n        char *title = json_get_string(ci->data, \"title\");\n        if (!title || strlen(title) == 0) {\n            free(title);\n            return send_json(connection, \"{\\\"error\\\":\\\"title is required\\\"}\", MHD_HTTP_BAD_REQUEST);\n        }\n        /* Check title is not just whitespace */\n        int all_space = 1;\n        for (size_t i = 0; title[i]; i++) {\n            if (!isspace(("]
[298.095016, "i", "unsigned char)title[i])) { all_space = 0; break; }\n        }\n        if (all_space) {\n            free(title);\n            return send_json(connection, \"{\\\"error\\\":\\\"title is required\\\"}\", MHD_HTTP_BAD_REQUEST);\n        }\n        char *content = json_get_string(ci->data, \"content\");\n        int id = create_note(title, content ? content : \"\");\n        if (id < 0) {\n            free(title); free(content);\n            return send_json(connection, \"{\\\"error\\\":\\\"server error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR);\n        }\n        char *note_json = get_note_json(id);\n        enum MHD_Result r = send_json(connection, note_json, MHD_HTTP_CREATED);\n        free(note_json);\n        free(title); free(content);\n        return r;\n    }\n\n    /* Routes with ID: /api/notes/{id} */\n    if (strncmp(url, \"/api/notes/\", 11) == 0 && strlen(url) > 11) {\n        int id = parse_id_from_url(url);\n        if (id < 0) {\n            return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\n        }\n\n        /* GET /api/notes/{id} */\n        if (strcmp(method, \"GET\") == 0) {\n            char *json = get_note_json(id);\n            if (!json) {\n                return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\n            }\n            enum MHD_Result r = send_json(connection, json, MHD_HTTP_OK);\n            free(json);\n            return r;\n        }\n\n        /* PUT /api/notes/{id} */\n        if (strcmp(method, \"PUT\") == 0) {\n            if (!api_key_valid(connection)) {\n                return send_json(connection, \"{\\\"error\\\":\\\"unauthorized\\\"}\", MHD_HTTP_UNAUTHORIZED);\n            }\n            if (!ci->data || ci->data_size == 0) {\n                return send_json(connection, \"{\\\"error\\\":\\\"title is required\\\"}\", MHD_HTTP_BAD_REQUEST);\n            }\n            char *title = json_get_string(ci->data, \"title\");\n            if (!title || strlen(title) == 0) {\n                free(title);\n                return send_json(connection, \"{\\\"error\\\":\\\"title is required\\\"}\", MHD_HTTP_BAD_REQUEST);\n            }\n            int all_space = 1;\n            for (size_t i = 0; title[i]; i++) {\n                if (!isspace((unsigned char)title[i])) { all_space = 0; break; }\n            }\n            if (all_space) {\n                free(title);\n                return send_json(connection, \"{\\\"error\\\":\\\"title is required\\\"}\", MHD_HTTP_BAD_REQUEST);\n            }\n            char *content = json_get_string(ci->data, \"content\");\n            int result = update_note(id, title, content ? content : \"\");\n            free(title); free(content);\n            if (result == 1) {\n                return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\n            }\n            if (result < 0) {\n                return send_json(connection, \"{\\\"error\\\":\\\"server error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR);\n            }\n            char *json = get_note_json(id);\n            enum MHD_Result r = send_json(connection, json, MHD_HTTP_OK);\n            free(json);\n            return r;\n        }\n\n        /* DELETE /api/notes/{id} */\n        if (strcmp(method, \"DELETE\") == 0) {\n            if (!api_key_valid(connection)) {\n                return send_json(connection, \"{\\\"error\\\":\\\"unauthorized\\\"}\", MHD_HTTP_UNAUTHORIZED);\n            }\n            int result = delete_note(id);\n            if (result == 1) {\n                return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\n            }\n            if (result < 0) {\n                return send_json(connection, \"{\\\"error\\\":\\\"server error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR);\n            }\n            return send_json(connection, \"{\\\"status\\\":\\\"deleted\\\"}\", MHD_HTTP_OK);\n        }\n    }\n\n    return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\n}\nEOF\n"]
