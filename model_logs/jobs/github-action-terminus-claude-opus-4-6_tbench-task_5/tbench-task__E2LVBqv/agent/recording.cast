[270.30481, "o", "\u001b[?2004h"]
[270.304827, "o", "> "]
[270.305001, "o", "        entry.carry_weight = pick_int64(block, \"carry_weight\");\r\n\u001b[?2004l\r"]
[270.305046, "o", "\u001b[?2004h"]
[270.305087, "o", "> "]
[270.305234, "o", "        entry.carry_drift = pick_int64(block, \"carry_drift\");\r\n\u001b[?2004l\r"]
[270.305255, "o", "\u001b[?2004h"]
[270.305273, "o", "> "]
[270.305414, "o", "        if (!entry.name.empty()) {\r\n\u001b[?2004l\r"]
[270.305469, "o", "\u001b[?2004h> "]
[270.305555, "o", "            state.units[entry.name] = entry;\r\n\u001b[?2004l\r"]
[270.30561, "o", "\u001b[?2004h> "]
[270.305632, "o", "        }\r\n\u001b[?2004l\r"]
[270.305698, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[270.305735, "o", "\u001b[?2004h"]
[270.305749, "o", "> "]
[270.305827, "o", "    state.valid = true;\r\n\u001b[?2004l\r"]
[270.305871, "o", "\u001b[?2004h> "]
[270.305935, "o", "    return state;\r\n\u001b[?2004l\r"]
