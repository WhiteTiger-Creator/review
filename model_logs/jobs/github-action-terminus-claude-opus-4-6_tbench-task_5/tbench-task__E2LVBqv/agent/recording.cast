[109.399287, "o", "            const char *line = blob.data() + offset;\r\n            size_t len = end - offset;\r\n            if (forge_scan_has_key(line, len, \"size_bytes=\")) {\r\n                return forge_scan_record_bytes(line, len);\r\n            }\r\n        }\r\n        if (end >= blob.size()) {\r\n            break;\r\n        }\r\n        offset = end + 1;\r\n    }\r\n    return 0;\r\n}\r\n\r\nstd::uint64_t digest_update(std::uint64_t h, const std::string &text) {\r\n    for (unsigned char ch : text) {\r\n        h ^= static_cast<std::uint64_t>(ch);\r\n        h = (h * kDigestStep) & kDigestMask;\r\n    }\r\n    return h;\r\n}\r\n\r\nstd::string json_escape(const std::string &s) {\r\n    std::string out;\r\n    for (char c : s) {\r\n        if (c == '\"' || c == '\\\\') {\r\n            out.push_back('\\\\');\r\n        }\r\n        out.push_back(c);\r\n    }\r\n    return out;\r\n}\r\n\r\n}  // namespace\r\n\r\nstd::vector<std::string> split_units_csv(const std::string &text) {\r\n    std::vector<std::string> out;\r\n    std::string cur;\r\n    for (char ch : text) {\r\n        if (ch == ',') "]
[109.399355, "o", "{\r\n            if (!cur.empty()) {\r\n                out.push_back(cur);\r\n            }\r\n            cur.clear();\r\n        } else if (!std::isspace(static_cast<unsigned char>(ch))) {\r\n            cur.push_back(ch);\r\n        }\r\n    }\r\n    if (!cur.empty()) {\r\n        out.push_back(cur);\r\n    }\r\n    return out;\r\n}\r\n\r\nint read_pass_epoch(const fs::path &checkpoint_path) {\r\n    std::ifstream in(checkpoint_path);\r\n    if (!in) {\r\n        return 0;\r\n    }\r\n    std::ostringstream buffer;\r\n    buffer << in.rdbuf();\r\n    const std::string doc = buffer.str();\r\n    size_t pos = doc.find(\"\\\"pass_epoch\\\"\");\r\n    if (pos == std::string::npos) {\r\n        return 0;\r\n    }\r\n    return pick_int(doc, \"pass_epoch\");\r\n}\r\n\r\nManifest load_manifest(const fs::path &path) {\r\n"]
[109.399379, "o", "    std::string doc = read_file(path);\r\n    Manifest manifest{};\r\n    manifest.release_id = pick_string(doc, \"release_id\");\r\n    manifest.order_weight_base = pick_int(doc, \"order_weight_base\");\r\n    std::string arr = extract_array(doc, \"units\");\r\n    for (const auto &block : split_object_blocks(arr)) {\r\n        UnitSpec spec;\r\n"]
[109.39986, "o", "\u001b[?2004hroot@dbf8340e129b:/app# "]
[109.513345, "i", "sed -n '200,350p' /app/environment/runner/emit_pipeline.cpp\n"]
[109.513912, "o", "sed -n '200,350p' /app/environment/runner/emit_pipeline.cpp\r\n\u001b[?2004l\r"]
[109.515035, "o", "        UnitSpec spec;\r\n        spec.name = pick_string(block, \"name\");\r\n        spec.mode = pick_string(block, \"mode\");\r\n        spec.record = pick_string(block, \"record\");\r\n        spec.manifest_bytes = pick_int(block, \"manifest_bytes\");\r\n        spec.start_pass = pick_int(block, \"start_pass\");\r\n        if (!spec.name.empty()) {\r\n"]
[109.515063, "o", "            manifest.units.push_back(spec);\r\n        }\r\n    }\r\n    return manifest;\r\n}\r\n\r\nstd::string digest_hex(const std::string &text) {\r\n    std::uint64_t h = digest_update(kDigestSeed, text);\r\n    std::ostringstream os;\r\n    os << std::hex << std::nouppercase << std::setfill('0') << std::setw(16) << h;\r\n    return os.str();\r\n}"]
[109.515079, "o", "\r\n\r\nUnitRun analyze_unit(const UnitSpec &spec, int order_rank, int order_weight_base, int pass_epoch,\r\n                     const fs::path &manifest_dir, const char *const *names, size_t name_count,\r\n"]
[109.515088, "o", "                     const LaneCheckpoint *checkpoint, int64_t carry_weight) {\r\n    fs::path record_path = manifest_dir / spec.record;\r\n    UnitRun run{};\r\n    run.name = spec.name;\r\n"]
[109.515099, "o", "    run.mode = forge_lane_mode(spec.mode.c_str(), spec.name.c_str(), pass_epoch);\r\n    run.manifest_bytes = spec.manifest_bytes;\r\n    run.record_bytes = read_record_bytes(record_path);\r\n"]
[109.515109, "o", "    run.drift_bytes = run.record_bytes - static_cast<int64_t>(run.manifest_bytes);\r\n    run.order_rank = order_rank;\r\n\r\n"]
[109.51512, "o", "    int pass_index = spec.start_pass;\r\n    int64_t seeded_weight = 0;\r\n    if (run.mode == \"resume\" && checkpoint != nullptr && checkpoint->valid) {\r\n"]
[109.51513, "o", "        auto it = checkpoint->units.find(spec.name);\r\n        if (it != checkpoint->units.end()) {\r\n            pass_index = it->second.next_pass;\r\n"]
[109.515141, "o", "            seeded_weight = it->second.carry_weight;\r\n        }\r\n    }\r\n"]
[109.515153, "o", "\r\n    if (run.mode == \"resume\" && seeded_weight != 0) {\r\n        run.order_weight = seeded_weight + static_cast<int64_t>(order_weight_base) + run.record_bytes;\r\n    } else {"]
[109.515162, "o", "\r\n        run.order_weight =\r\n"]
[109.515176, "o", "            forge_lane_weight(spec.name.c_str(), names, name_count, order_weight_base, run.record_bytes);\r\n    }\r\n    (void)carry_weight;\r\n"]
[109.515191, "o", "    run.pass_index = pass_index;\r\n    run.row_serial = forge_lane_row_text(run);\r\n    run.row_digest = digest_hex(run.row_serial);\r\n\r\n"]
[109.515205, "o", "    std::ostringstream js;\r\n    js << \"{\\\"name\\\":\\\"\" << json_escape(run.name) << \"\\\",\\\"mode\\\":\\\"\" << json_escape(run.mode)\r\n       << \"\\\",\\\"pass_index\\\":\" << run.pass_index << \",\\\"manifest_bytes\\\":\" << run.manifest_bytes\r\n"]
[109.515213, "o", "       << \",\\\"record_bytes\\\":\" << run.record_bytes << \",\\\"drift_bytes\\\":\" << run.drift_bytes\r\n       << \",\\\"order_rank\\\":\" << run.order_rank << \",\\\"order_weight\\\":\" << run.order_weight\r\n"]
[109.515225, "o", "       << \",\\\"row_digest\\\":\\\"\" << run.row_digest << \"\\\"}\";\r\n    run.json = js.str();\r\n    return run;\r\n"]
[109.515234, "o", "}\r\n\r\n}  // namespace forge\r\n"]
[109.515243, "o", "\r\nint forge_run_emit(int argc, char **argv) {\r\n    if (argc != 4) {\r\n"]
[109.515254, "o", "        std::cerr << \"usage: forge_emit <manifest-json> <output-json> <units-csv>\\n\";\r\n        return 2;\r\n    }\r\n"]
[109.515262, "o", "    fs::path manifest_path = argv[1];\r\n"]
[109.51527, "o", "    fs::path output_path = argv[2];\r\n    std::vector<std::string> requested = forge::split_units_csv(argv[3]);\r\n"]
[109.515281, "o", "    forge::Manifest manifest = forge::load_manifest(manifest_path);\r\n    fs::path manifest_dir = manifest_path.parent_path();\r\n\r\n"]
[109.515292, "o", "    const char *lane_token = forge_lane_fingerprint(manifest.units.data(), manifest.units.size());\r\n    fs::path checkpoint_path = forge::kCheckpointPath;\r\n    int pass_epoch = forge::read_pass_epoch(checkpoint_path);\r\n"]
[109.515303, "o", "    forge::LaneCheckpoint checkpoint = forge_lane_load_checkpoint(checkpoint_path, lane_token);\r\n\r\n    std::vector<const char *> name_ptrs;\r\n"]
[109.515311, "o", "    for (const auto &unit : manifest.units) {\r\n        name_ptrs.push_back(unit.name.c_str());\r\n    }\r\n"]
[109.51532, "o", "\r\n    std::map<std::string, forge::UnitSpec> spec_by_name;\r\n"]
[109.515332, "o", "    for (const auto &unit : manifest.units) {\r\n        spec_by_name[unit.name] = unit;\r\n    }\r\n"]
[109.515341, "o", "\r\n    std::vector<forge::UnitRun> units;\r\n    std::vector<forge::UnitCheckpoint> updated_entries;\r\n"]
[109.515349, "o", "    std::vector<std::string> requested_resume;\r\n    for (const auto &name : requested) {\r\n"]
[109.515357, "o", "        auto it = spec_by_name.find(name);\r\n        if (it == spec_by_name.end()) {\r\n"]
[109.515368, "o", "            continue;\r\n        }\r\n        int order_rank = static_cast<int>(std::distance(\r\n"]
[109.515379, "o", "            manifest.units.begin(),\r\n            std::find_if(manifest.units.begin(), manifest.units.end(),\r\n"]
[109.515391, "o", "                         [&](const forge::UnitSpec &u) { return u.name == name; })));\r\n        int64_t carry_weight = 0;\r\n        if (checkpoint.valid) {\r\n"]
[109.515399, "o", "            auto cp = checkpoint.units.find(name);\r\n            if (cp != checkpoint.units.end()) {\r\n"]
[109.51541, "o", "                carry_weight = cp->second.carry_weight;\r\n            }\r\n        }\r\n"]
[109.515419, "o", "        forge::UnitRun run = forge::analyze_unit(it->second, order_rank, manifest.order_weight_base,\r\n                                                 pass_epoch, manifest_dir, name_ptrs.data(),\r\n"]
[109.515429, "o", "                                                 name_ptrs.size(), &checkpoint, carry_weight);\r\n        units.push_back(run);\r\n        if (run.mode == \"resume\") {\r\n"]
[109.51544, "o", "            requested_resume.push_back(name);\r\n            forge::UnitCheckpoint entry;\r\n            entry.name = run.name;\r\n"]
[109.515448, "o", "            entry.next_pass = run.pass_index + 1;\r\n            entry.carry_weight = run.order_weight;\r\n"]
[109.515463, "o", "            entry.carry_drift = run.drift_bytes;\r\n            updated_entries.push_back(entry);\r\n        }\r\n    }\r\n"]
[109.515471, "o", "\r\n    int64_t drift_total = forge_lane_drift_total(units.data(), units.size());\r\n"]
[109.515482, "o", "    int64_t weight_total = forge_lane_score_total(units.data(), units.size());\r\n\r\n    std::ostringstream serial;\r\n"]
[109.515491, "o", "    serial << forge_lane_header_text(forge::kSchemaVersion, manifest.release_id,\r\n                                     manifest.order_weight_base, pass_epoch, drift_total,\r\n"]
[109.5155, "o", "                                     weight_total);\r\n    for (const auto &unit : units) {\r\n"]
[109.515508, "o", "        serial << '\\n' << unit.row_serial;\r\n    }\r\n    std::string top_digest = forge::digest_hex(serial.str());\r\n"]
[109.515517, "o", "\r\n    fs::create_directories(output_path.parent_path());\r\n"]
[109.515525, "o", "    std::ostringstream out;\r\n    out << \"{\\\"schema_version\\\":\" << forge::kSchemaVersion << \",\\\"release_id\\\":\\\"\"\r\n"]
[109.515533, "o", "        << manifest.release_id << \"\\\",\\\"order_weight_base\\\":\" << manifest.order_weight_base\r\n        << \",\\\"pass_epoch\\\":\" << pass_epoch << \",\\\"units\\\":[\";\r\n"]
[109.51554, "o", "    for (std::size_t i = 0; i < units.size(); ++i) {\r\n        if (i) {\r\n"]
[109.515553, "o", "            out << ',';\r\n        }\r\n        out << units[i].json;\r\n    }"]
[109.515562, "o", "\r\n    out << \"],\\\"total_drift_bytes\\\":\" << drift_total << \",\\\"order_score\\\":\" << weight_total\r\n"]
[109.515574, "o", "        << \",\\\"digest\\\":\\\"\" << top_digest << \"\\\"}\\n\";\r\n    std::ofstream file(output_path, std::ios::binary);\r\n"]
[109.51673, "o", "\u001b[?2004hroot@dbf8340e129b:/app# "]
[195.272795, "i", "cat > /app/environment/c9/pass_gate.cpp << 'EOF'\n#include \"c9_api.h\"\n#include <string.h>\n\nextern \"C\" const char *c9_resolve_mode(const char *manifest_mode, const char *unit_name,\n                                         int pass_epoch) {\n    static thread_local char mode_buf[16];\n    (void)pass_epoch;\n    (void)unit_name;\n    if (manifest_mode == NULL) {\n        mode_buf[0] = '\\0';\n        return mode_buf;\n    }\n    strncpy(mode_buf, manifest_mode, sizeof(mode_buf) - 1);\n    mode_buf[sizeof(mode_buf) - 1] = '\\0';\n    return mode_buf;\n}\nEOF\n"]
