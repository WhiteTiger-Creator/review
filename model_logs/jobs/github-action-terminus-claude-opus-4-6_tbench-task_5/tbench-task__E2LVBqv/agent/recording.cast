[270.306612, "o", "\u001b[?2004h"]
[270.306625, "o", "> "]
[270.306798, "o", "    const std::vector<std::string> &requested_resume) {\r\n\u001b[?2004l\r"]
[270.306827, "o", "\u001b[?2004h"]
[270.30684, "o", "> "]
[270.306974, "o", "    // Start with existing valid entries\r\n\u001b[?2004l\r"]
[270.307002, "o", "\u001b[?2004h"]
[270.307014, "o", "> "]
[270.30719, "o", "    std::map<std::string, forge::UnitCheckpoint> merged;\r\n\u001b[?2004l\r"]
[270.307218, "o", "\u001b[?2004h"]
[270.307231, "o", "> "]
