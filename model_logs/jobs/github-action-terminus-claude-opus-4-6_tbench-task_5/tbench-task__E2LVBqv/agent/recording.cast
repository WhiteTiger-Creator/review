[270.31264, "o", "\u001b[?2004h> "]
[270.312856, "o", "            << \",\\\"carry_weight\\\":\" << entry.carry_weight << \",\\\"carry_drift\\\":\"\r\n\u001b[?2004l\r"]
[270.31291, "o", "\u001b[?2004h> "]
