[270.303743, "o", "\u001b[?2004h"]
[270.303806, "o", "> "]
[270.303967, "o", "    const std::string arr = doc.substr(arr_start, arr_end - arr_start + 1);\r\n\u001b[?2004l\r"]
[270.304032, "o", "\u001b[?2004h> "]
