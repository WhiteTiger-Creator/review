[270.308253, "o", "\u001b[?2004h"]
[270.308265, "o", "> "]
[270.308392, "o", "        merged[entry.name] = entry;\r\n\u001b[?2004l\r"]
[270.308422, "o", "\u001b[?2004h"]
[270.308434, "o", "> "]
[270.308536, "o", "    }\r\n\u001b[?2004l\r"]
[270.308558, "o", "\u001b[?2004h> "]
