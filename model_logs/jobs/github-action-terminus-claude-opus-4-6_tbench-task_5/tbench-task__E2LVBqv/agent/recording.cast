[195.48859, "i", "cat > /app/environment/n21/extra_n2.cpp << 'EOF'\n#include \"types.h\"\n#include <sstream>\n\nnamespace forge {\n\nstd::string n21_header_serial(int schema_version, const std::string &release_id, int base,\n                              int pass_epoch, int64_t drift_total, int64_t weight_total) {\n    std::ostringstream os;\n    os << schema_version << '|' << release_id << '|' << base << '|' << pass_epoch << '|'\n       << drift_total << '|' << weight_total;\n    return os.str();\n}\n\n}\nEOF\n"]
[195.488901, "o", "cat > /app/environment/n21/extra_n2.cpp << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h"]
[195.489082, "o", "> "]
[195.489356, "o", "#include \"types.h\"\r\n\u001b[?2004l\r\u001b[?2004h> #include <sstream>\r\n\u001b[?2004l\r"]
[195.489468, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> namespace forge {\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[195.492648, "o", "std::string n21_header_serial(int schema_version, const std::string &release_id, int base,\r\n\u001b[?2004l\r\u001b[?2004h>                               int pass_epoch, int64_t drift_total, int64_t weight_total) {\r\n\u001b[?2004l\r\u001b[?2004h>     std::ostringstream os;\r\n\u001b[?2004l\r\u001b[?2004h>     os << schema_version << '|' << release_id << '|' << base << '|' << pass_epoch << '|'\r\n\u001b[?2004l\r\u001b[?2004h>        << drift_total << '|' << weight_total;\r\n\u001b[?2004l\r\u001b[?2004h>     return os.str();\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r\u001b[?2004hroot@dbf8340e129b:/app# "]
[195.597502, "i", "cat > /app/environment/f12/k8_rank_slot.cpp << 'EOF'\n#include \"types.h\"\n#include <cstring>\n#include <string>\n#include <vector>\n\nstatic int f12_array_rank(const char *target, const char *const *names, size_t count) {\n    for (size_t i = 0; i < count; ++i) {\n        if (strcmp(names[i], target) == 0) {\n            return static_cast<int>(i);\n        }\n    }\n    return 0;\n}\n\nstatic int64_t k8_rank_slot(int base, int rank, int64_t record_bytes) {\n    return static_cast<int64_t>(base) * (static_cast<int64_t>(rank) + 1) + record_bytes;\n}\n\nextern \"C\" int64_t f12_slot_total(const char *target, const char *const *names, size_t count, int base,\n                                  int64_t record_bytes) {\n    int rank = f12_array_rank(target, names, count);\n    return k8_rank_slot(base, rank, record_bytes);\n}\nEOF\n"]
[195.597585, "o", "cat > /app/environment/f12/k8_rank_slot.cpp << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> #include \"types.h\"\r\n\u001b[?2004l\r\u001b[?2004h> #include <cstring>\r\n\u001b[?2004l\r\u001b[?2004h> #include <string>\r\n\u001b[?2004l\r\u001b[?2004h> #include <vector>\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[195.597845, "o", "static int f12_array_rank(const char *target, const char *const *names, size_t count) {\r\n"]
[195.598101, "o", "\u001b[?2004l\r"]
