[270.302745, "o", "        return state;\r\n\u001b[?2004l\r"]
[270.302773, "o", "\u001b[?2004h> "]
[270.302825, "o", "    }\r\n\u001b[?2004l\r"]
[270.302846, "o", "\u001b[?2004h> "]
[270.303012, "o", "    size_t arr_start = doc.find('[', units_pos);\r\n\u001b[?2004l\r"]
[270.303073, "o", "\u001b[?2004h> "]
[270.303206, "o", "    size_t arr_end = doc.find(']', arr_start);\r\n\u001b[?2004l\r"]
[270.303305, "o", "\u001b[?2004h> "]
[270.303481, "o", "    if (arr_start == std::string::npos || arr_end == std::string::npos) {\r\n\u001b[?2004l\r"]
[270.30358, "o", "\u001b[?2004h> "]
