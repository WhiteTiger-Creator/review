[270.298705, "o", "\u001b[?2004h"]
[270.298742, "o", "> "]
[270.298918, "o", "    if (on_disk_token == nullptr || expected_token == nullptr) {\r\n\u001b[?2004l\r"]
[270.298966, "o", "\u001b[?2004h> "]
[270.29903, "o", "        return 0;\r\n\u001b[?2004l\r"]
[270.29906, "o", "\u001b[?2004h"]
[270.299073, "o", "> "]
[270.299104, "o", "    }\r\n\u001b[?2004l\r"]
[270.299157, "o", "\u001b[?2004h> "]
[270.299388, "o", "    return std::string(on_disk_token) == std::string(expected_token) ? 1 : 0;\r\n\u001b[?2004l\r"]
[270.299439, "o", "\u001b[?2004h"]
