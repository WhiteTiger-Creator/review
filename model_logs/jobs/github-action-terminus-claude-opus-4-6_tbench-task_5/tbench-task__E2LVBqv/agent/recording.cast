[270.307343, "o", "\u001b[?2004h"]
[270.307362, "o", "> "]
[270.307521, "o", "        for (const auto &pair : existing.units) {\r\n\u001b[?2004l\r"]
[270.30755, "o", "\u001b[?2004h"]
[270.307563, "o", "> "]
