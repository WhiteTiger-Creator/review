[348.42555, "o", "        spec.manifest_bytes = pick_int(block, \"manifest_bytes\");\r\n\u001b[?2004l\r"]
[348.425571, "o", "\u001b[?2004h"]
[348.425632, "o", "> "]
[348.42592, "o", "        spec.start_pass = pick_int(block, \"start_pass\");\r\n\u001b[?2004l\r"]
[348.425975, "o", "\u001b[?2004h> "]
[348.426159, "o", "        if (!spec.name.empty()) {\r\n\u001b[?2004l\r"]
[348.426254, "o", "\u001b[?2004h> "]
[348.426463, "o", "            manifest.units.push_back(spec);\r\n\u001b[?2004l\r"]
[348.426546, "o", "\u001b[?2004h> "]
[348.426629, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[348.42672, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[348.426839, "o", "    return manifest;\r\n\u001b[?2004l\r"]
[348.426863, "o", "\u001b[?2004h"]
[348.42698, "o", "> }\r\n\u001b[?2004l\r"]
[348.426996, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[348.427218, "o", "std::string digest_hex(const std::string &text) {\r\n\u001b[?2004l\r"]
[348.42734, "o", "\u001b[?2004h"]
[348.427427, "o", "> "]
[348.427604, "o", "    std::uint64_t h = digest_update(kDigestSeed, text);\r\n\u001b[?2004l\r"]
[348.427634, "o", "\u001b[?2004h> "]
[348.427822, "o", "    std::ostringstream os;\r\n\u001b[?2004l\r"]
[348.427918, "o", "\u001b[?2004h> "]
[348.428333, "o", "    os << std::hex << std::nouppercase << std::setfill('0') << std::setw(16) << h;\r\n\u001b[?2004l\r"]
[348.428357, "o", "\u001b[?2004h"]
[348.428404, "o", "> "]
[348.428533, "o", "    return os.str();\r\n\u001b[?2004l\r"]
[348.428557, "o", "\u001b[?2004h"]
[348.428653, "o", "> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[348.42876, "o", "\u001b[?2004h"]
[348.428874, "o", "> "]
[348.429279, "o", "UnitRun analyze_unit(const UnitSpec &spec, int order_rank, int order_weight_base, int pass_epoch,\r\n\u001b[?2004l\r"]
[348.429354, "o", "\u001b[?2004h> "]
[348.429831, "o", "                     const fs::path &manifest_dir, const char *const *names, size_t name_count,\r\n\u001b[?2004l\r"]
[348.429891, "o", "\u001b[?2004h> "]
[348.430298, "o", "                     const LaneCheckpoint *checkpoint, int64_t carry_weight) {\r\n\u001b[?2004l\r"]
[348.430361, "o", "\u001b[?2004h> "]
[348.430491, "o", "    (void)carry_weight;\r\n\u001b[?2004l\r"]
[348.430557, "o", "\u001b[?2004h> "]
[348.430816, "o", "    fs::path record_path = manifest_dir / spec.record;\r\n\u001b[?2004l\r"]
[348.43088, "o", "\u001b[?2004h> "]
[348.430992, "o", "    UnitRun run{};\r\n\u001b[?2004l\r\u001b[?2004h"]
[348.431048, "o", "> "]
[348.431129, "o", "    run.name = spec.name;\r\n\u001b[?2004l\r"]
[348.431191, "o", "\u001b[?2004h> "]
[348.431485, "o", "    run.mode = forge_lane_mode(spec.mode.c_str(), spec.name.c_str(), pass_epoch);\r\n\u001b[?2004l\r"]
[348.43156, "o", "\u001b[?2004h> "]
[348.431728, "o", "    run.manifest_bytes = spec.manifest_bytes;\r\n\u001b[?2004l\r"]
[348.43175, "o", "\u001b[?2004h"]
[348.431773, "o", "> "]
[348.432039, "o", "    run.record_bytes = read_record_bytes(record_path);\r\n\u001b[?2004l\r"]
[348.4321, "o", "\u001b[?2004h> "]
[348.432492, "o", "    run.drift_bytes = run.record_bytes - static_cast<int64_t>(run.manifest_bytes);\r\n\u001b[?2004l\r\u001b[?2004h"]
[348.432613, "o", "> "]
[348.432726, "o", "    run.order_rank = order_rank;\r\n\u001b[?2004l\r"]
[348.432779, "o", "\u001b[?2004h> \r\n\u001b[?2004l\ri"]
[348.43288, "o", "\u001b[?2004h> "]
[348.43303, "o", "    int pass_index = spec.start_pass;\r\n\u001b[?2004l\r"]
[348.433085, "o", "\u001b[?2004h> "]
[348.433273, "o", "    bool has_checkpoint_entry = false;\r\n\u001b[?2004l\r"]
[348.433376, "o", "\u001b[?2004h> "]
[348.433522, "o", "    int64_t stored_carry_weight = 0;\r\n\u001b[?2004l\r"]
[348.433574, "o", "\u001b[?2004h> "]
[348.433991, "o", "    if (run.mode == \"resume\" && checkpoint != nullptr && checkpoint->valid) {\r\n\u001b[?2004l\r"]
[348.43409, "o", "\u001b[?2004h> "]
[348.434325, "o", "        auto it = checkpoint->units.find(spec.name);\r\n\u001b[?2004l\r"]
[348.434406, "o", "\u001b[?2004h> "]
[348.43456, "o", "        if (it != checkpoint->units.end()) {\r\n\u001b[?2004l\r"]
[348.434631, "o", "\u001b[?2004h> "]
[348.434834, "o", "            pass_index = it->second.next_pass;\r\n\u001b[?2004l\r"]
[348.434853, "o", "\u001b[?2004h"]
[348.434862, "o", "> "]
[348.435145, "o", "            stored_carry_weight = it->second.carry_weight;\r\n\u001b[?2004l\r"]
[348.435191, "o", "\u001b[?2004h> "]
[348.435359, "o", "            has_checkpoint_entry = true;\r\n\u001b[?2004l\r"]
[348.435376, "o", "\u001b[?2004h"]
[348.435385, "o", "> "]
[348.435478, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[348.435591, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[348.43569, "o", "\u001b[?2004h> "]
[348.435868, "o", "    if (run.mode == \"resume\" && has_checkpoint_entry) {\r\n\u001b[?2004l\r"]
[348.43597, "o", "\u001b[?2004h> "]
[348.436387, "o", "        run.order_weight = stored_carry_weight + static_cast<int64_t>(order_weight_base) + run.record_bytes;\r\n\u001b[?2004l\r"]
[348.436476, "o", "\u001b[?2004h"]
[348.436538, "o", ">     } else {\r\n\u001b[?2004l\r"]
[348.436594, "o", "\u001b[?2004h> "]
[348.437085, "o", "        run.order_weight = static_cast<int64_t>(order_weight_base) * (static_cast<int64_t>(order_rank) + 1) + run.record_bytes;\r\n\u001b[?2004l\r"]
[348.437116, "o", "\u001b[?2004h> "]
[348.437146, "o", "    }\r\n\u001b[?2004l\r"]
[348.437261, "o", "\u001b[?2004h> "]
[348.437384, "o", "    run.pass_index = pass_index;\r\n\u001b[?2004l\r"]
[348.437443, "o", "\u001b[?2004h> "]
[348.437642, "o", "    run.row_serial = forge_lane_row_text(run);\r\n\u001b[?2004l\r"]
[348.437703, "o", "\u001b[?2004h> "]
[348.437904, "o", "    run.row_digest = digest_hex(run.row_serial);\r\n\u001b[?2004l\r"]
[348.437993, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r)\u001b[?2004h> "]
[348.438098, "o", "    std::ostringstream js;\r\n\u001b[?2004l\r"]
[348.438162, "o", "\u001b[?2004h> "]
[348.438527, "o", "    js << \"{\\\"name\\\":\\\"\" << json_escape(run.name) << \"\\\",\\\"mode\\\":\\\"\" << json_escape(run.mode)\r\n\u001b[?2004l\r"]
[348.438611, "o", "\u001b[?2004h> "]
[348.438957, "o", "       << \"\\\",\\\"pass_index\\\":\" << run.pass_index << \",\\\"manifest_bytes\\\":\" << run.manifest_bytes\r\n\u001b[?2004l\r"]
[348.439038, "o", "\u001b[?2004h> "]
[348.439369, "o", "       << \",\\\"record_bytes\\\":\" << run.record_bytes << \",\\\"drift_bytes\\\":\" << run.drift_bytes\r\n\u001b[?2004l\r"]
[348.439453, "o", "\u001b[?2004h"]
[348.439508, "o", "> "]
[348.439845, "o", "       << \",\\\"order_rank\\\":\" << run.order_rank << \",\\\"order_weight\\\":\" << run.order_weight\r\n\u001b[?2004l\r"]
[348.439933, "o", "\u001b[?2004h> "]
[348.440139, "o", "       << \",\\\"row_digest\\\":\\\"\" << run.row_digest << \"\\\"}\";\r\n\u001b[?2004l\r"]
[348.440202, "o", "\u001b[?2004h"]
[348.440257, "o", "> "]
[348.440342, "o", "    run.json = js.str();\r\n\u001b[?2004l\r"]
[348.44036, "o", "\u001b[?2004h"]
[348.440432, "o", "> "]
[348.440506, "o", "    return run;\r\n\u001b[?2004l\r"]
[348.440531, "o", "\u001b[?2004h> }\r\n"]
[348.440547, "o", "\u001b[?2004l\r"]
[348.440613, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[348.440641, "o", "\u001b[?2004h> "]
[348.440765, "o", "}  // namespace forge\r\n\u001b[?2004l\r"]
[348.440786, "o", "\u001b[?2004h"]
[348.440795, "o", "> \r\n"]
[348.440806, "o", "\u001b[?2004l\r"]
[348.440914, "o", "\u001b[?2004h> "]
[348.441078, "o", "int forge_run_emit(int argc, char **argv) {\r\n\u001b[?2004l\r"]
[348.441097, "o", "\u001b[?2004h"]
[348.441106, "o", "> "]
[348.441237, "o", "    if (argc != 4) {\r\n\u001b[?2004l\r"]
[348.441258, "o", "\u001b[?2004h> "]
[348.441637, "o", "        std::cerr << \"usage: forge_emit <manifest-json> <output-json> <units-csv>\\n\";\r\n\u001b[?2004l\r"]
[348.441657, "o", "\u001b[?2004h"]
[348.441684, "o", "> "]
[348.441781, "o", "        return 2;\r\n\u001b[?2004l\r"]
[348.441804, "o", "\u001b[?2004h"]
[348.441821, "o", "> "]
[348.441927, "o", "    }\r\n"]
[348.441963, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[348.442104, "o", "    fs::path manifest_path = argv[1];\r\n\u001b[?2004l\r"]
[348.44219, "o", "\u001b[?2004h"]
[348.442209, "o", "> "]
[348.442319, "o", "    fs::path output_path = argv[2];\r\n\u001b[?2004l\r"]
[348.442391, "o", "\u001b[?2004h"]
[348.442446, "o", "> "]
[348.442709, "o", "    std::vector<std::string> requested = forge::split_units_csv(argv[3]);\r\n\u001b[?2004l\r"]
[348.442823, "o", "\u001b[?2004h> "]
[348.443076, "o", "    forge::Manifest manifest = forge::load_manifest(manifest_path);\r\n\u001b[?2004l\r"]
[348.443201, "o", "\u001b[?2004h> "]
[348.443401, "o", "    fs::path manifest_dir = manifest_path.parent_path();\r\n\u001b[?2004l\r"]
[348.443514, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[348.443903, "o", "    const char *lane_token = forge_lane_fingerprint(manifest.units.data(), manifest.units.size());\r\n\u001b[?2004l\r"]
[348.443995, "o", "\u001b[?2004h> "]
[348.444109, "o", "    std::string lane_token_str(lane_token);\r\n\u001b[?2004l\r"]
[348.444194, "o", "\u001b[?2004h> "]
[348.444343, "o", "    fs::path checkpoint_path = forge::kCheckpointPath;\r\n\u001b[?2004l\r"]
[348.444367, "o", "\u001b[?2004h"]
[348.444381, "o", "> "]
[348.444618, "o", "    int pass_epoch = forge::read_pass_epoch(checkpoint_path, lane_token_str);\r\n\u001b[?2004l\r"]
[348.444638, "o", "\u001b[?2004h"]
[348.44469, "o", "> "]
[348.444945, "o", "    forge::LaneCheckpoint checkpoint = forge_lane_load_checkpoint(checkpoint_path, lane_token_str);\r\n\u001b[?2004l\r"]
[348.444964, "o", "\u001b[?2004h"]
[348.445012, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[348.445029, "o", "> "]
[348.445167, "o", "    std::vector<const char *> name_ptrs;\r\n\u001b[?2004l\r"]
[348.445185, "o", "\u001b[?2004h"]
[348.445235, "o", "> "]
[348.445352, "o", "    for (const auto &unit : manifest.units) {\r\n\u001b[?2004l\r"]
[348.445371, "o", "\u001b[?2004h"]
[348.44542, "o", "> "]
[348.445541, "o", "        name_ptrs.push_back(unit.name.c_str());\r\n\u001b[?2004l\r"]
[348.44556, "o", "\u001b[?2004h"]
[348.445612, "o", ">     }\r\n\u001b[?2004l\r"]
[348.445629, "o", "\u001b[?2004h"]
[348.445639, "o", "> \r\n"]
[348.445652, "o", "\u001b[?2004l\r"]
[348.445714, "o", "\u001b[?2004h> "]
[348.445872, "o", "    std::map<std::string, forge::UnitSpec> spec_by_name;\r\n\u001b[?2004l\r"]
[348.445935, "o", "\u001b[?2004h"]
[348.44595, "o", "> "]
[348.446069, "o", "    for (const auto &unit : manifest.units) {\r\n\u001b[?2004l\r"]
[348.446088, "o", "\u001b[?2004h"]
[348.446141, "o", "> "]
[348.446241, "o", "        spec_by_name[unit.name] = unit;\r\n\u001b[?2004l\r"]
[348.446257, "o", "\u001b[?2004h"]
[348.446272, "o", "> "]
[348.446327, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[348.446345, "o", "> \r\n\u001b[?2004l\r"]
[348.44639, "o", "\u001b[?2004h> "]
[348.446516, "o", "    std::vector<forge::UnitRun> units;\r\n\u001b[?2004l\r"]
[348.446532, "o", "\u001b[?2004h"]
[348.446546, "o", "> "]
[348.446723, "o", "    std::vector<forge::UnitCheckpoint> updated_entries;\r\n\u001b[?2004l\r"]
[348.44674, "o", "\u001b[?2004h"]
[348.44675, "o", "> "]
[348.446906, "o", "    std::vector<std::string> requested_resume;\r\n\u001b[?2004l\r"]
[348.446923, "o", "\u001b[?2004h"]
[348.446934, "o", "> "]
[348.447073, "o", "    for (const auto &name : requested) {\r\n\u001b[?2004l\r"]
[348.44709, "o", "\u001b[?2004h"]
[348.447101, "o", "> "]
[348.447246, "o", "        auto it = spec_by_name.find(name);\r\n\u001b[?2004l\r"]
[348.447263, "o", "\u001b[?2004h"]
[348.447312, "o", "> "]
[348.447416, "o", "        if (it == spec_by_name.end()) {\r\n\u001b[?2004l\r"]
[348.447433, "o", "\u001b[?2004h"]
[348.447447, "o", "> "]
[348.447543, "o", "            continue;\r\n\u001b[?2004l\r"]
[348.447618, "o", "\u001b[?2004h>         }\r\n\u001b[?2004l\r"]
[348.447694, "o", "\u001b[?2004h> "]
[348.447825, "o", "        int order_rank = static_cast<int>(std::distance(\r\n\u001b[?2004l\r"]
[348.447893, "o", "\u001b[?2004h> "]
[348.447997, "o", "            manifest.units.begin(),\r\n\u001b[?2004l\r"]
[348.448089, "o", "\u001b[?2004h"]
[348.448166, "o", "> "]
[348.448258, "o", "            std::find_if(manifest.units.begin(), manifest.units.end(),\r\n\u001b[?2004l\r"]
[348.448276, "o", "\u001b[?2004h"]
[348.448344, "o", "> "]
[348.448569, "o", "                         [&](const forge::UnitSpec &u) { return u.name == name; })));\r\n\u001b[?2004l\r"]
[348.448616, "o", "\u001b[?2004h"]
[348.448657, "o", "> "]
[348.448915, "o", "        forge::UnitRun run = forge::analyze_unit(it->second, order_rank, manifest.order_weight_base,\r\n\u001b[?2004l\r"]
[348.448992, "o", "\u001b[?2004h> "]
[348.449219, "o", "                                                 pass_epoch, manifest_dir, name_ptrs.data(),\r\n\u001b[?2004l\r"]
[348.449281, "o", "\u001b[?2004h> "]
[348.449511, "o", "                                                 name_ptrs.size(), &checkpoint, 0);\r\n\u001b[?2004l\r"]
[348.449577, "o", "\u001b[?2004h> "]
[348.449666, "o", "        units.push_back(run);\r\n\u001b[?2004l\r"]
[348.449741, "o", "\u001b[?2004h> "]
[348.449816, "o", "        if (run.mode == \"resume\") {\r\n\u001b[?2004l\r"]
[348.449878, "o", "\u001b[?2004h> "]
[348.450009, "o", "            requested_resume.push_back(name);\r\n\u001b[?2004l\r"]
[348.45008, "o", "\u001b[?2004h"]
[348.450143, "o", "> "]
[348.450208, "o", "            forge::UnitCheckpoint entry;\r\n\u001b[?2004l\r"]
[348.450277, "o", "\u001b[?2004h> "]
[348.450355, "o", "            entry.name = run.name;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[348.450509, "o", "            entry.next_pass = run.pass_index + 1;\r\n\u001b[?2004l\r"]
[348.450552, "o", "\u001b[?2004h> "]
[348.450704, "o", "            entry.carry_weight = run.order_weight;\r\n\u001b[?2004l\r"]
[348.450722, "o", "\u001b[?2004h"]
[348.450738, "o", "> "]
[348.450907, "o", "            entry.carry_drift = run.drift_bytes;\r\n\u001b[?2004l\r"]
[348.450962, "o", "\u001b[?2004h"]
[348.450979, "o", "> "]
[348.451105, "o", "            updated_entries.push_back(entry);\r\n\u001b[?2004l\r"]
[348.451155, "o", "\u001b[?2004h"]
[348.451172, "o", ">         }\r\n"]
[348.451184, "o", "\u001b[?2004l\r"]
[348.451238, "o", "\u001b[?2004h> "]
[348.451274, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[348.451311, "o", "> \r\n\u001b[?2004l\r"]
[348.451327, "o", "\u001b[?2004h"]
[348.451369, "o", "> "]
[348.45158, "o", "    int64_t drift_total = forge_lane_drift_total(units.data(), units.size());\r\n\u001b[?2004l\r"]
[348.451626, "o", "\u001b[?2004h"]
[348.451643, "o", "> "]
[348.451853, "o", "    int64_t weight_total = forge_lane_score_total(units.data(), units.size());\r\n\u001b[?2004l\r"]
[348.45191, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[348.451996, "o", "\u001b[?2004h> "]
[348.452068, "o", "    std::ostringstream serial;\r\n\u001b[?2004l\r\u001b[?2004h"]
[348.45214, "o", "> "]
[348.452333, "o", "    serial << forge_lane_header_text(forge::kSchemaVersion, manifest.release_id,\r\n\u001b[?2004l\r"]
[348.452386, "o", "\u001b[?2004h> "]
[348.45264, "o", "                                     manifest.order_weight_base, pass_epoch, drift_total,\r\n\u001b[?2004l\r"]
[348.452691, "o", "\u001b[?2004h> "]
[348.452842, "o", "                                     weight_total);\r\n\u001b[?2004l\r"]
[348.452889, "o", "\u001b[?2004h> "]
[348.453012, "o", "    for (const auto &unit : units) {\r\n\u001b[?2004l\r"]
[348.453052, "o", "\u001b[?2004h> "]
[348.453194, "o", "        serial << '\\n' << unit.row_serial;\r\n\u001b[?2004l\r"]
[348.45321, "o", "\u001b[?2004h"]
[348.453231, "o", "> "]
[348.453274, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[348.453299, "o", "> "]
[348.453495, "o", "    std::string top_digest = forge::digest_hex(serial.str());\r\n\u001b[?2004l\r"]
[348.453514, "o", "\u001b[?2004h"]
[348.453534, "o", "> \r\n\u001b[?2004l\r"]
[348.453641, "o", "\u001b[?2004h> "]
[348.453756, "o", "    fs::create_directories(output_path.parent_path());\r\n\u001b[?2004l\r"]
[348.453819, "o", "\u001b[?2004h> "]
[348.453894, "o", "    std::ostringstream out;\r\n\u001b[?2004l\r"]
[348.453941, "o", "\u001b[?2004h> "]
[348.454187, "o", "    out << \"{\\\"schema_version\\\":\" << forge::kSchemaVersion << \",\\\"release_id\\\":\\\"\"\r\n\u001b[?2004l\r"]
[348.454205, "o", "\u001b[?2004h> "]
[348.454486, "o", "        << manifest.release_id << \"\\\",\\\"order_weight_base\\\":\" << manifest.order_weight_base\r\n\u001b[?2004l\r"]
[348.454501, "o", "\u001b[?2004h"]
[348.454564, "o", "> "]
[348.454717, "o", "        << \",\\\"pass_epoch\\\":\" << pass_epoch << \",\\\"units\\\":[\";\r\n\u001b[?2004l\r"]
[348.454737, "o", "\u001b[?2004h"]
[348.454838, "o", "> "]
[348.45494, "o", "    for (std::size_t i = 0; i < units.size(); ++i) {\r\n\u001b[?2004l\r"]
[348.455023, "o", "\u001b[?2004h> "]
[348.45505, "o", "        if (i) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[348.455102, "o", "> "]
[348.455157, "o", "            out << ',';\r\n\u001b[?2004l\r"]
[348.455202, "o", "\u001b[?2004h> "]
[348.455245, "o", "        }\r\n\u001b[?2004l\r"]
[348.455261, "o", "\u001b[?2004h"]
[348.45531, "o", "> "]
[348.455389, "o", "        out << units[i].json;\r\n\u001b[?2004l\r"]
[348.455405, "o", "\u001b[?2004h"]
[348.45542, "o", "> "]
[348.455475, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[348.455493, "o", "> "]
[348.455758, "o", "    out << \"],\\\"total_drift_bytes\\\":\" << drift_total << \",\\\"order_score\\\":\" << weight_total\r\n\u001b[?2004l\r"]
[348.455774, "o", "\u001b[?2004h"]
[348.455787, "o", "> "]
[348.455959, "o", "        << \",\\\"digest\\\":\\\"\" << top_digest << \"\\\"}\\n\";\r\n\u001b[?2004l\r"]
[348.45599, "o", "\u001b[?2004h"]
[348.456002, "o", "> "]
[348.456176, "o", "    std::ofstream file(output_path, std::ios::binary);\r\n\u001b[?2004l\r"]
[348.456196, "o", "\u001b[?2004h"]
[348.456245, "o", "> "]
[348.456312, "o", "    file << out.str();\r\n\u001b[?2004l\r"]
[348.456327, "o", "\u001b[?2004h"]
[348.456338, "o", "> "]
[348.456419, "o", "    file.close();\r\n\u001b[?2004l\r"]
[348.456435, "o", "\u001b[?2004h"]
[348.456444, "o", "> \r\n"]
[348.456459, "o", "\u001b[?2004l\r"]
[348.456523, "o", "\u001b[?2004h> "]
[348.456673, "o", "    // Merge checkpoint entries preserving existing\r\n\u001b[?2004l\r"]
[348.45669, "o", "\u001b[?2004h"]
[348.456705, "o", "> "]
[348.456861, "o", "    std::vector<forge::UnitCheckpoint> merged =\r\n\u001b[?2004l\r"]
[348.456878, "o", "\u001b[?2004h"]
[348.456891, "o", "> "]
[348.457141, "o", "        forge_lane_merge_checkpoint(checkpoint, updated_entries, requested_resume);\r\n\u001b[?2004l\r"]
[348.45716, "o", "\u001b[?2004h"]
[348.457209, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[348.457282, "o", "> "]
[348.457359, "o", "    // Write checkpoint with pass_epoch\r\n\u001b[?2004l\r"]
[348.457376, "o", "\u001b[?2004h"]
[348.457389, "o", "> "]
[348.457605, "o", "    fs::create_directories(fs::path(checkpoint_path).parent_path());\r\n\u001b[?2004l\r"]
[348.457621, "o", "\u001b[?2004h"]
[348.457634, "o", "> "]
[348.457749, "o", "    std::ostringstream cp_out;\r\n\u001b[?2004l\r"]
[348.457765, "o", "\u001b[?2004h"]
[348.457779, "o", "> "]
[348.458034, "o", "    cp_out << \"{\\\"schema_version\\\":\" << forge::kSchemaVersion << \",\\\"lane_token\\\":\\\"\"\r\n\u001b[?2004l\r"]
[348.458051, "o", "\u001b[?2004h"]
[348.458064, "o", "> "]
[348.458335, "o", "           << lane_token_str << \"\\\",\\\"pass_epoch\\\":\" << (pass_epoch + 1) << \",\\\"units\\\":[\";\r\n\u001b[?2004l\r"]
[348.458385, "o", "\u001b[?2004h> "]
[348.458533, "o", "    for (size_t i = 0; i < merged.size(); ++i) {\r\n\u001b[?2004l\r"]
[348.458582, "o", "\u001b[?2004h> "]
[348.458649, "o", "        if (i) {\r\n\u001b[?2004l\r"]
[348.458667, "o", "\u001b[?2004h"]
[348.458716, "o", "> "]
[348.458787, "o", "            cp_out << ',';\r\n\u001b[?2004l\r"]
[348.458803, "o", "\u001b[?2004h"]
[348.458817, "o", "> "]
[348.458872, "o", "        }\r\n\u001b[?2004l\r"]
[348.458888, "o", "\u001b[?2004h"]
[348.458902, "o", "> "]
[348.459185, "o", "        cp_out << \"{\\\"name\\\":\\\"\" << merged[i].name << \"\\\",\\\"next_pass\\\":\" << merged[i].next_pass\r\n\u001b[?2004l\r"]
[348.459204, "o", "\u001b[?2004h"]
[348.459217, "o", "> "]
[348.459478, "o", "               << \",\\\"carry_weight\\\":\" << merged[i].carry_weight << \",\\\"carry_drift\\\":\"\r\n\u001b[?2004l\r"]
[348.459496, "o", "\u001b[?2004h"]
[348.459508, "o", "> "]
[348.459666, "o", "               << merged[i].carry_drift << '}';\r\n\u001b[?2004l\r"]
[348.459683, "o", "\u001b[?2004h"]
[348.459693, "o", "> "]
[348.459751, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[348.459768, "o", "> "]
[348.459859, "o", "    cp_out << \"]}\\n\";\r\n\u001b[?2004l\r"]
[348.459924, "o", "\u001b[?2004h> "]
[348.460096, "o", "    std::ofstream cp_file(checkpoint_path, std::ios::binary);\r\n\u001b[?2004l\r"]
[348.460113, "o", "\u001b[?2004h"]
[348.460127, "o", "> "]
[348.460233, "o", "    cp_file << cp_out.str();\r\n\u001b[?2004l\r"]
[348.46025, "o", "\u001b[?2004h"]
[348.46026, "o", "> "]
[348.460364, "o", "    cp_file.close();\r\n\u001b[?2004l\r"]
[348.460432, "o", "\u001b[?2004h> "]
[348.460481, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[348.460563, "o", "    return 0;\r\n\u001b[?2004l\r"]
[348.460615, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h"]
