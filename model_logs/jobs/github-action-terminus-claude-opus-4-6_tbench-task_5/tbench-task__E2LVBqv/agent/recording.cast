[270.301806, "o", "\u001b[?2004h"]
[270.301821, "o", "> "]
[270.302069, "o", "    if (!m14_checkpoint_valid(state.lane_token.c_str(), expected_token.c_str())) {\r\n\u001b[?2004l\r"]
[270.302136, "o", "\u001b[?2004h> "]
