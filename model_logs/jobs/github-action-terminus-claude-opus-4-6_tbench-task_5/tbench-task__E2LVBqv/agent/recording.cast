[270.313057, "o", "\u001b[?2004h"]
[270.313112, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[270.313137, "o", "> "]
[270.313238, "o", "    out << \"]}\\n\";\r\n\u001b[?2004l\r\u001b[?2004h> "]
