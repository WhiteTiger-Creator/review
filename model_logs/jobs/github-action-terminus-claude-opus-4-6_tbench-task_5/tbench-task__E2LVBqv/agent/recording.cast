[270.308652, "o", "\u001b[?2004h> "]
[270.308803, "o", "    std::vector<forge::UnitCheckpoint> out;\r\n\u001b[?2004l\r"]
[270.308884, "o", "\u001b[?2004h> "]
[270.308958, "o", "    for (const auto &pair : merged) {\r\n\u001b[?2004l\r"]
[270.309025, "o", "\u001b[?2004h"]
[270.309093, "o", "> "]
[270.309197, "o", "        out.push_back(pair.second);\r\n\u001b[?2004l\r\u001b[?2004h"]
[270.30925, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[270.309364, "o", "    std::sort(out.begin(), out.end(),\r\n\u001b[?2004l\r"]
[270.309386, "o", "\u001b[?2004h"]
[270.309404, "o", "> "]
