[653.199599, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[653.199634, "o", "\u001b[?2004h"]
[653.199648, "o", "> "]
[653.199766, "o", "def validate(path):\r\n\u001b[?2004l\r"]
