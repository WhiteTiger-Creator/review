[469.051971, "o", "  for (size_t i = 0; i < spins; i++) {\r\n\u001b[?2004l\r"]
[469.052018, "o", "\u001b[?2004h> "]
[469.052099, "o", "    uint64_t token = 0;\r\n\u001b[?2004l\r"]
[469.052146, "o", "\u001b[?2004h> "]
[469.052269, "o", "    if (!tb_q64_pop(&rt->in_q, &token))\r\n\u001b[?2004l\r"]
[469.052313, "o", "\u001b[?2004h> "]
[469.05237, "o", "      break;\r\n\u001b[?2004l\r"]
