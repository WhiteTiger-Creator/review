[653.200938, "o", "    completes = [e for e in evs if e['kind']=='complete']\r\n\u001b[?2004l\r"]
[653.200966, "o", "\u001b[?2004h> "]
[653.201204, "o", "    notifies = [e for e in evs if e['kind']=='notify']\r\n\u001b[?2004l\r\u001b[?2004h"]
[653.201306, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[653.201567, "o", "    # Same count\r\n\u001b[?2004l\r\u001b[?2004h> "]
[653.202235, "o", "    assert len(submits) == len(completes) == len(notifies), f\"Count mismatch: {len(submits)}/{len(completes)}/{len(notifies)}\"\r\n\u001b[?2004l\r"]
[653.202264, "o", "\u001b[?2004h"]
