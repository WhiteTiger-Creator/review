[489.937973, "i", "rm -f /app/run/state.bin && /usr/local/bin/arena --scenario stress2 --profile burst --order a_then_b --out /app/output/report2.json && python3 -c \"\nimport json, sys\nwith open('/app/output/report2.json') as f:\n    d = json.load(f)\nevs = d['events']\nsubmits = [e for e in evs if e['kind']=='submit']\ncompletes = [e for e in evs if e['kind']=='complete']\nnotifies = [e for e in evs if e['kind']=='notify']\nprint(f'submits={len(submits)} completes={len(completes)} notifies={len(notifies)}')\nsub_ids = [e['id'] for e in submits]\ncomp_ids = [e['id'] for e in completes]\nnotify_ids = [e['id'] for e in notifies]\nprint(f'unique sub_ids={len(set(sub_ids))} comp_ids={len(set(comp_ids))} notify_ids={len(set(notify_ids))}')\n# Check contiguous from 1\nsorted_subs = sorted(set(sub_ids))\nif sorted_subs == list(range(1, len(sorted_subs)+1)):\n    print('IDs contiguous from 1: OK')\nelse:\n    print(f'IDs NOT contiguous! min={min(sorted_subs)} max={max(sorted_subs)} count={len(sorted_subs)}')\n# Check every sub has complete and notify\nsu"]
[489.938105, "i", "b_set = set(sub_ids)\ncomp_set = set(comp_ids)\nnotify_set = set(notify_ids)\nmissing_comp = sub_set - comp_set\nmissing_notify = sub_set - notify_set\nextra_comp = comp_set - sub_set\nextra_notify = notify_set - sub_set\nprint(f'missing_comp={missing_comp}')\nprint(f'missing_notify={missing_notify}')\nprint(f'extra_comp={extra_comp}')\nprint(f'extra_notify={extra_notify}')\n# Check ordering: submit before complete before notify\nfirst_submit = {}\nfirst_complete = {}\nfirst_notify = {}\nfor i, e in enumerate(evs):\n    eid = e['id']\n    if e['kind'] == 'submit' and eid not in first_submit:\n        first_submit[eid] = i\n    elif e['kind'] == 'complete' and eid not in first_complete:\n        first_complete[eid] = i\n    elif e['kind'] == 'notify' and eid not in first_notify:\n        first_notify[eid] = i\norder_ok = True\nfor eid in sub_set:\n    if eid in first_complete and first_submit.get(eid, 999999) >= first_complete[eid]:\n        print(f'ORDER FAIL: submit after complete for id {eid}')\n        order_ok = False\n    if eid in"]
[489.938163, "i", " first_notify and first_complete.get(eid, 999999) >= first_notify[eid]:\n        print(f'ORDER FAIL: complete after notify for id {eid}')\n        order_ok = False\nif order_ok:\n    print('Ordering invariant: OK')\n# Check no duplicate (kind, id)\nfrom collections import Counter\npairs = [(e['kind'], e['id']) for e in evs]\ncounts = Counter(pairs)\ndupes = {k: v for k, v in counts.items() if v > 1}\nif dupes:\n    print(f'DUPLICATES: {dupes}')\nelse:\n    print('No duplicates: OK')\n# Check submits appear in order 1..N\nif sub_ids == list(range(1, len(sub_ids)+1)):\n    print('Submits in contiguous order: OK')\nelse:\n    print(f'Submits NOT in order 1..N')\nprint(f'Total events: {len(evs)}, expected 3*{len(submits)}={3*len(submits)}')\n\"\n"]
