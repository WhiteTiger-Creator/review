[469.054462, "o", "\u001b[?2004h"]
[469.054508, "o", "> "]
[469.054588, "o", "      // not ready, requeue at tail\r\n\u001b[?2004l\r"]
[469.054632, "o", "\u001b[?2004h"]
[469.054651, "o", "> "]
[469.054766, "o", "      if (!tb_q64_push(&rt->in_q, token))\r\n\u001b[?2004l\r"]
[469.054829, "o", "\u001b[?2004h> "]
[469.05491, "o", "        return TB_ERR_CORRUPT;\r\n\u001b[?2004l\r"]
