[653.199115, "i", "python3 << 'PYEOF'\nimport json, sys\nfrom collections import Counter\n\ndef validate(path):\n    with open(path) as f:\n        d = json.load(f)\n    evs = d['events']\n    submits = [e for e in evs if e['kind']=='submit']\n    completes = [e for e in evs if e['kind']=='complete']\n    notifies = [e for e in evs if e['kind']=='notify']\n    \n    # Same count\n    assert len(submits) == len(completes) == len(notifies), f\"Count mismatch: {len(submits)}/{len(completes)}/{len(notifies)}\"\n    \n    # Three events per id\n    assert len(evs) == 3 * len(submits), f\"Total events {len(evs)} != 3*{len(submits)}\"\n    \n    # IDs contiguous 1..N\n    sub_ids = [e['id'] for e in submits]\n    assert sub_ids == list(range(1, len(sub_ids)+1)), \"Submit IDs not 1..N\"\n    \n    # No duplicate (kind,id)\n    pairs = [(e['kind'], e['id']) for e in evs]\n    counts = Counter(pairs)\n    assert all(v == 1 for v in counts.values()), f\"Duplicates found\"\n    \n    # Coverage\n    sub_set = set(sub_ids)\n    comp_set = set(e['id'] for e in completes)\n    no"]
[653.199173, "i", "tify_set = set(e['id'] for e in notifies)\n    assert sub_set == comp_set == notify_set, \"ID coverage mismatch\"\n    \n    # Ordering\n    first = {}\n    for i, e in enumerate(evs):\n        key = (e['kind'], e['id'])\n        if key not in first:\n            first[key] = i\n    for eid in sub_set:\n        si = first[('submit', eid)]\n        ci = first[('complete', eid)]\n        ni = first[('notify', eid)]\n        assert si < ci < ni, f\"Order violation for id {eid}: s={si} c={ci} n={ni}\"\n    \n    # Interleaving\n    complete_positions = [i for i, e in enumerate(evs) if e['kind']=='complete']\n    submit_positions = [i for i, e in enumerate(evs) if e['kind']=='submit']\n    assert min(complete_positions) < max(submit_positions), \"No interleaving\"\n    \n    return len(submits)\n\nn = validate('/app/output/report.json')\nprint(f'report.json: PASS ({n} ids)')\nPYEOF\n"]
[653.199345, "o", "python3 << 'PYEOF'\r\n\u001b[?2004l\r\u001b[?2004h> "]
