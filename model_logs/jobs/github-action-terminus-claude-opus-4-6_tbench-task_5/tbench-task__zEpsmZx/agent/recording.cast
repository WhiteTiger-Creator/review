[653.20628, "o", "\u001b[?2004h"]
[653.206296, "o", "> "]
[653.206509, "o", "    assert sub_set == comp_set == notify_set, \"ID coverage mismatch\"\r\n\u001b[?2004l\r"]
[653.206547, "o", "\u001b[?2004h"]
[653.206591, "o", "> "]
[653.206663, "o", "    \r\n\u001b[?2004l\r"]
[653.20671, "o", "\u001b[?2004h> "]
[653.206768, "o", "    # Ordering\r\n\u001b[?2004l\r"]
