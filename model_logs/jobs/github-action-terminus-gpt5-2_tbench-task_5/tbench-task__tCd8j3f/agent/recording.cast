[64.629121, "i", "python3 - <<'PY'\nimport json\nfrom collections import defaultdict\np='/app/output/report.json'\nwith open(p) as f: r=json.load(f)\nev=r['events']\nby=defaultdict(list)\nfor i,e in enumerate(ev):\n    by[(e['kind'],e['id'])].append(i)\nmaxid=max((e['id'] for e in ev), default=0)\nprint('scenario',r.get('scenario'),'profile',r.get('profile'),'events',len(ev),'maxid',maxid)\n# submit ids contiguous and ordered\nsub_ids=[e['id'] for e in ev if e['kind']=='submit']\nprint('submits',len(sub_ids),'first10',sub_ids[:10],'last10',sub_ids[-10:])\ncontig_ok=(sub_ids==list(range(1,len(sub_ids)+1)))\nprint('submit_contiguous',contig_ok)\n# duplicates\nkdups=[k for k,v in by.items() if len(v)>1]\nprint('duplicate(kind,id)',len(kdups),kdups[:10])\n# missing per id\nbad=[]\nfor id in range(1,len(sub_ids)+1):\n    sub=by.get(('submit',id))\n    com=by.get(('complete',id))\n    noti=by.get(('notify',id))\n    if not(sub and com and noti):\n        bad.append((id,'missing',bool(sub),bool(com),bool(noti)))\n        continue\n    if not(sub[0] < com[0] < n"]
