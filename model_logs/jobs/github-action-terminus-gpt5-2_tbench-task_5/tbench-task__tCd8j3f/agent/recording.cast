[213.594202, "i", "python3 - <<'PY'\nimport json\nfrom collections import Counter\n\ndef ids(p):\n    r=json.load(open(p))\n    c=Counter((e['kind'] for e in r['events']))\n    subs=[e['id'] for e in r['events'] if e['kind']=='submit']\n    return len(subs),c\nfor p in ['/app/output/ord_a.json','/app/output/ord_b.json']:\n    print(p, ids(p))\nPY\n"]
