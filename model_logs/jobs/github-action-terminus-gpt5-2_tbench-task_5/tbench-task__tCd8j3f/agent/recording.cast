[49.025986, "i", "python3 - <<'PY'\nimport json\np='/app/output/report.json'\nwith open(p) as f: r=json.load(f)\nseen=set();\nfrom collections import defaultdict\nby=defaultdict(list)\nfor i,e in enumerate(r['events']):\n    by[(e['kind'],e['id'])].append(i)\nprint('scenario',r.get('scenario'),'profile',r.get('profile'),'events',len(r['events']))\n# check duplicates\ndups=[k for k,v in by.items() if len(v)>1]\nprint('dups',len(dups),dups[:10])\n# per-id ordering\nmaxid=max(e['id'] for e in r['events']) if r['events'] else 0\nbad=[]\nfor id in range(1,maxid+1):\n    sub=by.get(('submit',id))\n    com=by.get(('complete',id))\n    noti=by.get(('notify',id))\n    if not(sub and com and noti):\n        bad.append((id,'missing',bool(sub),bool(com),bool(noti)))\n        continue\n    if not(sub[0] < com[0] < noti[0]):\n        bad.append((id,'order',sub[0],com[0],noti[0]))\nprint('bad',len(bad))\nprint('bad sample',bad[:10])\nPY\n"]
