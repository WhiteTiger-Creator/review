[214.601393, "i", "python3 - <<'PY'\nimport json,subprocess,os\nfrom collections import defaultdict\n\ndef check(out,scenario,profile,order):\n    if os.path.exists(out): os.remove(out)\n    cmd=[\"/usr/local/bin/arena\",\"--scenario\",scenario,\"--profile\",profile,\"--order\",order,\"--out\",out]\n    r=subprocess.run(cmd,stdout=subprocess.PIPE,stderr=subprocess.PIPE)\n    if r.returncode!=0:\n        print('run failed',cmd,'rc',r.returncode)\n        print(r.stderr.decode())\n        return\n    ev=json.load(open(out))['events']\n    by=defaultdict(int)\n    for e in ev:\n        by[(e['kind'],e['id'])]+=1\n    subs=[e['id'] for e in ev if e['kind']=='submit']\n    ok_sub=(subs==list(range(1,len(subs)+1)))\n    dups=sum(1 for k,v in by.items() if v>1)\n    missing=0\n    for i in range(1,len(subs)+1):\n        if by[(\"submit\",i)]!=1 or by[(\"complete\",i)]!=1 or by[(\"notify\",i)]!=1:\n            missing+=1\n    print(scenario,profile,order,'events',len(ev),'N',len(subs),'sub_ok',ok_sub,'dups',dups,'missing',missing)\n\nfor sc in ['basic','stress','stress2']:\n  "]
[214.601454, "i", "for prof in ['steady','burst']:\n    for ord in ['a_then_b','b_then_a']:\n      check(f'/app/output/{sc}_{prof}_{ord}.json',sc,prof,ord)\nPY\n"]
