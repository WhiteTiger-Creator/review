[151.009048, "o", "/app/src/logic/nudge.c:5:tb_status tb_nudge_drain(tb_rt *rt, uint32_t tick) {\r\n/app/src/logic/nudge.c:11:  while (tb_q64_pop(&rt->notify_q, &token)) {\r\n/app/src/logic/settle.c:37:        if (!tb_q64_push(&rt->notify_q, token))\r\n/app/src/runtime/runtime.c:28:  if (!tb_q64_init(&rt->notify_q, 4096))\r\n/app/src/runtime/runtime.c:48:  tb_q64_free(&rt->notify_q);\r\n/app/src/runtime/runtime.c:107:    st = tb_nudge_drain(rt, tick);\r\n/app/src/runtime/runtime.c:120:    st = tb_nudge_drain(rt, sc.ticks + i);\r\n/app/include/logic/nudge.h:6:tb_status tb_nudge_drain(tb_rt *rt, uint32_t tick);\r\n/app/include/runtime/runtime.h:31:  tb_q64 notify_q;\r\n\u001b[?2004hroot@0d4ff0619871:/app# "]
