[208.59754, "i", "python3 - <<'PY'\nimport hashlib,subprocess,os,shlex\n\ndef run(out,scenario,profile,order):\n    if os.path.exists(out): os.remove(out)\n    cmd=f\"/usr/local/bin/arena --scenario {scenario} --profile {profile} --order {order} --out {out}\"\n    r=subprocess.run(cmd,shell=True,stdout=subprocess.PIPE,stderr=subprocess.PIPE)\n    if r.returncode!=0:\n        print('FAIL',cmd,'rc',r.returncode)\n        print(r.stderr.decode())\n        return None\n    b=open(out,'rb').read()\n    return hashlib.sha256(b).hexdigest(),len(b)\n\nh1=run('/app/output/det1.json','stress2','burst','a_then_b')\nh2=run('/app/output/det2.json','stress2','burst','a_then_b')\nprint('determinism',h1,h2,'same',h1==h2)\nha=run('/app/output/ord_a.json','stress2','burst','a_then_b')\nhb=run('/app/output/ord_b.json','stress2','burst','b_then_a')\nprint('order differs',ha,hb,'same',ha==hb)\nPY\n"]
