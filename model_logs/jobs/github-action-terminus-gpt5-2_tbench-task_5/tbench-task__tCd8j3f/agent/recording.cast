[68.633265, "o", "usage: arena --scenario <basic|stress|stress2> --profile <burst|steady> --order <a_then_b|b_then_a> --out <path> [--seed <n>]\r\ncli: bad_arg\r\nexit=2\r\nbad.json absent\r\n\u001b[?2004hroot@0d4ff0619871:/app# "]
[69.629191, "i", "sed -n '1,220p' /app/src/runtime/runtime.c\n"]
[69.629428, "o", "sed -n '1,220p' /app/src/runtime/runtime.c\r\n\u001b[?2004l\r"]
[69.630895, "o", "#include \"runtime/runtime.h\"\r\n\r\n#include \"core/idgen.h\"\r\n#include \"logic/ingest.h\"\r\n#include \"logic/link.h\"\r\n#include \"logic/merge.h\"\r\n#include \"logic/nudge.h\"\r\n#include \"logic/settle.h\"\r\n"]
[69.63093, "o", "\r\n#include <stdio.h>\r\n#include <string.h>\r\n\r\ntb_status tb_rt_init(tb_rt *rt, const char *journal_path) {\r\n  if (!rt || !journal_path)\r\n    return TB_ERR_BAD_ARG;\r\n  memset(rt, 0, sizeof(*rt));\r\n\r\n"]
[69.630943, "o", "  if (!tb_map_u64_init(&rt->token_to_id, 128))\r\n    return TB_ERR_OOM;\r\n"]
[69.630955, "o", "  if (!tb_map_u64_init(&rt->token_done, 128))\r\n"]
[69.630965, "o", "    return TB_ERR_OOM;\r\n  if (!tb_q64_init(&rt->in_q, 4096))\r\n"]
[69.630973, "o", "    return TB_ERR_OOM;\r\n"]
[69.630981, "o", "  if (!tb_q64_init(&rt->done_a, 4096))\r\n"]
[69.630993, "o", "    return TB_ERR_OOM;\r\n"]
[69.631015, "o", "  if (!tb_q64_init(&rt->done_b, 4096))\r\n    return TB_ERR_OOM;\r\n  if (!tb_q64_init(&rt->notify_q, 4096))\r\n    return TB_ERR_OOM;\r\n"]
[69.631044, "o", "  if (!tb_vec_ev_init(&rt->evlog, 2048))\r\n"]
[69.631118, "o", "    return TB_ERR_OOM;\r\n\r\n  rt->gen = 1;\r\n  rt->cursor = 1;\r\n  rt->attached = true;\r\n"]
[69.631138, "o", "  rt->journal_path = journal_path;\r\n  return TB_OK;\r\n}\r\n\r\nvoid tb_rt_free(tb_rt *rt) {\r\n  if (!rt)\r\n    return;\r\n  tb_map_u64_free(&rt->token_to_id);\r\n"]
[69.631168, "o", "  tb_map_u64_free(&rt->token_done);\r\n  tb_q64_free(&rt->in_q);\r\n  tb_q64_free(&rt->done_a);\r\n  tb_q64_free(&rt->done_b);\r\n  tb_q64_free(&rt->notify_q);\r\n  tb_vec_ev_free(&rt->evlog);\r\n}\r\n\r\nconst tb_vec_ev *tb_rt_events(const tb_rt *rt) { return &rt->evlog; }\r\n\r\n"]
[69.63118, "o", "static tb_status maybe_detach_attach(tb_rt *rt, const tb_script *sc, uint32_t tick) {\r\n  if (sc->detach_at && tick == sc->detach_at) {\r\n    return tb_link_detach(rt, tick);\r\n  }\r\n"]
[69.631189, "o", "  if (sc->detach_at && tick == sc->detach_at + sc->detach_len) {\r\n    return tb_link_attach(rt, tick);\r\n  }\r\n"]
[69.631196, "o", "  if (sc->detach2_at && tick == sc->detach2_at) {\r\n    return tb_link_detach(rt, tick);\r\n  }\r\n"]
[69.631208, "o", "  if (sc->detach2_at && tick == sc->detach2_at + sc->detach2_len) {\r\n    return tb_link_attach(rt, tick);\r\n  }\r\n  return TB_OK;\r\n"]
[69.631235, "o", "}\r\n\r\ntb_status tb_rt_run(tb_rt *rt, tb_scenario scn, tb_profile prof, tb_order ord, uint32_t seed) {\r\n  (void)seed;\r\n  if (!rt)\r\n    return TB_ERR_BAD_ARG;\r\n\r\n"]
[69.631246, "o", "  tb_script sc = {0};\r\n  if (!tb_script_for(scn, &sc))\r\n    return TB_ERR_BAD_ARG;\r\n"]
[69.631254, "o", "\r\n  tb_stamp last = {0};\r\n  bool found = false;\r\n"]
[69.631262, "o", "  tb_status st = journal_load_last(rt->journal_path, &last, &found);\r\n  if (st != TB_OK)\r\n    return st;\r\n"]
[69.63127, "o", "  if (found) {\r\n    rt->gen = last.gen + 1;\r\n    rt->cursor = last.cursor;\r\n"]
[69.631279, "o", "  }\r\n\r\n  for (uint32_t tick = 0; tick < sc.ticks; tick++) {\r\n"]
[69.631287, "o", "    st = maybe_detach_attach(rt, &sc, tick);\r\n    if (st != TB_OK)\r\n      return st;\r\n"]
[69.631311, "o", "\r\n    uint32_t submitted = 0;\r\n"]
[69.631325, "o", "    st = tb_ingest_tick(rt, prof, tick, &submitted);\r\n    if (st != TB_OK)\r\n      return st;\r\n\r\n    st = tb_settle_tick(rt, tick);\r\n    if (st != TB_OK)\r\n      return st;\r\n\r\n"]
[69.63134, "o", "    st = tb_merge_drain(rt, tick, ord);\r\n    if (st != TB_OK)\r\n      return st;\r\n"]
[69.631349, "o", "\r\n    st = tb_nudge_drain(rt, tick);\r\n    if (st != TB_OK)\r\n      return st;\r\n  }\r\n"]
[69.631358, "o", "\r\n  // Final drain to avoid leaving work in queues.\r\n  for (uint32_t i = 0; i < 16; i++) {\r\n"]
[69.631368, "o", "    st = tb_settle_tick(rt, sc.ticks + i);\r\n    if (st != TB_OK)\r\n      return st;\r\n"]
[69.631397, "o", "    st = tb_merge_drain(rt, sc.ticks + i, ord);\r\n    if (st != TB_OK)\r\n      return st;\r\n    st = tb_nudge_drain(rt, sc.ticks + i);\r\n    if (st != TB_OK)\r\n      return st;\r\n  }\r\n"]
[69.631411, "o", "\r\n  return TB_OK;\r\n}\r\n\r\n"]
[69.631682, "o", "\u001b[?2004h"]
[69.631695, "o", "root@0d4ff0619871:/app# "]
[69.757154, "i", "sed -n '1,240p' /app/src/logic/merge.c\n"]
[69.757486, "o", "sed -n '1,240p' /app/src/logic/merge.c\r\n\u001b[?2004l\r"]
[69.759086, "o", "#include \"logic/merge.h\"\r\n\r\n#include \"core/ev.h\"\r\n\r\n"]
[69.759175, "o", "static bool drain_one(tb_rt *rt, tb_q64 *q, uint32_t tick) {\r\n  (void)tick;\r\n  uint64_t token = 0;\r\n  if (!tb_q64_pop(q, &token))\r\n"]
[69.759392, "o", "    return false;\r\n"]
[69.759534, "o", "\r\n  uint64_t key = (uint32_t)token;\r\n\r\n  if (!tb_map_u64_has(&rt->token_done, key)) {\r\n"]
[69.759566, "o", "    uint64_t id64 = 0;\r\n    if (!tb_map_u64_get(&rt->token_to_id, token, &id64)) {\r\n      return true;\r\n    }\r\n    (void)tb_map_u64_put(&rt->token_done, key, 1);\r\n    tb_event ev = {.kind = TB_EV_DONE, .id = (uint32_t)id64};\r\n"]
[69.759753, "o", "    (void)tb_vec_ev_push(&rt->evlog, ev);\r\n  }\r\n"]
[69.759805, "o", "  return true;\r\n}\r\n\r\ntb_status tb_merge_drain(tb_rt *rt, uint32_t tick, tb_order ord) {\r\n  if (!rt)\r\n    return TB_ERR_BAD_ARG;\r\n\r\n  tb_q64 *a = &rt->done_a;\r\n  tb_q64 *b = &rt->done_b;\r\n\r\n  if (ord == TB_ORDER_A_THEN_B) {\r\n    while (drain_one(rt, a, tick)) {\r\n    }\r\n    while (drain_one(rt, b, tick)) {\r\n    }\r\n  } else {\r\n    while (drain_one(rt, b, tick)) {\r\n    }\r\n    while (drain_one(rt, a, tick)) {\r\n    }\r\n  }\r\n\r\n  return TB_OK;\r\n}\r\n"]
[69.760098, "o", "\u001b[?2004hroot@0d4ff0619871:/app# "]
[69.881003, "i", "sed -n '1,220p' /app/src/logic/link.c\n"]
[69.881262, "o", "sed -n '1,220p' /app/src/logic/link.c"]
[69.881839, "o", "\r\n\u001b[?2004l\r"]
[69.882697, "o", "#include \"logic/link.h\"\r\n\r\n#include \"io/journal.h\"\r\n\r\n#include <string.h>\r\n\r\ntb_status tb_link_detach(tb_rt *rt, uint32_t tick) {\r\n  (void)tick;\r\n  if (!rt)\r\n    return TB_ERR_BAD_ARG;\r\n  if (!rt->attached)\r\n"]
[69.882763, "o", "    return TB_OK;\r\n\r\n  rt->attached = false;\r\n\r\n  tb_stamp s = {.gen = rt->gen, .cursor = rt->cursor};\r\n  tb_status st = journal_append_stamp(rt->journal_path, s);\r\n  if (st != TB_OK)\r\n    return st;\r\n\r\n  // A \"device-side\" queue continues to exist while detached; the notifier doesn't.\r\n"]
[69.882987, "o", "  tb_q64_clear(&rt->notify_q);\r\n  return TB_OK;\r\n}\r\n\r\ntb_status tb_link_attach(tb_rt *rt, uint32_t tick) {\r\n  (void)tick;\r\n  if (!rt)\r\n    return TB_ERR_BAD_ARG;\r\n  if (rt->attached)\r\n    return TB_OK;\r\n\r\n  tb_stamp last = {0};\r\n  bool found = false;\r\n  tb_status st = journal_load_last(rt->journal_path, &last, &found);\r\n  if (st != TB_OK)\r\n    return st;\r\n  if (found) {\r\n    rt->gen = last.gen + 1;\r\n    rt->cursor = last.cursor;\r\n  }\r\n\r\n  rt->attached = true;\r\n  return TB_OK;\r\n}\r\n\r\n"]
[69.883387, "o", "\u001b[?2004hroot@0d4ff0619871:/app# "]
[70.013103, "i", "sed -n '1,260p' /app/src/core/queue.c\n"]
[70.013367, "o", "sed -n '1,260p' /app/src/core/queue.c\r\n\u001b[?2004l\r"]
[70.014903, "o", "#include \"core/queue.h\"\r\n\r\n#include <stdlib.h>\r\n#include <string.h>\r\n\r\nbool tb_q64_init(tb_q64 *q, size_t cap) {\r\n  if (!q || cap == 0)\r\n    return false;\r\n  q->buf = (uint64_t *)calloc(cap, sizeof(uint64_t));\r\n  if (!q->buf)\r\n    return false;\r\n  q->cap = cap;\r\n  q->len = 0;\r\n  q->head = 0;\r\n  return true;\r\n}\r\n\r\nvoid tb_q64_free(tb_q64 *q) {\r\n  if (!q)\r\n    return;\r\n  free(q->buf);\r\n  q->buf = NULL;\r\n  q->cap = 0;\r\n  q->len = 0;\r\n  q->head = 0;\r\n}\r\n\r\nstatic size_t idx(const tb_q64 *q, size_t i) { return (q->head + i) % q->cap; }\r\n\r\nbool tb_q64_push(tb_q64 *q, uint64_t v) {\r\n  if (!q || !q->buf)\r\n    return false;\r\n  if (q->len == q->cap)\r\n    return false;\r\n  q->buf[idx(q, q->len)] = v;\r\n  q->len++;\r\n  return true;\r\n}\r\n\r\nbool tb_q64_pop(tb_q64 *q, uint64_t *out) {\r\n  if (!q || !q->buf || !out)\r\n    return false;\r\n  if (q->len == 0)\r\n    return false;\r\n  *out = q->buf[q->head];\r\n"]
[70.015108, "o", "  q->head = (q->head + 1) % q->cap;\r\n  q->len--;\r\n  return true;\r\n}\r\n\r\nbool tb_q64_empty(const tb_q64 *q) { return !q || q->len == 0; }\r\n\r\nvoid tb_q64_clear(tb_q64 *q) {\r\n  if (!q || !q->buf)\r\n    return;\r\n  q->len = 0;\r\n  q->head = 0;\r\n  memset(q->buf, 0, q->cap * sizeof(uint64_t));\r\n}\r\n\r\n"]
[70.015193, "o", "\u001b[?2004h"]
[70.015243, "o", "root@0d4ff0619871:/app# "]
[70.133744, "i", "sed -n '1,260p' /app/src/io/journal.c\n"]
[70.134209, "o", "sed -n '1,260p' /app/src/io/journal.c\r\n\u001b[?2004l\r"]
[70.13668, "o", "#include \"io/journal.h\"\r\n\r\n#include \"io/fs.h\"\r\n\r\n#include <errno.h>\r\n#include <stdio.h>\r\n\r\nstatic tb_status append_rec(FILE *f, tb_stamp s) {\r\n  if (!fs_write_u32(f, s.gen))\r\n"]
[70.136718, "o", "    return TB_ERR_IO;\r\n\r\n  uint32_t lo = (uint32_t)s.cursor;\r\n  if (!fs_write_u32(f, lo))\r\n    return TB_ERR_IO;\r\n\r\n  return TB_OK;\r\n}\r\n\r\nstatic bool read_rec(FILE *f, tb_stamp *out) {\r\n  uint32_t gen = 0;\r\n  if (!fs_read_u32(f, &gen))\r\n"]
[70.136734, "o", "    return false;\r\n\r\n  uint32_t lo = 0;\r\n  if (!fs_read_u32(f, &lo))\r\n    return false;\r\n\r\n  out->gen = gen;\r\n  out->cursor = (uint64_t)lo;\r\n"]
[70.136749, "o", "  return true;\r\n}\r\n\r\ntb_status journal_append_stamp(const char *path, tb_stamp s) {\r\n  FILE *f = fopen(path, \"ab\");\r\n  if (!f)\r\n    return TB_ERR_IO;\r\n"]
[70.136763, "o", "  tb_status st = append_rec(f, s);\r\n  if (fclose(f) != 0)\r\n    return TB_ERR_IO;\r\n  return st;\r\n"]
[70.136776, "o", "}\r\n\r\ntb_status journal_load_last(const char *path, tb_stamp *out, bool *found) {\r\n  if (!out || !found)\r\n"]
[70.13679, "o", "    return TB_ERR_BAD_ARG;\r\n\r\n  FILE *f = fopen(path, \"rb\");\r\n  if (!f) {\r\n"]
[70.137196, "o", "    if (errno == ENOENT) {\r\n      *found = false;\r\n      return TB_OK;\r\n    }\r\n    return TB_ERR_IO;\r\n  }\r\n\r\n  tb_stamp cur = {0};\r\n  bool any = false;\r\n  while (read_rec(f, &cur)) {\r\n    any = true;\r\n  }\r\n  fclose(f);\r\n  if (!any) {\r\n    *found = false;\r\n    return TB_OK;\r\n  }\r\n  *found = true;\r\n  *out = cur;\r\n  return TB_OK;\r\n}\r\n\u001b[?2004hroot@0d4ff0619871:/app# "]
[87.925555, "i", "apply_patch <<'PATCH'\n*** Begin Patch\n*** Update File: /app/src/io/journal.c\n@@\n static tb_status append_rec(FILE *f, tb_stamp s) {\n   if (!fs_write_u32(f, s.gen))\n     return TB_ERR_IO;\n-\n-  uint32_t lo = (uint32_t)s.cursor;\n-  if (!fs_write_u32(f, lo))\n-    return TB_ERR_IO;\n+\n+  // On-disk format is 12 bytes: u32 generation + u64 cursor.\n+  // Cursor must not be truncated; detach/reattach correctness depends on it.\n+  uint32_t lo = (uint32_t)(s.cursor & 0xffffffffu);\n+  uint32_t hi = (uint32_t)((s.cursor >> 32) & 0xffffffffu);\n+  if (!fs_write_u32(f, lo))\n+    return TB_ERR_IO;\n+  if (!fs_write_u32(f, hi))\n+    return TB_ERR_IO;\n@@\n static bool read_rec(FILE *f, tb_stamp *out) {\n   uint32_t gen = 0;\n   if (!fs_read_u32(f, &gen))\n     return false;\n \n   uint32_t lo = 0;\n   if (!fs_read_u32(f, &lo))\n     return false;\n+\n+  uint32_t hi = 0;\n+  if (!fs_read_u32(f, &hi))\n+    return false;\n \n   out->gen = gen;\n-  out->cursor = (uint64_t)lo;\n+  out->cursor = ((uint64_t)hi << 32) | (uint64_t)lo;\n   return true;\n "]
[87.925984, "i", "}\n*** End Patch\nPATCH\n"]
