[104.06169, "i", "python3 - <<'PY'\nimport json\nfrom collections import defaultdict\n\ndef check(p):\n    with open(p) as f: r=json.load(f)\n    ev=r['events']\n    by=defaultdict(list)\n    for i,e in enumerate(ev):\n        by[(e['kind'],e['id'])].append(i)\n    sub_ids=[e['id'] for e in ev if e['kind']=='submit']\n    contig_ok=(sub_ids==list(range(1,len(sub_ids)+1)))\n    dups=[k for k,v in by.items() if len(v)>1]\n    bad=[]\n    for id in range(1,len(sub_ids)+1):\n        sub=by.get(('submit',id))\n        com=by.get(('complete',id))\n        noti=by.get(('notify',id))\n        if not(sub and com and noti):\n            bad.append((id,'missing',bool(sub),bool(com),bool(noti)))\n            continue\n        if not(sub[0] < com[0] < noti[0]):\n            bad.append((id,'order',sub[0],com[0],noti[0]))\n    print(p)\n    print(' scenario',r.get('scenario'),'profile',r.get('profile'))\n    print(' events',len(ev),'submits',len(sub_ids),'max_submit',max(sub_ids) if sub_ids else 0)\n    print(' submit_contiguous',contig_ok)\n    print(' duplicates',le"]
[104.061849, "i", "n(dups))\n    print(' bad',len(bad),'sample',bad[:10])\n\ncheck('/app/output/report.json')\ncheck('/app/output/report_b.json')\nPY\n"]
