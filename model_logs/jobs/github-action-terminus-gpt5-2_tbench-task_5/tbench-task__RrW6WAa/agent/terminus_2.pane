    12	
    13	type poolConfig struct {
    14		MaxWorkers         int  `json:"max_workers"`
    15		AutoRetryCancelled bool `json:"auto_retry_cancelled"`
    16	}
    17	
    18	// startConfigWatcher syncs runtime pool settings from the ops config file.
    19	// Allows on-call to tune concurrency and retry policy without a redeploy.
    20	func startConfigWatcher(pool *WorkerPool) {
    21		const cfgPath = "/opt/jobqueue/worker_config.json"
    22		for {
    23			time.Sleep(3 * time.Second)
    24			data, err := os.ReadFile(cfgPath)
    25			if err != nil {
    26				continue
    27			}
    28			var cfg poolConfig
    29			if json.Unmarshal(data, &cfg) != nil {
    30				continue
    31			}
    32			if cfg.MaxWorkers > 0 {
    33				pool.SetMax(cfg.MaxWorkers)
    34			}
    35			// Cancelled jobs are terminal by contract; do not auto-retry cancelled jobs.
    36			_ = cfg.AutoRetryCancelled
    37		}
    38	}
    39	
    40	func main() {
    41		db, err := initDB()
    42		if err != nil {
    43			log.Fatalf("db init: %v", err)
    44		}
    45	
    46		pool := NewWorkerPool(5, db)
    47		pool.Start()
    48		go startConfigWatcher(pool)
    49	
    50		svc := NewService(db, pool)
    51		h := &Handler{svc: svc}
    52	
    53		r := mux.NewRouter()
    54		r.HandleFunc("/jobs", h.createJob).Methods(http.MethodPost)
