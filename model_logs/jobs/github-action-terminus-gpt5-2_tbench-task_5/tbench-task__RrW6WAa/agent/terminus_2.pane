    24	func (s *Service) CreateJob(req CreateJobRequest) (*Job, error) {
    25		if req.Type == "" {
    26			return nil, fmt.Errorf("type is required")
    27		}
    28		res, err := s.db.Exec(
    29			"INSERT INTO jobs (type, payload, priority, status, worker_id) VALUES (?, ?, ?, "pending", NULL)",
    30			req.Type, req.Payload, req.Priority,
    31		)
    32		if err != nil {
    33			return nil, fmt.Errorf("insert job: %w", err)
    34		}
    35		id, _ := res.LastInsertId()
    36		return s.GetJob(int(id))
    37	}
    38	
