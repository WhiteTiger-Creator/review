    58		r.HandleFunc("/jobs/{id:[0-9]+}/complete", h.completeJob).Methods(http.MethodPost)
    59		r.HandleFunc("/jobs/{id:[0-9]+}/fail", h.failJob).Methods(http.MethodPost)
    60		r.HandleFunc("/workers", h.listWorkers).Methods(http.MethodGet)
    61		r.HandleFunc("/workers/register", h.registerWorker).Methods(http.MethodPost)
    62		r.HandleFunc("/stats", h.getStats).Methods(http.MethodGet)
    63	
    64		port := os.Getenv("PORT")
    65		if port == "" {
    66			port = "8080"
    67		}
