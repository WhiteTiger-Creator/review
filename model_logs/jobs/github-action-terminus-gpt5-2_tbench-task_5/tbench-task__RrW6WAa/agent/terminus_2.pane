   119	
   120	func (s *Service) CancelJob(id int) (*Job, error) {
   121		job, err := s.GetJob(id)
   122		if err != nil {
   123			return nil, err
   124		}
   125		if job.Status != "pending" {
   126			return nil, fmt.Errorf("%w: job status is %q", ErrConflict, job.Status)
   127		}
   128		if _, err := s.db.Exec(
   129			"UPDATE jobs SET status='cancelled', updated_at=? WHERE id=?",
   130			time.Now(), id,
   131		); err != nil {
   132			return nil, err
   133		}
   134		return s.GetJob(id)
   135	}
   136	
   137	func (s *Service) CompleteJob(id int) (*Job, error) {
   138		job, err := s.GetJob(id)
   139		if err != nil {
   140			return nil, err
   141		}
   142		if job.Status != "running" {
   143			return nil, fmt.Errorf("%w: job must be running to complete, got %q", ErrConflict, job.Status)
   144		}
   145		if _, err := s.db.Exec(
   146			"UPDATE jobs SET status='completed', updated_at=? WHERE id=?",
   147			time.Now(), id,
   148		); err != nil {
   149			return nil, err
   150		}
   151		return s.GetJob(id)
   152	}
   153	
   154	func (s *Service) FailJob(id int) (*Job, error) {
   155		job, err := s.GetJob(id)
   156		if err != nil {
   157			return nil, err
   158		}
   159		if job.Status != "running" {
   160			return nil, fmt.Errorf("%w: job must be running to fail, got %q", ErrConflict, job.Status)
   161		}
   162		if _, err := s.db.Exec(
   163			"UPDATE jobs SET status='failed', updated_at=? WHERE id=?",
   164			time.Now(), id,
   165		); err != nil {
   166			return nil, err
   167		}
   168		return s.GetJob(id)
   169	}
   170	
   171	func (s *Service) RegisterWorker(name string) (*Worker, error) {
   172		if name == "" {
   173			return nil, fmt.Errorf("name is required")
   174		}
   175		res, err := s.db.Exec("INSERT INTO workers (name) VALUES (?)", name)
   176		if err != nil {
   177			return nil, fmt.Errorf("insert worker: %w", err)
   178		}
   179		id, _ := res.LastInsertId()
   180		return s.GetWorker(int(id))
   181	}
   182	
   183	func (s *Service) GetWorker(id int) (*Worker, error) {
   184		var w Worker
   185		err := s.db.QueryRow(
   186			"SELECT id, name, status, registered_at FROM workers WHERE id=?", id,
   187		).Scan(&w.ID, &w.Name, &w.Status, &w.RegisteredAt)
   188		if errors.Is(err, sql.ErrNoRows) {
   189			return nil, ErrNotFound
   190		}
   191		return &w, err
   192	}
   193	
   194	func (s *Service) ListWorkers() ([]Worker, error) {
   195		rows, err := s.db.Query("SELECT id, name, status, registered_at FROM workers ORDER BY id")
   196		if err != nil {
   197			return nil, err
   198		}
   199		defer rows.Close()
   200	
   201		var workers []Worker
   202		for rows.Next() {
   203			var w Worker
   204			if err := rows.Scan(&w.ID, &w.Name, &w.Status, &w.RegisteredAt); err != nil {
   205				return nil, err
   206			}
   207			workers = append(workers, w)
   208		}
   209		return workers, rows.Err()
   210	}
