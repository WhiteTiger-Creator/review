[103.054321, "i", "apply_patch <<'PATCH'\n*** Begin Patch\n*** Update File: src/main.c\n@@\n-static int url_contains_encoded_dotdot(const char *url) {\n-    const char *p = url;\n-    while (*p) {\n-        if (strncasecmp(p, \"%2e%2e\", 6) == 0)\n-            return 1;\n-        p++;\n-    }\n-    return 0;\n-}\n+static int hexval(char c) {\n+    if (c >= '0' && c <= '9') return c - '0';\n+    if (c >= 'a' && c <= 'f') return 10 + (c - 'a');\n+    if (c >= 'A' && c <= 'F') return 10 + (c - 'A');\n+    return -1;\n+}\n+\n+// Decode %XX in URL paths. Keeps other bytes as-is.\n+// Returns 0 on success, -1 on error/overflow.\n+static int url_percent_decode(const char *in, char *out, size_t out_sz) {\n+    size_t oi = 0;\n+    for (size_t i = 0; in[i] != '\\0'; i++) {\n+        if (oi + 1 >= out_sz) return -1;\n+        if (in[i] == '%' && in[i+1] && in[i+2]) {\n+            int hi = hexval(in[i+1]);\n+            int lo = hexval(in[i+2]);\n+            if (hi < 0 || lo < 0) return -1;\n+            out[oi++] = (char)((hi << 4) | lo);\n+            i += 2;\n+        } else {\n+            out[oi++] = in[i];\n+        }\n+    }\n+    out[oi] = '\\0';\n+    return 0;\n+}\n+\n+static int decoded_path_has_dotdot_segment(const char *path) {\n+    // Expect an absolute path (starts with '/'), but be defensive.\n+    const char *p = path;\n+    while (*p) {\n+        while (*p == '/') p++;\n+        if (!*p) break;\n+        const char *seg = p;\n+        while (*p && *p != '/') p++;\n+        size_t len = (size_t)(p - seg);\n+        if (len == 2 && seg[0] == '.' && seg[1] == '.') return 1;\n+    }\n+    return 0;\n+}\n@@\n static enum MHD_Result serve_static_file(struct MHD_Connection *connection,\n     const char *url) {\n-    if (strstr(url, \"..\") != NULL || url_contains_encoded_dotdot(url)) {\n+    char decoded[512];\n+    if (url_percent_decode(url, decoded, sizeof(decoded)) != 0) {\n+        struct MHD_Response *r = MHD_create_response_from_buffer(\n+            9, (void *)\"Forbidden\", MHD_RESPMEM_PERSISTENT);\n+        enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_FORBIDDEN, r);\n+        MHD_destroy_response(r);\n+        return ret;\n+    }\n+\n+    if (decoded_path_has_dotdot_segment(decoded)) {\n         struct MHD_Response *r = MHD_create_response_from_buffer(\n             9, (void *)\"Forbidden\", MHD_RESPMEM_PERSISTENT);\n         enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_FORBIDDEN, r);\n         MHD_destroy_response(r);\n         return ret;\n     }\n*** End Patch\nPATCH\n"]
[103.054744, "o", "apply_patch <<'PATCH'\r\n\u001b[?2004l\r"]
