[333.614843, "o", "#include <microhttpd.h>\r\n#include <stdio.h>\r\n#include <string.h>\r\n#include <stdlib.h>\r\n#include <signal.h>\r\n#include <sys/stat.h>\r\n#include <strings.h>\r\n#include <unistd.h>\r\n\r\n#include \"routes.h\"\r\n#include \"db.h\"\r\n\r\n#define PORT 8080\r\n#define WWW_DIR \"/app/www\"\r\n\r\nstatic struct MHD_Daemon *daemon_handle = NULL;\r\n\r\nstatic void handle_signal(int sig) {\r\n    (void)sig;\r\n    if (daemon_handle) MHD_stop_daemon(daemon_handle);\r\n    close_db();\r\n    exit(0);\r\n}\r\n\r\nstatic const char *get_content_type(const char *path) {\r\n    const char *ext = strrchr(path, '.');\r\n    if (!ext) return \"application/octet-stream\";\r\n    if (strcmp(ext, \".html\") == 0) return \"text/html\";\r\n    if (strcmp(ext, \".css\") == 0) return \"text/css\";\r\n    if (strcmp(ext, \".js\") == 0) return \"application/javascript\";\r\n    return \"application/octet-stream\";\r\n}\r\n\r\nstatic int hexval(char c) {\r\n    if (c >= '0' && c <= '9') return c - '0';\r\n    if (c >= 'a' && c <= 'f') return 10 + (c - 'a');\r\n    if (c >= 'A' && c <= 'F') return 10 + (c - 'A');\r\n    return -1;\r\n}\r\n\r\nstatic int url_percent_decode(const char *in, char *out, size_t out_sz) {\r\n    size_t oi = 0;\r\n    for (size_t i = 0; in[i] != '\\0'; i++) {\r\n        if (oi + 1 >= out_sz) return -1;\r\n        if (in[i] == '%' && in[i+1] && in[i+2]) {\r\n            int hi = hexval(in[i+1]);\r\n            int lo = hexval(in[i+2]);\r\n            if (hi < 0 || lo < 0) return -1;\r\n            out[oi++] = (char)((hi << 4) | lo);\r\n            i += 2;\r\n        } else {\r\n            out[oi++] = in[i];\r\n        }\r\n    }\r\n    out[oi] = '\\0';\r\n    return 0;\r\n}\r\n\r\nstatic int decoded_path_has_dotdot_segment(const char *path) {\r\n    const char *p = path;\r\n    while (*p) {\r\n        while (*p == '/') p++;\r\n        if (!*p) break;\r\n        const char *seg = p;\r\n        while (*p && *p != '/') p++;\r\n        size_t len = (size_t)(p - seg);\r\n        if (len == 2 && seg[0] == '.' && seg[1] == '.') return 1;\r\n    }\r\n    return 0;\r\n}\r\n\r\nstatic int url_has_traversal(const char *url) {\r\n    if (!url) return 0;\r\n    char decoded[512];\r\n    if (url_percent_decode(url, decoded, sizeof(decoded)) != 0) return 1;\r\n    return decoded_path_has_dotdot_segment(decoded);\r\n}\r\n\r\nstatic enum MHD_Result serve_static_file(struct MHD_Connection *connection,\r\n                                        const char *url) {\r\n    if (url_has_traversal(url)) {\r\n        struct MHD_Response *r = MHD_create_response_from_buffer(\r\n            9, (void *)\"Forbidden\", MHD_RESPMEM_PERSISTENT);\r\n        enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_FORBIDDEN, r);\r\n        MHD_destroy_response(r);\r\n        return ret;\r\n    }\r\n\r\n    char filepath[512];\r\n    const char *path = (strcmp(url, \"/\") == 0) ? \"/index.html\" : url;\r\n    snprintf(filepath, sizeof(filepath), \"%s%s\", WWW_DIR, path);\r\n\r\n    struct stat st;\r\n    if (stat(filepath, &st) != 0) return MHD_NO;\r\n\r\n    FILE *f = fopen(filepath, \"rb\");\r\n    if (!f) return MHD_NO;\r\n\r\n    char *buf = malloc(st.st_size);\r\n    if (!buf) {\r\n        fclose(f);\r\n        return MHD_NO;\r\n    }\r\n    fread(buf, 1, st.st_size, f);\r\n    fclose(f);\r\n\r\n    struct MHD_Response *response = MHD_create_response_from_buffer(\r\n        st.st_size, buf, MHD_RESPMEM_MUST_FREE);\r\n    MHD_add_response_header(response, \"Content-Type\", get_content_type(filepath));\r\n    enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_OK, response);\r\n    MHD_destroy_response(response);\r\n    return ret;\r\n}\r\n\r\nstatic void request_completed(void *cls, struct MHD_Connection *connection,\r\n                              void **con_cls, enum MHD_RequestTerminationCode toe) {\r\n    (void)cls;\r\n    (void)connection;\r\n    (void)toe;\r\n    if (con_cls && *con_cls) {\r\n        struct connection_info *ci = *con_cls;\r\n        if (ci->data) free(ci->data);\r\n        free(ci);\r\n        *con_cls = NULL;\r\n    }\r\n}\r\n\r\nstatic enum MHD_Result handle_request(void *cls,\r\n                                     struct MHD_Connection *connection,\r\n                                     const char *url, const char *method,\r\n                                     const char *version,\r\n        "]
[333.614882, "o", "                             const char *upload_data,\r\n                                     size_t *upload_data_size,\r\n                                     void **con_cls) {\r\n    (void)cls;\r\n    (void)version;\r\n\r\n    if (strncmp(url, \"/api/\", 5) == 0) {\r\n        return route_request(connection, url, method, upload_data,\r\n                             upload_data_size, con_cls);\r\n    }\r\n\r\n    if (strcmp(method, \"GET\") == 0) {\r\n        enum MHD_Result ret = serve_static_file(connection, url);\r\n        if (ret == MHD_YES) return ret;\r\n    }\r\n\r\n    struct MHD_Response *response = MHD_create_response_from_buffer(\r\n        9, (void *)\"Not Found\", MHD_RESPMEM_PERSISTENT);\r\n    enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_NOT_FOUND, response);\r\n    MHD_destroy_response(response);\r\n    return ret;\r\n}\r\n\r\nint main(void) {\r\n    signal(SIGINT, handle_signal);\r\n    signal(SIGTERM, handle_signal);\r\n\r\n    mkdir(\"/app/data\", 0755);\r\n\r\n    if (init_db(\"/app/data/notes.db\") != 0) {\r\n        fprintf(stderr, \"Failed to initialize database\\n\");\r\n        return 1;\r\n    }\r\n\r\n    daemon_handle = MHD_start_daemon(\r\n        MHD_USE_THREAD_PER_CONNECTION,\r\n        PORT,\r\n        NULL, NULL,\r\n        &handle_request, NULL,\r\n        MHD_OPTION_NOTIFY_COMPLETED, &request_completed, NULL,\r\n        MHD_OPTION_END);\r\n\r\n    if (!daemon_handle) {\r\n        fprintf(stderr, \"Failed to start server\\n\");\r\n        return 1;\r\n    }\r\n\r\n    printf(\"Server running on port %d\\n\", PORT);\r\n    while (1) pause();\r\n    return 0;\r\n}\r\n"]
