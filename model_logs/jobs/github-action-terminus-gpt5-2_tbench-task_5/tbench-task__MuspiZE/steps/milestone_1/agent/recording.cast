[103.066638, "o", "\u001b[?2004h> "]
[103.066801, "o", "             9, (void *)\"Forbidden\", MHD_RESPMEM_PERSISTENT);\r\n\u001b[?2004l\r"]
[103.066891, "o", "\u001b[?2004h> "]
[103.067119, "o", "         enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_FORBIDDEN, r);\r\n\u001b[?2004l\r"]
[103.067187, "o", "\u001b[?2004h> "]
[103.067288, "o", "         MHD_destroy_response(r);\r\n\u001b[?2004l\r"]
[103.067352, "o", "\u001b[?2004h> "]
