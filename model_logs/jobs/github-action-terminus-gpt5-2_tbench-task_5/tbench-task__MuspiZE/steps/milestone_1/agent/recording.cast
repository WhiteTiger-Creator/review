[312.913275, "o", "     8\tstatic enum MHD_Result send_json(struct MHD_Connection *connection,\r\n     9\t                                  const char *body, unsigned int status_code) {\r\n    10\t    struct MHD_Response *response = MHD_create_response_from_buffer(\r\n    11\t        strlen(body), (void *)body, MHD_RESPMEM_MUST_COPY);\r\n    12\t    MHD_add_response_header(response, \"Content-Type\", \"application/json\");\r\n    13\t    MHD_add_response_header(response, \"Access-Control-Allow-Origin\", \"*\");\r\n    14\t    MHD_add_response_header(response, \"Access-Control-Allow-Methods\",\r\n    15\t                            \"GET, POST, PUT, DELETE, OPTIONS\");\r\n    16\t    MHD_add_response_header(response, \"Access-Control-Allow-Headers\",\r\n    17\t                            \"Content-Type, X-API-Key\");\r\n    18\t    enum MHD_Result ret = MHD_queue_response(connection, status_code, response);\r\n    19\t    MHD_destroy_response(response);\r\n    20\t    return ret;\r\n    21\t}\r\n    22\t\r\n    23\tstatic enum MHD_Result send_json_total(struct MHD_Connection *connection,\r\n    24\t                                       const char *body, unsigned int status_code,\r\n    25\t                                       int total) {\r\n    26\t    struct MHD_Response *response = MHD_create_response_from_buffer(\r\n    27\t        strlen(body), (void *)body, MHD_RESPMEM_MUST_COPY);\r\n    28\t    MHD_add_response_header(response, \"Content-Type\", \"application/json\");\r\n    29\t    MHD_add_response_header(response, \"Access-Control-Allow-Origin\", \"*\");\r\n    30\t    MHD_add_response_header(response, \"Access-Control-Allow-Methods\",\r\n    31\t                            \"GET, POST, PUT, DELETE, OPTIONS\");\r\n    32\t    MHD_add_response_header(response, \"Access-Control-Allow-Headers\",\r\n    33\t                            \"Content-Type, X-API-Key\");\r\n    34\t    char count_str[32];\r\n    35\t    snprintf(count_str, sizeof(count_str), \"%d\", total);\r\n    36\t    MHD_add_response_header(response, \"X-Total-Count\", count_str);\r\n    37\t    enum MHD_Result ret = MHD_queue_response(connection, status_code, response);\r\n    38\t    MHD_destroy_response(response);\r\n    39\t    return ret;\r\n    40\t}\r\n    41\t\r\n    42\tstatic void request_completed(void *cls, struct MHD_Connection *connection,\r\n    43\t                              void **con_cls, enum MHD_RequestTerminationCode toe) {\r\n    44\t    (void)cls;\r\n    45\t    (void)connection;\r\n    46\t    (void)toe;\r\n    47\t    if (con_cls && *con_cls) {\r\n    48\t        struct connection_info *ci = *con_cls;\r\n    49\t        if (ci->data)\r\n    50\t            free(ci->data);\r\n    51\t        free(ci);\r\n    52\t        *con_cls = NULL;\r\n    53\t    }\r\n    54\t}\r\n    55\t\r\n    56\tenum MHD_Result route_request(struct MHD_Connection *connection, const char *url,\r\n    57\t                              const char *method, const char *upload_data,\r\n    58\t                              size_t *upload_data_size, void **con_cls) {\r\n    59\t    (void)upload_data;\r\n    60\t    (void)upload_data_size;\r\n    61\t    (void)con_cls;\r\n    62\t\r\n    63\t    if (strcmp(method, \"OPTIONS\") == 0)\r\n    64\t        return send_json(connection, \"\", MHD_HTTP_OK);\r\n    65\t\r\n    66\t    if (strcmp(url, \"/api/notes\") == 0 && strcmp(method, \"GET\") == 0) {\r\n    67\t        int total = get_total_notes_count();\r\n    68\t        char *json = get_notes_paginated_json(50, 0);\r\n    69\t        if (!json)\r\n    70\t            return send_json_total(connection, \"[]\", MHD_HTTP_OK, total);\r\n    71\t        enum MHD_Result r = send_json_total(connection, json, MHD_HTTP_OK, total);\r\n    72\t        free(json);\r\n    73\t        return r;\r\n    74\t    }\r\n    75\t\r\n    76\t    return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\r\n    77\t}\r\n"]
