[194.82067, "o", "\u001b[?2004h> "]
[194.820718, "o", "        ci->data = NULL;\r\n\u001b[?2004l\r\u001b[?2004h>         ci->data_size = 0;\r\n\u001b[?2004l\r\u001b[?2004h>         ci->raw_url = NULL;\r\n\u001b[?2004l\r\u001b[?2004h>         *con_cls = ci;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     struct connection_info *ci = (struct connection_info *)(*con_cls);\r\n\u001b[?2004l\r\u001b[?2004h>     // Best-effort: keep a copy of the URL we are given (may already be normalized)\r\n\u001b[?2004l\r\u001b[?2004h>     if (!ci->raw_url && url) ci->raw_url = strdup(url);\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     if (strncmp(url, \"/api/\", 5) == 0) {\r\n\u001b[?2004l\r\u001b[?2004h>         return route_request(connection, url, method, upload_data,\r\n\u001b[?2004l\r\u001b[?2004h>                              upload_data_size, con_cls);\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     if (strcmp(method, \"GET\") == 0) {\r\n\u001b[?2004l\r\u001b[?2004h>         enum MHD_Result ret = serve_static_file(connection, ci, url);\r\n\u001b[?2004l\r\u001b[?2004h>         if (ret == MHD_YES) return ret;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     struct MHD_Response *response = MHD_create_response_from_buffer(\r\n\u001b[?2004l\r\u001b[?2004h>         9, (void *)\"Not Found\", MHD_RESPMEM_PERSISTENT);\r\n\u001b[?2004l\r\u001b[?2004h>     enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_NOT_FOUND, response);\r\n\u001b[?2004l\r\u001b[?2004h>     MHD_destroy_response(response);\r\n\u001b[?2004l\r\u001b[?2004h>     return ret;\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> int main(void) {\r\n\u001b[?2004l\r\u001b[?2004h>     signal(SIGINT, handle_signal);\r\n\u001b[?2004l\r"]
