[103.0559, "o", "\u001b[?2004h"]
[103.055924, "o", "> "]
[103.056079, "o", "-        if (strncasecmp(p, \"%2e%2e\", 6) == 0)\r\n\u001b[?2004l\r\u001b[?2004h"]
[103.05611, "o", "> "]
[103.056189, "o", "-            return 1;\r\n\u001b[?2004l\r"]
[103.056732, "o", "\u001b[?2004h> -        p++;\r\n\u001b[?2004l\r\u001b[?2004h> -    }\r\n\u001b[?2004l\r\u001b[?2004h> -    return 0;\r\n\u001b[?2004l\r\u001b[?2004h> -}\r\n\u001b[?2004l\r"]
[103.056831, "o", "\u001b[?2004h> "]
[103.056937, "o", "+static int hexval(char c) {\r\n\u001b[?2004l\r"]
[103.056971, "o", "\u001b[?2004h"]
[103.056995, "o", "> "]
[103.057209, "o", "+    if (c >= '0' && c <= '9') return c - '0';\r\n\u001b[?2004l\r"]
[103.05725, "o", "\u001b[?2004h> "]
[103.057408, "o", "+    if (c >= 'a' && c <= 'f') return 10 + (c - 'a');\r\n\u001b[?2004l\r"]
[103.057433, "o", "\u001b[?2004h"]
[103.057457, "o", "> "]
[103.057661, "o", "+    if (c >= 'A' && c <= 'F') return 10 + (c - 'A');\r\n\u001b[?2004l\r"]
[103.057684, "o", "\u001b[?2004h"]
[103.057706, "o", "> "]
[103.057947, "o", "+    return -1;\r\n\u001b[?2004l\r\u001b[?2004h> +}\r\n\u001b[?2004l\r\u001b[?2004h> +\r\n"]
[103.058009, "o", "\u001b[?2004l\r"]
[103.058762, "o", "\u001b[?2004h> "]
[103.058804, "o", "+// Decode %XX in URL paths. Keeps other bytes as-is.\r\n\u001b[?2004l\r\u001b[?2004h> +// Returns 0 on success, -1 on error/overflow.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[103.058913, "o", "+static int url_percent_decode(const char *in, char *out, size_t out_sz) {"]
[103.059022, "o", "\r\n"]
[103.059342, "o", "\u001b[?2004l\r"]
[103.059736, "o", "\u001b[?2004h> +    size_t oi = 0;\r\n\u001b[?2004l\r\u001b[?2004h> +    for (size_t i = 0; in[i] != '\\0'; i++) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[103.059775, "o", "> +        if (oi + 1 >= out_sz) return -1;\r\n\u001b[?2004l\r\u001b[?2004h> +        if (in[i] == '%' && in[i+1] && in[i+2]) {\r\n\u001b[?2004l\r"]
[103.059801, "o", "\u001b[?2004h"]
[103.059823, "o", "> "]
[103.059964, "o", "+            int hi = hexval(in[i+1]);\r\n\u001b[?2004l\r"]
[103.059996, "o", "\u001b[?2004h> "]
[103.060154, "o", "+            int lo = hexval(in[i+2]);\r\n\u001b[?2004l\r"]
[103.060182, "o", "\u001b[?2004h> "]
[103.060344, "o", "+            if (hi < 0 || lo < 0) return -1;\r\n\u001b[?2004l\r"]
[103.060377, "o", "\u001b[?2004h> "]
[103.060532, "o", "+            out[oi++] = (char)((hi << 4) | lo);\r\n\u001b[?2004l\r"]
[103.06056, "o", "\u001b[?2004h> "]
[103.060687, "o", "+            i += 2;\r\n\u001b[?2004l\r\u001b[?2004h"]
[103.060804, "o", "> +        } else {"]
[103.060893, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[103.06097, "o", "+            out[oi++] = in[i];\r\n\u001b[?2004l\r"]
[103.061058, "o", "\u001b[?2004h> +        }\r\n\u001b[?2004l\r"]
[103.061132, "o", "\u001b[?2004h> +    }\r\n"]
[103.061245, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[103.06137, "o", "+    out[oi] = '\\0';\r\n\u001b[?2004l\r\u001b[?2004h> "]
[103.061476, "o", "+    return 0;\r\n\u001b[?2004l\r\u001b[?2004h> +}\r\n\u001b[?2004l\r\u001b[?2004h> "]
[103.06156, "o", "+\r\n\u001b[?2004l\r\u001b[?2004h> "]
[103.061741, "o", "+static int decoded_path_has_dotdot_segment(const char *path) {\r\n\u001b[?2004l\r"]
[103.061769, "o", "\u001b[?2004h> "]
[103.061992, "o", "+    // Expect an absolute path (starts with '/'), but be defensive.\r\n\u001b[?2004l\r"]
[103.062016, "o", "\u001b[?2004h"]
[103.062034, "o", "> "]
[103.062136, "o", "+    const char *p = path;\r\n\u001b[?2004l\r"]
[103.062217, "o", "\u001b[?2004h> "]
[103.062325, "o", "+    while (*p) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[103.062451, "o", "> "]
[103.062523, "o", "+        while (*p == '/') p++;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[103.062601, "o", "+        if (!*p) break;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[103.062729, "o", "+        const char *seg = p;\r\n\u001b[?2004l\r"]
[103.06288, "o", "\u001b[?2004h> "]
[103.062967, "o", "+        while (*p && *p != '/') p++;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[103.063083, "o", "+        size_t len = (size_t)(p - seg);\r\n\u001b[?2004l\r"]
[103.063139, "o", "\u001b[?2004h> "]
[103.063354, "o", "+        if (len == 2 && seg[0] == '.' && seg[1] == '.') return 1;\r\n\u001b[?2004l\r"]
[103.063382, "o", "\u001b[?2004h"]
[103.063404, "o", "> +    }\r\n\u001b[?2004l\r"]
[103.063495, "o", "\u001b[?2004h> +    return 0;\r\n"]
[103.063525, "o", "\u001b[?2004l\r\u001b[?2004h"]
[103.063563, "o", "> "]
[103.06365, "o", "+}\r\n\u001b[?2004l\r"]
[103.063783, "o", "\u001b[?2004h> @@\r\n\u001b[?2004l\r\u001b[?2004h> "]
[103.063959, "o", " static enum MHD_Result serve_static_file(struct MHD_Connection *connection,\r\n\u001b[?2004l\r"]
