[194.791895, "o", "static int hexval(char c) {\r\n\u001b[?2004l\r"]
[194.791929, "o", "\u001b[?2004h> "]
[194.792234, "o", "    if (c >= '0' && c <= '9') return c - '0';\r\n\u001b[?2004l\r\u001b[?2004h"]
[194.792274, "o", "> "]
[194.792626, "o", "    if (c >= 'a' && c <= 'f') return 10 + (c - 'a');\r\n\u001b[?2004l\r"]
[194.792805, "o", "\u001b[?2004h> "]
[194.793009, "o", "    if (c >= 'A' && c <= 'F') return 10 + (c - 'A');\r\n\u001b[?2004l\r"]
[194.793047, "o", "\u001b[?2004h> "]
[194.793223, "o", "    return -1;\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h"]
