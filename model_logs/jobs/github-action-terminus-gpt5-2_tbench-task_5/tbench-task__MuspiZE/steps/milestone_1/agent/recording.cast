[454.478706, "i", "te_exists(int id) {\n+    sqlite3 *db = NULL;\n+    if (open_db(&db) != 0) return 0;\n+    sqlite3_stmt *st = NULL;\n+    int exists = 0;\n+    if (sqlite3_prepare_v2(db, \"SELECT 1 FROM notes WHERE id = ?\", -1, &st, NULL) == SQLITE_OK) {\n+        sqlite3_bind_int(st, 1, id);\n+        if (sqlite3_step(st) == SQLITE_ROW) exists = 1;\n+    }\n+    if (st) sqlite3_finalize(st);\n+    sqlite3_close(db);\n+    return exists;\n+}\n+\n+int update_note(int id, const char *title, const char *content) {\n+    sqlite3 *db = NULL;\n+    if (open_db(&db) != 0) return -1;\n+    if (exec_with_retry(db, \"BEGIN IMMEDIATE\") != 0) {\n+        sqlite3_close(db);\n+        return -1;\n+    }\n+    sqlite3_stmt *st = NULL;\n+    const char *sql = \"UPDATE notes SET title = ?, content = ? WHERE id = ?\";\n+    if (sqlite3_prepare_v2(db, sql, -1, &st, NULL) != SQLITE_OK) {\n+        exec_with_retry(db, \"ROLLBACK\");\n+        sqlite3_close(db);\n+        return -1;\n+    }\n+    sqlite3_bind_text(st, 1, title ? title : \"\", -1, SQLITE_TRANSIENT);\n+    sqlite3_bind_text(st, 2, content ? content : \"\", -1, SQLITE_TRANSIENT);\n+    sqlite3_bind_int(st, 3, id);\n+\n+    int rc;\n+    for (int tries = 0; tries < 20; tries++) {\n+        rc = sqlite3_step(st);\n+        if (rc == SQLITE_DONE) break;\n+        if (rc == SQLITE_BUSY || rc == SQLITE_LOCKED) {\n+            usleep(10 * 1000);\n+            continue;\n+        }\n+        break;\n+    }\n+    sqlite3_finalize(st);\n+    if (rc != SQLITE_DONE) {\n+        exec_with_retry(db, \"ROLLBACK\");\n+        sqlite3_close(db);\n+        return -1;\n+    }\n+    int changed = sqlite3_changes(db);\n+    if (exec_with_retry(db, \"COMMIT\") != 0) {\n+        sqlite3_close(db);\n+        return -1;\n+    }\n+    sqlite3_close(db);\n+    return changed > 0 ? 1 : 0;\n+}\n+\n+int delete_note(int id) {\n+    sqlite3 *db = NULL;\n+    if (open_db(&db) != 0) return -1;\n+    if (exec_with_retry(db, \"BEGIN IMMEDIATE\") != 0) {\n+        sqlite3_close(db);\n+        return -1;\n+    }\n+    sqlite3_stmt *st = NULL;\n+    const char *sql = \"DELETE FROM notes WHERE id = ?\";\n+    if (sqlite3_prepare_v2(db, sql, -1, &st, NULL) != SQLITE_OK) {\n+        exec_with_retry(db, \"ROLLBACK\");\n+        sqlite3_close(db);\n+        return -1;\n+    }\n+    sqlite3_bind_int(st, 1, id);\n+\n+    int rc;\n+    for (int tries = 0; tries < 20; tries++) {\n+        rc = sqlite3_step(st);\n+        if (rc == SQLITE_DONE) break;\n+        if (rc == SQLITE_BUSY || rc == SQLITE_LOCKED) {\n+            usleep(10 * 1000);\n+            continue;\n+        }\n+        break;\n+    }\n+    sqlite3_finalize(st);\n+    if (rc != SQLITE_DONE) {\n+        exec_with_retry(db, \"ROLLBACK\");\n+        sqlite3_close(db);\n+        return -1;\n+    }\n+    int changed = sqlite3_changes(db);\n+    if (exec_with_retry(db, \"COMMIT\") != 0) {\n+        sqlite3_close(db);\n+        return -1;\n+    }\n+    sqlite3_close(db);\n+    return changed > 0 ? 1 : 0;\n+}\n+\n*** End Patch\nPATCH\n"]
