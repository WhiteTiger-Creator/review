[351.334551, "o", "     1\t#include \"db.h\"\r\n     2\t#include <sqlite3.h>\r\n     3\t#include <stdio.h>\r\n     4\t#include <stdlib.h>\r\n     5\t#include <string.h>\r\n     6\t\r\n     7\tstatic sqlite3 *db = NULL;\r\n     8\t\r\n     9\tint init_db(const char *path) {\r\n    10\t    if (sqlite3_open_v2(path, &db,\r\n    11\t            SQLITE_OPEN_READWRITE | SQLITE_OPEN_CREATE | SQLITE_OPEN_NOMUTEX,\r\n    12\t            NULL) != SQLITE_OK) {\r\n    13\t        fprintf(stderr, \"Cannot open database: %s\\n\", sqlite3_errmsg(db));\r\n    14\t        return -1;\r\n    15\t    }\r\n    16\t\r\n    17\t    const char *sql = \"CREATE TABLE IF NOT EXISTS notes (\"\r\n    18\t                      \"id INTEGER PRIMARY KEY AUTOINCREMENT,\"\r\n    19\t                      \"title TEXT NOT NULL,\"\r\n    20\t                      \"content TEXT DEFAULT ''\"\r\n    21\t                      \");\";\r\n    22\t    char *err_msg = NULL;\r\n    23\t    if (sqlite3_exec(db, sql, NULL, NULL, &err_msg) != SQLITE_OK) {\r\n    24\t        fprintf(stderr, \"SQL error: %s\\n\", err_msg);\r\n    25\t        sqlite3_free(err_msg);\r\n    26\t        return -1;\r\n    27\t    }\r\n    28\t    return 0;\r\n    29\t}\r\n    30\t\r\n    31\tvoid close_db(void) {\r\n    32\t    if (db)\r\n    33\t        sqlite3_close(db);\r\n    34\t    db = NULL;\r\n"]
