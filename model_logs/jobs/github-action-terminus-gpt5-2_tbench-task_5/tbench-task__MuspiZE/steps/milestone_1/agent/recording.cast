[333.500447, "o", "#include \"static.h\"\r\n\r\nenum MHD_Result serve_static_file(struct MHD_Connection *connection, const char *url) {\r\n    (void)connection;\r\n    (void)url;\r\n    return MHD_NO;\r\n}\r\n\u001b[?2004hroot@bb40ba43d60f:/app# "]
