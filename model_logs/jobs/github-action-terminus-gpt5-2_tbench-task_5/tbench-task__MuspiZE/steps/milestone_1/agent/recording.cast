[452.477574, "i", "apply_patch<<'PATCH'\n*** Begin Patch\n*** Update File: /app/src/auth.c\n@@\n-#include \"auth.h\"\n-\n-int api_key_valid(struct MHD_Connection *connection) {\n-    (void)connection;\n-    return 0;\n-}\n+#include \"auth.h\"\n+\n+#include <ctype.h>\n+#include <stdio.h>\n+#include <stdlib.h>\n+#include <string.h>\n+\n+static char *g_api_key = NULL;\n+\n+static void trim_in_place(char *s) {\n+    if (!s) return;\n+    size_t len = strlen(s);\n+    size_t start = 0;\n+    while (start < len && isspace((unsigned char)s[start])) start++;\n+    size_t end = len;\n+    while (end > start && isspace((unsigned char)s[end - 1])) end--;\n+    if (start > 0) memmove(s, s + start, end - start);\n+    s[end - start] = '\\0';\n+}\n+\n+static void load_api_key_once(void) {\n+    if (g_api_key) return;\n+    FILE *f = fopen(\"/app/config/api.key\", \"rb\");\n+    if (!f) {\n+        g_api_key = strdup(\"\");\n+        return;\n+    }\n+    char buf[512];\n+    size_t n = fread(buf, 1, sizeof(buf) - 1, f);\n+    fclose(f);\n+    buf[n] = '\\0';\n+    trim_in_place(buf);\n+    g_api_key = strdup(buf);\n+    if (!g_api_key) g_api_key = strdup(\"\");\n+}\n+\n+int api_key_valid(struct MHD_Connection *connection) {\n+    load_api_key_once();\n+    const char *hdr = MHD_lookup_connection_value(connection, MHD_HEADER_KIND, \"X-API-Key\");\n+    if (!hdr) return 0;\n+    // header values are already trimmed by MHD, but be safe\n+    char tmp[512];\n+    snprintf(tmp, sizeof(tmp), \"%s\", hdr);\n+    trim_in_place(tmp);\n+    return (strcmp(tmp, g_api_key) == 0);\n+}\n*** End Patch\nPATCH\n"]
