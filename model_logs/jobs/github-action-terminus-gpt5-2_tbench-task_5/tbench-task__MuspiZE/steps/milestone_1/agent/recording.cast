[290.359664, "o", "enum MHD_Result route_request(struct MHD_Connection *connection, const char *url,\r\n                              const char *method, const char *upload_data,\r\n                              size_t *upload_data_size, void **con_cls) {\r\n"]
[290.359686, "o", "    (void)upload_data;\r\n    (void)upload_data_size;\r\n    (void)con_cls;\r\n\r\n"]
[290.359704, "o", "    if (strcmp(method, \"OPTIONS\") == 0)\r\n        return send_json(connection, \"\", MHD_HTTP_OK);\r\n\r\n"]
[290.359724, "o", "    if (strcmp(url, \"/api/notes\") == 0 && strcmp(method, \"GET\") == 0) {\r\n        int total = get_total_notes_count();\r\n        char *json = get_notes_paginated_json(50, 0);\r\n"]
[290.360404, "o", "        if (!json)\r\n            return send_json_total(connection, \"[]\", MHD_HTTP_OK, total);\r\n"]
[290.360541, "o", "        enum MHD_Result r = send_json_total(connection, json, MHD_HTTP_OK, total);\r\n        free(json);\r\n        return r;\r\n    }\r\n\r\n    return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\r\n}\r\n\u001b[?2004hroot@bb40ba43d60f:/app# "]
