[454.477034, "i", "apply_patch<<'PATCH'\n*** Begin Patch\n*** Add File: /app/src/db.c\n+#include \"db.h\"\n+\n+#include <sqlite3.h>\n+#include <stdio.h>\n+#include <stdlib.h>\n+#include <string.h>\n+#include <unistd.h>\n+\n+static char g_db_path[512] = {0};\n+\n+static int exec_sql(sqlite3 *db, const char *sql) {\n+    char *err = NULL;\n+    int rc = sqlite3_exec(db, sql, NULL, NULL, &err);\n+    if (rc != SQLITE_OK) {\n+        if (err) {\n+            fprintf(stderr, \"sqlite exec error: %s\\n\", err);\n+            sqlite3_free(err);\n+        }\n+        return -1;\n+    }\n+    return 0;\n+}\n+\n+static int open_db(sqlite3 **out) {\n+    *out = NULL;\n+    int flags = SQLITE_OPEN_READWRITE | SQLITE_OPEN_CREATE | SQLITE_OPEN_FULLMUTEX;\n+    sqlite3 *db = NULL;\n+    int rc = sqlite3_open_v2(g_db_path[0] ? g_db_path : \"/app/data/notes.db\", &db, flags, NULL);\n+    if (rc != SQLITE_OK) {\n+        fprintf(stderr, \"Cannot open database: %s\\n\", sqlite3_errmsg(db));\n+        if (db) sqlite3_close(db);\n+        return -1;\n+    }\n+    sqlite3_busy_timeout(db, 2000);\n+    // Concurrency-friendly settings\n+    exec_sql(db, \"PRAGMA journal_mode=WAL;\");\n+    exec_sql(db, \"PRAGMA synchronous=NORMAL;\");\n+    exec_sql(db, \"PRAGMA foreign_keys=ON;\");\n+    *out = db;\n+    return 0;\n+}\n+\n+int init_db(const char *path) {\n+    if (path && *path) {\n+        snprintf(g_db_path, sizeof(g_db_path), \"%s\", path);\n+    }\n+    sqlite3 *db = NULL;\n+    if (open_db(&db) != 0) return -1;\n+\n+    const char *sql =\n+        \"CREATE TABLE IF NOT EXISTS notes (\"\n+        \"id INTEGER PRIMARY KEY AUTOINCREMENT,\"\n+        \"title TEXT NOT NULL,\"\n+        \"content TEXT DEFAULT ''\"\n+        \");\";\n+    int rc = exec_sql(db, sql);\n+    sqlite3_close(db);\n+    return rc;\n+}\n+\n+void close_db(void) {\n+    // no global handles\n+}\n+\n+static void json_append(char **buf, size_t *cap, size_t *len, const char *s) {\n+    size_t sl = strlen(s);\n+    if (*len + sl + 1 > *cap) {\n+        size_t ncap = (*cap == 0) ? 512 : *cap;\n+        while (*len + sl + 1 > ncap) ncap *= 2;\n+        char *nb = realloc(*buf, ncap);\n+        if (!nb) return;\n+        *buf = nb;\n+        *cap = ncap;\n+    }\n+    memcpy(*buf + *len, s, sl);\n+    *len += sl;\n+    (*buf)[*len] = '\\0';\n+}\n+\n+static void json_append_escaped(char **buf, size_t *cap, size_t *len, const char *s) {\n+    json_append(buf, cap, len, \"\\\"\");\n+    for (const unsigned char *p = (const unsigned char *)s; p && *p; p++) {\n+        char tmp[8];\n+        switch (*p) {\n+            case '\"': json_append(buf, cap, len, \"\\\\\\\"\"); break;\n+            case '\\\\': json_append(buf, cap, len, \"\\\\\\\\\"); break;\n+            case '\\b': json_append(buf, cap, len, \"\\\\b\"); break;\n+            case '\\f': json_append(buf, cap, len, \"\\\\f\"); break;\n+            case '\\n': json_append(buf, cap, len, \"\\\\n\"); break;\n+            case '\\r': json_append(buf, cap, len, \"\\\\r\"); break;\n+            case '\\t': json_append(buf, cap, len, \"\\\\t\"); break;\n+            default:\n+                if (*p < 0x20) {\n+                    snprintf(tmp, sizeof(tmp), \"\\\\u%04x\", *p);\n+                    json_append(buf, cap, len, tmp);\n+                } else {\n+                    tmp[0] = (char)*p;\n+                    tmp[1] = '\\0';\n+                    json_append(buf, cap, len, tmp);\n+                }\n+        }\n+    }\n+    json_append(buf, cap, len, \"\\\"\");\n+}\n+\n+int get_total_notes_count(void) {\n+    sqlite3 *db = NULL;\n+    if (open_db(&db) != 0) return 0;\n+    sqlite3_stmt *st = NULL;\n+    int total = 0;\n+    if (sqlite3_prepare_v2(db, \"SELECT COUNT(*) FROM notes\", -1, &st, NULL) == SQLITE_OK) {\n+        if (sqlite3_step(st) == SQLITE_ROW) {\n+            total = sqlite3_column_int(st, 0);\n+        }\n+    }\n+    if (st) sqlite3_finalize(st);\n+    sqlite3_close(db);\n+    return total;\n+}\n+\n+char *get_notes_paginated_json(int limit, int offset) {\n+    sqlite3 *db = NULL;\n+    if (open_db(&db) != 0) return NULL;\n+    sqlite3_stmt *st = NULL;\n+    const char *sql = \"SELECT id, title, content FROM notes ORDER BY id LIMIT ? OFFSET ?\";\n+    if (sqlite3_prepare_v2(db, sql, -1, &st, NULL) != SQLITE_OK) {\n+        sqlite3_cl"]
[454.477204, "i", "ose(db);\n+        return NULL;\n+    }\n+    sqlite3_bind_int(st, 1, limit);\n+    sqlite3_bind_int(st, 2, offset);\n+\n+    char *out = NULL;\n+    size_t cap = 0, len = 0;\n+    json_append(&out, &cap, &len, \"[\");\n+    int first = 1;\n+    while (sqlite3_step(st) == SQLITE_ROW) {\n+        int id = sqlite3_column_int(st, 0);\n+        const char *title = (const char *)sqlite3_column_text(st, 1);\n+        const char *content = (const char *)sqlite3_column_text(st, 2);\n+        if (!first) json_append(&out, &cap, &len, \",\");\n+        first = 0;\n+        char tmp[64];\n+        snprintf(tmp, sizeof(tmp), \"{\\\"id\\\":%d,\\\"title\\\":\", id);\n+        json_append(&out, &cap, &len, tmp);\n+        json_append_escaped(&out, &cap, &len, title ? title : \"\");\n+        json_append(&out, &cap, &len, \",\\\"content\\\":\");\n+        json_append_escaped(&out, &cap, &len, content ? content : \"\");\n+        json_append(&out, &cap, &len, \"}\");\n+    }\n+    json_append(&out, &cap, &len, \"]\");\n+\n+    sqlite3_finalize(st);\n+    sqlite3_close(db);\n+    return out;\n+}\n+\n+char *get_all_notes_json(void) {\n+    return get_notes_paginated_json(100, 0);\n+}\n+\n+char *get_note_json(int id) {\n+    sqlite3 *db = NULL;\n+    if (open_db(&db) != 0) return NULL;\n+    sqlite3_stmt *st = NULL;\n+    const char *sql = \"SELECT id, title, content FROM notes WHERE id = ?\";\n+    if (sqlite3_prepare_v2(db, sql, -1, &st, NULL) != SQLITE_OK) {\n+        sqlite3_close(db);\n+        return NULL;\n+    }\n+    sqlite3_bind_int(st, 1, id);\n+    char *out = NULL;\n+    if (sqlite3_step(st) == SQLITE_ROW) {\n+        int rid = sqlite3_column_int(st, 0);\n+        const char *title = (const char *)sqlite3_column_text(st, 1);\n+        const char *content = (const char *)sqlite3_column_text(st, 2);\n+        size_t cap = 0, len = 0;\n+        char tmp[64];\n+        snprintf(tmp, sizeof(tmp), \"{\\\"id\\\":%d,\\\"title\\\":\", rid);\n+        json_append(&out, &cap, &len, tmp);\n+        json_append_escaped(&out, &cap, &len, title ? title : \"\");\n+        json_append(&out, &cap, &len, \",\\\"content\\\":\");\n+        json_append_escaped(&out, &cap, &len, content ? content : \"\");\n+        json_append(&out, &cap, &len, \"}\");\n+    }\n+    sqlite3_finalize(st);\n+    sqlite3_close(db);\n+    return out;\n+}\n+\n+static int exec_with_retry(sqlite3 *db, const char *sql) {\n+    for (int i = 0; i < 20; i++) {\n+        char *err = NULL;\n+        int rc = sqlite3_exec(db, sql, NULL, NULL, &err);\n+        if (rc == SQLITE_OK) return 0;\n+        if (rc == SQLITE_BUSY || rc == SQLITE_LOCKED) {\n+            if (err) sqlite3_free(err);\n+            usleep(10 * 1000);\n+            continue;\n+        }\n+        if (err) {\n+            fprintf(stderr, \"sqlite exec error: %s\\n\", err);\n+            sqlite3_free(err);\n+        }\n+        return -1;\n+    }\n+    return -1;\n+}\n+\n+int create_note(const char *title, const char *content) {\n+    sqlite3 *db = NULL;\n+    if (open_db(&db) != 0) return -1;\n+    if (exec_with_retry(db, \"BEGIN IMMEDIATE\") != 0) {\n+        sqlite3_close(db);\n+        return -1;\n+    }\n+    sqlite3_stmt *st = NULL;\n+    const char *sql = \"INSERT INTO notes(title, content) VALUES(?, ?)\";\n+    if (sqlite3_prepare_v2(db, sql, -1, &st, NULL) != SQLITE_OK) {\n+        exec_with_retry(db, \"ROLLBACK\");\n+        sqlite3_close(db);\n+        return -1;\n+    }\n+    sqlite3_bind_text(st, 1, title ? title : \"\", -1, SQLITE_TRANSIENT);\n+    sqlite3_bind_text(st, 2, content ? content : \"\", -1, SQLITE_TRANSIENT);\n+\n+    int rc;\n+    int tries;\n+    for (tries = 0; tries < 20; tries++) {\n+        rc = sqlite3_step(st);\n+        if (rc == SQLITE_DONE) break;\n+        if (rc == SQLITE_BUSY || rc == SQLITE_LOCKED) {\n+            usleep(10 * 1000);\n+            continue;\n+        }\n+        break;\n+    }\n+    sqlite3_finalize(st);\n+    if (rc != SQLITE_DONE) {\n+        exec_with_retry(db, \"ROLLBACK\");\n+        sqlite3_close(db);\n+        return -1;\n+    }\n+    int id = (int)sqlite3_last_insert_rowid(db);\n+    if (exec_with_retry(db, \"COMMIT\") != 0) {\n+        sqlite3_close(db);\n+        return -1;\n+    }\n+    sqlite3_close(db);\n+    return id;\n+}\n+\n+int no"]
