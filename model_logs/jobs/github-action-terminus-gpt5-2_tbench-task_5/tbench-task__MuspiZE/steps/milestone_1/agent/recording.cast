[1462.946818, "i", "apply_patch<<'PATCH'\n*** Begin Patch\n*** Update File: /app/www/app.js\n@@\n-// TODO: implement client\n+// Notes SPA client\n+// Requirements:\n+// - Use same-origin API base: /api/notes\n+// - GET must NOT send API key header\n+// - POST/PUT/DELETE must send Content-Type: application/json and X-API-Key\n+\n+const API_BASE = '/api/notes';\n+\n+let apiKey = '';\n+let activeNoteId = null;\n+\n+function $(id) {\n+  return document.getElementById(id);\n+}\n+\n+function getKey() {\n+  // In the harness, fetch exists; this runs in a \"browser-like\" environment.\n+  // Load key once; keep it trimmed.\n+  if (apiKey) return Promise.resolve(apiKey);\n+  return fetch('/config/api.key')\n+    .then((r) => r.text())\n+    .then((t) => {\n+      apiKey = (t || '').trim();\n+      return apiKey;\n+    });\n+}\n+\n+function headersWithKey() {\n+  return getKey().then((k) => ({\n+    'Content-Type': 'application/json',\n+    'X-API-Key': k\n+  }));\n+}\n+\n+function clearForm() {\n+  const title = $('note-title');\n+  const content = $('note-content');\n+  if (title) title.value = '';\n+  if (content) content.value = '';\n+  activeNoteId = null;\n+}\n+\n+function setFormFromNote(note) {\n+  const title = $('note-title');\n+  const content = $('note-content');\n+  if (title) title.value = note && note.title != null ? String(note.title) : '';\n+  if (content) content.value = note && note.content != null ? String(note.content) : '';\n+}\n+\n+function renderNotes(notes) {\n+  const list = $('notes-list');\n+  if (!list) return;\n+  list.innerHTML = '';\n+\n+  (notes || []).forEach((note) => {\n+    const row = document.createElement('div');\n+    row.className = 'note-row';\n+    row.dataset.noteId = String(note.id);\n+\n+    const title = document.createElement('span');\n+    title.className = 'note-title';\n+    title.textContent = note.title == null ? '' : String(note.title);\n+\n+    const content = document.createElement('span');\n+    content.className = 'note-content';\n+    content.textContent = note.content == null ? '' : String(note.content);\n+\n+    const editBtn = document.createElement('button');\n+    editBtn.type = 'button';\n+    editBtn.className = 'edit-btn';\n+    editBtn.textContent = 'Edit';\n+    editBtn.dataset.noteId = String(note.id);\n+\n+    const deleteBtn = document.createElement('button');\n+    deleteBtn.type = 'button';\n+    deleteBtn.className = 'delete-btn';\n+    deleteBtn.textContent = 'Delete';\n+    deleteBtn.dataset.noteId = String(note.id);\n+\n+    row.appendChild(title);\n+    row.appendChild(content);\n+    row.appendChild(editBtn);\n+    row.appendChild(deleteBtn);\n+    list.appendChild(row);\n+  });\n+}\n+\n+function loadNotes() {\n+  // GET should not send API key.\n+  return fetch(API_BASE)\n+    .then((r) => r.json())\n+    .then((data) => {\n+      // API may return array directly or {notes:[...]}\n+      const notes = Array.isArray(data) ? data : (data && data.notes) ? data.notes : [];\n+      renderNotes(notes);\n+      return notes;\n+    });\n+}\n+\n+function createNote(payload) {\n+  return headersWithKey().then((headers) =>\n+    fetch(API_BASE, {\n+      method: 'POST',\n+      headers,\n+      body: JSON.stringify(payload)\n+    })\n+  );\n+}\n+\n+function updateNote(id, payload) {\n+  return headersWithKey().then((headers) =>\n+    fetch(`${API_BASE}/${encodeURIComponent(String(id))}`, {\n+      method: 'PUT',\n+      headers,\n+      body: JSON.stringify(payload)\n+    })\n+  );\n+}\n+\n+function deleteNote(id) {\n+  return headersWithKey().then((headers) =>\n+    fetch(`${API_BASE}/${encodeURIComponent(String(id))}`, {\n+      method: 'DELETE',\n+      headers\n+    })\n+  );\n+}\n+\n+function noteFromRow(row) {\n+  const id = row && row.dataset ? row.dataset.noteId : null;\n+  const titleEl = row ? row.querySelector('.note-title') : null;\n+  const contentEl = row ? row.querySelector('.note-content') : null;\n+  return {\n+    id: id,\n+    title: titleEl ? titleEl.textContent : '',\n+    content: contentEl ? contentEl.textContent : ''\n+  };\n+}\n+\n+function wireEvents() {\n+  const form = $('note-form');\n+  const list = $('notes-list');\n+\n+  if (form) {\n+    form.addEventListener('submit', (e) => {\n+      e.prevent"]
[1462.947309, "i", "Default();\n+      const title = ($('note-title') && $('note-title').value != null) ? $('note-title').value : '';\n+      const content = ($('note-content') && $('note-content').value != null) ? $('note-content').value : '';\n+\n+      const payload = {\n+        title: String(title).trim(),\n+        content: String(content).trim()\n+      };\n+\n+      const op = activeNoteId ? updateNote(activeNoteId, payload) : createNote(payload);\n+      op.then(() => {\n+        clearForm();\n+        return loadNotes();\n+      });\n+    });\n+  }\n+\n+  if (list) {\n+    // Event delegation to satisfy mock DOM quirks.\n+    list.addEventListener('click', (e) => {\n+      const t = e && e.target ? e.target : null;\n+      if (!t) return;\n+\n+      if (t.classList && t.classList.contains('edit-btn')) {\n+        const id = t.dataset ? t.dataset.noteId : null;\n+        activeNoteId = id;\n+        const row = t.closest ? t.closest('[data-note-id]') : null;\n+        const note = row ? noteFromRow(row) : { title: '', content: '' };\n+        setFormFromNote(note);\n+        return;\n+      }\n+\n+      if (t.classList && t.classList.contains('delete-btn')) {\n+        const id = t.dataset ? t.dataset.noteId : null;\n+        deleteNote(id).then(() => loadNotes());\n+      }\n+    });\n+  }\n+}\n+\n+// Boot\n+wireEvents();\n+loadNotes();\n*** End Patch\nPATCH\n"]
