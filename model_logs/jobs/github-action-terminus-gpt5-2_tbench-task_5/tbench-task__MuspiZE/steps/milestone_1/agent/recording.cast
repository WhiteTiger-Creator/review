[266.09721, "i", "cat > /tmp/inspect_db.c <<'EOF'\n#include <stdio.h>\n#include <sqlite3.h>\n\nstatic int cb(void* u, int argc, char** argv, char** col){\n  (void)u;\n  for(int i=0;i<argc;i++) printf(\"%s=%s\\n\", col[i], argv[i]?argv[i]:\"NULL\");\n  printf(\"---\\n\");\n  return 0;\n}\n\nint main(int argc, char** argv){\n  const char* path = argc>1?argv[1]:\"/app/data/notes.db\";\n  sqlite3* db=NULL;\n  if(sqlite3_open_v2(path,&db,SQLITE_OPEN_READONLY,NULL)!=SQLITE_OK){\n    fprintf(stderr,\"open failed: %s\\n\", sqlite3_errmsg(db));\n    return 2;\n  }\n  char* err=NULL;\n  sqlite3_exec(db,\"PRAGMA user_version;\",cb,NULL,&err);\n  if(err){ fprintf(stderr,\"err: %s\\n\", err); sqlite3_free(err); err=NULL; }\n  sqlite3_exec(db,\"SELECT name, sql FROM sqlite_master WHERE type IN ('table','index','trigger') ORDER BY type,name;\",cb,NULL,&err);\n  if(err){ fprintf(stderr,\"err: %s\\n\", err); sqlite3_free(err); err=NULL; }\n  sqlite3_close(db);\n  return 0;\n}\nEOF\ncc -O2 -Wall -Wextra /tmp/inspect_db.c -lsqlite3 -o /tmp/inspect_db\n/tmp/inspect_db /app/data/notes.db\n"]
