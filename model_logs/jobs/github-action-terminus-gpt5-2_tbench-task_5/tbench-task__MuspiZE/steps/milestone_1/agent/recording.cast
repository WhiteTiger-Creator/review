switch (c) {\n+                case '\"': c = '\"'; break;\n+                case '\\\\': c = '\\\\'; break;\n+                case '/': c = '/'; break;\n+                case 'b': c = '\\b'; break;\n+                case 'f': c = '\\f'; break;\n+                case 'n': c = '\\n'; break;\n+                case 'r': c = '\\r'; break;\n+                case 't': c = '\\t'; break;\n+                default: break;\n+            }\n+            if (len + 2 > cap) {\n+                cap *= 2;\n+                char *nb = realloc(out, cap);\n+                if (!nb) { free(out); return NULL; }\n+                out = nb;\n+            }\n+            out[len++] = c;\n+            p++;\n+            continue;\n+        }\n+        if (len + 2 > cap) {\n+            cap *= 2;\n+            char *nb = realloc(out, cap);\n+            if (!nb) { free(out); return NULL; }\n+            out = nb;\n+        }\n+        out[len++] = *p;\n+        p++;\n+    }\n+    free(out);\n+    return NULL;\n+}\n+\n+static enum MHD_Result unauthorized(struct MHD_Connection *connection) {\n+    return send_json(connection, \"{\\\"error\\\":\\\"unauthorized\\\"}\", MHD_HTTP_UNAUTHORIZED);\n+}\n+\n+static enum MHD_Result too_large(struct MHD_Connection *connection) {\n+    return send_json(connection, \"{\\\"error\\\":\\\"payload too large\\\"}\", MHD_HTTP_REQUEST_ENTITY_TOO_LARGE);\n+}\n+\n+static enum MHD_Result bad_request(struct MHD_Connection *connection) {\n+    return send_json(connection, \"{\\\"error\\\":\\\"bad request\\\"}\", MHD_HTTP_BAD_REQUEST);\n+}\n+\n+static int parse_id(const char *url) {\n+    const char *p = \"/api/notes/\";\n+    size_t n = strlen(p);\n+    if (strncmp(url, p, n) != 0) return -1;\n+    const char *idstr = url + n;\n+    if (!*idstr) return -1;\n+    char *end = NULL;\n+    long v = strtol(idstr, &end, 10);\n+    if (!end || *end != '\\0') return -1;\n+    if (v < 0 || v > 2147483647L) return -1;\n+    return (int)v;\n+}\n@@\n enum MHD_Result route_request(struct MHD_Connection *connection, const char *url,\n                               const char *method, const char *upload_data,\n                               size_t *upload_data_size, void **con_cls) {\n-    (void)upload_data;\n-    (void)upload_data_size;\n-    (void)con_cls;\n-\n     if (strcmp(method, \"OPTIONS\")"]
[455.479968, "i", " == 0)\n         return send_json(connection, \"\", MHD_HTTP_OK);\n+\n+    // Handle upload (POST/PUT)\n+    int is_write = (strcmp(method, \"POST\") == 0 || strcmp(method, \"PUT\") == 0 || strcmp(method, \"DELETE\") == 0);\n+    if (is_write && !api_key_valid(connection)) {\n+        return unauthorized(connection);\n+    }\n+\n+    if ((strcmp(method, \"POST\") == 0 || strcmp(method, \"PUT\") == 0) && *upload_data_size) {\n+        struct connection_info *ci = *con_cls;\n+        if (!ci) {\n+            ci = calloc(1, sizeof(*ci));\n+            if (!ci) return MHD_NO;\n+            *con_cls = ci;\n+        }\n+        if (ci->data_size + *upload_data_size > NOTES_MAX_BODY_BYTES) {\n+            *upload_data_size = 0;\n+            return too_large(connection);\n+        }\n+        char *nb = realloc(ci->data, ci->data_size + *upload_data_size + 1);\n+        if (!nb) return MHD_NO;\n+        ci->data = nb;\n+        memcpy(ci->data + ci->data_size, upload_data, *upload_data_size);\n+        ci->data_size += *upload_data_size;\n+        ci->data[ci->data_size] = '\\0';\n+        *upload_data_size = 0;\n+        return MHD_YES;\n+    }\n \n     if (strcmp(url, \"/api/notes\") == 0 && strcmp(method, \"GET\") == 0) {\n-        int total = get_total_notes_count();\n-        char *json = get_notes_paginated_json(50, 0);\n+        const char *limit_s = MHD_lookup_connection_value(connection, MHD_GET_ARGUMENT_KIND, \"limit\");\n+        const char *offset_s = MHD_lookup_connection_value(connection, MHD_GET_ARGUMENT_KIND, \"offset\");\n+        int limit = parse_int_param(limit_s, NOTES_DEFAULT_PAGE_SIZE);\n+        int offset = parse_int_param(offset_s, 0);\n+        if (limit > NOTES_MAX_PAGE_SIZE) limit = NOTES_MAX_PAGE_SIZE;\n+\n+        int total = get_total_notes_count();\n+        char *json = get_notes_paginated_json(limit, offset);\n         if (!json)\n             return send_json_total(connection, \"[]\", MHD_HTTP_OK, total);\n         enum MHD_Result r = send_json_total(connection, json, MHD_HTTP_OK, total);\n         free(json);\n         return r;\n     }\n+\n+    if (strcmp(url, \"/api/notes\") == 0 && strcmp(method, \"POST\") == 0) {\n+        struct connection_info *ci = *con_cls;\n+        const char *body = (ci && ci->data) ? ci->data : \"\";\n+        char *title = json_get_string_dup(body, \"title\");\n+        char *content = json_get_string_dup(body, \"content\");\n+        if (!title || is_blank(title)) {\n+            free(title);\n+            free(content);\n+            return bad_request(connection);\n+        }\n+        if (!content) content = strdup(\"\");\n+        int id = create_note(title, content);\n+        if (id < 0) {\n+            free(title);\n+            free(content);\n+            return send_json(connection, \"{\\\"error\\\":\\\"server error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR);\n+        }\n+        size_t sz = strlen(title) + strlen(content) + 64;\n+        char *resp = malloc(sz);\n+        if (!resp) {\n+            free(title);\n+            free(content);\n+            return MHD_NO;\n+        }\n+        // simple JSON, title/content already raw; escape minimally by reusing db JSON readback would be safer, but contract only uses arbitrary strings\n+        // We will read back from DB to ensure proper escaping.\n+        free(resp);\n+        char *obj = get_note_json(id);\n+        free(title);\n+        free(content);\n+        if (!obj) return send_json(connection, \"{\\\"error\\\":\\\"server error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR);\n+        enum MHD_Result r = send_json(connection, obj, MHD_HTTP_CREATED);\n+        free(obj);\n+        return r;\n+    }\n+\n+    int id = parse_id(url);\n+    if (id >= 0 && strcmp(method, \"GET\") == 0) {\n+        char *obj = get_note_json(id);\n+        if (!obj) return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\n+        enum MHD_Result r = send_json(connection, obj, MHD_HTTP_OK);\n+        free(obj);\n+        return r;\n+    }\n+\n+    if (id >= 0 && strcmp(method, \"PUT\") == 0) {\n+        if (!note_exists(id)) return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\n+        struct connection_info *ci = *con_cls;\n+"]
[455.480051, "i", "        const char *body = (ci && ci->data) ? ci->data : \"\";\n+        char *title = json_get_string_dup(body, \"title\");\n+        char *content = json_get_string_dup(body, \"content\");\n+        if (!title || is_blank(title)) {\n+            free(title);\n+            free(content);\n+            return bad_request(connection);\n+        }\n+        if (!content) content = strdup(\"\");\n+        int rc = update_note(id, title, content);\n+        free(title);\n+        free(content);\n+        if (rc < 0) return send_json(connection, \"{\\\"error\\\":\\\"server error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR);\n+        if (rc == 0) return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\n+        char *obj = get_note_json(id);\n+        if (!obj) return send_json(connection, \"{\\\"error\\\":\\\"server error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR);\n+        enum MHD_Result r = send_json(connection, obj, MHD_HTTP_OK);\n+        free(obj);\n+        return r;\n+    }\n+\n+    if (id >= 0 && strcmp(method, \"DELETE\") == 0) {\n+        int rc = delete_note(id);\n+        if (rc < 0) return send_json(connection, \"{\\\"error\\\":\\\"server error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR);\n+        if (rc == 0) return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\n+        return send_json(connection, \"{\\\"status\\\":\\\"deleted\\\"}\", MHD_HTTP_OK);\n+    }\n \n     return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\n }\n*** End Patch\nPATCH\n"]
