[194.801345, "o", "\u001b[?2004h> "]
[194.801778, "o", "    if (url_percent_decode(url, decoded, sizeof(decoded)) != 0) return 1;\r\n\u001b[?2004l\r"]
[194.801818, "o", "\u001b[?2004h> "]
