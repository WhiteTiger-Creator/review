[194.798009, "o", "static int decoded_path_has_dotdot_segment(const char *path) {\r\n\u001b[?2004l\r"]
[194.798054, "o", "\u001b[?2004h> "]
[194.798231, "o", "    const char *p = path;\r\n\u001b[?2004l\r"]
[194.79826, "o", "\u001b[?2004h> "]
[194.798421, "o", "    while (*p) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.79863, "o", "        while (*p == '/') p++;\r\n\u001b[?2004l\r"]
[194.798654, "o", "\u001b[?2004h> "]
[194.798815, "o", "        if (!*p) break;\r\n\u001b[?2004l\r"]
[194.798844, "o", "\u001b[?2004h> "]
[194.79902, "o", "        const char *seg = p;\r\n\u001b[?2004l\r"]
[194.799048, "o", "\u001b[?2004h> "]
[194.799308, "o", "        while (*p && *p != '/') p++;\r\n\u001b[?2004l\r"]
[194.799336, "o", "\u001b[?2004h> "]
[194.799562, "o", "        size_t len = (size_t)(p - seg);\r\n\u001b[?2004l\r"]
[194.799591, "o", "\u001b[?2004h> "]
[194.800304, "o", "        if (len == 2 && seg[0] == '.' && seg[1] == '.') return 1;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.800382, "o", "    return 0;\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[194.800479, "o", "\u001b[?2004h> "]
