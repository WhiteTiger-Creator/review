[194.808906, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.809076, "o", "    struct MHD_Response *response = MHD_create_response_from_buffer(\r\n\u001b[?2004l\r"]
