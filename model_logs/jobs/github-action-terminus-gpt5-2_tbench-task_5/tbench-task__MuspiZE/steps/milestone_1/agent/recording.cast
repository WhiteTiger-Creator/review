[313.167728, "o", "     9\tint init_db(const char *path) {\r\n    10\t    if (sqlite3_open_v2(path, &db,\r\n    11\t            SQLITE_OPEN_READWRITE | SQLITE_OPEN_CREATE | SQLITE_OPEN_NOMUTEX,\r\n    12\t            NULL) != SQLITE_OK) {\r\n    13\t        fprintf(stderr, \"Cannot open database: %s\\n\", sqlite3_errmsg(db));\r\n    14\t        return -1;\r\n    15\t    }\r\n    16\t\r\n    17\t    const char *sql = \"CREATE TABLE IF NOT EXISTS notes (\"\r\n    18\t                      \"id INTEGER PRIMARY KEY AUTOINCREMENT,\"\r\n    19\t                      \"title TEXT NOT NULL,\"\r\n"]
[313.168123, "o", "    20\t                      \"content TEXT DEFAULT ''\"\r\n    21\t                      \");\";\r\n    22\t    char *err_msg = NULL;\r\n    23\t    if (sqlite3_exec(db, sql, NULL, NULL, &err_msg) != SQLITE_OK) {\r\n    24\t        fprintf(stderr, \"SQL error: %s\\n\", err_msg);\r\n    25\t        sqlite3_free(err_msg);\r\n    26\t        return -1;\r\n"]
[313.168686, "o", "    27\t    }\r\n    28\t    return 0;\r\n    29\t}\r\n    30\t\r\n    31\tvoid close_db(void) {\r\n    32\t    if (db)\r\n    33\t        sqlite3_close(db);\r\n    34\t    db = NULL;\r\n    35\t}\r\n    36\t\r\n    37\tint create_note(const char *title, const char *content) {\r\n    38\t    (void)title;\r\n    39\t    (void)content;\r\n    40\t    return 0;\r\n    41\t}\r\n    42\t\r\n    43\tchar *get_all_notes_json(void) {\r\n    44\t    return strdup(\"[]\");\r\n    45\t}\r\n    46\t\r\n    47\tchar *get_notes_paginated_json(int limit, int offset) {\r\n    48\t    (void)limit;\r\n    49\t    (void)offset;\r\n    50\t    return strdup(\"[]\");\r\n    51\t}\r\n    52\t\r\n    53\tint get_total_notes_count(void) {\r\n    54\t    return 0;\r\n"]
[313.168858, "o", "    55\t}\r\n    56\t\r\n    57\tchar *get_note_json(int id) {\r\n    58\t    (void)id;\r\n    59\t    return NULL;\r\n    60\t}\r\n    61\t\r\n    62\tint update_note(int id, const char *title, const char *content) {\r\n    63\t    (void)id;\r\n    64\t    (void)title;\r\n    65\t    (void)content;\r\n    66\t    return 0;\r\n    67\t}\r\n    68\t\r\n    69\tint delete_note(int id) {\r\n    70\t    (void)id;\r\n    71\t    return 0;\r\n    72\t}\r\n    73\t\r\n    74\tint note_exists(int id) {\r\n    75\t    (void)id;\r\n    76\t    return 0;\r\n    77\t}\r\n"]
