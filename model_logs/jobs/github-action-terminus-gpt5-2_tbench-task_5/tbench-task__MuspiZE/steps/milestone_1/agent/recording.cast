[194.81639, "o", "\u001b[?2004h> "]
[194.816452, "o", "    if (*con_cls == NULL) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[194.816515, "o", "> "]
[194.816791, "o", "        struct connection_info *ci = calloc(1, sizeof(*ci));\r\n\u001b[?2004l\r\u001b[?2004h> "]
