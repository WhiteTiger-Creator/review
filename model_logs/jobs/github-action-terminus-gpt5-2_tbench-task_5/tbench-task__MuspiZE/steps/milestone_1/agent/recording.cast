[469.503928, "o", "   170\t        &handle_request, NULL,\r\n   171\t        MHD_OPTION_NOTIFY_COMPLETED, &request_completed, NULL,\r\n   172\t        MHD_OPTION_END);\r\n   173\t\r\n   174\t    if (!daemon_handle) {\r\n   175\t        fprintf(stderr, \"Failed to start server\\n\");\r\n   176\t        return 1;\r\n   177\t    }\r\n   178\t\r\n   179\t    printf(\"Server running on port %d\\n\", PORT);\r\n   180\t    while (1) pause();\r\n   181\t    return 0;\r\n   182\t}\r\n"]
