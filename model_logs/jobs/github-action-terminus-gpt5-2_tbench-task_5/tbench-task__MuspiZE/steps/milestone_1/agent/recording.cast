[486.773526, "i", "apply_patch<<'PATCH'\n*** Begin Patch\n*** Update File: /app/src/routes.c\n@@\n-static void request_completed(void *cls, struct MHD_Connection *connection,\n-                              void **con_cls, enum MHD_RequestTerminationCode toe) {\n-    (void)cls;\n-    (void)connection;\n-    (void)toe;\n-    if (con_cls && *con_cls) {\n-        struct connection_info *ci = *con_cls;\n-        if (ci->data)\n-            free(ci->data);\n-        free(ci);\n-        *con_cls = NULL;\n-    }\n-}\n-\n enum MHD_Result route_request(struct MHD_Connection *connection, const char *url,\n                               const char *method, const char *upload_data,\n                               size_t *upload_data_size, void **con_cls) {\n+    // libmicrohttpd calls the handler multiple times per request.\n+    // First call must initialize per-connection state and return.\n+    if (*con_cls == NULL) {\n+        struct connection_info *ci = calloc(1, sizeof(*ci));\n+        if (!ci) return MHD_NO;\n+        *con_cls = ci;\n+        return MHD_YES;\n+    }\n+\n     if (strcmp(method, \"OPTIONS\") == 0)\n         return send_json(connection, \"\", MHD_HTTP_OK);\n@@\n-    // Handle upload (POST/PUT)\n+    // Handle upload (POST/PUT)\n     int is_write = (strcmp(method, \"POST\") == 0 || strcmp(method, \"PUT\") == 0 || strcmp(method, \"DELETE\") == 0);\n     if (is_write && !api_key_valid(connection)) {\n         return unauthorized(connection);\n     }\n@@\n-    if ((strcmp(method, \"POST\") == 0 || strcmp(method, \"PUT\") == 0) && *upload_data_size) {\n-        struct connection_info *ci = *con_cls;\n-        if (!ci) {\n-            ci = calloc(1, sizeof(*ci));\n-            if (!ci) return MHD_NO;\n-            *con_cls = ci;\n-        }\n+    if ((strcmp(method, \"POST\") == 0 || strcmp(method, \"PUT\") == 0) && *upload_data_size) {\n+        struct connection_info *ci = *con_cls;\n         if (ci->data_size + *upload_data_size > NOTES_MAX_BODY_BYTES) {\n             *upload_data_size = 0;\n             return too_large(connection);\n         }\n@@\n         *upload_data_size = 0;\n         return MHD_YES;\n     }\n*** End Patch\nPATCH\n"]
