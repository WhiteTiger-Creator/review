[313.527346, "o", "     1\t#include <microhttpd.h>\r\n     2\t#include <stdio.h>\r\n     3\t#include <string.h>\r\n     4\t#include <stdlib.h>\r\n     5\t#include <signal.h>\r\n     6\t#include <sys/stat.h>\r\n     7\t#include <strings.h>\r\n"]
[313.527404, "o", "     8\t#include <unistd.h>\r\n     9\t\r\n    10\t#include \"routes.h\"\r\n    11\t#include \"db.h\"\r\n    12\t\r\n    13\t#define PORT 8080\r\n    14\t#define WWW_DIR \"/app/www\"\r\n    15\t\r\n    16\tstatic struct MHD_Daemon *daemon_handle = NULL;\r\n    17\t\r\n    18\tstatic void handle_signal(int sig) {\r\n"]
[313.52743, "o", "    19\t    (void)sig;\r\n    20\t    if (daemon_handle) MHD_stop_daemon(daemon_handle);\r\n    21\t    close_db();\r\n    22\t    exit(0);\r\n    23\t}\r\n    24\t\r\n    25\tstatic const char *get_content_type(const char *path) {\r\n    26\t    const char *ext = strrchr(path, '.');\r\n    27\t    if (!ext) return \"application/octet-stream\";\r\n    28\t    if (strcmp(ext, \".html\") == 0) return \"text/html\";\r\n    29\t    if (strcmp(ext, \".css\") == 0) return \"text/css\";\r\n"]
[313.527452, "o", "    30\t    if (strcmp(ext, \".js\") == 0) return \"application/javascript\";\r\n    31\t    return \"application/octet-stream\";\r\n    32\t}\r\n    33\t\r\n    34\tstatic int hexval(char c) {\r\n"]
[313.527907, "o", "    35\t    if (c >= '0' && c <= '9') return c - '0';\r\n    36\t    if (c >= 'a' && c <= 'f') return 10 + (c - 'a');\r\n    37\t    if (c >= 'A' && c <= 'F') return 10 + (c - 'A');\r\n    38\t    return -1;\r\n    39"]
[313.527949, "o", "\t}\r\n    40\t\r\n    41\tstatic int url_percent_decode(const char *in, char *out, size_t out_sz) {\r\n    42\t    size_t oi = 0;\r\n    43\t    for (size_t i = 0; in[i] != '\\0'; i++) {\r\n    44\t        if (oi + 1 >= out_sz) return -1;\r\n    45\t        if (in[i] == '%' && in[i+1] && in[i+2]) {\r\n    46\t            int hi = hexval(in[i+1]);\r\n    47\t            int lo = hexval(in[i+2]);\r\n    48\t            if (hi < 0 || lo < 0) return -1;\r\n    49\t            out[oi++] = (char)((hi << 4) | lo);\r\n    50\t            i += 2;\r\n    51\t        } else {\r\n    52\t            out[oi++] = in[i];\r\n    53\t        }\r\n    54\t    }\r\n    55\t    out[oi] = '\\0';\r\n    56\t    return 0;\r\n    57\t}\r\n    58\t\r\n    59\tstatic int decoded_path_has_dotdot_segment(const char *path) {\r\n    60\t    const char *p = path;\r\n    61\t    while (*p) {\r\n    62\t        while (*p == '/') p++;\r\n    63\t        if (!*p) break;\r\n    64\t        const char *seg = p;\r\n    65\t        while (*p && *p != '/') p++;\r\n    66\t        size_t len = (size_t)(p - seg);\r\n    67\t        if (len == 2 && seg[0] == '.' && seg[1] == '.') return 1;\r\n    68\t    }\r\n    69\t    return 0;\r\n    70\t}\r\n    71\t\r\n    72\tstatic int url_has_traversal(const char *url) {\r\n    73\t    if (!url) return 0;\r\n    74\t    char decoded[512];\r\n    75\t    if (url_percent_decode(url, decoded, sizeof(decoded)) != 0) return 1;\r\n    76\t    return decoded_path_has_dotdot_segment(decoded);\r\n    77\t}\r\n    78\t\r\n    79\tstatic enum MHD_Result serve_static_file(struct MHD_Connection *connection,\r\n    80\t                                        const char *url) {\r\n    81\t    if (url_has_traversal(url)) {\r\n    82\t        struct MHD_Response *r = MHD_create_response_from_buffer(\r\n    83\t            9, (void *)\"Forbidden\", MHD_RESPMEM_PERSISTENT);\r\n    84\t        enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_FORBIDDEN, r);\r\n    85\t        MHD_destroy_response(r);\r\n    86\t        return ret;\r\n    87\t    }\r\n    88\t\r\n    89\t    char filepath[512];\r\n    90\t    const char *path = (strcmp(url, \"/\") == 0) ? \"/index.html\" : url;\r\n    91\t    snprintf(filepath, sizeof(filepath), \"%s%s\", WWW_DIR, path);\r\n    92\t\r\n    93\t    struct stat st;\r\n    94\t    if (stat(filepath, &st) != 0) return MHD_NO;\r\n    95\t\r\n    96\t    FILE *f = fopen(filepath, \"rb\");\r\n    97\t    if (!f) return MHD_NO;\r\n    98\t\r\n    99\t    char *buf = malloc(st.st_size);\r\n   100\t    if (!buf) {\r\n   101\t        fclose(f);\r\n   102\t        return MHD_NO;\r\n   103\t    }\r\n   104\t    fread(buf, 1, st.st_size, f);\r\n   105\t    fclose(f);\r\n   106\t\r\n   107\t    struct MHD_Response *response = MHD_create_response_from_buffer(\r\n   108\t        st.st_size, buf, MHD_RESPMEM_MUST_FREE);\r\n   109\t    MHD_add_response_header(response, \"Content-Type\", get_content_type(filepath));\r\n   110\t    enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_OK, response);\r\n   111\t    MHD_destroy_response(response);\r\n   112\t    return ret;\r\n   113\t}\r\n   114\t\r\n   115\tstatic void request_completed(void *cls, struct MHD_Connection *connection,\r\n   116\t                              void **con_cls, enum MHD_RequestTerminationCode toe) {\r\n   117\t    (void)cls;\r\n   118\t    (void)connection;\r\n   119\t    (void)toe;\r\n   120\t    if (con_cls && *con_cls) {\r\n   121\t        struct connection_info *ci = *con_cls;\r\n   122\t        if (ci->data) free(ci->data);\r\n   123\t        free(ci);\r\n   124\t        *con_cls = NULL;\r\n   125\t    }\r\n   126\t}\r\n   127\t\r\n   128\tstatic enum MHD_Result handle_request(void *cls,\r\n   129\t                                     struct MHD_Connection *connection,\r\n   130\t                                     const char *url, const char *method,\r\n   131\t                                     const char *version,\r\n   132\t                                     const char *upload_data,\r\n   133\t                                     size_t *upload_data_size,\r\n   134\t                                     void **con_cls) {\r\n   135\t    (void)cls;\r\n   136\t    (void)version;\r\n   137\t\r\n"]
[313.529063, "o", "   138\t    if (strncmp(url, \"/api/\", 5) == 0) {\r\n   139\t        return route_request(connection, url, method, upload_data,\r\n   140\t                             upload_data_size, con_cls);\r\n   141\t    }\r\n   142\t\r\n   143\t    if (strcmp(method, \"GET\") == 0) {\r\n   144\t        enum MHD_Result ret = serve_static_file(connection, url);\r\n   145\t        if (ret == MHD_YES) return ret;\r\n   146\t    }\r\n   147\t\r\n   148\t    struct MHD_Response *response = MHD_create_response_from_buffer(\r\n   149\t        9, (void *)\"Not Found\", MHD_RESPMEM_PERSISTENT);\r\n   150\t    enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_NOT_FOUND, response);\r\n   151\t    MHD_destroy_response(response);\r\n   152\t    return ret;\r\n   153\t}\r\n   154\t\r\n   155\tint main(void) {\r\n   156\t    signal(SIGINT, handle_signal);\r\n   157\t    signal(SIGTERM, handle_signal);\r\n   158\t\r\n   159\t    mkdir(\"/app/data\", 0755);\r\n   160\t\r\n   161\t    if (init_db(\"/app/data/notes.db\") != 0) {\r\n   162\t        fprintf(stderr, \"Failed to initialize database\\n\");\r\n   163\t        return 1;\r\n   164\t    }\r\n   165\t\r\n   166\t    daemon_handle = MHD_start_daemon(\r\n   167\t        MHD_USE_THREAD_PER_CONNECTION,\r\n   168\t        PORT,\r\n   169\t        NULL, NULL,\r\n   170\t        &handle_request, NULL,\r\n   171\t        MHD_OPTION_NOTIFY_COMPLETED, &request_completed, NULL,\r\n   172\t        MHD_OPTION_END);\r\n   173\t\r\n   174\t    if (!daemon_handle) {\r\n   175\t        fprintf(stderr, \"Failed to start server\\n\");\r\n   176\t        return 1;\r\n   177\t    }\r\n   178\t\r\n   179\t    printf(\"Server running on port %d\\n\", PORT);\r\n   180\t    while (1) pause();\r\n   181\t    return 0;\r\n   182\t}\r\n\u001b[?2004hroot@bb40ba43d60f:/app# "]
