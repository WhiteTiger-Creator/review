[194.793779, "o", "static int url_percent_decode(const char *in, char *out, size_t out_sz) {\r\n\u001b[?2004l\r"]
[194.793815, "o", "\u001b[?2004h> "]
[194.794028, "o", "    size_t oi = 0;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.794305, "o", "    for (size_t i = 0; in[i] != '\\0'; i++) {\r\n\u001b[?2004l\r"]
[194.794406, "o", "\u001b[?2004h> "]
[194.794634, "o", "        if (oi + 1 >= out_sz) return -1;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.794976, "o", "        if (in[i] == '%' && in[i+1] && in[i+2]) {\r\n\u001b[?2004l\r"]
[194.79506, "o", "\u001b[?2004h> "]
[194.795278, "o", "            int hi = hexval(in[i+1]);\r\n\u001b[?2004l\r\u001b[?2004h"]
[194.795364, "o", "> "]
[194.795574, "o", "            int lo = hexval(in[i+2]);\r\n\u001b[?2004l\r"]
[194.795658, "o", "\u001b[?2004h> "]
[194.795927, "o", "            if (hi < 0 || lo < 0) return -1;\r\n\u001b[?2004l\r"]
[194.796016, "o", "\u001b[?2004h> "]
[194.79626, "o", "            out[oi++] = (char)((hi << 4) | lo);\r\n\u001b[?2004l\r"]
[194.796345, "o", "\u001b[?2004h> "]
[194.796414, "o", "            i += 2;\r\n\u001b[?2004l\r"]
[194.796488, "o", "\u001b[?2004h> "]
[194.796626, "o", "        } else {\r\n\u001b[?2004l\rc\u001b[?2004h> "]
[194.796957, "o", "            out[oi++] = in[i];\r\n\u001b[?2004l\r"]
[194.796993, "o", "\u001b[?2004h> "]
[194.797061, "o", "        }\r\n\u001b[?2004l\r"]
[194.797141, "o", "\u001b[?2004h> "]
[194.797226, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.797325, "o", "    out[oi] = '\\0';\r\n\u001b[?2004l\r\u001b[?2004h"]
[194.797356, "o", "> "]
[194.797466, "o", "    return 0;\r\n\u001b[?2004l\r\u001b[?2004h"]
