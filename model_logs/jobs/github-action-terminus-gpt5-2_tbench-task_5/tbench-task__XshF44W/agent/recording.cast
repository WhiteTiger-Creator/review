[38.707432, "o", "#include \"constants.h\"\r\n#include \"m14_api.h\"\r\n#include \"types.h\"\r\n#include <algorithm>\r\n#include <cctype>\r\n#include <fstream>\r\n#include <sstream>\r\n"]
[38.707516, "o", "#include <stdexcept>\r\n#include <string>\r\n#include <vector>\r\n\r\nnamespace {\r\n\r\nstd::uint64_t digest_update(std::uint64_t h, const std::string &text) {\r\n    for (unsigned char ch : text) {\r\n"]
[38.707676, "o", "        h ^= static_cast<std::uint64_t>(ch);\r\n        h = (h * forge::kDigestStep) & forge::kDigestMask;\r\n    }\r\n    return h;\r\n}\r\n"]
[38.707754, "o", "\r\nstd::string digest_hex(const std::string &text) {\r\n    std::uint64_t h = digest_update(forge::kDigestSeed, text);\r\n    std::ostringstream os;\r\n    os << std::hex << std::nouppercase;\r\n    os.width(16);\r\n    os.fill('0');\r\n    os << h;\r\n"]
[38.707868, "o", "    return os.str();\r\n}\r\n\r\nstd::string descriptor_line(const forge::UnitSpec &unit) {\r\n    std::ostringstream os;\r\n"]
[38.70797, "o", "    os << unit.name << '|' << unit.mode << '|' << unit.record << '|' << unit.manifest_bytes << '|'\r\n"]
[38.708035, "o", "       << unit.start_pass;\r\n    return os.str();\r\n}\r\n\r\nstd::string pick_string(const std::string &block, const std::string &key) {\r\n    std::string needle = \"\\\"\" + key + \"\\\"\";\r\n    size_t k = block.find(needle);\r\n    if (k == std::string::npos) {\r\n        return \"\";\r\n    }\r\n    size_t q = block.find('\"', block.find(':', k) + 1);\r\n    size_t e = block.find('\"', q + 1);\r\n    return block.substr(q + 1, e - q - 1);\r\n}\r\n\r\nint pick_int(const std::string &block, const std::string &key) {\r\n    std::string needle = \"\\\"\" + key + \"\\\"\";\r\n    size_t k = block.find(needle);\r\n    if (k == std::string::npos) {\r\n        return 0;\r\n    }\r\n    size_t p = block.find(':', k) + 1;\r\n    while (p < block.size() && !std::isdigit(static_cast<unsigned char>(block[p])) && block[p] != '-') {\r\n        ++p;\r\n    }\r\n    size_t e = p;\r\n    while (e < block.size() && (std::isdigit(static_cast<unsigned char>(block[e])) || block[e] == '-')) {\r\n        ++e;\r\n"]
[38.708097, "o", "    }\r\n"]
[38.708188, "o", "    return std::stoi(block.substr(p, e - p));\r\n}\r\n\r\nint64_t pick_int64(const std::string &block, const std::string &key) {\r\n    return static_cast<int64_t>(pick_int(block, key));\r\n}\r\n\r\nstd::vector<std::string> split_object_blocks(const std::string &array_text) {\r\n"]
[38.708251, "o", "    std::vector<std::string> out;\r\n    int depth = 0;\r\n    size_t start = std::string::npos;\r\n    for (size_t i = 0; i < array_text.size(); ++i) {\r\n"]
[38.708275, "o", "        if (array_text[i] == '{') {\r\n            if (depth == 0) {\r\n"]
[38.708328, "o", "                start = i;\r\n            }\r\n"]
[38.708343, "o", "            ++depth;\r\n        } else if (array_text[i] == '}') {\r\n"]
[38.708411, "o", "            --depth;\r\n            if (depth == 0 && start != std::string::npos) {\r\n                out.push_back(array_text.substr(start, i - start + 1));\r\n"]
[38.708428, "o", "                start = std::string::npos;\r\n"]
[38.708486, "o", "            }\r\n        }\r\n    }\r\n"]
[38.708502, "o", "    return out;\r\n"]
[38.708554, "o", "}\r\n\r\n}  // namespace\r\n"]
[38.708568, "o", "\r\n"]
[38.708622, "o", "extern \"C\" const char *m14_lane_token(const forge::UnitSpec *units, size_t count) {\r\n    static std::string cached;\r\n"]
[38.708636, "o", "    std::ostringstream joined;\r\n    for (size_t i = 0; i < count; ++i) {\r\n"]
[38.708712, "o", "        if (i) {\r\n            joined << '\\n';\r\n        }\r\n        joined << descriptor_line(units[i]);\r\n"]
[38.708825, "o", "    }\r\n    cached = digest_hex(joined.str());\r\n    return cached.c_str();\r\n}\r\n\r\n"]
[38.708848, "o", "extern \"C\" int m14_checkpoint_valid(const char *on_disk_token, const char *expected_token) {\r\n    if (on_disk_token == nullptr || expected_token == nullptr) {\r\n        return 0;\r\n    }\r\n    return std::string(on_disk_token) == std::string(expected_token) ? 1 : 0;\r\n}\r\n"]
[38.708861, "o", "\r\n"]
[38.708872, "o", "forge::LaneCheckpoint m14_read_checkpoint(const std::filesystem::path &path,\r\n"]
[38.709042, "o", "                                                   const std::string &expected_token) {\r\n    forge::LaneCheckpoint state;\r\n    std::ifstream in(path);\r\n    if (!in) {\r\n        return state;\r\n    }\r\n    std::ostringstream buffer;\r\n    buffer << in.rdbuf();\r\n    const std::string doc = buffer.str();\r\n    if (doc.find(\"\\\"schema_version\\\"\") == std::string::npos) {\r\n        return state;\r\n    }\r\n    state.lane_token = pick_string(doc, \"lane_token\");\r\n    if (!m14_checkpoint_valid(state.lane_token.c_str(), expected_token.c_str())) {\r\n        return state;\r\n    }\r\n    size_t units_pos = doc.find(\"\\\"units\\\"\");\r\n    if (units_pos == std::string::npos) {\r\n        return state;\r\n    }\r\n    size_t arr_start = doc.find('[', units_pos);\r\n    size_t arr_end = doc.find(']', arr_start);\r\n    if (arr_start == std::string::npos || arr_end == std::string::npos) {\r\n        return state;\r\n    }\r\n    const std::string arr = doc.substr(arr_start, arr_end - arr_start + 1);\r\n    for (const auto &block : split_object_blocks(arr)) {\r\n  "]
[38.709063, "o", "      forge::UnitCheckpoint entry;\r\n        entry.name = pick_string(block, \"name\");\r\n        entry.next_pass = pick_int(block, \"next_pass\");\r\n"]
[38.709189, "o", "        entry.carry_weight = pick_int64(block, \"carry_weight\");\r\n        entry.carry_drift = pick_int64(block, \"carry_drift\");\r\n"]
[38.709206, "o", "        if (!entry.name.empty()) {\r\n            state.units[entry.name] = entry;\r\n"]
[38.709271, "o", "        }\r\n    }\r\n"]
[38.709285, "o", "    state.valid = true;\r\n"]
[38.709338, "o", "    return state;\r\n}\r\n\r\n"]
[38.709353, "o", "std::vector<forge::UnitCheckpoint> m14_merge_entries(\r\n"]
[38.709415, "o", "    const forge::LaneCheckpoint &existing, const std::vector<forge::UnitCheckpoint> &updated,\r\n    const std::vector<std::string> &requested_resume) {\r\n"]
[38.709429, "o", "    (void)existing;\r\n    (void)requested_resume;\r\n"]
[38.709495, "o", "    std::vector<forge::UnitCheckpoint> out = updated;\r\n    std::sort(out.begin(), out.end(),\r\n"]
[38.709508, "o", "              [](const forge::UnitCheckpoint &a, const forge::UnitCheckpoint &b) {\r\n"]
[38.709568, "o", "                  return a.name < b.name;\r\n              });\r\n    return out;\r\n"]
[38.709582, "o", "}\r\n"]
[38.709642, "o", "\r\nvoid m14_write_checkpoint(const std::filesystem::path &path, const char *lane_token,\r\n"]
[38.709659, "o", "                                     const std::vector<forge::UnitCheckpoint> &entries) {\r\n"]
[38.709714, "o", "    std::filesystem::create_directories(path.parent_path());\r\n    std::ostringstream out;\r\n    out << \"{\\\"schema_version\\\":\" << forge::kSchemaVersion << \",\\\"lane_token\\\":\\\"\" << lane_token\r\n"]
[38.709728, "o", "        << \"\\\",\\\"units\\\":[\";\r\n"]
[38.709793, "o", "    for (size_t i = 0; i < entries.size(); ++i) {\r\n        if (i) {\r\n"]
[38.709807, "o", "            out << ',';\r\n"]
[38.709863, "o", "        }\r\n        const auto &entry = entries[i];\r\n        out << \"{\\\"name\\\":\\\"\" << entry.name << \"\\\",\\\"next_pass\\\":\" << entry.next_pass\r\n"]
[38.709881, "o", "            << \",\\\"carry_weight\\\":\" << entry.carry_weight << \",\\\"carry_drift\\\":\"\r\n"]
[38.709937, "o", "            << entry.carry_drift << '}';\r\n    }\r\n    out << \"]}\\n\";\r\n"]
[38.709952, "o", "    std::ofstream file(path, std::ios::binary);\r\n"]
[38.710019, "o", "    file << out.str();\r\n}\r\n"]
