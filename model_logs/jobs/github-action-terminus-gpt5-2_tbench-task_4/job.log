Sending keys: ['cat > /app/environment/m14/lane_store.cpp.tmp <<\'EOF\'\n#include "m14_api.h"\n#include "constants.h"\n#include "store_bridge.h"\n#include "types.h"\n\n#include <algorithm>\n#include <cctype>\n#include <cstdint>\n#include <filesystem>\n#include <fstream>\n#include <map>\n#include <numeric>\n#include <sstream>\n#include <stdexcept>\n#include <string>\n#include <vector>\n\nnamespace forge {\n\nnamespace {\n\nstd::string pick_string(const std::string &block, const std::string &key) {\n    std::string needle = "\\"" + key + "\\"";\n    size_t k = block.find(needle);\n    if (k == std::string::npos) {\n        return "";\n    }\n    size_t q = block.find(\'"\', block.find(\':\', k) + 1);\n    size_t e = block.find(\'"\', q + 1);\n    if (q == std::string::npos || e == std::string::npos) {\n        return "";\n    }\n    return block.substr(q + 1, e - q - 1);\n}\n\nint pick_int(const std::string &block, const std::string &key) {\n    std::string needle = "\\"" + key + "\\"";\n    size_t k = block.find(needle);\n    if (k == std::string::npos) {\n        return 0;\n    }\n    size_t colon = block.find(\':\', k);\n    if (colon == std::string::npos) {\n        return 0;\n    }\n    size_t start = colon + 1;\n    while (start < block.size() && std::isspace(static_cast<unsigned char>(block[start]))) {\n        ++start;\n    }\n    return std::stoi(block.substr(start));\n}\n\nint64_t pick_int64(const std::string &block, const std::string &key) {\n    std::string needle = "\\"" + key + "\\"";\n    size_t k = block.find(needle);\n    if (k == std::string::npos) {\n        return 0;\n    }\n    size_t colon = block.find(\':\', k);\n    if (colon == std::string::npos) {\n        return 0;\n    }\n    size_t start = colon + 1;\n    while (start < block.size() && std::isspace(static_cast<unsigned char>(block[start]))) {\n        ++start;\n    }\n    return std::stoll(block.substr(start));\n}\n\nstd::vector<std::string> split_object_blocks(const std::string &array_text) {\n    std::vector<std::string> out;\n    int depth = 0;\n    size_t start = std::string::npos;\n    for (size_t i = 0; i < array_text.size(); ++i) {\n        if (array_text[i] == \'{\') {\n            if (depth == 0) {\n                start = i;\n            }\n            ++depth;\n        } else if (array_text[i] == \'}\') {\n            --depth;\n            if (depth == 0 && start != std::string::npos) {\n                out.push_back(array_text.substr(start, i - start + 1));\n                start = std::string::npos;\n            }\n        }\n    }\n    return out;\n}\n\n} // namespace\n\n} // namespace forge\n\nextern "C" const char *m14_lane_token(const forge::UnitSpec *units, size_t count) {\n    static thread_local std::string cached;\n    std::vector<forge::UnitSpec> sorted;\n    sorted.reserve(count);\n    for (size_t i = 0; i < count; ++i) {\n        sorted.push_back(units[i]);\n    }\n    std::sort(sorted.begin(), sorted.end(), [](const forge::UnitSpec &a, const forge::UnitSpec &b) {\n        return a.name < b.name;\n    });\n\n    std::ostringstream joined;\n    for (size_t i = 0; i < sorted.size(); ++i) {\n        if (i) {\n            joined << \'\\n\';\n        }\n        joined << sorted[i].name << \'|\' << sorted[i].mode << \'|\' << sorted[i].record_path << \'|\'\n               << sorted[i].manifest_bytes << \'|\' << sorted[i].start_pass;\n    }\n\n    cached = forge::digest_hex(joined.str());\n    return cached.c_str();\n}\n\nextern "C" int m14_checkpoint_valid(const char *on_disk_token, const char *expected_token) {\n    if (on_disk_token == nullptr || expected_token == nullptr) {\n        return 0;\n    }\n    return std::string(on_disk_token) == std::string(expected_token) ? 1 : 0;\n}\n\nforge::LaneCheckpoint m14_read_checkpoint(const std::filesystem::path &path,\n                                         const std::string &expected_token) {\n    forge::LaneCheckpoint state;\n    std::ifstream in(path);\n    if (!in) {\n        return state;\n    }\n    std::ostringstream buffer;\n    buffer << in.rdbuf();\n    const std::string doc = buffer.str();\n    if (doc.find("\\"schema_version\\"") == std::string::npos) {\n        return state;\n    }\n    state.lane_token = forge::pick_string(doc, "lane_token");\n    if (!m14_checkpoint_valid(state.lane_token.c_str(), expected_token.c_str())) {\n        return state;\n    }\n    state.pass_epoch = forge::pick_int(doc, "pass_epoch");\n\n    size_t units_pos = doc.find("\\"units\\"");\n    if (units_pos == std::string::npos) {\n        state.valid = true;\n        return state;\n    }\n    size_t arr_start = doc.find(\'[\', units_pos);\n    size_t arr_end = doc.find(\']\', arr_start);\n    if (arr_start == std::string::npos || arr_end == std::string::npos) {\n        return state;\n    }\n    const std::string arr = doc.substr(arr_start, arr_end - arr_start + 1);\n    for (const auto &block : forge::split_object_blocks(arr)) {\n        forge::UnitCheckpoint entry;\n        entry.name = forge::pick_string(block, "name");\n        entry.next_pass = forge::pick_int(block, "next_pass");\n        entry.carry_weight = forge::pick_int64(block, "carry_weight");\n        entry.carry_drift = forge::pick_int64(block, "carry_drift");\n        if (!entry.name.empty()) {\n            state.units[entry.name] = entry;\n        }\n    }\n    state.valid = true;\n    return state;\n}\n\nstd::vector<forge::UnitCheckpoint> m14_merge_entries(\n    const forge::LaneCheckpoint &existing, const std::vector<forge::UnitCheckpoint> &updated,\n    const std::vector<std::string> &requested_resume) {\n    (void)requested_resume;\n\n    std::map<std::string, forge::UnitCheckpoint> merged;\n    if (existing.valid) {\n        merged = existing.units;\n    }\n    for (const auto &entry : updated) {\n        if (!entry.name.empty()) {\n            merged[entry.name] = entry;\n        }\n    }\n\n    std::vector<forge::UnitCheckpoint> out;\n    out.reserve(merged.size());\n    for (const auto &kv : merged) {\n        out.push_back(kv.second);\n    }\n    std::sort(out.begin(), out.end(),\n              [](const forge::UnitCheckpoint &a, const forge::UnitCheckpoint &b) {\n                  return a.name < b.name;\n              });\n    return out;\n}\n\nvoid m14_write_checkpoint(const std::filesystem::path &path, const char *lane_token, int pass_epoch,\n                          const std::vector<forge::UnitCheckpoint> &entries) {\n    std::filesystem::create_directories(path.parent_path());\n    std::ostringstream out;\n    out << "{\\"schema_version\\":" << forge::kSchemaVersion << ",\\"lane_token\\":\\"" << lane_token\n        << "\\",\\"pass_epoch\\":" << pass_epoch << ",\\"units\\":[";\n    for (size_t i = 0; i < entries.size(); ++i) {\n        if (i) {\n            out << \',\';\n        }\n        const auto &entry = entries[i];\n        out << "{\\"name\\":\\"" << entry.name << "\\",\\"next_pass\\":" << entry.next_pass\n            << ",\\"carry_weight\\":" << entry.carry_weight << ",\\"carry_drift\\":"\n            << entry.carry_drift << \'}\';\n    }\n    out << "]}\\n";\n    std::ofstream file(path, std::ios::binary);\n    file << out.str();\n}\nEOF\nmv /app/environment/m14/lane_store.cpp.tmp /app/environment/m14/lane_store.cpp\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
