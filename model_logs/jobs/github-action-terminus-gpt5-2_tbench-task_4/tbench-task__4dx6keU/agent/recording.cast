[123.230464, "i", "python3 - <<'PY'\nfrom pathlib import Path\npath=Path('/app/src/io/journal.c')\ns=path.read_text()\nold=s\ns=s.replace(\"  uint32_t lo = (uint32_t)s.cursor;\\n  if (!fs_write_u32(f, lo))\\n    return TB_ERR_IO;\\n\",\n            \"  // stamp format is exactly 12 bytes: u32 generation + u64 cursor\\n  // (cursor is the next id/cursor to allocate).\\n  if (!fs_write_u64(f, s.cursor))\\n    return TB_ERR_IO;\\n\")\ns=s.replace(\"  uint32_t lo = 0;\\n  if (!fs_read_u32(f, &lo))\\n    return false;\\n\\n  out->gen = gen;\\n  out->cursor = (uint64_t)lo;\\n\",\n            \"  uint64_t cursor = 0;\\n  if (!fs_read_u64(f, &cursor))\\n    return false;\\n\\n  out->gen = gen;\\n  out->cursor = cursor;\\n\")\nif s==old:\n    raise SystemExit('journal.c: no changes applied (pattern mismatch)')\npath.write_text(s)\nprint('patched',path)\nPY\n"]
