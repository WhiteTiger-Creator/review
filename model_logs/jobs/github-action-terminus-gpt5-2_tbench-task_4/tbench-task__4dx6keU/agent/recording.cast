[52.804131, "i", "python3 - <<'PY'\nimport json,sys\np='/app/output/report.json'\nobj=json.load(open(p))\nev=obj['events']\nfrom collections import Counter,defaultdict\nc=Counter((e['kind'],e['id']) for e in ev)\ndups=[k for k,v in c.items() if v!=1]\nprint('events',len(ev),'unique pairs',len(c),'dups_or_missing_pairs',len(dups))\nif dups[:10]:\n  print('sample bad pairs',dups[:10],[c[k] for k in dups[:10]])\n# ordering checks\nstate=defaultdict(int) # 0 none,1 submitted,2 completed,3 notified\nbad=[]\nfor i,e in enumerate(ev):\n  k,id_=e['kind'],e['id']\n  st=state[id_]\n  if k=='submit':\n    if st!=0: bad.append((i,'resubmit',id_,st))\n    state[id_]=1\n  elif k=='complete':\n    if st!=1: bad.append((i,'complete_before_submit_or_dup',id_,st))\n    state[id_]=2\n  elif k=='notify':\n    if st!=2: bad.append((i,'notify_before_complete_or_dup',id_,st))\n    state[id_]=3\n  else:\n    bad.append((i,'unknown_kind',k,id_))\n# id contiguity based on submits\nsubs=[e['id'] for e in ev if e['kind']=='submit']\ncontig_ok = subs==list(range(1,len(subs)+1))\nprint("]
[52.806279, "i", "'submits',len(subs),'contiguous',contig_ok,'first_last', (subs[0],subs[-1]) if subs else None)\n# completion+notify coverage\nids=set(subs)\ncomp=set(e['id'] for e in ev if e['kind']=='complete')\nnoti=set(e['id'] for e in ev if e['kind']=='notify')\nprint('missing_complete',sorted(ids-comp)[:10],'missing_notify',sorted(ids-noti)[:10])\nprint('extra_complete',sorted(comp-ids)[:10],'extra_notify',sorted(noti-ids)[:10])\nprint('bad_order_count',len(bad))\nif bad[:20]:\n  print('sample bad order',bad[:20])\nPY\n"]
[52.806945, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r\u001b[?2004h> import json,sys\r\n\u001b[?2004l\r\u001b[?2004h> p='/app/output/report.json'\r\n\u001b[?2004l\r\u001b[?2004h> obj=json.load(open(p))\r\n\u001b[?2004l\r\u001b[?2004h> ev=obj['events']\r\n\u001b[?2004l\r\u001b[?2004h> from collections import Counter,defaultdict\r\n\u001b[?2004l\r\u001b[?2004h> c=Counter((e['kind'],e['id']) for e in ev)\r\n\u001b[?2004l\r\u001b[?2004h> dups=[k for k,v in c.items() if v!=1]\r\n\u001b[?2004l\r\u001b[?2004h> print('events',len(ev),'unique pairs',len(c),'dups_or_missing_pairs',len(dups))\r\n\u001b[?2004l\r'submits',len(subs),'contiguous',contig_ok,'first_last', (subs[0],subs[-1]) if subs else None)\r\n# completion+notify coverage\r\nids=set(subs)\r\ncomp=set(e['id'] for e in ev if e['kind']=='complete')\r\nnoti=set(e['id'] for e in ev if e['kind']=='notify')\r\nprint('missing_complete',sorted(ids-comp)[:10],'missing_notify',sorted(ids-noti)[:10])\r\nprint('extra_complete',sorted(comp-ids)[:10],'extra_notify',sorted(noti-ids)[:10])\r\nprint('bad_order_count',len(bad))\r\nif bad[:20]:\r\n  print('sample bad order',bad[:20])\r\nPY\r\n\u001b[?2004h> if dups[:10]:\r\n\u001b[?2004l\r"]
