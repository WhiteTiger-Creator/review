[67.049281, "o", "#include \"runtime/profile.h\"\r\n\r\n#include <string.h>\r\n\r\ntb_profile tb_profile_parse(const char *s) {\r\n  if (!s)\r\n"]
[67.049345, "o", "    return 0;\r\n  if (strcmp(s, \"burst\") == 0)\r\n"]
[67.049588, "o", "    return TB_PROFILE_BURST;\r\n"]
[67.049706, "o", "  if (strcmp(s, \"steady\") == 0)\r\n"]
[67.049794, "o", "    return TB_PROFILE_STEADY;\r\n  return 0;\r\n}\r\n\r\nconst char *tb_profile_str(tb_profile p) {\r\n"]
[67.049821, "o", "  switch (p) {\r\n  case TB_PROFILE_BURST:\r\n    return \"burst\";\r\n  case TB_PROFILE_STEADY:\r\n    return \"steady\";\r\n  default:\r\n    return \"unknown\";\r\n  }\r\n"]
[67.049832, "o", "}\r\n\r\nuint32_t tb_profile_should_submit(tb_profile p, uint32_t tick) {\r\n"]
[67.049842, "o", "  switch (p) {\r\n  case TB_PROFILE_BURST:\r\n    return tick < 10 ? 3 : (tick < 20 ? 2 : 1);\r\n  case TB_PROFILE_STEADY:\r\n"]
[67.04985, "o", "    return (tick % 3) == 0 ? 1 : 0;\r\n  default:\r\n"]
[67.049862, "o", "    return 0;\r\n  }\r\n"]
[67.050173, "o", "}\r\n\r\n"]
[67.050199, "o", "\u001b[?2004hroot@0c4a89e29ee7:/app# "]
[67.171103, "i", "sed -n '1,240p' /app/include/logic/ingest.h /app/src/logic/ingest.c\n"]
[67.171523, "o", "sed -n '1,240p' /app/include/logic/ingest.h /app/src/logic/ingest.c"]
[67.171554, "o", "\r\n\u001b[?2004l\r"]
[67.172829, "o", "#pragma once\r\n"]
[67.173046, "o", "\r\n#include \"tb_err.h\"\r\n#include \"runtime/runtime.h\"\r\n\r\ntb_status tb_ingest_tick(tb_rt *rt, tb_profile prof, uint32_t tick, uint32_t *submitted_out);\r\n\r\n#include \"logic/ingest.h\"\r\n\r\n#include \"core/ev.h\"\r\n#include \"runtime/profile.h\"\r\n\r\nstatic uint64_t make_token(uint32_t gen, uint64_t cursor) { return (((uint64_t)gen) << 32) ^ cursor; }\r\n\r\n"]
[67.173132, "o", "tb_status tb_ingest_tick(tb_rt *rt, tb_profile prof, uint32_t tick, uint32_t *submitted_out) {\r\n  if (!rt || !submitted_out)\r\n    return TB_ERR_BAD_ARG;\r\n\r\n  uint32_t n = tb_profile_should_submit(prof, tick);\r\n  *submitted_out = n;\r\n\r\n  for (uint32_t i = 0; i < n; i++) {\r\n    uint32_t id = (uint32_t)(rt->cursor & 0xffffffffu);\r\n    uint64_t token = make_token(rt->gen, rt->cursor);\r\n    rt->cursor++;\r\n\r\n    if (!tb_map_u64_put(&rt->token_to_id, token, (uint64_t)id))\r\n      return TB_ERR_OOM;\r\n    if (!tb_q64_push(&rt->in_q, token))\r\n      return TB_ERR_CORRUPT;\r\n\r\n    tb_event ev = {.kind = TB_EV_SUBMIT, .id = id};\r\n    if (!tb_vec_ev_push(&rt->evlog, ev))\r\n      return TB_ERR_OOM;\r\n  }\r\n\r\n  return TB_OK;\r\n}\r\n\r\n"]
[67.17328, "o", "\u001b[?2004hroot@0c4a89e29ee7:/app# "]
[67.295492, "i", "sed -n '1,260p' /app/include/logic/settle.h /app/src/logic/settle.c\n"]
[67.296989, "o", "sed -n '1,260p' /app/include/logic/settle.h /app/src/logic/settle.c\r\n\u001b[?2004l\r"]
[67.297714, "o", "#pragma once\r\n\r\n#include \"tb_err.h\"\r\n#include \"runtime/runtime.h\"\r\n\r\ntb_status tb_settle_tick(tb_rt *rt, uint32_t tick);\r\n\r\n#include \"logic/settle.h\"\r\n\r\n#include \"runtime/runtime.h\"\r\n\r\n// Deterministic \"work takes time\": only move certain tokens each tick.\r\nstatic bool ready(uint64_t token, uint32_t tick) {\r\n  // spread completion across ticks, but deterministic and input-dependent\r\n  return (((uint32_t)token) ^ tick) % 3 == 0;\r\n}\r\n\r\nstatic bool lane_a(uint64_t token, uint32_t tick) {\r\n  // Choose which completion source produced the \"done\" record.\r\n  return ((((uint32_t)(token >> 32)) + (uint32_t)token + tick) & 1u) == 0u;\r\n}\r\n\r\ntb_status tb_settle_tick(tb_rt *rt, uint32_t tick) {\r\n  if (!rt)\r\n    return TB_ERR_BAD_ARG;\r\n\r\n  // rotate through at most a bounded number so runs are stable\r\n  size_t spins = rt->in_q.len;\r\n  for (size_t i = 0; i < spins; i++) {\r\n    uint64_t token = 0;\r\n    if (!tb_q64_pop(&rt->in_q, &token))\r\n      break;\r\n\r\n"]
[67.297742, "o", "    if (ready(token, tick)) {\r\n      if (lane_a(token, tick)) {\r\n        if (!tb_q64_push(&rt->done_a, token))\r\n          return TB_ERR_CORRUPT;\r\n      } else {\r\n        if (!tb_q64_push(&rt->done_b, token))\r\n          return TB_ERR_CORRUPT;\r\n      }\r\n      if (rt->attached) {\r\n        // The notifier is only live while attached.\r\n        if (!tb_q64_push(&rt->notify_q, token))\r\n"]
[67.297761, "o", "          return TB_ERR_CORRUPT;\r\n      }\r\n    } else {\r\n      // not ready, requeue at tail\r\n      if (!tb_q64_push(&rt->in_q, token))\r\n"]
[67.297772, "o", "        return TB_ERR_CORRUPT;\r\n    }\r\n  }\r\n\r\n"]
[67.298055, "o", "  return TB_OK;\r\n}\r\n"]
[67.298198, "o", "\r\n\u001b[?2004hroot@0c4a89e29ee7:/app# "]
[67.419741, "i", "sed -n '1,240p' /app/include/logic/merge.h /app/src/logic/merge.c\n"]
[67.419801, "o", "sed -n '1,240p' /app/include/logic/merge.h /app/src/logic/merge.c\r\n\u001b[?2004l\r"]
[67.422003, "o", "#pragma once\r\n\r\n#include \"tb_err.h\"\r\n#include \"runtime/runtime.h\"\r\n"]
[67.422039, "o", "\r\ntb_status tb_merge_drain(tb_rt *rt, uint32_t tick, tb_order ord);\r\n\r\n#include \"logic/merge.h\"\r\n\r\n#include \"core/ev.h\"\r\n"]
[67.422058, "o", "\r\nstatic bool drain_one(tb_rt *rt, tb_q64 *q, uint32_t tick) {\r\n  (void)tick;\r\n  uint64_t token = 0;\r\n"]
[67.422068, "o", "  if (!tb_q64_pop(q, &token))\r\n    return false;\r\n\r\n  uint64_t key = (uint32_t)token;\r\n\r\n  if (!tb_map_u64_has(&rt->token_done, key)) {\r\n    uint64_t id64 = 0;\r\n"]
[67.422078, "o", "    if (!tb_map_u64_get(&rt->token_to_id, token, &id64)) {\r\n      return true;\r\n    }\r\n"]
[67.422092, "o", "    (void)tb_map_u64_put(&rt->token_done, key, 1);\r\n    tb_event ev = {.kind = TB_EV_DONE, .id = (uint32_t)id64};\r\n    (void)tb_vec_ev_push(&rt->evlog, ev);\r\n  }\r\n"]
[67.422108, "o", "  return true;\r\n}\r\n\r\n"]
[67.42212, "o", "tb_status tb_merge_drain(tb_rt *rt, uint32_t tick, tb_order ord) {\r\n  if (!rt)\r\n    return TB_ERR_BAD_ARG;\r\n\r\n  tb_q64 *a = &rt->done_a;\r\n"]
[67.422303, "o", "  tb_q64 *b = &rt->done_b;\r\n\r\n  if (ord == TB_ORDER_A_THEN_B) {\r\n    while (drain_one(rt, a, tick)) {\r\n    }\r\n    while (drain_one(rt, b, tick)) {\r\n    }\r\n  } else {\r\n    while (drain_one(rt, b, tick)) {\r\n    }\r\n    while (drain_one(rt, a, tick)) {\r\n    }\r\n  }\r\n\r\n  return TB_OK;\r\n}\r\n"]
[67.422429, "o", "\u001b[?2004hroot@0c4a89e29ee7:/app# "]
[67.547542, "i", "sed -n '1,260p' /app/include/logic/link.h /app/src/logic/link.c\n"]
[67.547862, "o", "sed -n '1,260p' /app/include/logic/link.h /app/src/logic/link.c\r\n\u001b[?2004l\r"]
[67.54918, "o", "#pragma once\r\n\r\n#include \"tb_err.h\"\r\n#include \"runtime/runtime.h\"\r\n\r\ntb_status tb_link_detach(tb_rt *rt, uint32_t tick);\r\ntb_status tb_link_attach(tb_rt *rt, uint32_t tick);\r\n\r\n"]
[67.549213, "o", "#include \"logic/link.h\"\r\n\r\n#include \"io/journal.h\"\r\n\r\n#include <string.h>\r\n\r\ntb_status tb_link_detach(tb_rt *rt, uint32_t tick) {\r\n  (void)tick;\r\n"]
[67.549224, "o", "  if (!rt)\r\n    return TB_ERR_BAD_ARG;\r\n  if (!rt->attached)\r\n    return TB_OK;\r\n\r\n  rt->attached = false;\r\n"]
[67.549263, "o", "\r\n  tb_stamp s = {.gen = rt->gen, .cursor = rt->cursor};\r\n  tb_status st = journal_append_stamp(rt->journal_path, s);\r\n  if (st != TB_OK)\r\n    return st;\r\n\r\n  // A \"device-side\" queue continues to exist while detached; the notifier doesn't.\r\n  tb_q64_clear(&rt->notify_q);\r\n"]
[67.549286, "o", "  return TB_OK;\r\n}\r\n\r\ntb_status tb_link_attach(tb_rt *rt, uint32_t tick) {\r\n  (void)tick;\r\n  if (!rt)\r\n    return TB_ERR_BAD_ARG;\r\n"]
[67.549297, "o", "  if (rt->attached)\r\n    return TB_OK;\r\n\r\n  tb_stamp last = {0};\r\n"]
[67.549307, "o", "  bool found = false;\r\n  tb_status st = journal_load_last(rt->journal_path, &last, &found);\r\n  if (st != TB_OK)\r\n"]
[67.549342, "o", "    return st;\r\n  if (found) {\r\n    rt->gen = last.gen + 1;\r\n    rt->cursor = last.cursor;\r\n  }\r\n\r\n  rt->attached = true;\r\n  return TB_OK;\r\n}\r\n"]
[67.549356, "o", "\r\n"]
[67.550132, "o", "\u001b[?2004hroot@0c4a89e29ee7:/app# "]
[87.682663, "i", "sed -n '1,220p' /app/src/logic/nudge.c\n"]
[87.683424, "o", "sed -n '1,220p' /app/src/logic/nudge.c\r\n\u001b[?2004l\r"]
[87.685323, "o", "#include \"logic/nudge.h\"\r\n\r\n#include \"core/ev.h\"\r\n\r\ntb_status tb_nudge_drain(tb_rt *rt, uint32_t tick) {\r\n  (void)tick;\r\n  if (!rt)\r\n    return TB_ERR_BAD_ARG;\r\n\r\n  uint64_t token = 0;\r\n  while (tb_q64_pop(&rt->notify_q, &token)) {\r\n    uint64_t key = (uint32_t)token;\r\n    if (!tb_map_u64_has(&rt->token_done, key)) {\r\n"]
[87.685355, "o", "      continue;\r\n    }\r\n    uint64_t id64 = 0;\r\n    if (!tb_map_u64_get(&rt->token_to_id, token, &id64))\r\n      continue;\r\n"]
[87.685488, "o", "    tb_event ev = {.kind = TB_EV_POKE, .id = (uint32_t)id64};\r\n    (void)tb_vec_ev_push(&rt->evlog, ev);\r\n  }\r\n  return TB_OK;\r\n}\r\n"]
[87.685735, "o", "\u001b[?2004h"]
[87.685786, "o", "root@0c4a89e29ee7:/app# "]
[87.796001, "i", "sed -n '1,200p' /app/include/core/ev.h /app/src/core/vec_ev.c\n"]
[87.796538, "o", "sed -n '1,200p' /app/include/core/ev.h /app/src/core/vec_ev.c\r\n\u001b[?2004l\r"]
[87.797531, "o", "#pragma once\r\n\r\n#include <stdint.h>\r\n\r\ntypedef enum {\r\n  TB_EV_SUBMIT = 1,\r\n  TB_EV_DONE = 2,\r\n  TB_EV_POKE = 3,\r\n} tb_ev_kind;\r\n\r\ntypedef struct {\r\n"]
[87.797563, "o", "  tb_ev_kind kind;\r\n  uint32_t id;\r\n} tb_event;\r\n\r\n#include \"core/vec_ev.h\"\r\n\r\n#include <stdlib.h>\r\n"]
[87.797611, "o", "\r\nbool tb_vec_ev_init(tb_vec_ev *a, size_t cap) {\r\n  if (!a)\r\n    return false;\r\n  if (cap == 0)\r\n    cap = 16;\r\n  a->v = (tb_event *)malloc(sizeof(tb_event) * cap);\r\n  if (!a->v)\r\n    return false;\r\n  a->len = 0;\r\n  a->cap = cap;\r\n"]
[87.797848, "o", "  return true;\r\n}\r\n\r\nvoid tb_vec_ev_free(tb_vec_ev *a) {\r\n  if (!a)\r\n    return;\r\n  free(a->v);\r\n  a->v = NULL;\r\n  a->len = 0;\r\n  a->cap = 0;\r\n}\r\n\r\nbool tb_vec_ev_push(tb_vec_ev *a, tb_event ev) {\r\n  if (!a || !a->v)\r\n    return false;\r\n  if (a->len == a->cap) {\r\n    size_t ncap = a->cap * 2;\r\n    tb_event *nv = (tb_event *)realloc(a->v, ncap * sizeof(tb_event));\r\n    if (!nv)\r\n      return false;\r\n    a->v = nv;\r\n    a->cap = ncap;\r\n  }\r\n  a->v[a->len++] = ev;\r\n  return true;\r\n}\r\n\r\nvoid tb_vec_ev_clear(tb_vec_ev *a) {\r\n  if (!a)\r\n    return;\r\n  a->len = 0;\r\n}\r\n\r\n"]
[87.798044, "o", "\u001b[?2004h"]
