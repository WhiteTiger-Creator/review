[193.479882, "i", "python3 - <<'PY'\nimport subprocess, json, os\nfrom collections import Counter,defaultdict\n\ndef check(path):\n  ev=json.load(open(path))['events']\n  c=Counter((e['kind'],e['id']) for e in ev)\n  viol=[k for k,v in c.items() if v!=1]\n  state=defaultdict(int); bad=[]\n  for i,e in enumerate(ev):\n    k,id_=e['kind'],e['id']; st=state[id_]\n    if k=='submit':\n      if st!=0: bad.append((i,'resubmit',id_,st))\n      state[id_]=1\n    elif k=='complete':\n      if st!=1: bad.append((i,'complete_before_submit_or_dup',id_,st))\n      state[id_]=2\n    elif k=='notify':\n      if st!=2: bad.append((i,'notify_before_complete_or_dup',id_,st))\n      state[id_]=3\n  subs=[e['id'] for e in ev if e['kind']=='submit']\n  ok = (not viol) and (not bad) and subs==list(range(1,len(subs)+1))\n  return ok,len(subs),len(ev)\n\ncases=[\n ('basic','burst','a_then_b'),('basic','steady','b_then_a'),\n ('stress','burst','a_then_b'),('stress','steady','b_then_a'),\n ('stress2','steady','a_then_b'),\n]\nfor scn,prof,ordr in cases:\n  out='/app/output/report.js"]
[193.48025, "i", "on'\n  subprocess.run(['rm','-f',out])\n  r=subprocess.run(['/usr/local/bin/arena','--scenario',scn,'--profile',prof,'--order',ordr,'--out',out])\n  ok,nsubs,nev=check(out)\n  print(scn,prof,ordr,'rc',r.returncode,'ok',ok,'submits',nsubs,'events',nev)\nPY\n"]
[193.480282, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[193.480299, "o", "import subprocess, json, os\r\n\u001b[?2004l\r"]
[193.480629, "o", "\u001b[?2004h> "]
