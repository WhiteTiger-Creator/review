[165.596779, "i", "python3 - <<'PY'\nfrom pathlib import Path\npath=Path('/app/src/logic/link.c')\ns=path.read_text(); old=s\ns=s.replace('    rt->gen = last.gen + 1;\\n    rt->cursor = last.cursor;\\n',\n            '    // Reattach creates a new generation for tokens, but must not rewind\\n    // the allocation cursor: submissions continue while detached.\\n    rt->gen = last.gen + 1;\\n')\nif s==old:\n    raise SystemExit('link.c: attach patch not applied (pattern mismatch)')\npath.write_text(s)\nprint('patched',path)\nPY\n"]
