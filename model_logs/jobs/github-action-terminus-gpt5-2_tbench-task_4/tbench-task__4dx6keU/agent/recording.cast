[127.23892, "i", "python3 - <<'PY'\nfrom pathlib import Path\npath=Path('/app/src/logic/settle.c')\ns=path.read_text(); old=s\n# Replace the attached-only notify enqueue with unconditional enqueue.\nneedle='      if (rt->attached) {\\n        // The notifier is only live while attached.\\n        if (!tb_q64_push(&rt->notify_q, token))\\n          return TB_ERR_CORRUPT;\\n      }\\n'\nrepl='      // Always queue notifications; emission is gated by attachment in tb_nudge_drain.\\n      if (!tb_q64_push(&rt->notify_q, token))\\n        return TB_ERR_CORRUPT;\\n'\ns=s.replace(needle,repl)\nif s==old:\n    raise SystemExit('settle.c: no changes applied (pattern mismatch)')\npath.write_text(s)\nprint('patched',path)\nPY\n"]
[127.241268, "o", "python3 - <<'PY'"]
