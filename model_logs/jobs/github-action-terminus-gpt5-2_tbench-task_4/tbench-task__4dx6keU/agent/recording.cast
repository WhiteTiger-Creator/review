[88.022955, "i", "apply_patch<<'PATCH'\n*** Begin Patch\n*** Update File: src/io/journal.c\n@@\n static tb_status append_rec(FILE *f, tb_stamp s) {\n   if (!fs_write_u32(f, s.gen))\n     return TB_ERR_IO;\n-\n-  uint32_t lo = (uint32_t)s.cursor;\n-  if (!fs_write_u32(f, lo))\n-    return TB_ERR_IO;\n+\n+  // stamp format is exactly 12 bytes: u32 generation + u64 cursor\n+  // (cursor is the next id/cursor to allocate).\n+  if (!fs_write_u64(f, s.cursor))\n+    return TB_ERR_IO;\n \n   return TB_OK;\n }\n@@\n static bool read_rec(FILE *f, tb_stamp *out) {\n   uint32_t gen = 0;\n   if (!fs_read_u32(f, &gen))\n     return false;\n-\n-  uint32_t lo = 0;\n-  if (!fs_read_u32(f, &lo))\n-    return false;\n-\n-  out->gen = gen;\n-  out->cursor = (uint64_t)lo;\n+\n+  uint64_t cursor = 0;\n+  if (!fs_read_u64(f, &cursor))\n+    return false;\n+\n+  out->gen = gen;\n+  out->cursor = cursor;\n   return true;\n }\n*** End Patch\nPATCH\n"]
