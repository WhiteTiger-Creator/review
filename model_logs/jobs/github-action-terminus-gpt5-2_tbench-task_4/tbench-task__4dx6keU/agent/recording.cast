[87.912166, "o", "\u001b[?2004l\r"]
[87.913847, "o", "#include \"io/fs.h\"\r\n\r\nbool fs_write_u32(FILE *f, uint32_t v) { return fwrite(&v, sizeof(v), 1, f) == 1; }\r\nbool fs_read_u32(FILE *f, uint32_t *out) { return fread(out, sizeof(*out), 1, f) == 1; }\r\n\r\n"]
[87.913997, "o", "bool fs_write_u64(FILE *f, uint64_t v) { return fwrite(&v, sizeof(v), 1, f) == 1; }\r\nbool fs_read_u64(FILE *f, uint64_t *out) { return fread(out, sizeof(*out), 1, f) == 1; }\r\n\r\n#pragma once\r\n"]
[87.914092, "o", "\r\n#include <stdbool.h>\r\n#include <stdint.h>\r\n#include <stdio.h>\r\n\r\nbool fs_write_u32(FILE *f, uint32_t v);\r\nbool fs_read_u32(FILE *f, uint32_t *out);\r\n\r\nbool fs_write_u64(FILE *f, uint64_t v);\r\nbool fs_read_u64(FILE *f, uint64_t *out);\r\n\r\n"]
[87.914142, "o", "\u001b[?2004h"]
