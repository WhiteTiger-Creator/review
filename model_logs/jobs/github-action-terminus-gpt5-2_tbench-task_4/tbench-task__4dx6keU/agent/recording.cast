[193.480849, "o", "\u001b[?2004h> "]
[193.481877, "o", "  ev=json.load(open(path))['events']\r\n\u001b[?2004l\r\u001b[?2004h>   c=Counter((e['kind'],e['id']) for e in ev)\r\n\u001b[?2004l\r\u001b[?2004h>   viol=[k for k,v in c.items() if v!=1]\r\n\u001b[?2004l\r\u001b[?2004h>   state=defaultdict(int); bad=[]\r\n\u001b[?2004l\r\u001b[?2004h>   for i,e in enumerate(ev):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[193.48203, "o", "    k,id_=e['kind'],e['id']; st=state[id_]\r\n\u001b[?2004l\r"]
[193.48213, "o", "\u001b[?2004h"]
[193.482198, "o", "> "]
[193.482218, "o", "    if k=='submit':"]
[193.482297, "o", "\r\n\u001b[?2004l\r"]
[193.482316, "o", "\u001b[?2004h"]
[193.482396, "o", "> "]
[193.482602, "o", "      if st!=0: bad.append((i,'resubmit',id_,st))\r\n\u001b[?2004l\r\u001b[?2004h"]
[193.482681, "o", "> "]
[193.482699, "o", "      state[id_]=1\r\n\u001b[?2004l\r"]
[193.482723, "o", "\u001b[?2004h"]
[193.48281, "o", "> "]
[193.482904, "o", "    elif k=='complete':\r\n"]
[193.482922, "o", "\u001b[?2004l\r"]
[193.482993, "o", "\u001b[?2004h"]
[193.483024, "o", "> "]
[193.483298, "o", "      if st!=1: bad.append((i,'complete_before_submit_or_dup',id_,st))\r\n\u001b[?2004l\r"]
[193.483335, "o", "\u001b[?2004h> "]
[193.483414, "o", "      state[id_]=2\r\n\u001b[?2004l\r"]
[193.483449, "o", "\u001b[?2004h> "]
[193.483733, "o", "    elif k=='notify':"]
[193.483808, "o", "\r\n"]
