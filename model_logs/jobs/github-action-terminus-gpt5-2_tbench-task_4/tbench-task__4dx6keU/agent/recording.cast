[91.030894, "i", "apply_patch<<'PATCH'\n*** Begin Patch\n*** Update File: src/logic/settle.c\n@@\n       if (lane_a(token, tick)) {\n@@\n       if (rt->attached) {\n-        // The notifier is only live while attached.\n-        if (!tb_q64_push(&rt->notify_q, token))\n-          return TB_ERR_CORRUPT;\n-      }\n+        // notifier live; enqueue as normal\n+      }\n+\n+      // Always enqueue the notification token. Emission is gated by\n+      // attachment in tb_nudge_tick; keeping the queue allows detach/reattach\n+      // to preserve exactly-once notify delivery.\n+      if (!tb_q64_push(&rt->notify_q, token))\n+        return TB_ERR_CORRUPT;\n     } else {\n*** End Patch\nPATCH\n"]
