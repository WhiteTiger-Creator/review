[151.416153, "o", "\u001b[?2004l\r"]
[151.417882, "o", "#include \"cli.h\"\r\n#include \"report.h\"\r\n#include \"runtime/runtime.h\"\r\n#include \"tb_err.h\"\r\n\r\n#include <stdio.h>\r\n\r\nint main(int argc, char **argv) {\r\n  tb_cli cli = {0};\r\n  tb_status st = tb_cli_parse(&cli, argc, argv);\r\n  if (st != TB_OK) {\r\n    fprintf(stderr, \"cli: %s\\n\", tb_status_str(st));\r\n    return 2;\r\n  }\r\n\r\n  // Per-invocation: persistence is only meant to model detach/reattach inside a run.\r\n  (void)remove(\"/app/run/state.bin\");\r\n\r\n  tb_rt rt = {0};\r\n  st = tb_rt_init(&rt, \"/app/run/state.bin\");\r\n  if (st != TB_OK) {\r\n    fprintf(stderr, \"init: %s\\n\", tb_status_str(st));\r\n    return 2;\r\n  }\r\n\r\n  st = tb_rt_run(&rt, cli.scenario, cli.profile, cli.order, cli.seed);\r\n  if (st != TB_OK) {\r\n    fprintf(stderr, \"run: %s\\n\", tb_status_str(st));\r\n    tb_rt_free(&rt);\r\n    return 1;\r\n  }\r\n\r\n  int rc = tb_report_write_json(cli.out_path, cli.scenario, cli.profile, tb_rt_events(&rt));\r\n  tb_rt_free(&rt);\r\n  return rc;"]
[151.418008, "o", "\r\n}\r\n\r\n"]
[151.418133, "o", "\u001b[?2004h"]
[151.41815, "o", "root@0c4a89e29ee7:/app# "]
[151.544038, "i", "sed -n '1,260p' /app/src/cli.c\n"]
[151.544274, "o", "sed -n '1,260p' /app/src/cli.c\r\n\u001b[?2004l\r"]
[151.545556, "o", "#include \"cli.h\"\r\n"]
[151.54568, "o", "\r\n"]
[151.545731, "o", "#include <stdio.h>\r\n"]
[151.54578, "o", "#include <string.h>\r\n"]
[151.545827, "o", "\r\n"]
[151.545878, "o", "static tb_status usage(void) {\r\n"]
[151.545962, "o", "  fprintf(stderr, \"usage: arena --scenario <basic|stress|stress2> --profile <burst|steady> --order <a_then_b|b_then_a> --out <path> [--seed <n>]\\n\");\r\n  return TB_ERR_BAD_ARG;\r\n}\r\n\r\ntb_order tb_order_parse(const char *s) {\r\n  if (!s)\r\n    return 0;\r\n  if (strcmp(s, \"a_then_b\") == 0)\r\n    return TB_ORDER_A_THEN_B;\r\n  if (strcmp(s, \"b_then_a\") == 0)\r\n    return TB_ORDER_B_THEN_A;\r\n  return 0;\r\n"]
[151.546042, "o", "}\r\n\r\nconst char *tb_order_str(tb_order o) {\r\n  switch (o) {\r\n  case TB_ORDER_A_THEN_B:\r\n"]
[151.54609, "o", "    return \"a_then_b\";\r\n"]
[151.546172, "o", "  case TB_ORDER_B_THEN_A:\r\n    return \"b_then_a\";\r\n  default:\r\n    return \"unknown\";\r\n  }\r\n}\r\n\r\n"]
[151.546243, "o", "tb_status tb_cli_parse(tb_cli *out, int argc, char **argv) {\r\n  if (!out || argc <= 1)\r\n"]
[151.546304, "o", "    return usage();\r\n\r\n  tb_cli c = {0};\r\n  c.seed = 1;\r\n"]
[151.546366, "o", "\r\n  for (int i = 1; i < argc; i++) {\r\n    if (strcmp(argv[i], \"--scenario\") == 0 && i + 1 < argc) {\r\n"]
[151.546433, "o", "      c.scenario = tb_scenario_parse(argv[++i]);\r\n    } else if (strcmp(argv[i], \"--profile\") == 0 && i + 1 < argc) {\r\n      c.profile = tb_profile_parse(argv[++i]);\r\n    } else if (strcmp(argv[i], \"--order\") == 0 && i + 1 < argc) {\r\n"]
[151.546569, "o", "      c.order = tb_order_parse(argv[++i]);\r\n    } else if (strcmp(argv[i], \"--out\") == 0 && i + 1 < argc) {\r\n      c.out_path = argv[++i];\r\n    } else if (strcmp(argv[i], \"--seed\") == 0 && i + 1 < argc) {\r\n      unsigned long v = 0;\r\n      if (sscanf(argv[++i], \"%lu\", &v) != 1)\r\n"]
[151.546665, "o", "        return usage();\r\n"]
[151.546722, "o", "      c.seed = (uint32_t)v;\r\n"]
[151.546767, "o", "    } else {\r\n"]
[151.546829, "o", "      return usage();\r\n    }\r\n  }\r\n\r\n  if (!c.scenario || !c.profile || !c.order || !c.out_path)\r\n    return usage();\r\n"]
[151.546875, "o", "\r\n  *out = c;\r\n  return TB_OK;\r\n}\r\n\r\n"]
[151.547121, "o", "\u001b[?2004h"]
[151.547191, "o", "root@0c4a89e29ee7:/app# "]
[151.684415, "i", "sed -n '1,320p' /app/src/runtime/runtime.c\n"]
[151.684764, "o", "sed -n '1,320p' /app/src/runtime/runtime.c\r\n\u001b[?2004l\r"]
[151.688362, "o", "#include \"runtime/runtime.h\"\r\n"]
[151.68841, "o", "\r\n"]
[151.688433, "o", "#include \"core/idgen.h\"\r\n"]
[151.688454, "o", "#include \"logic/ingest.h\"\r\n"]
[151.688475, "o", "#include \"logic/link.h\"\r\n"]
[151.688496, "o", "#include \"logic/merge.h\"\r\n"]
[151.688517, "o", "#include \"logic/nudge.h\"\r\n"]
[151.688538, "o", "#include \"logic/settle.h\"\r\n"]
[151.688559, "o", "\r\n"]
[151.688579, "o", "#include <stdio.h>\r\n"]
[151.6886, "o", "#include <string.h>\r\n"]
[151.68862, "o", "\r\n"]
[151.688641, "o", "tb_status tb_rt_init(tb_rt *rt, const char *journal_path) {\r\n"]
[151.688662, "o", "  if (!rt || !journal_path)\r\n"]
[151.688683, "o", "    return TB_ERR_BAD_ARG;\r\n"]
[151.688707, "o", "  memset(rt, 0, sizeof(*rt));\r\n"]
[151.688729, "o", "\r\n"]
[151.688751, "o", "  if (!tb_map_u64_init(&rt->token_to_id, 128))\r\n"]
[151.688774, "o", "    return TB_ERR_OOM;\r\n"]
[151.689146, "o", "  if (!tb_map_u64_init(&rt->token_done, 128))\r\n    return TB_ERR_OOM;\r\n  if (!tb_q64_init(&rt->in_q, 4096))\r\n    return TB_ERR_OOM;\r\n  if (!tb_q64_init(&rt->done_a, 4096))\r\n    return TB_ERR_OOM;\r\n  if (!tb_q64_init(&rt->done_b, 4096))\r\n    return TB_ERR_OOM;\r\n  if (!tb_q64_init(&rt->notify_q, 4096))\r\n    return TB_ERR_OOM;\r\n  if (!tb_vec_ev_init(&rt->evlog, 2048))\r\n    return TB_ERR_OOM;\r\n\r\n  rt->gen = 1;\r\n  rt->cursor = 1;\r\n"]
[151.689363, "o", "  rt->attached = true;\r\n  rt->journal_path = journal_path;\r\n  return TB_OK;\r\n}\r\n\r\nvoid tb_rt_free(tb_rt *rt) {\r\n  if (!rt)\r\n    return;\r\n  tb_map_u64_free(&rt->token_to_id);\r\n  tb_map_u64_free(&rt->token_done);\r\n  tb_q64_free(&rt->in_q);\r\n  tb_q64_free(&rt->done_a);\r\n  tb_q64_free(&rt->done_b);\r\n  tb_q64_free(&rt->notify_q);\r\n  tb_vec_ev_free(&rt->evlog);\r\n}\r\n"]
[151.689476, "o", "\r\nconst tb_vec_ev *tb_rt_events(const tb_rt *rt) { return &rt->evlog; }\r\n\r\nstatic tb_status maybe_detach_attach(tb_rt *rt, const tb_script *sc, uint32_t tick) {\r\n  if (sc->detach_at && tick == sc->detach_at) {\r\n    return tb_link_detach(rt, tick);\r\n  }\r\n  if (sc->detach_at && tick == sc->detach_at + sc->detach_len) {\r\n    return tb_link_attach(rt, tick);\r\n  }\r\n  if (sc->detach2_at && tick == sc->detach2_at) {\r\n    return tb_link_detach(rt, tick);\r\n  }\r\n  if (sc->detach2_at && tick == sc->detach2_at + sc->detach2_len) {\r\n    return tb_link_attach(rt, tick);\r\n  }\r\n  return TB_OK;\r\n}\r\n\r\ntb_status tb_rt_run(tb_rt *rt, tb_scenario scn, tb_profile prof, tb_order ord, uint32_t seed) {\r\n  (void)seed;\r\n  if (!rt)\r\n    return TB_ERR_BAD_ARG;\r\n\r\n  tb_script sc = {0};\r\n  if (!tb_script_for(scn, &sc))\r\n    return TB_ERR_BAD_ARG;\r\n\r\n  tb_stamp last = {0};\r\n  bool found = false;\r\n  tb_status st = journal_load_last(rt->journal_path, &last, &found);\r\n  if (st != TB_OK)\r\n    return st;\r\n"]
[151.689607, "o", "  if (found) {\r\n    rt->gen = last.gen + 1;\r\n    rt->cursor = last.cursor;\r\n  }\r\n\r\n  for (uint32_t tick = 0; tick < sc.ticks; tick++) {\r\n    st = maybe_detach_attach(rt, &sc, tick);\r\n    if (st != TB_OK)\r\n      return st;\r\n\r\n"]
[151.689625, "o", "    uint32_t submitted = 0;\r\n"]
[151.689666, "o", "    st = tb_ingest_tick(rt, prof, tick, &submitted);\r\n    if (st != TB_OK)\r\n      return st;\r\n\r\n    st = tb_settle_tick(rt, tick);\r\n    if (st != TB_OK)\r\n      return st;\r\n\r\n    st = tb_merge_drain(rt, tick, ord);\r\n    if (st != TB_OK)\r\n"]
[151.689676, "o", "      return st;\r\n\r\n    st = tb_nudge_drain(rt, tick);\r\n    if (st != TB_OK)\r\n"]
[151.689688, "o", "      return st;\r\n  }\r\n"]
[151.689698, "o", "\r\n  // Final drain to avoid leaving work in queues.\r\n  for (uint32_t i = 0; i < 16; i++) {\r\n    st = tb_settle_tick(rt, sc.ticks + i);\r\n    if (st != TB_OK)\r\n"]
[151.689709, "o", "      return st;\r\n    st = tb_merge_drain(rt, sc.ticks + i, ord);\r\n"]
[151.689718, "o", "    if (st != TB_OK)\r\n      return st;\r\n    st = tb_nudge_drain(rt, sc.ticks + i);\r\n    if (st != TB_OK)\r\n      return st;\r\n"]
[151.689726, "o", "  }\r\n\r\n  return TB_OK;\r\n"]
[151.689736, "o", "}\r\n\r\n"]
