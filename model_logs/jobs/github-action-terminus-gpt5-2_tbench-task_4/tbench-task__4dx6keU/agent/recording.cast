[66.929688, "o", "#include \"runtime/script.h\"\r\n\r\n#include <string.h>\r\n\r\ntb_scenario tb_scenario_parse(const char *s) {\r\n  if (!s)\r\n"]
[66.929718, "o", "    return 0;\r\n  if (strcmp(s, \"basic\") == 0)\r\n    return TB_SCN_BASIC;\r\n  if (strcmp(s, \"stress\") == 0)\r\n    return TB_SCN_STRESS;\r\n  if (strcmp(s, \"stress2\") == 0)\r\n    return TB_SCN_STRESS2;\r\n  return 0;\r\n}\r\n\r\nconst char *tb_scenario_str(tb_scenario scn) {\r\n  switch (scn) {\r\n"]
[66.929729, "o", "  case TB_SCN_BASIC:\r\n    return \"basic\";\r\n  case TB_SCN_STRESS:\r\n"]
[66.929737, "o", "    return \"stress\";\r\n  case TB_SCN_STRESS2:\r\n    return \"stress2\";\r\n"]
[66.929754, "o", "  default:\r\n    return \"unknown\";\r\n"]
[66.929764, "o", "  }\r\n}\r\n\r\nbool tb_script_for(tb_scenario scn, tb_script *out) {\r\n  if (!out)\r\n"]
[66.929787, "o", "    return false;\r\n  tb_script s = {0};\r\n  switch (scn) {\r\n  case TB_SCN_BASIC:\r\n    s.ticks = 40;\r\n    s.detach_at = 0;\r\n"]
[66.929797, "o", "    s.detach_len = 0;\r\n    s.detach2_at = 0;\r\n    s.detach2_len = 0;\r\n"]
[66.929839, "o", "    break;\r\n  case TB_SCN_STRESS:\r\n    s.ticks = 80;\r\n    s.detach_at = 22;\r\n    s.detach_len = 10;\r\n    s.detach2_at = 0;\r\n"]
[66.929875, "o", "    s.detach2_len = 0;\r\n    break;\r\n  case TB_SCN_STRESS2:\r\n    s.ticks = 110;\r\n    s.detach_at = 26;\r\n    s.detach_len = 10;\r\n    s.detach2_at = 68;\r\n    s.detach2_len = 12;\r\n    break;\r\n  default:\r\n    return false;\r\n  }\r\n  *out = s;\r\n  return true;\r\n}\r\n\r\n"]
