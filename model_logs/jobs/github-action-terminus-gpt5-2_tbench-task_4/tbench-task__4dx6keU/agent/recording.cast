[90.027007, "i", "apply_patch<<'PATCH'\n*** Begin Patch\n*** Update File: src/logic/link.c\n@@\n tb_status tb_link_detach(tb_rt *rt, uint32_t tick) {\n@@\n   tb_status st = journal_append_stamp(rt->journal_path, s);\n   if (st != TB_OK)\n     return st;\n \n-  // A \"device-side\" queue continues to exist while detached; the notifier doesn't.\n-  tb_q64_clear(&rt->notify_q);\n+  // While detached the device can still complete work. We must *not* drop\n+  // pending notifications; they will be flushed on reattach.\n   return TB_OK;\n }\n*** End Patch\nPATCH\n"]
