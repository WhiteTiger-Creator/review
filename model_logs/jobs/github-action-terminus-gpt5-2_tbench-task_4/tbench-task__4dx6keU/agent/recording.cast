[55.923631, "i", "python3 - <<'PY'\nimport json\nA=json.load(open('/app/output/report_a_then_b.json'))['events']\nB=json.load(open('/app/output/report.json'))['events']\nprint('lenA',len(A),'lenB',len(B))\nprint('same_sequence',A==B)\n# compare id coverage\nsa=[e['id'] for e in A if e['kind']=='submit']\nsb=[e['id'] for e in B if e['kind']=='submit']\nprint('same_submit_count',len(sa)==len(sb))\nprint('same_id_set',set(sa)==set(sb))\n# first divergence point\nm=min(len(A),len(B))\nidx=None\nfor i in range(m):\n  if A[i]!=B[i]:\n    idx=i;break\nprint('first_diff',idx,'A',A[idx] if idx is not None else None,'B',B[idx] if idx is not None else None)\nPY\n"]
