[178.74749, "i", "python3 - <<'PY'\nimport json\nfrom collections import Counter,defaultdict\np='/app/output/report.json'\nev=json.load(open(p))['events']\nc=Counter((e['kind'],e['id']) for e in ev)\nviol=[k for k,v in c.items() if v!=1]\nprint('events',len(ev),'unique_pairs',len(c),'bad_pairs',len(viol))\nstate=defaultdict(int); bad=[]\nfor i,e in enumerate(ev):\n  k,id_=e['kind'],e['id']; st=state[id_]\n  if k=='submit':\n    if st!=0: bad.append((i,'resubmit',id_,st))\n    state[id_]=1\n  elif k=='complete':\n    if st!=1: bad.append((i,'complete_before_submit_or_dup',id_,st))\n    state[id_]=2\n  elif k=='notify':\n    if st!=2: bad.append((i,'notify_before_complete_or_dup',id_,st))\n    state[id_]=3\nsubs=[e['id'] for e in ev if e['kind']=='submit']\nprint('submits',len(subs),'contiguous',subs==list(range(1,len(subs)+1)),'last',subs[-1] if subs else None)\nids=set(subs)\ncomp=set(e['id'] for e in ev if e['kind']=='complete')\nnoti=set(e['id'] for e in ev if e['kind']=='notify')\nprint('missing_complete',len(ids-comp),'missing_notify',len(ids-noti"]
[178.747662, "i", "))\nprint('bad_order',len(bad))\nif viol[:5]: print('sample_bad_pairs',viol[:5],[c[k] for k in viol[:5]])\nif bad[:10]: print('sample_bad_order',bad[:10])\nPY\n"]
