[401.809916, "i", "cat > src/db.c <<'EOF'\n#include \"db.h\"\n\n#include <sqlite3.h>\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n\nstatic sqlite3 *db = NULL;\n\nstatic int exec_simple(const char *sql) {\n    char *err = NULL;\n    int rc = sqlite3_exec(db, sql, NULL, NULL, &err);\n    if (rc != SQLITE_OK) {\n        fprintf(stderr, \"SQL error: %s\\n\", err ? err : sqlite3_errmsg(db));\n        sqlite3_free(err);\n        return -1;\n    }\n    return 0;\n}\n\nstatic void json_append_escaped(char **buf, size_t *cap, size_t *len, const char *s) {\n    if (!s)\n        s = \"\";\n    for (const unsigned char *p = (const unsigned char *)s; *p; p++) {\n        char tmp[8];\n        const char *out = NULL;\n        size_t outn = 0;\n        switch (*p) {\n        case '\"': out = \"\\\\\\\"\"; outn = 2; break;\n        case '\\\\': out = \"\\\\\\\\\"; outn = 2; break;\n        case '\\b': out = \"\\\\b\"; outn = 2; break;\n        case '\\f': out = \"\\\\f\"; outn = 2; break;\n        case '\\n': out = \"\\\\n\"; outn = 2; break;\n        case '\\r': out = \"\\\\r\"; outn = 2; break;\n        case '\\t': out = \"\\\\t\"; outn = 2; break;\n        default:\n            if (*p < 0x20) {\n                snprintf(tmp, sizeof(tmp), \"\\\\u%04x\", (unsigned int)*p);\n                out = tmp;\n                outn = strlen(tmp);\n            } else {\n                tmp[0] = (char)*p;\n                tmp[1] = '\\0';\n                out = tmp;\n                outn = 1;\n            }\n        }\n\n        if (*len + outn + 1 >= *cap) {\n            size_t ncap = (*cap == 0) ? 1024 : (*cap * 2);\n            while (*len + outn + 1 >= ncap)\n                ncap *= 2;\n            char *nbuf = realloc(*buf, ncap);\n            if (!nbuf)\n                return;\n            *buf = nbuf;\n            *cap = ncap;\n        }\n        memcpy(*buf + *len, out, outn);\n        *len += outn;\n        (*buf)[*len] = '\\0';\n    }\n}\n\nstatic int begin_immediate(void) {\n    return exec_simple(\"BEGIN IMMEDIATE;\");\n}\n\nstatic void rollback_tx(void) {\n    (void)exec_simple(\"ROLLBACK;\");\n}\n\nstatic int commit_tx(void) {\n    return exec_simple(\"COMMIT;\");\n}\n\nint init_db(const char *path) {\n    if (sqlite3_open_v2(path, &db,\n                        SQLITE_OPEN_READWRITE | SQLITE_OPEN_CREATE | SQLITE_OPEN_FULLMUTEX,\n                        NULL) != SQLITE_OK) {\n        fprintf(stderr, \"Cannot open database: %s\\n\", sqlite3_errmsg(db));\n        return -1;\n    }\n\n    if (exec_simple(\"PRAGMA journal_mode=WAL;\") != 0)\n        return -1;\n    if (exec_simple(\"PRAGMA synchronous=NORMAL;\") != 0)\n        return -1;\n    if (exec_simple(\"PRAGMA busy_timeout=5000;\") != 0)\n        return -1;\n\n    const char *sql = \"CREATE TABLE IF NOT EXISTS notes (\"\n                      \"id INTEGER PRIMARY KEY AUTOINCREMENT,\"\n                      \"title TEXT NOT NULL,\"\n                      \"content TEXT DEFAULT ''\"\n                      \");\";\n    if (exec_simple(sql) != 0)\n        return -1;\n\n    return 0;\n}\n\nvoid close_db(void) {\n    if (db)\n        sqlite3_close(db);\n    db = NULL;\n}\n\nint create_note(const char *title, const char *content) {\n    if (!db)\n        return -1;\n    if (begin_immediate() != 0)\n        return -1;\n\n    sqlite3_stmt *stmt = NULL;\n    const char *sql = \"INSERT INTO notes (title, content) VALUES (?, ?);\";\n    if (sqlite3_prepare_v2(db, sql, -1, &stmt, NULL) != SQLITE_OK) {\n        rollback_tx();\n        return -1;\n    }\n    sqlite3_bind_text(stmt, 1, title ? title : \"\", -1, SQLITE_TRANSIENT);\n    sqlite3_bind_text(stmt, 2, content ? content : \"\", -1, SQLITE_TRANSIENT);\n    int rc = sqlite3_step(stmt);\n    sqlite3_finalize(stmt);\n    if (rc != SQLITE_DONE) {\n        rollback_tx();\n        return -1;\n    }\n\n    int id = (int)sqlite3_last_insert_rowid(db);\n    if (commit_tx() != 0)\n        return -1;\n    return id;\n}\n\nchar *get_all_notes_json(void) {\n    return get_notes_paginated_json(1000000, 0);\n}\n\nchar *get_notes_paginated_json(int limit, int offset) {\n    if (!db)\n        return NULL;\n\n    sqlite3_stmt *stmt = NULL;\n    const char *sql = \"SELECT id, title, content FROM notes ORDER BY id ASC LIMIT ? OFFSET ?;\";\n    if (sqlite3_prepare_v2(db, sql, -1, &stmt, N"]
[401.809966, "i", "ULL) != SQLITE_OK)\n        return NULL;\n    sqlite3_bind_int(stmt, 1, limit);\n    sqlite3_bind_int(stmt, 2, offset);\n\n    char *buf = malloc(2);\n    if (!buf) {\n        sqlite3_finalize(stmt);\n        return NULL;\n    }\n    size_t cap = 2, len = 1;\n    buf[0] = '[';\n    buf[1] = '\\0';\n\n    int first = 1;\n    while (sqlite3_step(stmt) == SQLITE_ROW) {\n        int id = sqlite3_column_int(stmt, 0);\n        const char *title = (const char *)sqlite3_column_text(stmt, 1);\n        const char *content = (const char *)sqlite3_column_text(stmt, 2);\n\n        char prefix[64];\n        snprintf(prefix, sizeof(prefix), \"%s{\\\"id\\\":%d,\\\"title\\\":\\\"\", first ? \"\" : \",\", id);\n        size_t pn = strlen(prefix);\n        if (len + pn + 1 >= cap) {\n            size_t ncap = cap * 2;\n            while (len + pn + 1 >= ncap)\n                ncap *= 2;\n            char *nbuf = realloc(buf, ncap);\n            if (!nbuf) {\n                free(buf);\n                sqlite3_finalize(stmt);\n                return NULL;\n            }\n            buf = nbuf;\n            cap = ncap;\n        }\n        memcpy(buf + len, prefix, pn);\n        len += pn;\n        buf[len] = '\\0';\n        json_append_escaped(&buf, &cap, &len, title);\n\n        const char *mid = \"\\\",\\\"content\\\":\\\"\";\n        size_t mn = strlen(mid);\n        if (len + mn + 1 >= cap) {\n            size_t ncap = cap * 2;\n            while (len + mn + 1 >= ncap)\n                ncap *= 2;\n            char *nbuf = realloc(buf, ncap);\n            if (!nbuf) {\n                free(buf);\n                sqlite3_finalize(stmt);\n                return NULL;\n            }\n            buf = nbuf;\n            cap = ncap;\n        }\n        memcpy(buf + len, mid, mn);\n        len += mn;\n        buf[len] = '\\0';\n        json_append_escaped(&buf, &cap, &len, content);\n\n        const char *suffix = \"\\\"}\";\n        size_t sn = strlen(suffix);\n        if (len + sn + 1 >= cap) {\n            size_t ncap = cap * 2;\n            while (len + sn + 1 >= ncap)\n                ncap *= 2;\n            char *nbuf = realloc(buf, ncap);\n            if (!nbuf) {\n                free(buf);\n                sqlite3_finalize(stmt);\n                return NULL;\n            }\n            buf = nbuf;\n            cap = ncap;\n        }\n        memcpy(buf + len, suffix, sn);\n        len += sn;\n        buf[len] = '\\0';\n\n        first = 0;\n    }\n    sqlite3_finalize(stmt);\n\n    if (len + 2 >= cap) {\n        char *nbuf = realloc(buf, len + 2);\n        if (!nbuf) {\n            free(buf);\n            return NULL;\n        }\n        buf = nbuf;\n        cap = len + 2;\n    }\n    buf[len++] = ']';\n    buf[len] = '\\0';\n    return buf;\n}\n\nint get_total_notes_count(void) {\n    if (!db)\n        return 0;\n    sqlite3_stmt *stmt = NULL;\n    const char *sql = \"SELECT COUNT(*) FROM notes;\";\n    if (sqlite3_prepare_v2(db, sql, -1, &stmt, NULL) != SQLITE_OK)\n        return 0;\n    int total = 0;\n    if (sqlite3_step(stmt) == SQLITE_ROW)\n        total = sqlite3_column_int(stmt, 0);\n    sqlite3_finalize(stmt);\n    return total;\n}\n\nchar *get_note_json(int id) {\n    if (!db)\n        return NULL;\n    sqlite3_stmt *stmt = NULL;\n    const char *sql = \"SELECT id, title, content FROM notes WHERE id = ?;\";\n    if (sqlite3_prepare_v2(db, sql, -1, &stmt, NULL) != SQLITE_OK)\n        return NULL;\n    sqlite3_bind_int(stmt, 1, id);\n    if (sqlite3_step(stmt) != SQLITE_ROW) {\n        sqlite3_finalize(stmt);\n        return NULL;\n    }\n    int rid = sqlite3_column_int(stmt, 0);\n    const char *title = (const char *)sqlite3_column_text(stmt, 1);\n    const char *content = (const char *)sqlite3_column_text(stmt, 2);\n    sqlite3_finalize(stmt);\n\n    size_t cap = 256, len = 0;\n    char *buf = malloc(cap);\n    if (!buf)\n        return NULL;\n\n    int n = snprintf(buf, cap, \"{\\\"id\\\":%d,\\\"title\\\":\\\"\", rid);\n    if (n < 0) {\n        free(buf);\n        return NULL;\n    }\n    len = (size_t)n;\n    buf[len] = '\\0';\n    json_append_escaped(&buf, &cap, &len, title);\n\n    const char *mid = \"\\\",\\\"content\\\":\\\"\";\n    size_t mn = strlen(mid);\n    if (len + mn + 1 >= cap) {\n        size_t ncap = cap *"]
[401.810155, "i", " 2;\n        while (len + mn + 1 >= ncap)\n            ncap *= 2;\n        char *nbuf = realloc(buf, ncap);\n        if (!nbuf) {\n            free(buf);\n            return NULL;\n        }\n        buf = nbuf;\n        cap = ncap;\n    }\n    memcpy(buf + len, mid, mn);\n    len += mn;\n    buf[len] = '\\0';\n    json_append_escaped(&buf, &cap, &len, content);\n\n    const char *end = \"\\\"}\";\n    size_t en = strlen(end);\n    if (len + en + 1 >= cap) {\n        char *nbuf = realloc(buf, len + en + 1);\n        if (!nbuf) {\n            free(buf);\n            return NULL;\n        }\n        buf = nbuf;\n        cap = len + en + 1;\n    }\n    memcpy(buf + len, end, en);\n    len += en;\n    buf[len] = '\\0';\n    return buf;\n}\n\nint update_note(int id, const char *title, const char *content) {\n    if (!db)\n        return -1;\n    if (begin_immediate() != 0)\n        return -1;\n\n    sqlite3_stmt *stmt = NULL;\n    const char *sql = \"UPDATE notes SET title = ?, content = ? WHERE id = ?;\";\n    if (sqlite3_prepare_v2(db, sql, -1, &stmt, NULL) != SQLITE_OK) {\n        rollback_tx();\n        return -1;\n    }\n    sqlite3_bind_text(stmt, 1, title ? title : \"\", -1, SQLITE_TRANSIENT);\n    sqlite3_bind_text(stmt, 2, content ? content : \"\", -1, SQLITE_TRANSIENT);\n    sqlite3_bind_int(stmt, 3, id);\n    int rc = sqlite3_step(stmt);\n    sqlite3_finalize(stmt);\n    if (rc != SQLITE_DONE) {\n        rollback_tx();\n        return -1;\n    }\n    int changed = sqlite3_changes(db);\n    if (commit_tx() != 0)\n        return -1;\n    return changed > 0 ? 1 : 0;\n}\n\nint delete_note(int id) {\n    if (!db)\n        return -1;\n    if (begin_immediate() != 0)\n        return -1;\n\n    sqlite3_stmt *stmt = NULL;\n    const char *sql = \"DELETE FROM notes WHERE id = ?;\";\n    if (sqlite3_prepare_v2(db, sql, -1, &stmt, NULL) != SQLITE_OK) {\n        rollback_tx();\n        return -1;\n    }\n    sqlite3_bind_int(stmt, 1, id);\n    int rc = sqlite3_step(stmt);\n    sqlite3_finalize(stmt);\n    if (rc != SQLITE_DONE) {\n        rollback_tx();\n        return -1;\n    }\n    int changed = sqlite3_changes(db);\n    if (commit_tx() != 0)\n        return -1;\n    return changed > 0 ? 1 : 0;\n}\n\nint note_exists(int id) {\n    if (!db)\n        return 0;\n    sqlite3_stmt *stmt = NULL;\n    const char *sql = \"SELECT 1 FROM notes WHERE id = ?;\";\n    if (sqlite3_prepare_v2(db, sql, -1, &stmt, NULL) != SQLITE_OK)\n        return 0;\n    sqlite3_bind_int(stmt, 1, id);\n    int exists = (sqlite3_step(stmt) == SQLITE_ROW);\n    sqlite3_finalize(stmt);\n    return exists;\n}\nEOF\n"]
