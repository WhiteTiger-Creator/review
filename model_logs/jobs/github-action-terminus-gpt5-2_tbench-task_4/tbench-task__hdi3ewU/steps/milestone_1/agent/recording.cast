[876.065817, "o", "#include <microhttpd.h>\r\n#include <stdio.h>\r\n#include <string.h>\r\n#include <stdlib.h>\r\n#include <signal.h>\r\n#include <sys/stat.h>\r\n#include <limits.h>\r\n#include <errno.h>\r\n#include <strings.h>\r\n#include \"routes.h\"\r\n#include \"db.h\"\r\n#include \"notes.h\"\r\n\r\n#define PORT 8080\r\n#define WWW_DIR \"/app/www\"\r\n\r\nstatic struct MHD_Daemon *daemon_handle = NULL;\r\n"]
[876.066019, "o", "\r\nstatic void handle_signal(int sig) {\r\n    (void)sig;\r\n    if (daemon_handle) MHD_stop_daemon(daemon_handle);\r\n    close_db();\r\n    exit(0);\r\n}\r\n\r\nstatic const char *get_content_type(const char *path) {\r\n    const char *ext = strrchr(path, '.');\r\n    if (!ext) return \"application/octet-stream\";\r\n    if (strcmp(ext, \".html\") == 0) return \"text/html\";\r\n    if (strcmp(ext, \".css\") == 0) return \"text/css\";\r\n    if (strcmp(ext, \".js\") == 0) return \"application/javascript\";\r\n    return \"application/octet-stream\";\r\n}\r\n\r\nstatic int hexval(int c){\r\n    if (c>='0' && c<='9') return c-'0';\r\n    if (c>='a' && c<='f') return 10 + (c-'a');\r\n    if (c>='A' && c<='F') return 10 + (c-'A');\r\n    return -1;\r\n"]
[876.066053, "o", "}\r\n\r\nstatic int url_decode(const char *in, char *out, size_t outsz){\r\n    size_t oi=0;\r\n    for (size_t i=0; in[i]; i++){\r\n        unsigned char ch = (unsigned char)in[i];\r\n        if (ch=='%'){\r\n            int a = hexval((unsigned char)in[i+1]);\r\n            int b = hexval((unsigned char)in[i+2]);\r\n            if (a<0 || b<0) return -1;\r\n            ch = (unsigned char)((a<<4)|b);\r\n            i += 2;\r\n        }\r\n        if (ch==0) return -1;\r\n        if (oi+1>=outsz) return -1;\r\n        out[oi++] = (char)ch;\r\n    }\r\n    out[oi]=0;\r\n    return 0;\r\n}\r\n\r\nstatic int decoded_path_has_dotdot(const char *url){\r\n    char dec[4096];\r\n    if (url_decode(url, dec, sizeof(dec))!=0) return 0;\r\n    const char *p = dec;\r\n    while (*p){\r\n        while (*p=='/') p++;\r\n        if (!*p) break;\r\n        const char *seg=p;\r\n        while (*p && *p!='/') p++;\r\n        size_t len = (size_t)(p-seg);\r\n        if (len==2 && seg[0]=='.' && seg[1]=='.') return 1;\r\n    }\r\n    return 0;\r\n}\r\n\r\nstatic int url_contains_encoded_dotdot(const char *url) {\r\n    const char *p = url;\r\n    while (*p) {\r\n        if (strncasecmp(p, \"%2e%2e\", 6) == 0)\r\n            return 1;\r\n        p++;\r\n    }\r\n    return 0;\r\n}\r\n\r\nstatic int serve_static_file(struct MHD_Connection *connection,\r\n                                        const char *url) {\r\n    if (strstr(url, \"..\") != NULL || url_contains_encoded_dotdot(url) || decoded_path_has_dotdot(url)) {\r\n        struct MHD_Response *r = MHD_create_response_from_buffer(\r\n            9, (void *)\"Forbidden\", MHD_RESPMEM_PERSISTENT);\r\n        int ret = MHD_queue_response(connection, MHD_HTTP_FORBIDDEN, r);\r\n        MHD_destroy_response(r);\r\n        return ret;\r\n"]
[876.066076, "o", "    }\r\n\r\n    char path[PATH_MAX];\r\n    if (strcmp(url, \"/\") == 0)\r\n        url = \"/index.html\";\r\n\r\n    snprintf(path, sizeof(path), \"%s%s\", WWW_DIR, url);\r\n\r\n    struct stat st;\r\n"]
[876.066097, "o", "    if (stat(path, &st) != 0 || !S_ISREG(st.st_mode)) {\r\n        struct MHD_Response *r = MHD_create_response_from_buffer(\r\n            9, (void *)\"Not Found\", MHD_RESPMEM_PERSISTENT);\r\n        int ret = MHD_queue_response(connection, MHD_HTTP_NOT_FOUND, r);\r\n        MHD_destroy_response(r);\r\n        return ret;\r\n    }\r\n"]
[876.066133, "o", "\r\n    FILE *f = fopen(path, \"rb\");\r\n    if (!f) {\r\n        struct MHD_Response *r = MHD_create_response_from_buffer(\r\n            5, (void *)\"Error\", MHD_RESPMEM_PERSISTENT);\r\n        int ret = MHD_queue_response(connection, MHD_HTTP_INTERNAL_SERVER_ERROR, r);\r\n        MHD_destroy_response(r);\r\n"]
[876.066151, "o", "        return ret;\r\n    }\r\n\r\n    char *data = malloc(st.st_size);\r\n"]
