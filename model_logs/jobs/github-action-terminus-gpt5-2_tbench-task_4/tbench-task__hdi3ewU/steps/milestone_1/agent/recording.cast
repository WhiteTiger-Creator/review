[681.798903, "o", "     1\t#include <microhttpd.h>\r\n     2\t#include <stdio.h>\r\n     3\t#include <string.h>\r\n     4\t#include <stdlib.h>\r\n     5\t#include <signal.h>\r\n     6\t#include <sys/stat.h>\r\n"]
[681.798959, "o", "     7\t#include <limits.h>\r\n     8\t#include <errno.h>\r\n     9\t#include <strings.h>\r\n    10\t#include \"routes.h\"\r\n    11\t#include \"db.h\"\r\n    12\t#include \"notes.h\"\r\n    13\t\r\n    14\t#define PORT NOTES_LISTEN_PORT\r\n"]
[681.799001, "o", "    15\t#define WWW_DIR \"/app/www\"\r\n    16\t\r\n    17\tstatic struct MHD_Daemon *daemon_handle = NULL;\r\n"]
[681.799039, "o", "    18\t\r\n    19\tstatic void handle_signal(int sig) {\r\n    20\t    (void)sig;\r\n"]
[681.799076, "o", "    21\t    if (daemon_handle) MHD_stop_daemon(daemon_handle);\r\n    22\t    close_db();\r\n    23\t    exit(0);\r\n"]
[681.799114, "o", "    24\t}\r\n    25\t\r\n    26\tstatic const char *get_content_type(const char *path) {\r\n"]
[681.799152, "o", "    27\t    const char *ext = strrchr(path, '.');\r\n    28\t    if (!ext) return \"application/octet-stream\";\r\n    29\t    if (strcmp(ext, \".html\") == 0) return \"text/html\";\r\n"]
[681.799189, "o", "    30\t    if (strcmp(ext, \".css\") == 0) return \"text/css\";\r\n    31\t    if (strcmp(ext, \".js\") == 0) return \"application/javascript\";\r\n    32\t    return \"application/octet-stream\";\r\n"]
[681.799227, "o", "    33\t}\r\n    34\t\r\n    35\tstatic int hexval(int c){\r\n"]
[681.799265, "o", "    36\t    if (c>='0' && c<='9') return c-'0';\r\n    37\t    if (c>='a' && c<='f') return 10 + (c-'a');\r\n    38\t    if (c>='A' && c<='F') return 10 + (c-'A');\r\n"]
[681.799303, "o", "    39\t    return -1;\r\n    40\t}\r\n    41\t\r\n"]
[681.799341, "o", "    42\tstatic int url_decode(const char *in, char *out, size_t outsz){\r\n    43\t    size_t oi=0;\r\n    44\t    for (size_t i=0; in[i]; i++){\r\n"]
[681.799379, "o", "    45\t        unsigned char ch = (unsigned char)in[i];\r\n    46\t        if (ch=='%'){\r\n    47\t            int a = hexval((unsigned char)in[i+1]);\r\n"]
[681.799416, "o", "    48\t            int b = hexval((unsigned char)in[i+2]);\r\n    49\t            if (a<0 || b<0) return -1;\r\n    50\t            ch = (unsigned char)((a<<4)|b);\r\n"]
[681.799453, "o", "    51\t            i += 2;\r\n    52\t        }\r\n    53\t        if (ch==0) return -1;\r\n"]
[681.799767, "o", "    54\t        if (oi+1>=outsz) return -1;\r\n    55\t        out[oi++] = (char)ch;\r\n    56\t    }\r\n"]
[681.800112, "o", "    57\t    out[oi]=0;\r\n    58\t    return 0;\r\n"]
[681.80027, "o", "    59\t}\r\n    60\t\r\n    61\tstatic int decoded_path_has_dotdot(const char *url){\r\n    62\t    char dec[4096];\r\n    63\t    if (url_decode(url, dec, sizeof(dec))!=0) return 0;\r\n    64\t    const char *p = dec;\r\n    65\t    while (*p){\r\n    66\t        while (*p=='/') p++;\r\n    67\t        if (!*p) break;\r\n    68\t        const char *seg=p;\r\n    69\t        while (*p && *p!='/') p++;\r\n    70\t        size_t len = (size_t)(p-seg);\r\n    71\t        if (len==2 && seg[0]=='.' && seg[1]=='.') return 1;\r\n    72\t    }\r\n    73\t    return 0;\r\n    74\t}\r\n    75\t\r\n    76\tstatic int url_contains_encoded_dotdot(const char *url) {\r\n    77\t    const char *p = url;\r\n    78\t    while (*p) {\r\n    79\t        if (strncasecmp(p, \"%2e%2e\", 6) == 0)\r\n    80\t            return 1;\r\n    81\t        p++;\r\n    82\t    }\r\n    83\t    return 0;\r\n    84\t}\r\n"]
[681.800744, "o", "    85\t\r\n    86\tstatic enum MHD_Result serve_static_file(struct MHD_Connection *connection,\r\n    87\t                                        const char *url) {\r\n    88\t    if (strstr(url, \"..\") != NULL || url_contains_encoded_dotdot(url) || decoded_path_has_dotdot(url)) {\r\n    89\t        struct MHD_Response *r = MHD_create_response_from_buffer(\r\n    90\t            9, (void *)\"Forbidden\", MHD_RESPMEM_PERSISTENT);\r\n    91\t        enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_FORBIDDEN, r);\r\n    92\t        MHD_destroy_response(r);\r\n    93\t        return ret;\r\n    94\t    }\r\n    95\t\r\n    96\t    char path[PATH_MAX];\r\n    97\t    if (strcmp(url, \"/\") == 0)\r\n    98\t        url = \"/index.html\";\r\n    99\t\r\n   100\t    snprintf(path, sizeof(path), \"%s%s\", WWW_DIR, url);\r\n   101\t\r\n   102\t    struct stat st;\r\n   103\t    if (stat(path, &st) != 0 || !S_ISREG(st.st_mode)) {\r\n   104\t        struct MHD_Response *r = MHD_create_response_from_buffer(\r\n   105\t            9, (void *)\"Not Found\", MHD_RESPMEM_PERSISTENT);\r\n   106\t        enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_NOT_FOUND, r);\r\n   107\t        MHD_destroy_response(r);\r\n   108\t        return ret;\r\n   109\t    }\r\n   110\t\r\n   111\t    FILE *f = fopen(path, \"rb\");\r\n   112\t    if (!f) {\r\n   113\t        struct MHD_Response *r = MHD_create_response_from_buffer(\r\n   114\t            5, (void *)\"Error\", MHD_RESPMEM_PERSISTENT);\r\n   115\t        enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_INTERNAL_SERVER_ERROR, r);\r\n   116\t        MHD_destroy_response(r);\r\n   117\t        return ret;\r\n   118\t    }\r\n   119\t\r\n   120\t    char *data = malloc(st.st_size);\r\n   121\t    if (!data) {\r\n"]
[681.800803, "o", "   122\t        fclose(f);\r\n   123\t        struct MHD_Response *r = MHD_create_response_from_buffer(\r\n   124\t            5, (void *)\"Error\", MHD_RESPMEM_PERSISTENT);\r\n   125\t        enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_INTERNAL_SERVER_ERROR, r);\r\n   126\t        MHD_destroy_response(r);\r\n   127\t        return ret;\r\n   128\t    }\r\n   129\t\r\n   130\t    size_t n = fread(data, 1, st.st_size, f);\r\n   131\t    fclose(f);\r\n   132\t    if (n != (size_t)st.st_size) {\r\n   133\t        free(data);\r\n   134\t        struct MHD_Response *r = MHD_create_response_from_buffer(\r\n   135\t            5, (void *)\"Error\", MHD_RESPMEM_PERSISTENT);\r\n   136\t        enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_INTERNAL_SERVER_ERROR, r);\r\n   137\t        MHD_destroy_response(r);\r\n   138\t        return ret;\r\n   139\t    }\r\n   140\t\r\n   141\t    struct MHD_Response *r = MHD_create_response_from_buffer(\r\n   142\t        n, (void *)data, MHD_RESPMEM_MUST_FREE);\r\n   143\t    MHD_add_response_header(r, \"Content-Type\", get_content_type(path));\r\n   144\t    enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_OK, r);\r\n   145\t    MHD_destroy_response(r);\r\n   146\t    return ret;\r\n   147\t}\r\n   148\t\r\n   149\tstatic void request_completed_cb(void *cls, struct MHD_Connection *connection,\r\n   150\t                                 void **con_cls, enum MHD_RequestTerminationCode toe) {\r\n   151\t    (void)cls;\r\n   152\t    (void)connection;\r\n   153\t    (void)toe;\r\n   154\t    if (!con_cls || !*con_cls)\r\n   155\t        return;\r\n   156\t    struct connection_info *ci = (struct connection_info *)(*con_cls);\r\n   157\t    free(ci->data);\r\n   158\t    free(ci);\r\n   159\t    *con_cls = NULL;\r\n   160\t}\r\n   161\t\r\n   162\tstatic enum MHD_Result access_handler(void *cls,\r\n   163\t                                     struct MHD_Connection *connection,\r\n   164\t                                     const char *url,\r\n   165\t                                     const char *method,\r\n   166\t                                     const char *version,\r\n   167\t                                     const char *upload_data,\r\n   168\t                                     size_t *upload_data_size,\r\n   169\t                                     void **con_cls) {\r\n   170\t    (void)cls;\r\n   171\t    (void)version;\r\n   172\t\r\n   173\t    if (strncmp(url, \"/api/\", 5) == 0)\r\n   174\t        return route_request(connection, url, method, upload_data, upload_data_size, con_cls);\r\n   175\t    return serve_static_file(connection, url);\r\n   176\t}\r\n   177\t\r\n   178\tint main(void) {\r\n   179\t    signal(SIGINT, handle_signal);\r\n   180\t    signal(SIGTERM, handle_signal);\r\n   181\t\r\n   182\t    if (init_db(\"/app/data/notes.db\") != 0) {\r\n   183\t        fprintf(stderr, \"Failed to initialize database\\n\");\r\n   184\t        return 1;\r\n   185\t    }\r\n   186\t\r\n   187\t    daemon_handle = MHD_start_daemon(MHD_USE_INTERNAL_POLLING_THREAD,\r\n   188\t                                    PORT,\r\n   189\t                                    NULL, NULL,\r\n   190\t                                    &access_handler, NULL,\r\n   191\t                                    MHD_OPTION_NOTIFY_COMPLETED, request_completed_cb, NULL,\r\n   192\t                                    MHD_OPTION_END);\r\n   193\t\r\n   194\t    if (!daemon_handle) {\r\n   195\t        fprintf(stderr, \"Failed to start server: %s\\n\", strerror(errno));\r\n   196\t        return 1;\r\n   197\t    }\r\n   198\t\r\n   199\t    printf(\"Server running on port %d\\n\", PORT);\r\n   200\t    while (1) pause();\r\n   201\t    return 0;\r\n   202\t}\r\n"]
