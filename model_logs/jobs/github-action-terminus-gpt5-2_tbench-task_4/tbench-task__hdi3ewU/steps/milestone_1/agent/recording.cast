[657.482756, "i", "cat > src/routes.c <<'EOF'\n#include \"routes.h\"\n\n#include \"auth.h\"\n#include \"common.h\"\n#include \"db.h\"\n\n#include <microhttpd.h>\n#include <ctype.h>\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n\nstatic enum MHD_Result send_json(struct MHD_Connection *connection,\n                                const char *body, unsigned int status_code) {\n    struct MHD_Response *response = MHD_create_response_from_buffer(\n        strlen(body), (void *)body, MHD_RESPMEM_MUST_COPY);\n    MHD_add_response_header(response, \"Content-Type\", \"application/json\");\n    MHD_add_response_header(response, \"Access-Control-Allow-Origin\", \"*\");\n    MHD_add_response_header(response, \"Access-Control-Allow-Methods\",\n                            \"GET, POST, PUT, DELETE, OPTIONS\");\n    MHD_add_response_header(response, \"Access-Control-Allow-Headers\",\n                            \"Content-Type, X-API-Key\");\n    enum MHD_Result ret = MHD_queue_response(connection, status_code, response);\n    MHD_destroy_response(response);\n    return ret;\n}\n\nstatic enum MHD_Result send_json_with_total(struct MHD_Connection *connection,\n                                           const char *body,\n                                           unsigned int status_code,\n                                           int total) {\n    struct MHD_Response *response = MHD_create_response_from_buffer(\n        strlen(body), (void *)body, MHD_RESPMEM_MUST_COPY);\n    MHD_add_response_header(response, \"Content-Type\", \"application/json\");\n    MHD_add_response_header(response, \"Access-Control-Allow-Origin\", \"*\");\n    MHD_add_response_header(response, \"Access-Control-Allow-Methods\",\n                            \"GET, POST, PUT, DELETE, OPTIONS\");\n    MHD_add_response_header(response, \"Access-Control-Allow-Headers\",\n                            \"Content-Type, X-API-Key\");\n    char count_str[32];\n    snprintf(count_str, sizeof(count_str), \"%d\", total);\n    MHD_add_response_header(response, \"X-Total-Count\", count_str);\n    enum MHD_Result ret = MHD_queue_response(connection, status_code, response);\n    MHD_destroy_response(response);\n    return ret;\n}\n\nstatic int is_blank_string(const char *s) {\n    if (!s)\n        return 1;\n    while (*s) {\n        if (!isspace((unsigned char)*s))\n            return 0;\n        s++;\n    }\n    return 1;\n}\n\nstatic void json_append_escaped(char **buf, size_t *cap, size_t *len, const char *s) {\n    if (!s)\n        s = \"\";\n    for (const unsigned char *p = (const unsigned char *)s; *p; p++) {\n        char tmp[8];\n        const char *out = NULL;\n        size_t outn = 0;\n        switch (*p) {\n        case '\"': out = \"\\\\\\\"\"; outn = 2; break;\n        case '\\\\': out = \"\\\\\\\\\"; outn = 2; break;\n        case '\\b': out = \"\\\\b\"; outn = 2; break;\n        case '\\f': out = \"\\\\f\"; outn = 2; break;\n        case '\\n': out = \"\\\\n\"; outn = 2; break;\n        case '\\r': out = \"\\\\r\"; outn = 2; break;\n        case '\\t': out = \"\\\\t\"; outn = 2; break;\n        default:\n            if (*p < 0x20) {\n                snprintf(tmp, sizeof(tmp), \"\\\\u%04x\", (unsigned int)*p);\n                out = tmp;\n                outn = strlen(tmp);\n            } else {\n                tmp[0] = (char)*p;\n                tmp[1] = '\\0';\n                out = tmp;\n                outn = 1;\n            }\n        }\n\n        if (*len + outn + 1 >= *cap) {\n            size_t ncap = (*cap == 0) ? 256 : (*cap * 2);\n            while (*len + outn + 1 >= ncap)\n                ncap *= 2;\n            char *nbuf = realloc(*buf, ncap);\n            if (!nbuf)\n                return;\n            *buf = nbuf;\n            *cap = ncap;\n        }\n        memcpy(*buf + *len, out, outn);\n        *len += outn;\n        (*buf)[*len] = '\\0';\n    }\n}\n\nstatic char *build_note_json(int id, const char *title, const char *content) {\n    size_t cap = 256, len = 0;\n    char *buf = malloc(cap);\n    if (!buf)\n        return NULL;\n    int n = snprintf(buf, cap, \"{\\\"id\\\":%d,\\\"title\\\":\\\"\", id);\n    if (n < 0) {\n        free(buf);\n        return NULL;\n    }\n    len = (size_t)n;\n    buf[len] = '\\0';\n    json_append_escaped(&buf, &cap, &len, title);\n"]
[657.482928, "i", "\n    const char *mid = \"\\\",\\\"content\\\":\\\"\";\n    size_t mn = strlen(mid);\n    if (len + mn + 1 >= cap) {\n        size_t ncap = cap * 2;\n        while (len + mn + 1 >= ncap)\n            ncap *= 2;\n        char *nbuf = realloc(buf, ncap);\n        if (!nbuf) {\n            free(buf);\n            return NULL;\n        }\n        buf = nbuf;\n        cap = ncap;\n    }\n    memcpy(buf + len, mid, mn);\n    len += mn;\n    buf[len] = '\\0';\n    json_append_escaped(&buf, &cap, &len, content);\n\n    const char *end = \"\\\"}\";\n    size_t en = strlen(end);\n    if (len + en + 1 >= cap) {\n        char *nbuf = realloc(buf, len + en + 1);\n        if (!nbuf) {\n            free(buf);\n            return NULL;\n        }\n        buf = nbuf;\n        cap = len + en + 1;\n    }\n    memcpy(buf + len, end, en);\n    len += en;\n    buf[len] = '\\0';\n    return buf;\n}\n\n// Minimal JSON extractor for {\"field\":\"value\"}\nstatic char *json_get_string_field(const char *json, const char *field) {\n    if (!json || !field)\n        return NULL;\n    char pat[128];\n    snprintf(pat, sizeof(pat), \"\\\"%s\\\"\", field);\n    const char *p = strstr(json, pat);\n    if (!p)\n        return NULL;\n    p += strlen(pat);\n    while (*p && isspace((unsigned char)*p))\n        p++;\n    if (*p != ':')\n        return NULL;\n    p++;\n    while (*p && isspace((unsigned char)*p))\n        p++;\n    if (*p != '\"')\n        return NULL;\n    p++;\n\n    size_t cap = 64, len = 0;\n    char *out = malloc(cap);\n    if (!out)\n        return NULL;\n\n    while (*p) {\n        if (*p == '\"') {\n            out[len] = '\\0';\n            return out;\n        }\n        unsigned char ch = (unsigned char)*p;\n        if (ch == '\\\\') {\n            p++;\n            if (!*p)\n                break;\n            switch (*p) {\n            case '\"': ch = '\"'; break;\n            case '\\\\': ch = '\\\\'; break;\n            case '/': ch = '/'; break;\n            case 'b': ch = '\\b'; break;\n            case 'f': ch = '\\f'; break;\n            case 'n': ch = '\\n'; break;\n            case 'r': ch = '\\r'; break;\n            case 't': ch = '\\t'; break;\n            default: ch = (unsigned char)*p; break;\n            }\n        }\n        if (len + 2 > cap) {\n            cap *= 2;\n            char *n = realloc(out, cap);\n            if (!n) {\n                free(out);\n                return NULL;\n            }\n            out = n;\n        }\n        out[len++] = (char)ch;\n        p++;\n    }\n    free(out);\n    return NULL;\n}\n\nstatic int parse_int_param(struct MHD_Connection *connection, const char *name, int defv) {\n    const char *v = MHD_lookup_connection_value(connection, MHD_GET_ARGUMENT_KIND, name);\n    if (!v || *v == '\\0')\n        return defv;\n    char *end = NULL;\n    long x = strtol(v, &end, 10);\n    if (!end || *end != '\\0')\n        return defv;\n    if (x < 0)\n        return defv;\n    if (x > 1000000000L)\n        x = 1000000000L;\n    return (int)x;\n}\n\nstatic int parse_id_from_url(const char *url, int *out_id) {\n    const char *prefix = \"/api/notes/\";\n    size_t n = strlen(prefix);\n    if (strncmp(url, prefix, n) != 0)\n        return 0;\n    const char *p = url + n;\n    if (*p == '\\0')\n        return 0;\n    char *end = NULL;\n    long id = strtol(p, &end, 10);\n    if (!end || *end != '\\0')\n        return 0;\n    if (id < 0 || id > 2147483647L)\n        return 0;\n    *out_id = (int)id;\n    return 1;\n}\n\nenum MHD_Result route_request(struct MHD_Connection *connection, const char *url,\n                              const char *method, const char *upload_data,\n                              size_t *upload_data_size, void **con_cls) {\n    if (*con_cls == NULL) {\n        struct connection_info *ci = calloc(1, sizeof(*ci));\n        if (!ci)\n            return MHD_NO;\n        *con_cls = ci;\n        return MHD_YES;\n    }\n\n    struct connection_info *ci = (struct connection_info *)(*con_cls);\n\n    if (ci->handled)\n        return MHD_YES;\n\n    // Upload handling for POST/PUT\n    if ((strcmp(method, \"POST\") == 0 || strcmp(method, \"PUT\") == 0) && *upload_data_size > 0) {\n        if (!ci->too_large) {\n            if (ci->data_size + *upload_data_size > NOTES_MA"]
[657.483068, "i", "X_BODY_BYTES) {\n                ci->too_large = 1;\n            } else {\n                char *n = realloc(ci->data, ci->data_size + *upload_data_size + 1);\n                if (!n)\n                    return MHD_NO;\n                ci->data = n;\n                memcpy(ci->data + ci->data_size, upload_data, *upload_data_size);\n                ci->data_size += *upload_data_size;\n                ci->data[ci->data_size] = '\\0';\n            }\n        }\n        *upload_data_size = 0;\n        return MHD_YES;\n    }\n\n    // End of request body; generate response once.\n    ci->handled = 1;\n\n    if (ci->too_large && (strcmp(method, \"POST\") == 0 || strcmp(method, \"PUT\") == 0))\n        return send_json(connection, \"{\\\"error\\\":\\\"payload too large\\\"}\", MHD_HTTP_PAYLOAD_TOO_LARGE);\n\n    if (strcmp(method, \"OPTIONS\") == 0)\n        return send_json(connection, \"\", MHD_HTTP_OK);\n\n    if (strcmp(url, \"/api/notes\") == 0 && strcmp(method, \"GET\") == 0) {\n        int limit = parse_int_param(connection, \"limit\", NOTES_DEFAULT_PAGE_SIZE);\n        int offset = parse_int_param(connection, \"offset\", 0);\n        if (limit > NOTES_MAX_PAGE_SIZE)\n            limit = NOTES_MAX_PAGE_SIZE;\n        int total = get_total_notes_count();\n        char *json = get_notes_paginated_json(limit, offset);\n        if (!json)\n            return send_json_with_total(connection, \"[]\", MHD_HTTP_OK, total);\n        enum MHD_Result r = send_json_with_total(connection, json, MHD_HTTP_OK, total);\n        free(json);\n        return r;\n    }\n\n    int id = 0;\n    if (parse_id_from_url(url, &id)) {\n        if (strcmp(method, \"GET\") == 0) {\n            char *json = get_note_json(id);\n            if (!json)\n                return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\n            enum MHD_Result r = send_json(connection, json, MHD_HTTP_OK);\n            free(json);\n            return r;\n        }\n\n        if (strcmp(method, \"PUT\") == 0) {\n            if (!api_key_valid(connection))\n                return send_json(connection, \"{\\\"error\\\":\\\"unauthorized\\\"}\", MHD_HTTP_UNAUTHORIZED);\n            if (!note_exists(id))\n                return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\n\n            const char *body = ci->data ? ci->data : \"\";\n            char *title = json_get_string_field(body, \"title\");\n            char *content = json_get_string_field(body, \"content\");\n            if (!title || is_blank_string(title)) {\n                free(title);\n                free(content);\n                return send_json(connection, \"{\\\"error\\\":\\\"invalid title\\\"}\", MHD_HTTP_BAD_REQUEST);\n            }\n            if (!content)\n                content = strdup(\"\");\n\n            int ok = update_note(id, title, content);\n            if (ok <= 0) {\n                free(title);\n                free(content);\n                return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\n            }\n\n            char *resp = build_note_json(id, title, content);\n            free(title);\n            free(content);\n            if (!resp)\n                return send_json(connection, \"{\\\"error\\\":\\\"server error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR);\n            enum MHD_Result r = send_json(connection, resp, MHD_HTTP_OK);\n            free(resp);\n            return r;\n        }\n\n        if (strcmp(method, \"DELETE\") == 0) {\n            if (!api_key_valid(connection))\n                return send_json(connection, \"{\\\"error\\\":\\\"unauthorized\\\"}\", MHD_HTTP_UNAUTHORIZED);\n            int ok = delete_note(id);\n            if (ok <= 0)\n                return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\n            return send_json(connection, \"{\\\"status\\\":\\\"deleted\\\"}\", MHD_HTTP_OK);\n        }\n    }\n\n    if (strcmp(url, \"/api/notes\") == 0 && strcmp(method, \"POST\") == 0) {\n        if (!api_key_valid(connection))\n            return send_json(connection, \"{\\\"error\\\":\\\"unauthorized\\\"}\", MHD_HTTP_UNAUTHORIZED);\n\n        const char *body = ci->data ? ci->data : \"\";\n        char *title = json_get_string_field(body, \"titl"]
[657.483096, "i", "e\");\n        char *content = json_get_string_field(body, \"content\");\n        if (!title || is_blank_string(title)) {\n            free(title);\n            free(content);\n            return send_json(connection, \"{\\\"error\\\":\\\"invalid title\\\"}\", MHD_HTTP_BAD_REQUEST);\n        }\n        if (!content)\n            content = strdup(\"\");\n\n        int new_id = create_note(title, content);\n        if (new_id <= 0) {\n            free(title);\n            free(content);\n            return send_json(connection, \"{\\\"error\\\":\\\"server error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR);\n        }\n\n        char *resp = build_note_json(new_id, title, content);\n        free(title);\n        free(content);\n        if (!resp)\n            return send_json(connection, \"{\\\"error\\\":\\\"server error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR);\n        enum MHD_Result r = send_json(connection, resp, MHD_HTTP_CREATED);\n        free(resp);\n        return r;\n    }\n\n    return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\n}\nEOF\n"]
