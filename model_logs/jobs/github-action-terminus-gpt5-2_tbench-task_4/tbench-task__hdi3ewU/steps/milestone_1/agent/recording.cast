[401.690146, "o", "int api_key_valid(struct MHD_Connection *connection) {\r\n\u001b[?2004l\r"]
[401.690225, "o", "\u001b[?2004h> "]
[401.690335, "o", "    const char *expected = get_expected_key();\r\n\u001b[?2004l\r"]
[401.69042, "o", "\u001b[?2004h> "]
