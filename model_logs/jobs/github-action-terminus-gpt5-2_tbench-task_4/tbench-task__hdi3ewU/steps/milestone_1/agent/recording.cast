[341.098954, "o", "\u001b[01m\u001b[Ksrc/routes.c:42:13:\u001b[m\u001b[K \u001b[01;35m\u001b[Kwarning: \u001b[m\u001b[K‘\u001b[01m\u001b[Krequest_completed\u001b[m\u001b[K’ defined but not used [\u001b[01;35m\u001b[K\u001b]8;;https://gcc.gnu.org/onlinedocs/gcc-14.2.0/gcc/Warning-Options.html#index-Wno-unused-function\u0007-Wunused-function\u001b]8;;\u0007\u001b[m\u001b[K]\r\n   42 | static void \u001b[01;35m\u001b[Krequest_completed\u001b[m\u001b[K(void *cls, struct MHD_Connection *connection,\r\n      |             \u001b[01;35m\u001b[K^~~~~~~~~~~~~~~~~\u001b[m\u001b[K\r\n"]
