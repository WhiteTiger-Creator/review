[48.227908, "i", "cat > Makefile <<'EOF'\nCC ?= gcc\nWARNFLAGS ?= -Wall -Wextra\nCFLAGS ?= -O2\nCPPFLAGS ?= -Iinclude\n\nSRC := $(wildcard src/*.c)\nOBJ := $(SRC:.c=.o)\n\nLDLIBS := -lmicrohttpd -lsqlite3\n\nTARGET := notes_server\n\nall: $(TARGET)\n\n$(TARGET): $(OBJ)\n\t$(CC) $(WARNFLAGS) $(CFLAGS) -o $@ $(OBJ) $(LDLIBS)\n\n%.o: %.c\n\t$(CC) $(WARNFLAGS) $(CFLAGS) $(CPPFLAGS) -c -o $@ $<\n\nclean:\n\trm -f $(TARGET) $(OBJ)\nEOF\n"]
