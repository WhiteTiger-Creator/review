[428.467677, "o", "root@27e807e19559:/app# "]
[428.591233, "i", "grep -n \"MHD_start_daemon\\|route_request\\|serve_static\\|NOTIFY_COMPLETED\\|request\" -n src/main.c\n"]
[428.591815, "o", "grep -n \"MHD_start_daemon\\|route_request\\|serve_static\\|NOTIFY_COMPLETED\\|request\" -n src/main.c\r\n\u001b[?2004l\r"]
[428.593425, "o", "85:static enum MHD_Result serve_static_file(struct MHD_Connection *connection,\r\n141:static void request_completed(void *cls, struct MHD_Connection *connection,\r\n152:static enum MHD_Result handle_request(void *cls,\r\n161:        return route_request(connection, url, method, upload_data,\r\n166:        enum MHD_Result ret = serve_static_file(connection, url);\r\n"]
[428.593896, "o", "188:    daemon_handle = MHD_start_daemon(\r\n192:        &handle_request, NULL,\r\n193:        MHD_OPTION_NOTIFY_COMPLETED, &request_completed, NULL,\r\n\u001b[?2004hroot@27e807e19559:/app# "]
[428.713246, "i", "cat > /tmp/main.c.new <<'EOF'\n#include <microhttpd.h>\n#include <stdio.h>\n#include <string.h>\n#include <stdlib.h>\n#include <signal.h>\n#include <sys/stat.h>\n#include <limits.h>\n#include <errno.h>\n#include <strings.h>\n#include \"routes.h\"\n#include \"db.h\"\n#include \"notes.h\"\n\n#define PORT NOTES_LISTEN_PORT\n#define WWW_DIR \"/app/www\"\n\nstatic struct MHD_Daemon *daemon_handle = NULL;\n\nstatic void handle_signal(int sig) {\n    (void)sig;\n    if (daemon_handle) MHD_stop_daemon(daemon_handle);\n    close_db();\n    exit(0);\n}\n\nstatic const char *get_content_type(const char *path) {\n    const char *ext = strrchr(path, '.');\n    if (!ext) return \"application/octet-stream\";\n    if (strcmp(ext, \".html\") == 0) return \"text/html\";\n    if (strcmp(ext, \".css\") == 0) return \"text/css\";\n    if (strcmp(ext, \".js\") == 0) return \"application/javascript\";\n    return \"application/octet-stream\";\n}\n\nstatic int hexval(int c){\n    if (c>='0' && c<='9') return c-'0';\n    if (c>='a' && c<='f') return 10 + (c-'a');\n    if (c>='A' && c<='F') return 10 + (c-'A');\n    return -1;\n}\n\nstatic int url_decode(const char *in, char *out, size_t outsz){\n    size_t oi=0;\n    for (size_t i=0; in[i]; i++){\n        unsigned char ch = (unsigned char)in[i];\n        if (ch=='%'){\n            int a = hexval((unsigned char)in[i+1]);\n            int b = hexval((unsigned char)in[i+2]);\n            if (a<0 || b<0) return -1;\n            ch = (unsigned char)((a<<4)|b);\n            i += 2;\n        }\n        if (ch==0) return -1;\n        if (oi+1>=outsz) return -1;\n        out[oi++] = (char)ch;\n    }\n    out[oi]=0;\n    return 0;\n}\n\nstatic int decoded_path_has_dotdot(const char *url){\n    char dec[4096];\n    if (url_decode(url, dec, sizeof(dec))!=0) return 0;\n    const char *p = dec;\n    while (*p){\n        while (*p=='/') p++;\n        if (!*p) break;\n        const char *seg=p;\n        while (*p && *p!='/') p++;\n        size_t len = (size_t)(p-seg);\n        if (len==2 && seg[0]=='.' && seg[1]=='.') return 1;\n    }\n    return 0;\n}\n\nstatic int url_contains_encoded_dotdot(const char *url) {\n    const char *p = url;\n    while (*p) {\n        if (strncasecmp(p, \"%2e%2e\", 6) == 0)\n            return 1;\n        p++;\n    }\n    return 0;\n}\n\nstatic enum MHD_Result serve_static_file(struct MHD_Connection *connection,\n                                        const char *url) {\n    if (strstr(url, \"..\") != NULL || url_contains_encoded_dotdot(url) || decoded_path_has_dotdot(url)) {\n        struct MHD_Response *r = MHD_create_response_from_buffer(\n            9, (void *)\"Forbidden\", MHD_RESPMEM_PERSISTENT);\n        enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_FORBIDDEN, r);\n        MHD_destroy_response(r);\n        return ret;\n    }\n\n    char path[PATH_MAX];\n    if (strcmp(url, \"/\") == 0)\n        url = \"/index.html\";\n\n    snprintf(path, sizeof(path), \"%s%s\", WWW_DIR, url);\n\n    struct stat st;\n    if (stat(path, &st) != 0 || !S_ISREG(st.st_mode)) {\n        struct MHD_Response *r = MHD_create_response_from_buffer(\n            9, (void *)\"Not Found\", MHD_RESPMEM_PERSISTENT);\n        enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_NOT_FOUND, r);\n        MHD_destroy_response(r);\n        return ret;\n    }\n\n    FILE *f = fopen(path, \"rb\");\n    if (!f) {\n        struct MHD_Response *r = MHD_create_response_from_buffer(\n            5, (void *)\"Error\", MHD_RESPMEM_PERSISTENT);\n        enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_INTERNAL_SERVER_ERROR, r);\n        MHD_destroy_response(r);\n        return ret;\n    }\n\n    char *data = malloc(st.st_size);\n    if (!data) {\n        fclose(f);\n        struct MHD_Response *r = MHD_create_response_from_buffer(\n            5, (void *)\"Error\", MHD_RESPMEM_PERSISTENT);\n        enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_INTERNAL_SERVER_ERROR, r);\n        MHD_destroy_response(r);\n        return ret;\n    }\n\n    size_t n = fread(data, 1, st.st_size, f);\n    fclose(f);\n    if (n != (size_t)st.st_size) {\n        free(data);\n        struct MHD_Response *r = MHD_create_response_from_buffer(\n            5, (void *)\""]
[428.713395, "i", "Error\", MHD_RESPMEM_PERSISTENT);\n        enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_INTERNAL_SERVER_ERROR, r);\n        MHD_destroy_response(r);\n        return ret;\n    }\n\n    struct MHD_Response *r = MHD_create_response_from_buffer(\n        n, (void *)data, MHD_RESPMEM_MUST_FREE);\n    MHD_add_response_header(r, \"Content-Type\", get_content_type(path));\n    enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_OK, r);\n    MHD_destroy_response(r);\n    return ret;\n}\n\nstatic void request_completed_cb(void *cls, struct MHD_Connection *connection,\n                                 void **con_cls, enum MHD_RequestTerminationCode toe) {\n    (void)cls;\n    (void)connection;\n    (void)toe;\n    if (!con_cls || !*con_cls)\n        return;\n    struct connection_info *ci = (struct connection_info *)(*con_cls);\n    free(ci->data);\n    free(ci);\n    *con_cls = NULL;\n}\n\nstatic enum MHD_Result access_handler(void *cls,\n                                     struct MHD_Connection *connection,\n                                     const char *url,\n                                     const char *method,\n                                     const char *version,\n                                     const char *upload_data,\n                                     size_t *upload_data_size,\n                                     void **con_cls) {\n    (void)cls;\n    (void)version;\n\n    if (strncmp(url, \"/api/\", 5) == 0) {\n        return route_request(connection, url, method, upload_data, upload_data_size, con_cls);\n    }\n    return serve_static_file(connection, url);\n}\n\nint main(void) {\n    signal(SIGINT, handle_signal);\n    signal(SIGTERM, handle_signal);\n\n    if (init_db(\"/app/data/notes.db\") != 0) {\n        fprintf(stderr, \"Failed to initialize database\\n\");\n        return 1;\n    }\n\n    daemon_handle = MHD_start_daemon(MHD_USE_INTERNAL_POLLING_THREAD,\n                                    PORT,\n                                    NULL, NULL,\n                                    &access_handler, NULL,\n                                    MHD_OPTION_NOTIFY_COMPLETED, request_completed_cb, NULL,\n                                    MHD_OPTION_END);\n\n    if (!daemon_handle) {\n        fprintf(stderr, \"Failed to start server: %s\\n\", strerror(errno));\n        return 1;\n    }\n\n    printf(\"Server running on port %d\\n\", PORT);\n    while (1) pause();\n    return 0;\n}\nEOF\nmv /tmp/main.c.new src/main.c\n"]
