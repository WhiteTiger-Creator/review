[465.944666, "o", "    sqlite3_stmt *stmt = NULL;\r\n\u001b[?2004l\r"]
[465.944705, "o", "\u001b[?2004h> "]
[465.94498, "o", "    const char *sql = \"UPDATE notes SET title = ?, content = ? WHERE id = ?;\";\r\n\u001b[?2004l\r"]
[465.945014, "o", "\u001b[?2004h> "]
[465.945253, "o", "    if (sqlite3_prepare_v2(db, sql, -1, &stmt, NULL) != SQLITE_OK) {\r\n\u001b[?2004l\r"]
[465.945289, "o", "\u001b[?2004h> "]
