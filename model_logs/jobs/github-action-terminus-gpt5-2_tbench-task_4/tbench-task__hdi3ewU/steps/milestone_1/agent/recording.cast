[256.03872, "o", "#include <microhttpd.h>\r\n#include <stdio.h>\r\n#include <string.h>\r\n#include <stdlib.h>\r\n#include <signal.h>\r\n#include <sys/stat.h>\r\n#include <limits.h>\r\n#include <errno.h>\r\n"]
[256.038752, "o", "#include <strings.h>\r\n#include \"routes.h\"\r\n#include \"db.h\"\r\n\r\n#define PORT 8080\r\n#define WWW_DIR \"/app/www\"\r\n\r\nstatic struct MHD_Daemon *daemon_handle = NULL;\r\n\r\nstatic void handle_signal(int sig) {\r\n    (void)sig;\r\n"]
[256.038772, "o", "    if (daemon_handle) MHD_stop_daemon(daemon_handle);\r\n    close_db();\r\n    exit(0);\r\n"]
[256.038796, "o", "}\r\n\r\nstatic const char *get_content_type(const char *path) {\r\n    const char *ext = strrchr(path, '.');\r\n"]
[256.038818, "o", "    if (!ext) return \"application/octet-stream\";\r\n    if (strcmp(ext, \".html\") == 0) return \"text/html\";\r\n    if (strcmp(ext, \".css\") == 0) return \"text/css\";\r\n"]
[256.03884, "o", "    if (strcmp(ext, \".js\") == 0) return \"application/javascript\";\r\n    return \"application/octet-stream\";\r\n}\r\n\r\n"]
[256.038858, "o", "static int hexval(int c){\r\n    if (c>='0' && c<='9') return c-'0';\r\n    if (c>='a' && c<='f') return 10 + (c-'a');\r\n"]
[256.038879, "o", "    if (c>='A' && c<='F') return 10 + (c-'A');\r\n    return -1;\r\n}\r\n\r\n"]
[256.038897, "o", "static int url_decode(const char *in, char *out, size_t outsz){\r\n    size_t oi=0;\r\n    for (size_t i=0; in[i]; i++){\r\n"]
[256.038919, "o", "        unsigned char ch = (unsigned char)in[i];\r\n        if (ch=='%'){\r\n            int a = hexval((unsigned char)in[i+1]);\r\n"]
[256.038938, "o", "            int b = hexval((unsigned char)in[i+2]);\r\n            if (a<0 || b<0) return -1;\r\n            ch = (unsigned char)((a<<4)|b);\r\n            i += 2;\r\n"]
[256.03896, "o", "        }\r\n        if (ch==0) return -1;\r\n        if (oi+1>=outsz) return -1;\r\n"]
[256.038981, "o", "        out[oi++] = (char)ch;\r\n    }\r\n    out[oi]=0;\r\n"]
[256.039359, "o", "    return 0;\r\n}\r\n\r\nstatic int decoded_path_has_dotdot(const char *url){\r\n    char dec[4096];\r\n    if (url_decode(url, dec, sizeof(dec))!=0) return 0;\r\n    const char *p = dec;\r\n    while (*p){\r\n        while (*p=='/') p++;\r\n        if (!*p) break;\r\n        const char *seg=p;\r\n        while (*p && *p!='/') p++;\r\n        size_t len = (size_t)(p-seg);\r\n        if (len==2 && seg[0]=='.' && seg[1]=='.') return 1;\r\n"]
[256.039477, "o", "    }\r\n    return 0;\r\n}\r\n\r\nstatic int url_contains_encoded_dotdot(const char *url) {\r\n    const char *p = url;\r\n    while (*p) {\r\n        if (strncasecmp(p, \"%2e%2e\", 6) == 0)\r\n"]
[256.039514, "o", "            return 1;\r\n        p++;\r\n    }\r\n    return 0;\r\n}\r\n\r\nstatic enum MHD_Result serve_static_file(struct MHD_Connection *connection,\r\n"]
[256.039623, "o", "    const char *url) {\r\n"]
[256.039794, "o", "    if (strstr(url, \"..\") != NULL || url_contains_encoded_dotdot(url) || decoded_path_has_dotdot(url)) {\r\n        struct MHD_Response *r = MHD_create_response_from_buffer(\r\n            9, (void *)\"Forbidden\", MHD_RESPMEM_PERSISTENT);\r\n        enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_FORBIDDEN, r);\r\n        MHD_destroy_response(r);\r\n"]
[256.039825, "o", "        return ret;\r\n    }\r\n\r\n"]
[256.040019, "o", "    char filepath[512];\r\n"]
[256.040107, "o", "    const char *path = strcmp(url, \"/\") == 0 ? \"/index.html\" : url;\r\n"]
[256.040209, "o", "    snprintf(filepath, sizeof(filepath), \"%s%s\", WWW_DIR, path);\r\n\r\n    struct stat st;\r\n    if (stat(filepath, &st) != 0) return MHD_NO;\r\n\r\n    // Robust containment check: resolve real paths and ensure we stay under WWW_DIR\r\n    char www_real[PATH_MAX];\r\n    char file_real[PATH_MAX];\r\n"]
[256.040293, "o", "    if (!realpath(WWW_DIR, www_real)) {\r\n        struct MHD_Response *r = MHD_create_response_from_buffer(\r\n            21, (void *)\"Internal Server Error\", MHD_RESPMEM_PERSISTENT);\r\n        enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_INTERNAL_SERVER_ERROR, r);\r\n        MHD_destroy_response(r);\r\n"]
[256.040362, "o", "        return ret;\r\n    }\r\n"]
[256.04052, "o", "    if (!realpath(filepath, file_real)) {\r\n        // should not happen after stat, but treat as not found\r\n        return MHD_NO;\r\n    }\r\n"]
[256.040544, "o", "    size_t rootlen = strlen(www_real);\r\n    if (!(strncmp(file_real, www_real, rootlen) == 0 &&\r\n          (file_real[rootlen] == '\\0' || file_real[rootlen] == '/'))) {\r\n"]
[256.040708, "o", "        struct MHD_Response *r = MHD_create_response_from_buffer(\r\n            9, (void *)\"Forbidden\", MHD_RESPMEM_PERSISTENT);\r\n        enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_FORBIDDEN, r);\r\n        MHD_destroy_response(r);\r\n"]
[256.040735, "o", "        return ret;\r\n    }\r\n\r\n"]
[256.040893, "o", "    FILE *f = fopen(filepath, \"rb\");\r\n    if (!f) return MHD_NO;\r\n\r\n    char *buf = malloc(st.st_size);\r\n    fread(buf, 1, st.st_size, f);\r\n"]
[256.040918, "o", "    fclose(f);\r\n\r\n    struct MHD_Response *response = MHD_create_response_from_buffer(\r\n"]
[256.04108, "o", "        st.st_size, buf, MHD_RESPMEM_MUST_FREE);\r\n"]
[256.041193, "o", "    MHD_add_response_header(response, \"Content-Type\", get_content_type(filepath));\r\n    enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_OK, response);\r\n    MHD_destroy_response(response);\r\n    return ret;\r\n}\r\n\r\n"]
[256.04127, "o", "static void request_completed(void *cls, struct MHD_Connection *connection,\r\n    void **con_cls, enum MHD_RequestTerminationCode toe) {\r\n"]
[256.041375, "o", "    (void)cls; (void)connection; (void)toe;\r\n    if (con_cls && *con_cls) {\r\n        struct connection_info *ci = *con_cls;\r\n        if (ci->data) free(ci->data);\r\n"]
[256.041415, "o", "        free(ci);\r\n        *con_cls = NULL;\r\n    }\r\n}\r\n"]
[256.041566, "o", "\r\nstatic enum MHD_Result handle_request(void *cls,\r\n    struct MHD_Connection *connection,\r\n    const char *url, const char *method,\r\n    const char *version,\r\n"]
[256.041607, "o", "    const char *upload_data, size_t *upload_data_size,\r\n    void **con_cls) {\r\n    (void)cls; (void)version;\r\n"]
[256.041835, "o", "\r\n    if (strncmp(url, \"/api/\", 5) == 0) {\r\n        return route_request(connection, url, method, upload_data,\r\n                             upload_data_size, con_cls);\r\n    }\r\n\r\n    if (strcmp(method, \"GET\") == 0) {\r\n        enum MHD_Result ret = serve_static_file(connection, url);\r\n        if (ret == MHD_YES) return ret;\r\n    }\r\n\r\n    struct MHD_Response *response = MHD_create_response_from_buffer(\r\n        9, (void *)\"Not Found\", MHD_RESPMEM_PERSISTENT);\r\n    enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_NOT_FOUND, response);\r\n    MHD_destroy_response(response);\r\n    return ret;\r\n}\r\n\r\nint main(void) {\r\n    signal(SIGINT, handle_signal);\r\n    signal(SIGTERM, handle_signal);\r\n\r\n    mkdir(\"/app/data\", 0755);\r\n\r\n    if (init_db(\"/app/data/notes.db\") != 0) {\r\n"]
[256.041968, "o", "        fprintf(stderr, \"Failed to initialize database\\n\");\r\n        return 1;\r\n    }\r\n\r\n    daemon_handle = MHD_start_daemon(\r\n        MHD_USE_THREAD_PER_CONNECTION,\r\n        PORT,\r\n        NULL, NULL,\r\n        &handle_request, NULL,\r\n        MHD_OPTION_NOTIFY_COMPLETED, &request_completed, NULL,\r\n        MHD_OPTION_END\r\n    );\r\n\r\n    if (!daemon_handle) {\r\n        fprintf(stderr, \"Failed to start server\\n\");\r\n        return 1;\r\n    }\r\n"]
[256.042212, "o", "--- src/main.o\r\n"]
[256.043141, "o", "ELF\u0002\u0001\u0001\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0001\u0000>\u0000\u0001\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000H\u0019\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000@\u0000\u0000\u0000\u0000\u0000@\u0000\u0010\u0000\u000f\u0000H��t;USH��H��\bH�*H��t\u001dH�}\u0000H��t\u0005�\u0000\u0000\u0000\u0000H���\u0000\u0000\u0000\u0000H�\u0003\u0000\u0000\u0000\u0000H��\b[]�f\u000f\u001fD\u0000\u0000�ff.\u000f\u001f�\u0000\u0000\u0000\u0000\u0000\u000f\u001f@\u0000H��\bH�=\u0000\u0000\u0000\u0000H��t\u0005�\u0000\u0000\u0000\u0000�\u0000\u0000\u0000\u00001��\u0000\u0000\u0000\u0000ff.\u000f\u001f�\u0000\u0000\u0000\u0000\u0000\u000f\u001f@\u0000AVAUATUH��SH��H�5\u0000\u0000\u0000\u0000H��H��\"\u0000\u0000�\u0000\u0000\u0000\u0000H��tG1�H�5\u0000\u0000\u0000\u0000�\t\u0000\u0000\u0000�\u0000\u0000\u0000\u0000��\u0001\u0000\u0000H��H��H���\u0000\u0000\u0000\u0000H�߉��\u0000\u0000\u0000\u0000H�Đ\"\u0000\u0000��[]A\\A]A^�\u000f\u001fD\u0000\u0000D\u000f�+E��\u000f�s\u0003\u0000\u0000I��L�5\u0000\u0000\u0000\u0000f\u000f\u001f�\u0000\u0000\u0000\u0000\u0000�\u0006\u0000\u0000\u0000L��L���\u0000\u0000\u0000\u0000��t�I��\u0001A�<$\u0000u�1�1�L��$�\u0012\u0000\u0000H��$�\u0012\u0000\u0000�,\u000f\u001f\u0000H��\u0001H��\u0000\u0010\u0000\u0000\u000f��\u0000\u0000\u0000H��\u0001�\u00147L��D\u000f�,\u000bE��\u000f�<\u0002\u0000\u0000D��A��%u�\u000f�D\u000b\u0001�PЃ�\tv\u0017�P���\u0005\u000f�\u0005\u0002\u0000\u0000�P���\u0005wI�P�H��\u0002\u000f�\u0004\u000bD�H�A��\tv(D�H�A��\u0005\u000f��\u0001\u0000\u0000D�H�A��\u0005w\u001c��\u0004��7\t��s���\u000f\u001f\u0000��\u0004D\b�\u000f�d����;/u\r�{\u0001\u0000u\u0007H�\u001d\u0000\u0000\u0000\u0000L��$�\u0000\u0000\u0000I��H�\u001d\u0000\u0000\u0000\u00001��\u0000\u0002\u0000\u0000L��H��H�\u0015\u0000\u0000\u0000\u0000�\u0000\u0000\u0000\u0000H��L���\u0000\u0000\u0000\u0000��\u000f�W\u0001\u0000\u0000L��$�\u0002\u0000\u0000H��L���\u0000\u0000\u0000\u0000H��\u000f�0\u0002\u0000\u0000L��$�\u0012\u0000\u0000L��L���\u0000\u0000\u0000\u0000H��\u000f�\u001f\u0001\u0000\u0000L���\u0000\u0000\u0000\u0000L��L��H��H���\u0000\u0000\u0000\u0000��\u000f�\u001c���\u000f��\u001c�\u0012\u0000\u0000��t\b</\u000f�\b���H�5\u0000\u0000\u0000\u0000L���\u0000\u0000\u0000\u0000H��H��\u000f��\u0000\u0000\u0000L�t$0L���\u0000\u0000\u0000\u0000H��L��\u0001\u0000\u0000\u0000H��I���\u0000\u0000\u0000\u0000H���\u0000\u0000\u0000\u0000H�|$0�\u0001\u0000\u0000\u0000L���\u0000\u0000\u0000\u0000L��.\u0000\u0000\u0000H���\u0000\u0000\u0000\u0000H�\u0015\u0000\u0000\u0000\u0000I��H��tWH�5\u0000\u0000\u0000\u0000H���\u0000\u0000\u0000\u0000H�\u0015\u0000\u0000\u0000\u0000��t=H�5\u0000\u0000\u0000\u0000L���\u0000\u0000\u0000\u0000H�\u0015\u0000\u0000\u0000\u0000��t#H�5\u0000\u0000\u0000\u0000L���\u0000\u0000\u0000\u0000H�\u0015\u0000\u0000\u0000\u0000��H�\u0005\u0000\u0000\u0000\u0000H\u000fE�H�5\u0000\u0000\u0000\u0000H���\u0000\u0000\u0000\u0000H�ھ�\u0000\u0000\u0000�<���1��G���f\u000f\u001fD\u0000\u0000�P��������\u0004��W\t�����L\u0001��\u0006\u0000\u000f��$�\u0012\u0000\u0000@��\u000f� ���H��@��/u*\u000f\u001f\u0000H��ff.\u000f\u001f�\u0000\u0000\u0000\u0000\u0000f�\u000f�p\u0001H��\u0001@��/t�@��\u000f�����\u000f�\b��tbH��/tZff.\u000f\u001f�\u0000\u0000\u0000\u0000\u0000ff.\u000f\u001f�\u0000\u0000\u0000\u0000\u0000\u000f\u001f@\u0000\u000f�J\u0001H��\u0001��t\u0005��/u�H��H)�H��\u0002u\u0006@��.t\r��u�����\u000f\u001f@\u0000�x\u0001.u��N���\u000f\u001fD\u0000\u0000H��\u000f�e����t���H��$�\u0012\u0000\u0000H���0���1�H�5\u0000\u0000\u0000\u0000�\u0015\u0000\u0000\u0000�\u0000\u0000\u0000\u0000��\u0001\u0000\u0000H��H���$���ff.\u000f\u001f�\u0000\u0000\u0000\u0000\u0000f�AWAVAUM��ATI��UH��H�5\u0000\u0000\u0000\u0000SH�Ӻ\u0005\u0000\u0000\u0000H��H��\bL�t$@L�|$H�\u0000\u0000\u0000\u0000��tlH�5\u0000\u0000\u0000\u0000L���\u0000\u0000\u0000\u0000��tA1�H�5\u0000\u0000\u0000\u0000�\t\u0000\u0000\u0000�\