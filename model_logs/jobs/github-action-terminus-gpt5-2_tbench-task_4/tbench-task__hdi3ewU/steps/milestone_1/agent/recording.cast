[256.045054, "o", "                            \"Content-Type, X-API-Key\");\r\n    char count_str[32];\r\n    snprintf(count_str, sizeof(count_str), \"%d\", total);\r\n    MHD_add_response_header(response, \"X-Total-Count\", count_str);\r\n"]
[256.045072, "o", "    enum MHD_Result ret = MHD_queue_response(connection, status_code, response);\r\n    MHD_destroy_response(response);\r\n    return ret;\r\n}\r\n"]
[256.045097, "o", "\r\nstatic void request_completed(void *cls, struct MHD_Connection *connection,\r\n                              void **con_cls, enum MHD_RequestTerminationCode toe) {\r\n    (void)cls;\r\n"]
[256.045115, "o", "    (void)connection;\r\n    (void)toe;\r\n    if (con_cls && *con_cls) {\r\n        struct connection_info *ci = *con_cls;\r\n"]
[256.045135, "o", "        if (ci->data)\r\n            free(ci->data);\r\n        free(ci);\r\n        *con_cls = NULL;\r\n"]
[256.045153, "o", "    }\r\n}\r\n\r\n"]
[256.045174, "o", "enum MHD_Result route_request(struct MHD_Connection *connection, const char *url,\r\n                              const char *method, const char *upload_data,\r\n                              size_t *upload_data_size, void **con_cls) {\r\n    (void)upload_data;\r\n"]
[256.045196, "o", "    (void)upload_data_size;\r\n    (void)con_cls;\r\n\r\n    if (strcmp(method, \"OPTIONS\") == 0)\r\n"]
[256.045215, "o", "        return send_json(connection, \"\", MHD_HTTP_OK);\r\n\r\n    if (strcmp(url, \"/api/notes\") == 0 && strcmp(method, \"GET\") == 0) {\r\n        int total = get_total_notes_count();\r\n"]
[256.045236, "o", "        char *json = get_notes_paginated_json(50, 0);\r\n        if (!json)\r\n            return send_json_total(connection, \"[]\", MHD_HTTP_OK, total);\r\n"]
[256.04526, "o", "        enum MHD_Result r = send_json_total(connection, json, MHD_HTTP_OK, total);\r\n        free(json);\r\n        return r;\r\n    }\r\n\r\n"]
[256.045281, "o", "    return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\r\n}\r\n"]
[256.046192, "o", "--- src/routes.h\r\n"]
[256.046714, "o", "#ifndef ROUTES_H\r\n#define ROUTES_H\r\n\r\n#include <microhttpd.h>\r\n\r\n"]
[256.046748, "o", "struct connection_info {\r\n    char *data;\r\n    size_t data_size;\r\n};\r\n\r\nenum MHD_Result route_request(struct MHD_Connection *connection,\r\n    const char *url, const char *method,\r\n    const char *upload_data, size_t *upload_data_size,\r\n    void **con_cls);\r\n"]
[256.046772, "o", "\r\n#endif\r\n"]
