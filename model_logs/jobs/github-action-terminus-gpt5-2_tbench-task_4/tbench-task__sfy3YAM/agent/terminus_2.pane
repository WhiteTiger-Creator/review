extern "C" const char *c9_resolve_mode(const char *manifest_mode, const char *unit_name,
                                         int pass_epoch) {
    static thread_local char mode_buf[16];
    (void)pass_epoch;
    if (manifest_mode == NULL) {
        mode_buf[0] = '\0';
        return mode_buf;
