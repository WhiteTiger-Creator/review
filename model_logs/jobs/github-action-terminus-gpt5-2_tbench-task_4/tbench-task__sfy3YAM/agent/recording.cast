[95.82856, "o", "\u001b[?2004h"]
[95.828574, "o", "> "]
[95.828924, "o", "    out << \"{\\\"schema_version\\\":\" << forge::kSchemaVersion << \",\\\"lane_token\\\":\\\"\" << lane_token\r\n\u001b[?2004l\r"]
[95.828957, "o", "\u001b[?2004h"]
