[43.029526, "o", "> "]
[43.029843, "o", "+    std::map<std::string, forge::UnitCheckpoint> merged;\r\n\u001b[?2004l\r"]
[43.029934, "o", "\u001b[?2004h"]
[43.030005, "o", "> "]
[43.030163, "o", "+    if (existing.valid) {"]
[43.030229, "o", "\r\n\u001b[?2004l\r"]
[43.030297, "o", "\u001b[?2004h"]
[43.030314, "o", "> "]
[43.030433, "o", "+        merged = existing.units;\r\n\u001b[?2004l\r"]
[43.030473, "o", "\u001b[?2004h"]
[43.030523, "o", "> "]
[43.030566, "o", "+    }"]
[43.03062, "o", "\r\n"]
[43.030668, "o", "\u001b[?2004l\r"]
[43.030756, "o", "\u001b[?2004h"]
[43.030783, "o", "> "]
[43.031118, "o", "+    // Only update the resume units that were actually emitted during this\r\n\u001b[?2004l\r"]
[43.03123, "o", "\u001b[?2004h"]
[43.031251, "o", "> +    // invocation.\r\n\u001b[?2004l\r"]
[43.031332, "o", "\u001b[?2004h"]
[43.031398, "o", "> "]
[43.031456, "o", "+    for (const auto &entry : updated) {\r\n\u001b[?2004l\r"]
[43.031529, "o", "\u001b[?2004h> "]
[43.031628, "o", "+        if (!entry.name.empty()) {\r\n\u001b[?2004l\r"]
[43.031675, "o", "\u001b[?2004h> "]
[43.031815, "o", "+            merged[entry.name] = entry;\r\n\u001b[?2004l\r"]
[43.031834, "o", "\u001b[?2004h"]
[43.031896, "o", "> "]
[43.031931, "o", "+        }\r\n\u001b[?2004l\r"]
[43.03195, "o", "\u001b[?2004h> "]
[43.031994, "o", "+    }\r\n\u001b[?2004l\r"]
[43.032012, "o", "\u001b[?2004h"]
[43.032048, "o", "> "]
[43.032283, "o", "+    // If the caller provides an explicit requested resume list, we should not\r\n\u001b[?2004l\r"]
[43.032355, "o", "\u001b[?2004h> "]
[43.032554, "o", "+    // drop non-requested entries (continuity across chained invocations).\r\n\u001b[?2004l\r"]
[43.032628, "o", "\u001b[?2004h"]
[43.03269, "o", "> "]
[43.032748, "o", "+    (void)requested_resume;\r\n"]
[43.032794, "o", "\u001b[?2004l\r"]
[43.032818, "o", "\u001b[?2004h"]
[43.03284, "o", "> "]
[43.032907, "o", "+\r\n\u001b[?2004l\r\u001b[?2004h> "]
[43.033057, "o", "+    std::vector<forge::UnitCheckpoint> out;\r\n\u001b[?2004l\r"]
[43.033108, "o", "\u001b[?2004h"]
[43.033296, "o", "> "]
[43.033412, "o", "+    out.reserve(merged.size());\r\n\u001b[?2004l\r"]
[43.033509, "o", "\u001b[?2004h> "]
[43.033598, "o", "+    for (const auto &kv : merged) {\r\n\u001b[?2004l\r"]
[43.03364, "o", "\u001b[?2004h"]
[43.033654, "o", "> "]
[43.033788, "o", "+        out.push_back(kv.second);\r\n\u001b[?2004l\r"]
[43.033835, "o", "\u001b[?2004h"]
[43.033878, "o", "> "]
[43.033892, "o", "+    }\r\n\u001b[?2004l\r"]
[43.033902, "o", "\u001b[?2004h"]
[43.033953, "o", "> "]
[43.034072, "o", "     std::sort(out.begin(), out.end(),\r\n\u001b[?2004l\r"]
[43.034104, "o", "\u001b[?2004h"]
[43.034121, "o", "> "]
[43.034394, "o", "               [](const forge::UnitCheckpoint &a, const forge::UnitCheckpoint &b) {\r\n\u001b[?2004l\r"]
[43.034437, "o", "\u001b[?2004h"]
[43.034455, "o", "> "]
[43.034604, "o", "                   return a.name < b.name;\r\n\u001b[?2004l\r"]
[43.034647, "o", "\u001b[?2004h"]
[43.034694, "o", "> "]
[43.03473, "o", "               });\r\n\u001b[?2004l\r"]
[43.034769, "o", "\u001b[?2004h"]
[43.034813, "o", "> "]
[43.034856, "o", "     return out;\r\n\u001b[?2004l\r"]
[43.034947, "o", "\u001b[?2004h> "]
[43.03501, "o", " }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[43.035089, "o", " \r\n\u001b[?2004l\r\u001b[?2004h"]
[43.035111, "o", "> "]
[43.035342, "o", "-void m14_write_checkpoint(const std::filesystem::path &path, const char *lane_token,\r\n\u001b[?2004l\r"]
[43.035386, "o", "\u001b[?2004h"]
[43.035434, "o", "> "]
[43.035674, "o", "-                                     const std::vector<forge::UnitCheckpoint> &entries) {\r\n\u001b[?2004l\r"]
[43.035718, "o", "\u001b[?2004h> "]
[43.036058, "o", "+void m14_write_checkpoint(const std::filesystem::path &path, const char *lane_token, int pass_epoch,\r\n\u001b[?2004l\r"]
[43.036142, "o", "\u001b[?2004h> "]
[43.036374, "o", "+                                     const std::vector<forge::UnitCheckpoint> &entries) {\r\n\u001b[?2004l\r"]
[43.03646, "o", "\u001b[?2004h> "]
[43.036629, "o", "     std::filesystem::create_directories(path.parent_path());\r\n\u001b[?2004l\r"]
[43.03665, "o", "\u001b[?2004h"]
[43.036664, "o", "> "]
[43.036775, "o", "     std::ostringstream out;\r\n\u001b[?2004l\r"]
[43.036832, "o", "\u001b[?2004h> "]
[43.037126, "o", "     out << \"{\\\"schema_version\\\":\" << forge::kSchemaVersion << \",\\\"lane_token\\\":\\\"\" << lane_token\r\n\u001b[?2004l\r"]
[43.037148, "o", "\u001b[?2004h"]
[43.037163, "o", "> "]
[43.037295, "o", "-        << \"\\\",\\\"units\\\":[\";\r\n\u001b[?2004l\r"]
[43.037355, "o", "\u001b[?2004h> "]
[43.03755, "o", "+        << \"\\\",\\\"pass_epoch\\\":\" << pass_epoch << \",\\\"units\\\":[\";\r\n\u001b[?2004l\r"]
[43.037573, "o", "\u001b[?2004h"]
[43.037586, "o", "> "]
[43.037598, "o", "@@\r\n"]
[43.037611, "o", "\u001b[?2004l\r"]
[43.037737, "o", "\u001b[?2004h> "]
[43.037793, "o", "     out << \"]}\\n\";\r\n\u001b[?2004l\r\u001b[?2004h"]
[43.037863, "o", "> "]
[43.037969, "o", "     std::ofstream file(path, std::ios::binary);\r\n\u001b[?2004l\r"]
[43.037991, "o", "\u001b[?2004h"]
[43.038073, "o", "> "]
[43.038182, "o", "     file << out.str();\r\n\u001b[?2004l\r\u001b[?2004h"]
[43.038201, "o", ">  }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[43.038256, "o", "*** End Patch\r\n"]
[43.038275, "o", "\u001b[?2004l\r"]
[43.038321, "o", "\u001b[?2004h"]
[43.038379, "o", "> "]
