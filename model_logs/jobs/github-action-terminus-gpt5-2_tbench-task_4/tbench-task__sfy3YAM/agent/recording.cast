[95.817566, "o", "\u001b[?2004h"]
[95.817603, "o", "> "]
[95.817882, "o", "    if (!m14_checkpoint_valid(state.lane_token.c_str(), expected_token.c_str())) {\r\n\u001b[?2004l\r"]
[95.817944, "o", "\u001b[?2004h"]
[95.817959, "o", "> "]
