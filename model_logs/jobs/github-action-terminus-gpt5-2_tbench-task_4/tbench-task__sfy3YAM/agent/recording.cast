[95.813827, "o", "extern \"C\" int m14_checkpoint_valid(const char *on_disk_token, const char *expected_token) {\r\n\u001b[?2004l\r"]
[95.813874, "o", "\u001b[?2004h> "]
[95.81413, "o", "    if (on_disk_token == nullptr || expected_token == nullptr) {\r\n\u001b[?2004l\r"]
[95.814177, "o", "\u001b[?2004h> "]
[95.814251, "o", "        return 0;\r\n\u001b[?2004l\r"]
[95.814328, "o", "\u001b[?2004h"]
[95.814396, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[95.814677, "o", "    return std::string(on_disk_token) == std::string(expected_token) ? 1 : 0;\r\n\u001b[?2004l\r"]
[95.814741, "o", "\u001b[?2004h"]
