[23.534729, "o", "#include \"emit_pipeline.h\"\r\n#include <iostream>\r\n\r\nint main(int argc, char **argv) {\r\n    try {\r\n        return forge_run_emit(argc, argv);\r\n    } catch (const std::exception &e) {\r\n        std::cerr << \"forge_emit: \" << e.what() << '\\n';\r\n        return 1;\r\n    }\r\n}\r\n\u001b[?2004hroot@c5c0f1c2990a:/app# "]
