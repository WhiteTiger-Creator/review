[95.779129, "i", " }\n    }\n    state.valid = true;\n    return state;\n}\n\nstd::vector<forge::UnitCheckpoint> m14_merge_entries(\n    const forge::LaneCheckpoint &existing, const std::vector<forge::UnitCheckpoint> &updated,\n    const std::vector<std::string> &requested_resume) {\n    (void)requested_resume;\n\n    std::map<std::string, forge::UnitCheckpoint> merged;\n    if (existing.valid) {\n        merged = existing.units;\n    }\n    for (const auto &entry : updated) {\n        if (!entry.name.empty()) {\n            merged[entry.name] = entry;\n        }\n    }\n\n    std::vector<forge::UnitCheckpoint> out;\n    out.reserve(merged.size());\n    for (const auto &kv : merged) {\n        out.push_back(kv.second);\n    }\n    std::sort(out.begin(), out.end(),\n              [](const forge::UnitCheckpoint &a, const forge::UnitCheckpoint &b) {\n                  return a.name < b.name;\n              });\n    return out;\n}\n\nvoid m14_write_checkpoint(const std::filesystem::path &path, const char *lane_token, int pass_epoch,\n                          cons"]
