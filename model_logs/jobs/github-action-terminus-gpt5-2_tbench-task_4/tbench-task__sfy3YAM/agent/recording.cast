[95.819721, "o", "\u001b[?2004h"]
[95.819735, "o", "> "]
[95.820007, "o", "    if (arr_start == std::string::npos || arr_end == std::string::npos) {\r\n\u001b[?2004l\r"]
[95.820028, "o", "\u001b[?2004h> "]
