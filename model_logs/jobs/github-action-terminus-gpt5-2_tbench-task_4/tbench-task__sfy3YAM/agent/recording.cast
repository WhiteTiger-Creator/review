[95.829361, "o", "\u001b[?2004h"]
[95.829397, "o", "> "]
[95.829648, "o", "    for (size_t i = 0; i < entries.size(); ++i) {\r\n\u001b[?2004l\r"]
[95.829667, "o", "\u001b[?2004h"]
[95.829897, "o", ">         if (i) {"]
[95.833301, "o", "\r\n\u001b[?2004l\r"]
[95.833384, "o", "\u001b[?2004h> "]
[95.833462, "o", "            out << ',';\r\n\u001b[?2004l\r"]
[95.833553, "o", "\u001b[?2004h> "]
[95.83358, "o", "        }\r\n\u001b[?2004l\r"]
