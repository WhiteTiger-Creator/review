[95.834241, "o", "\u001b[?2004h"]
[95.834369, "o", "> "]
[95.834561, "o", "            << \",\\\"carry_weight\\\":\" << entry.carry_weight << \",\\\"carry_drift\\\":\"\r\n\u001b[?2004l\r"]
[95.834591, "o", "\u001b[?2004h"]
[95.834603, "o", "> "]
