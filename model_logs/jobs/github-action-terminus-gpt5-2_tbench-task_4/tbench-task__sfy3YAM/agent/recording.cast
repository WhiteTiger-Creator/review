[95.822074, "o", "\u001b[?2004h> "]
[95.82221, "o", "        if (!entry.name.empty()) {\r\n\u001b[?2004l\r"]
[95.822246, "o", "\u001b[?2004h> "]
[95.822421, "o", "            state.units[entry.name] = entry;\r\n\u001b[?2004l\r"]
[95.822514, "o", "\u001b[?2004h> "]
[95.822535, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[95.822592, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[95.822612, "o", "> "]
[95.822712, "o", "    state.valid = true;\r\n\u001b[?2004l\r"]
[95.822791, "o", "\u001b[?2004h> "]
[95.822882, "o", "    return state;\r\n\u001b[?2004l\r"]
[95.822907, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h"]
