[109.237619, "o", "\u001b[?2004l\r"]
[109.278901, "o", "#include \"m14_api.h\"\r\n#include \"constants.h\"\r\n#include \"store_bridge.h\"\r\n#include \"types.h\"\r\n\r\n#include <algorithm>\r\n#include <cctype>\r\n#include <cstdint>\r\n"]
[109.278943, "o", "#include <filesystem>\r\n#include <fstream>\r\n#include <map>\r\n#include <numeric>\r\n#include <sstream>\r\n#include <stdexcept>\r\n#include <string>\r\n#include <vector>\r\n\r\nnamespace forge {\r\n\r\nnamespace {\r\n\r\n"]
[109.278954, "o", "std::string pick_string(const std::string &block, const std::string &key) {\r\n    std::string needle = \"\\\"\" + key + \"\\\"\";\r\n    size_t k = block.find(needle);\r\n    if (k == std::string::npos) {\r\n        return \"\";\r\n"]
[109.278969, "o", "    }\r\n    size_t q = block.find('\"', block.find(':', k) + 1);\r\n    size_t e = block.find('\"', q + 1);\r\n    if (q == std::string::npos || e == std::string::npos) {\r\n        return \"\";\r\n"]
[109.278979, "o", "    }\r\n    return block.substr(q + 1, e - q - 1);\r\n}\r\n"]
[109.278987, "o", "\r\nint pick_int(const std::string &block, const std::string &key) {\r\n    std::string needle = \"\\\"\" + key + \"\\\"\";\r\n"]
[109.278996, "o", "    size_t k = block.find(needle);\r\n    if (k == std::string::npos) {\r\n        return 0;\r\n"]
[109.279004, "o", "    }\r\n    size_t colon = block.find(':', k);\r\n    if (colon == std::string::npos) {\r\n"]
[109.279012, "o", "        return 0;\r\n    }\r\n    size_t start = colon + 1;\r\n"]
[109.279022, "o", "    while (start < block.size() && std::isspace(static_cast<unsigned char>(block[start]))) {\r\n        ++start;\r\n    }\r\n"]
[109.279031, "o", "    return std::stoi(block.substr(start));\r\n}\r\n\r\n"]
[109.279039, "o", "int64_t pick_int64(const std::string &block, const std::string &key) {\r\n    std::string needle = \"\\\"\" + key + \"\\\"\";\r\n    size_t k = block.find(needle);\r\n"]
[109.279047, "o", "    if (k == std::string::npos) {\r\n        return 0;\r\n    }\r\n"]
[109.279062, "o", "    size_t colon = block.find(':', k);\r\n    if (colon == std::string::npos) {\r\n        return 0;\r\n    }\r\n    size_t start = colon + 1;\r\n    while (start < block.size() && std::isspace(static_cast<unsigned char>(block[start]))) {\r\n"]
[109.279254, "o", "        ++start;\r\n    }\r\n    return std::stoll(block.substr(start));\r\n}\r\n\r\nstd::vector<std::string> split_object_blocks(const std::string &array_text) {\r\n    std::vector<std::string> out;\r\n    int depth = 0;\r\n    size_t start = std::string::npos;\r\n    for (size_t i = 0; i < array_text.size(); ++i) {\r\n        if (array_text[i] == '{') {\r\n            if (depth == 0) {\r\n                start = i;\r\n            }\r\n            ++depth;\r\n        } else if (array_text[i] == '}') {\r\n            --depth;\r\n            if (depth == 0 && start != std::string::npos) {\r\n                out.push_back(array_text.substr(start, i - start + 1));\r\n                start = std::string::npos;\r\n            }\r\n        }\r\n    }\r\n    return out;\r\n}\r\n\r\n} // namespace\r\n\r\n} // namespace forge\r\n\r\nextern \"C\" const char *m14_lane_token(const forge::UnitSpec *units, size_t count) {\r\n    static thread_local std::string cached;\r\n    std::vector<forge::UnitSpec> sorted;\r\n    sorted.reserve(count);\r\n    for (size_t i = 0; i < count; ++i) {\r\n      "]
[109.279275, "o", "  sorted.push_back(units[i]);\r\n    }\r\n    std::sort(sorted.begin(), sorted.end(), [](const forge::UnitSpec &a, const forge::UnitSpec &b) {\r\n        return a.name < b.name;\r\n    });\r\n\r\n    std::ostringstream joined;\r\n    for (size_t i = 0; i < sorted.size(); ++i) {\r\n        if (i) {\r\n            joined << '\\n';\r\n        }\r\n        joined << sorted[i].name << '|' << sorted[i].mode << '|' << sorted[i].record_path << '|'\r\n               << sorted[i].manifest_bytes << '|' << sorted[i].start_pass;\r\n    }\r\n\r\n    cached = forge::digest_hex(joined.str());\r\n    return cached.c_str();\r\n}\r\n\r\nextern \"C\" int m14_checkpoint_valid(const char *on_disk_token, const char *expected_token) {\r\n    if (on_disk_token == nullptr || expected_token == nullptr) {\r\n        return 0;\r\n    }\r\n    return std::string(on_disk_token) == std::string(expected_token) ? 1 : 0;\r\n}\r\n\r\nforge::LaneCheckpoint m14_read_checkpoint(const std::filesystem::path &path,\r\n                                         const std::string &expected_token) {\r\n"]
[109.279287, "o", "    forge::LaneCheckpoint state;\r\n"]
[109.2793, "o", "    std::ifstream in(path);\r\n"]
[109.279309, "o", "    if (!in) {\r\n        return state;\r\n"]
[109.279322, "o", "    }\r\n"]
[109.27933, "o", "    std::ostringstream buffer;\r\n    buffer << in.rdbuf();\r\n"]
[109.27934, "o", "    const std::string doc = buffer.str();\r\n"]
[109.279352, "o", "    if (doc.find(\"\\\"schema_version\\\"\") == std::string::npos) {\r\n"]
[109.279361, "o", "        return state;\r\n    }\r\n"]
[109.279372, "o", "    state.lane_token = forge::pick_string(doc, \"lane_token\");\r\n"]
[109.279381, "o", "    if (!m14_checkpoint_valid(state.lane_token.c_str(), expected_token.c_str())) {\r\n"]
[109.279391, "o", "        return state;\r\n"]
[109.279402, "o", "    }\r\n"]
[109.27941, "o", "    state.pass_epoch = forge::pick_int(doc, \"pass_epoch\");\r\n\r\n"]
[109.279419, "o", "    size_t units_pos = doc.find(\"\\\"units\\\"\");\r\n"]
[109.279431, "o", "    if (units_pos == std::string::npos) {\r\n"]
[109.279439, "o", "        state.valid = true;\r\n        return state;\r\n"]
[109.27945, "o", "    }\r\n"]
[109.279462, "o", "    size_t arr_start = doc.find('[', units_pos);\r\n"]
[109.279471, "o", "    size_t arr_end = doc.find(']', arr_start);\r\n    if (arr_start == std::string::npos || arr_end == std::string::npos) {\r\n"]
[109.279483, "o", "        return state;\r\n    }\r\n"]
[109.279494, "o", "    const std::string arr = doc.substr(arr_start, arr_end - arr_start + 1);\r\n"]
[109.279506, "o", "    for (const auto &block : forge::split_object_blocks(arr)) {\r\n"]
[109.279515, "o", "        forge::UnitCheckpoint entry;\r\n        entry.name = forge::pick_string(block, \"name\");\r\n"]
[109.279526, "o", "        entry.next_pass = forge::pick_int(block, \"next_pass\");\r\n"]
[109.279538, "o", "        entry.carry_weight = forge::pick_int64(block, \"carry_weight\");\r\n"]
[109.279547, "o", "        entry.carry_drift = forge::pick_int64(block, \"carry_drift\");\r\n        if (!entry.name.empty()) {\r\n"]
[109.27956, "o", "            state.units[entry.name] = entry;\r\n"]
[109.279573, "o", "        }\r\n    }\r\n"]
[109.279588, "o", "    state.valid = true;\r\n    return state;\r\n"]
[109.279602, "o", "}\r\n\r\nstd::vector<forge::UnitCheckpoint> m14_merge_entries(\r\n"]
[109.279611, "o", "    const forge::LaneCheckpoint &existing, const std::vector<forge::UnitCheckpoint> &updated,\r\n"]
[109.279619, "o", "    const std::vector<std::string> &requested_resume) {\r\n    (void)requested_resume;\r\n\r\n"]
[109.279627, "o", "    std::map<std::string, forge::UnitCheckpoint> merged;\r\n    if (existing.valid) {\r\n"]
[109.279638, "o", "        merged = existing.units;\r\n    }\r\n"]
[109.279649, "o", "    for (const auto &entry : updated) {\r\n        if (!entry.name.empty()) {\r\n            merged[entry.name] = entry;\r\n"]
[109.279659, "o", "        }\r\n    }\r\n\r\n    std::vector<forge::UnitCheckpoint> out;\r\n    out.reserve(merged.size());\r\n"]
[109.279671, "o", "    for (const auto &kv : merged) {\r\n        out.push_back(kv.second);\r\n"]
[109.279682, "o", "    }\r\n    std::sort(out.begin(), out.end(),\r\n              [](const forge::UnitCheckpoint &a, const forge::UnitCheckpoint &b) {\r\n                  return a.name < b.name;\r\n              });\r\n"]
[109.279693, "o", "    return out;\r\n}\r\n"]
[109.279702, "o", "\r\nvoid m14_write_checkpoint(const std::filesystem::path &path, const char *lane_token, int pass_epoch,\r\n                          const std::vector<forge::UnitCheckpoint> &entries) {\r\n"]
[109.279715, "o", "    std::filesystem::create_directories(path.parent_path());\r\n    std::ostringstream out;\r\n    out << \"{\\\"schema_version\\\":\" << forge::kSchemaVersion << \",\\\"lane_token\\\":\\\"\" << lane_token\r\n"]
[109.279728, "o", "        << \"\\\",\\\"pass_epoch\\\":\" << pass_epoch << \",\\\"units\\\":[\";\r\n    for (size_t i = 0; i < entries.size(); ++i) {\r\n        if (i) {\r\n            out << ',';\r\n"]
[109.279737, "o", "        }\r\n        const auto &entry = entries[i];\r\n"]
[109.279748, "o", "        out << \"{\\\"name\\\":\\\"\" << entry.name << \"\\\",\\\"next_pass\\\":\" << entry.next_pass\r\n"]
[109.279756, "o", "            << \",\\\"carry_weight\\\":\" << entry.carry_weight << \",\\\"carry_drift\\\":\"\r\n            << entry.carry_drift << '}';\r\n"]
[109.279768, "o", "    }\r\n    out << \"]}\\n\";\r\n    std::ofstream file(path, std::ios::binary);\r\n    file << out.str();\r\n}\r\n"]
