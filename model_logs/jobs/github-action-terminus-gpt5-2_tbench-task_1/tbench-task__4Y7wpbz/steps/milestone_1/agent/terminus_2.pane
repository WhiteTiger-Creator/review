    42	static enum MHD_Result send_json_with_headers(struct MHD_Connection *connection,
    43	                                             const char *body,
    44	                                             unsigned int status_code,
    45	                                             const char *extra_header_name,
    46	                                             const char *extra_header_value) {
    47	    struct MHD_Response *response = MHD_create_response_from_buffer(
    48	        strlen(body), (void *)body, MHD_RESPMEM_MUST_COPY);
    49	
    50	    MHD_add_response_header(response, "Content-Type", "application/json");
    51	    MHD_add_response_header(response, "Access-Control-Allow-Origin", "*");
    52	    MHD_add_response_header(response, "Access-Control-Allow-Methods",
    53	                            "GET, POST, PUT, DELETE, OPTIONS");
    54	    MHD_add_response_header(response, "Access-Control-Allow-Headers",
    55	                            "Content-Type, X-API-Key");
    56	
    57	    if (extra_header_name && extra_header_value)
    58	        MHD_add_response_header(response, extra_header_name, extra_header_value);
    59	
    60	    enum MHD_Result ret = MHD_queue_response(connection, status_code, response);
    61	    MHD_destroy_response(response);
    62	    return ret;
    63	}
    64	
    65	static enum MHD_Result send_json(struct MHD_Connection *connection,
    66	                                const char *body,
    67	                                unsigned int status_code) {
    68	    return send_json_with_headers(connection, body, status_code, NULL, NULL);
    69	}
    70	
    71	static enum MHD_Result send_json_total(struct MHD_Connection *connection,
    72	                                      const char *body,
    73	                                      unsigned int status_code,
    74	                                      int total) {
    75	    char count_str[32];
    76	    snprintf(count_str, sizeof(count_str), "%d", total);
    77	    return send_json_with_headers(connection, body, status_code, "X-Total-Count", count_str);
    78	}
