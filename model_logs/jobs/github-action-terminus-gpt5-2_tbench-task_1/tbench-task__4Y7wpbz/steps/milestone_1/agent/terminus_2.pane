[?2004l[?2004h> enum MHD_Result route_request(struct MHD_Connection *connection, const char *url,
[?2004l[?2004h>                               const char *method, const char *upload_data,
[?2004l[?2004h>                               size_t *upload_data_size, void **con_cls) {
