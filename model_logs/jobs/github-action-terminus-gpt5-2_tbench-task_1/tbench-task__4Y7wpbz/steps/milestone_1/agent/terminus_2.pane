[?2004l[?2004h> static int parse_int(const char *s, int *out) {
[?2004l[?2004h>     if (!s || !*s) return 0;
[?2004l[?2004h>     char *end = NULL;
[?2004l[?2004h>     long v = strtol(s, &end, 10);
[?2004l[?2004h>     if (end == s || *end != '\0') return 0;
[?2004l[?2004h>     if (v < 0) v = 0;
[?2004l[?2004h>     if (v > 1000000000L) v = 1000000000L;
[?2004l[?2004h>     *out = (int)v;
[?2004l[?2004h>     return 1;
[?2004l[?2004h> }
