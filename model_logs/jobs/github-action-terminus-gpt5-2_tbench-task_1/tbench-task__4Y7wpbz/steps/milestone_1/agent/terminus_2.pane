   263	enum MHD_Result route_request(struct MHD_Connection *connection, const char *url,
   264	                              const char *method, const char *upload_data,
   265	                              size_t *upload_data_size, void **con_cls) {
   266	    if (strcmp(method, "OPTIONS") == 0)
   267	        return send_json(connection, "", MHD_HTTP_OK);
   268	
   269	    if (strcmp(url, "/api/notes") == 0 && strcmp(method, "GET") == 0) {
   270	        int limit = NOTES_DEFAULT_PAGE_SIZE;
   271	        int offset = 0;
   272	        const char *q_limit = MHD_lookup_connection_value(connection, MHD_GET_ARGUMENT_KIND, "limit");
   273	        const char *q_offset = MHD_lookup_connection_value(connection, MHD_GET_ARGUMENT_KIND, "offset");
   274	        if (q_limit) parse_int(q_limit, &limit);
   275	        if (q_offset) parse_int(q_offset, &offset);
   276	        if (limit <= 0) limit = NOTES_DEFAULT_PAGE_SIZE;
   277	        if (limit > NOTES_MAX_PAGE_SIZE) limit = NOTES_MAX_PAGE_SIZE;
   278	        if (offset < 0) offset = 0;
   279	
   280	        int total = get_total_notes_count();
   281	        char *json = get_notes_paginated_json(limit, offset);
   282	        if (!json) return send_json_total(connection, "[]", MHD_HTTP_OK, total);
   283	        enum MHD_Result r = send_json_total(connection, json, MHD_HTTP_OK, total);
   284	        free(json);
   285	        return r;
   286	    }
   287	
   288	    int id = 0;
   289	    if (parse_id_from_url(url, &id) && strcmp(method, "GET") == 0) {
   290	        char *json = get_note_json(id);
   291	        if (!json) return send_json(connection, "{\"error\":\"not found\"}", MHD_HTTP_NOT_FOUND);
   292	        enum MHD_Result r = send_json(connection, json, MHD_HTTP_OK);
   293	        free(json);
   294	        return r;
   295	    }
   296	
   297	    if (strcmp(method, "POST") == 0 && strcmp(url, "/api/notes") == 0) {
   298	        if (!api_key_valid(connection))
   299	            return send_json(connection, "{\"error\":\"unauthorized\"}", MHD_HTTP_UNAUTHORIZED);
   300	
   301	        const char *cl = MHD_lookup_connection_value(connection, MHD_HEADER_KIND, "Content-Length");
   302	        if (cl) {
   303	            int v = 0;
   304	            if (parse_int(cl, &v) && v > NOTES_MAX_BODY_BYTES)
   305	                return send_json(connection, "{\"error\":\"payload too large\"}", MHD_HTTP_PAYLOAD_TOO_LARGE);
   306	        }
   307	
   308	        if (*con_cls == NULL) return init_con_info(con_cls);
   309	        return handle_post_put_body(connection, method, url, upload_data, upload_data_size, con_cls);
   310	    }
   311	
   312	    if (strcmp(method, "PUT") == 0 && strncmp(url, "/api/notes/", 11) == 0) {
   313	        if (!api_key_valid(connection))
   314	            return send_json(connection, "{\"error\":\"unauthorized\"}", MHD_HTTP_UNAUTHORIZED);
   315	
   316	        const char *cl = MHD_lookup_connection_value(connection, MHD_HEADER_KIND, "Content-Length");
   317	        if (cl) {
   318	            int v = 0;
   319	            if (parse_int(cl, &v) && v > NOTES_MAX_BODY_BYTES)
   320	                return send_json(connection, "{\"error\":\"payload too large\"}", MHD_HTTP_PAYLOAD_TOO_LARGE);
   321	        }
   322	
   323	        if (*con_cls == NULL) return init_con_info(con_cls);
   324	        return handle_post_put_body(connection, method, url, upload_data, upload_data_size, con_cls);
   325	    }
   326	
   327	    if (strcmp(method, "DELETE") == 0 && parse_id_from_url(url, &id)) {
   328	        if (!api_key_valid(connection))
   329	            return send_json(connection, "{\"error\":\"unauthorized\"}", MHD_HTTP_UNAUTHORIZED);
   330	        if (!note_exists(id))
   331	            return send_json(connection, "{\"error\":\"not found\"}", MHD_HTTP_NOT_FOUND);
   332	        if (!delete_note(id))
   333	            return send_json(connection, "{\"error\":\"server error\"}", MHD_HTTP_INTERNAL_SERVER_ERROR);
   334	        return send_json(connection, "{\"status\":\"deleted\"}", MHD_HTTP_OK);
   335	    }
   336	
   337	    return send_json(connection, "{\"error\":\"not found\"}", MHD_HTTP_NOT_FOUND);
   338	}
