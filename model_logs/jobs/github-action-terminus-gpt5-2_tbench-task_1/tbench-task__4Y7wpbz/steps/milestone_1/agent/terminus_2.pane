   307	        const char *q_limit = MHD_lookup_connection_value(connection, MHD_GET_ARGUMENT_KIND, "limit");
   308	        const char *q_offset = MHD_lookup_connection_value(connection, MHD_GET_ARGUMENT_KIND, "offset");
