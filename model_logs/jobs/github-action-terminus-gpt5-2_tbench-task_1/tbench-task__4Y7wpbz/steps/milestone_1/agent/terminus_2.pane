[?2004l[?2004h>         if (limit > NOTES_MAX_PAGE_SIZE) limit = NOTES_MAX_PAGE_SIZE;
[?2004l[?2004h>         if (offset < 0) offset = 0;
[?2004l[?2004h> 
[?2004l[?2004h>         int total = get_total_notes_count();
[?2004l[?2004h>         char *json = get_notes_paginated_json(limit, offset);
[?2004l[?2004h>         if (!json) return send_json_total(connection, "[]", MHD_HTTP_OK, total);
[?2004l[?2004h>         enum MHD_Result r = send_json_total(connection, json, MHD_HTTP_OK, total);
[?2004l[?2004h>         free(json);
[?2004l[?2004h>         return r;
[?2004l[?2004h>     }
