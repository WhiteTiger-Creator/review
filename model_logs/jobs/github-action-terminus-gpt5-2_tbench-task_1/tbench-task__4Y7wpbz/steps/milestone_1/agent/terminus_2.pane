   249	        free(content);
   250	        char *saved = get_note_json(id);
   251	        if (!saved)
   252	            return send_json(connection, "{\"error\":\"server error\"}", MHD_HTTP_INTERNAL_SERVER_ERROR);
   253	        enum MHD_Result r = send_json(connection, saved, MHD_HTTP_OK);
   254	        free(saved);
   255	        return r;
   256	    }
   257	
   258	    free(title);
   259	    free(content);
   260	    return send_json(connection, "{\"error\":\"not found\"}", MHD_HTTP_NOT_FOUND);
   261	}
