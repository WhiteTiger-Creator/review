    47	static enum MHD_Result send_json_with_headers(struct MHD_Connection *connection,
    48	                                             const char *body,
    49	                                             unsigned int status_code,
    50	                                             const char *extra_header_name,
    51	                                             const char *extra_header_value) {
    52	    struct MHD_Response *response = MHD_create_response_from_buffer(
    53	        strlen(body), (void *)body, MHD_RESPMEM_MUST_COPY);
    54	
    55	    MHD_add_response_header(response, "Content-Type", "application/json");
    56	    MHD_add_response_header(response, "Access-Control-Allow-Origin", "*");
    57	    MHD_add_response_header(response, "Access-Control-Allow-Methods",
    58	                            "GET, POST, PUT, DELETE, OPTIONS");
    59	    MHD_add_response_header(response, "Access-Control-Allow-Headers",
    60	                            "Content-Type, X-API-Key");
    61	
    62	    if (extra_header_name && extra_header_value)
    63	        MHD_add_response_header(response, extra_header_name, extra_header_value);
    64	
    65	    enum MHD_Result ret = MHD_queue_response(connection, status_code, response);
    66	    MHD_destroy_response(response);
    67	    return ret;
    68	}
    69	
    70	static enum MHD_Result send_json(struct MHD_Connection *connection,
