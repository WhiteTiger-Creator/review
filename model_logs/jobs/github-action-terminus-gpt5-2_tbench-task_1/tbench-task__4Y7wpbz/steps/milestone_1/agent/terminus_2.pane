    26	static int send_file_text(struct MHD_Connection *connection, const char *path) {
    27	    FILE *f = fopen(path, "rb");
    28	    if (!f) return send_json(connection, "{\"error\":\"not found\"}", MHD_HTTP_NOT_FOUND);
    29	    fseek(f, 0, SEEK_END);
    30	    long n = ftell(f);
    31	    fseek(f, 0, SEEK_SET);
    32	    if (n < 0 || n > 1024 * 1024) { fclose(f); return send_json(connection, "{\"error\":\"server error\"}", MHD_HTTP_INTERNAL_SERVER_ERROR); }
    33	    char *buf = (char*)calloc((size_t)n + 1, 1);
    34	    if (!buf) { fclose(f); return send_json(connection, "{\"error\":\"server error\"}", MHD_HTTP_INTERNAL_SERVER_ERROR); }
    35	    size_t r = fread(buf, 1, (size_t)n, f);
    36	    fclose(f);
    37	    buf[r] = "\0"[0];
    38	    int ret = send_text(connection, buf, MHD_HTTP_OK);
    39	    free(buf);
    40	    return ret;
    41	}
