    14	static enum MHD_Result send_json_with_headers(struct MHD_Connection *connection,
    15	                                             const char *body,
    16	                                             unsigned int status_code,
    17	                                             const char *extra_header_name,
    18	                                             const char *extra_header_value) {
    19	    struct MHD_Response *response = MHD_create_response_from_buffer(
    20	        strlen(body), (void *)body, MHD_RESPMEM_MUST_COPY);
    21	
    22	    MHD_add_response_header(response, "Content-Type", "application/json");
    23	    MHD_add_response_header(response, "Access-Control-Allow-Origin", "*");
    24	    MHD_add_response_header(response, "Access-Control-Allow-Methods",
    25	                            "GET, POST, PUT, DELETE, OPTIONS");
    26	    MHD_add_response_header(response, "Access-Control-Allow-Headers",
    27	                            "Content-Type, X-API-Key");
    28	
    29	    if (extra_header_name && extra_header_value)
    30	        MHD_add_response_header(response, extra_header_name, extra_header_value);
    31	
    32	    enum MHD_Result ret = MHD_queue_response(connection, status_code, response);
    33	    MHD_destroy_response(response);
    34	    return ret;
    35	}
    36	
    37	static enum MHD_Result send_json(struct MHD_Connection *connection,
    38	                                const char *body,
    39	                                unsigned int status_code) {
    40	    return send_json_with_headers(connection, body, status_code, NULL, NULL);
    41	}
    42	
    43	static enum MHD_Result send_json_total(struct MHD_Connection *connection,
    44	                                      const char *body,
    45	                                      unsigned int status_code,
    46	                                      int total) {
    47	    char count_str[32];
    48	    snprintf(count_str, sizeof(count_str), "%d", total);
    49	    return send_json_with_headers(connection, body, status_code, "X-Total-Count", count_str);
    50	}
    51	
    52	static int parse_int(const char *s, int *out) {
    53	    if (!s || !*s) return 0;
    54	    char *end = NULL;
    55	    long v = strtol(s, &end, 10);
    56	    if (end == s || *end != '\0') return 0;
    57	    if (v < 0) v = 0;
    58	    if (v > 1000000000L) v = 1000000000L;
    59	    *out = (int)v;
    60	    return 1;
    61	}
    62	
    63	static void skip_ws(const char **p) {
    64	    while (**p && isspace((unsigned char)**p)) (*p)++;
    65	}
    66	
    67	static int parse_json_string(const char **p, char **out) {
    68	    if (**p != '"') return 0;
    69	    (*p)++;
    70	
    71	    size_t cap = 64, len = 0;
    72	    char *buf = malloc(cap);
    73	    if (!buf) return 0;
    74	
    75	    while (**p) {
    76	        unsigned char c = (unsigned char)**p;
    77	        if (c == '"') {
    78	            (*p)++;
    79	            buf[len] = '\0';
    80	            *out = buf;
    81	            return 1;
    82	        }
    83	
    84	        if (c == '\\') {
    85	            (*p)++;
    86	            c = (unsigned char)**p;
