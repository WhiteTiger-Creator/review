    80	static int parse_int(const char *s, int *out) {
    81	    if (!s || !*s) return 0;
    82	    char *end = NULL;
    83	    long v = strtol(s, &end, 10);
    84	    if (end == s || *end != '\0') return 0;
    85	    if (v < 0) v = 0;
    86	    if (v > 1000000000L) v = 1000000000L;
    87	    *out = (int)v;
    88	    return 1;
    89	}
