    13	static int send_text(struct MHD_Connection *connection, const char *text, int status) {
    14	    struct MHD_Response *response = MHD_create_response_from_buffer(strlen(text), (void*)text, MHD_RESPMEM_MUST_COPY);
    15	    if (!response) return MHD_NO;
    16	    MHD_add_response_header(response, "Content-Type", "text/plain; charset=utf-8");
    17	    int ret = MHD_queue_response(connection, status, response);
    18	    MHD_destroy_response(response);
    19	    return ret;
    20	}
    21	
    22	static int send_file_text(struct MHD_Connection *connection, const char *path) {
    23	    FILE *f = fopen(path, "rb");
    24	    if (!f) return send_json(connection, "{\"error\":\"not found\"}", MHD_HTTP_NOT_FOUND);
    25	    fseek(f, 0, SEEK_END);
    26	    long n = ftell(f);
    27	    fseek(f, 0, SEEK_SET);
    28	    if (n < 0 || n > 1024 * 1024) { fclose(f); return send_json(connection, "{\"error\":\"server error\"}", MHD_HTTP_INTERNAL_SERVER_ERROR); }
    29	    char *buf = (char*)calloc((size_t)n + 1, 1);
    30	    if (!buf) { fclose(f); return send_json(connection, "{\"error\":\"server error\"}", MHD_HTTP_INTERNAL_SERVER_ERROR); }
    31	    size_t r = fread(buf, 1, (size_t)n, f);
    32	    fclose(f);
    33	    buf[r] = "\0"[0];
    34	    int ret = send_text(connection, buf, MHD_HTTP_OK);
    35	    free(buf);
    36	    return ret;
    37	}
