    32	static int url_contains_encoded_dotdot(const char *url) {
    33	    const char *p = url;
    34	    while (*p) {
    35	        if (strncasecmp(p, "%2e%2e", 6) == 0)
    36	            return 1;
    37	        p++;
    38	    }
    39	    return 0;
    40	}
    41	
    42	static enum MHD_Result serve_static_file(struct MHD_Connection *connection,
    43	    const char *url) {
    44	    if (strstr(url, "..") != NULL || url_contains_encoded_dotdot(url)) {
    45	        struct MHD_Response *r = MHD_create_response_from_buffer(
    46	            9, (void *)"Forbidden", MHD_RESPMEM_PERSISTENT);
    47	        enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_FORBIDDEN, r);
    48	        MHD_destroy_response(r);
    49	        return ret;
    50	    }
    51	
    52	    char filepath[512];
    53	    const char *path = strcmp(url, "/") == 0 ? "/index.html" : url;
    54	    snprintf(filepath, sizeof(filepath), "%s%s", WWW_DIR, path);
    55	
    56	    struct stat st;
    57	    if (stat(filepath, &st) != 0) return MHD_NO;
    58	
    59	    FILE *f = fopen(filepath, "rb");
    60	    if (!f) return MHD_NO;
    61	
    62	    char *buf = malloc(st.st_size);
    63	    fread(buf, 1, st.st_size, f);
    64	    fclose(f);
    65	
    66	    struct MHD_Response *response = MHD_create_response_from_buffer(
    67	        st.st_size, buf, MHD_RESPMEM_MUST_FREE);
    68	    MHD_add_response_header(response, "Content-Type", get_content_type(filepath));
    69	    enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_OK, response);
    70	    MHD_destroy_response(response);
    71	    return ret;
    72	}
    73	
    74	static void request_completed(void *cls, struct MHD_Connection *connection,
    75	    void **con_cls, enum MHD_RequestTerminationCode toe) {
    76	    (void)cls; (void)connection; (void)toe;
    77	    if (con_cls && *con_cls) {
    78	        struct connection_info *ci = *con_cls;
    79	        if (ci->data) free(ci->data);
    80	        free(ci);
    81	        *con_cls = NULL;
    82	    }
    83	}
    84	
    85	static enum MHD_Result handle_request(void *cls,
    86	    struct MHD_Connection *connection,
    87	    const char *url, const char *method,
    88	    const char *version,
    89	    const char *upload_data, size_t *upload_data_size,
    90	    void **con_cls) {
    91	    (void)cls; (void)version;
    92	
    93	    if (strncmp(url, "/api/", 5) == 0) {
    94	        return route_request(connection, url, method, upload_data,
    95	                             upload_data_size, con_cls);
    96	    }
    97	
    98	    if (strcmp(method, "GET") == 0) {
    99	        enum MHD_Result ret = serve_static_file(connection, url);
   100	        if (ret == MHD_YES) return ret;
   101	    }
   102	
   103	    struct MHD_Response *response = MHD_create_response_from_buffer(
   104	        9, (void *)"Not Found", MHD_RESPMEM_PERSISTENT);
   105	    enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_NOT_FOUND, response);
   106	    MHD_destroy_response(response);
   107	    return ret;
   108	}
