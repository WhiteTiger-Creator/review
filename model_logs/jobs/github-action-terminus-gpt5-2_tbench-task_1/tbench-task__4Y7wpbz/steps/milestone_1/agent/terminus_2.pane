    23	static const char *get_content_type(const char *path) {
    24	    const char *ext = strrchr(path, '.');
    25	    if (!ext) return "application/octet-stream";
    26	    if (strcmp(ext, ".html") == 0) return "text/html";
    27	    if (strcmp(ext, ".css") == 0) return "text/css";
    28	    if (strcmp(ext, ".js") == 0) return "application/javascript";
    29	    return "application/octet-stream";
    30	}
