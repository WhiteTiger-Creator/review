[?2004l[?2004h> static void skip_ws(const char **p) {
[?2004l[?2004h>     while (**p && isspace((unsigned char)**p)) (*p)++;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> static int parse_json_string(const char **p, char **out) {
[?2004l[?2004h>     // expects opening quote
[?2004l[?2004h>     if (**p != '"') return 0;
[?2004l[?2004h>     (*p)++;
[?2004l[?2004h> 
[?2004l[?2004h>     size_t cap = 64, len = 0;
[?2004l[?2004h>     char *buf = malloc(cap);
[?2004l[?2004h>     if (!buf) return 0;
[?2004l[?2004h> 
[?2004l[?2004h>     while (**p) {
[?2004l[?2004h>         unsigned char c = (unsigned char)**p;
[?2004l[?2004h>         if (c == '"') {
[?2004l[?2004h>             (*p)++;
[?2004l[?2004h>             buf[len] = '\0';
[?2004l[?2004h>             *out = buf;
[?2004l[?2004h>             return 1;
[?2004l[?2004h>         }
[?2004l[?2004h>         if (c == '\\') {
[?2004l[?2004h>             (*p)++;
[?2004l[?2004h>             c = (unsigned char)**p;
[?2004l[?2004h>             if (!c) break;
[?2004l[?2004h>             switch (c) {
[?2004l[?2004h>                 case '"': c = '"'; break;
[?2004l[?2004h>                 case '\\': c = '\\'; break;
[?2004l[?2004h>                 case '/': c = '/'; break;
[?2004l[?2004h>                 case 'b': c = '\b'; break;
[?2004l[?2004h>                 case 'f': c = '\f'; break;
[?2004l[?2004h>                 case 'n': c = '\n'; break;
[?2004l[?2004h>                 case 'r': c = '\r'; break;
[?2004l[?2004h>                 case 't': c = '\t'; break;
[?2004l[?2004h>                 case 'u':
[?2004l[?2004h>                     // minimal: keep as literal 'u' sequence unsupported -> reject
[?2004l[?2004h>                     free(buf);
[?2004l[?2004h>                     return 0;
[?2004l[?2004h>                 default:
[?2004l[?2004h>                     // unknown escape
[?2004l[?2004h>                     free(buf);
[?2004l[?2004h>                     return 0;
[?2004l[?2004h>             }
[?2004l[?2004h>             (*p)++;
[?2004l[?2004h>         } else {
[?2004l[?2004h>             (*p)++;
[?2004l[?2004h>         }
[?2004l[?2004h> 
[?2004l[?2004h>         if (len + 2 > cap) {
[?2004l[?2004h>             cap *= 2;
[?2004l[?2004h>             char *nb = realloc(buf, cap);
[?2004l[?2004h>             if (!nb) {
[?2004l[?2004h>                 free(buf);
[?2004l[?2004h>                 return 0;
[?2004l[?2004h>             }
[?2004l[?2004h>             buf = nb;
[?2004l[?2004h>         }
[?2004l[?2004h>         buf[len++] = (char)c;
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     free(buf);
[?2004l[?2004h>     return 0;
[?2004l[?2004h> }
