[?2004l[?2004h> static int json_get_string_field(const char *json, const char *field, char **out) {
[?2004l[?2004h>     // Very small extractor: finds "field" : "value" with optional whitespace.
[?2004l[?2004h>     // Rejects non-string values.
[?2004l[?2004h>     char needle[128];
[?2004l[?2004h>     snprintf(needle, sizeof(needle), "\"%s\"", field);
[?2004l[?2004h>     const char *p = strstr(json, needle);
[?2004l[?2004h>     if (!p) return 0;
[?2004ls[?2004h>     p += strlen(needle);
[?2004l[?2004h>     skip_ws(&p);
[?2004l[?2004h>     if (*p != ':') return 0;
[?2004l[?2004h>     p++;
[?2004l[?2004h>     skip_ws(&p);
[?2004l[?2004h>     if (*p != '"') return 0;
[?2004l[?2004h>     return parse_json_string(&p, out);
[?2004l[?2004h> }
