[323.330032, "o", "\u001b[?2004h> "]
[323.331153, "o", "    // expects opening quote\r\n\u001b[?2004l\r\u001b[?2004h>     if (**p != '\"') return 0;\r\n\u001b[?2004l\r\u001b[?2004h>     (*p)++;\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     size_t cap = 64, len = 0;\r\n\u001b[?2004l\r\u001b[?2004h> "]
