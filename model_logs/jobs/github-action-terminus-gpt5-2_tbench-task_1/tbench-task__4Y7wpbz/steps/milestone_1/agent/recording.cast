[290.70367, "i", "cat > /app/src/db.c <<'EOF'\n#include \"db.h\"\n\n#include <sqlite3.h>\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n\nstatic sqlite3 *db = NULL;\n\nstatic char *json_escape(const char *s) {\n    if (!s) s = \"\";\n    size_t len = 0;\n    for (const unsigned char *p = (const unsigned char *)s; *p; p++) {\n        switch (*p) {\n            case '\"':\n            case '\\\\':\n                len += 2;\n                break;\n            case '\\b':\n            case '\\f':\n            case '\\n':\n            case '\\r':\n            case '\\t':\n                len += 2;\n                break;\n            default:\n                if (*p < 0x20)\n                    len += 6; // \\u00XX\n                else\n                    len += 1;\n        }\n    }\n\n    char *out = malloc(len + 1);\n    if (!out) return NULL;\n\n    char *o = out;\n    for (const unsigned char *p = (const unsigned char *)s; *p; p++) {\n        switch (*p) {\n            case '\"': *o++ = '\\\\'; *o++ = '\"'; break;\n            case '\\\\': *o++ = '\\\\'; *o++ = '\\\\'; break;\n            case '\\b': *o++ = '\\\\'; *o++ = 'b'; break;\n            case '\\f': *o++ = '\\\\'; *o++ = 'f'; break;\n            case '\\n': *o++ = '\\\\'; *o++ = 'n'; break;\n            case '\\r': *o++ = '\\\\'; *o++ = 'r'; break;\n            case '\\t': *o++ = '\\\\'; *o++ = 't'; break;\n            default:\n                if (*p < 0x20) {\n                    sprintf(o, \"\\\\u%04x\", (unsigned int)*p);\n                    o += 6;\n                } else {\n                    *o++ = (char)*p;\n                }\n        }\n    }\n    *o = '\\0';\n    return out;\n}\n\nint init_db(const char *path) {\n    if (sqlite3_open_v2(path, &db,\n                        SQLITE_OPEN_READWRITE | SQLITE_OPEN_CREATE | SQLITE_OPEN_FULLMUTEX,\n                        NULL) != SQLITE_OK) {\n        fprintf(stderr, \"Cannot open database: %s\\n\", sqlite3_errmsg(db));\n        return -1;\n    }\n\n    sqlite3_busy_timeout(db, 5000);\n\n    char *err_msg = NULL;\n    sqlite3_exec(db, \"PRAGMA journal_mode=WAL;\", NULL, NULL, &err_msg);\n    if (err_msg) sqlite3_free(err_msg);\n    err_msg = NULL;\n    sqlite3_exec(db, \"PRAGMA synchronous=NORMAL;\", NULL, NULL, &err_msg);\n    if (err_msg) sqlite3_free(err_msg);\n\n    const char *sql =\n        \"CREATE TABLE IF NOT EXISTS notes (\"\n        \"id INTEGER PRIMARY KEY AUTOINCREMENT,\"\n        \"title TEXT NOT NULL,\"\n        \"content TEXT NOT NULL\"\n        \");\";\n\n    if (sqlite3_exec(db, sql, NULL, NULL, &err_msg) != SQLITE_OK) {\n        fprintf(stderr, \"SQL error: %s\\n\", err_msg);\n        sqlite3_free(err_msg);\n        return -1;\n    }\n\n    return 0;\n}\n\nvoid close_db(void) {\n    if (db) sqlite3_close(db);\n    db = NULL;\n}\n\nint create_note(const char *title, const char *content) {\n    if (!db) return -1;\n\n    sqlite3_stmt *stmt = NULL;\n    const char *sql = \"INSERT INTO notes(title, content) VALUES(?, ?);\";\n\n    if (sqlite3_prepare_v2(db, sql, -1, &stmt, NULL) != SQLITE_OK) return -1;\n\n    sqlite3_bind_text(stmt, 1, title ? title : \"\", -1, SQLITE_TRANSIENT);\n    sqlite3_bind_text(stmt, 2, content ? content : \"\", -1, SQLITE_TRANSIENT);\n\n    int rc = sqlite3_step(stmt);\n    sqlite3_finalize(stmt);\n    if (rc != SQLITE_DONE) return -1;\n\n    return (int)sqlite3_last_insert_rowid(db);\n}\n\nstatic int append_str(char **buf, size_t *cap, size_t *len, const char *s) {\n    size_t add = strlen(s);\n    if (*len + add + 1 > *cap) {\n        size_t ncap = (*cap == 0) ? 256 : *cap;\n        while (*len + add + 1 > ncap) ncap *= 2;\n        char *nbuf = realloc(*buf, ncap);\n        if (!nbuf) return -1;\n        *buf = nbuf;\n        *cap = ncap;\n    }\n    memcpy(*buf + *len, s, add);\n    *len += add;\n    (*buf)[*len] = '\\0';\n    return 0;\n}\n\nchar *get_notes_paginated_json(int limit, int offset) {\n    if (!db) return NULL;\n\n    const char *sql = \"SELECT id, title, content FROM notes ORDER BY id LIMIT ? OFFSET ?;\";\n    sqlite3_stmt *stmt = NULL;\n    if (sqlite3_prepare_v2(db, sql, -1, &stmt, NULL) != SQLITE_OK) return NULL;\n    sqlite3_bind_int(stmt, 1, limit);\n    sqlite3_bind_int(stmt, 2, offset);\n\n    char *out = NULL;\n    size_t cap = 0, len = 0;\n    if (ap"]
[290.703841, "i", "pend_str(&out, &cap, &len, \"[\") != 0) {\n        sqlite3_finalize(stmt);\n        return NULL;\n    }\n\n    int first = 1;\n    while (sqlite3_step(stmt) == SQLITE_ROW) {\n        int id = sqlite3_column_int(stmt, 0);\n        const char *title = (const char *)sqlite3_column_text(stmt, 1);\n        const char *content = (const char *)sqlite3_column_text(stmt, 2);\n\n        char *et = json_escape(title);\n        char *ec = json_escape(content);\n        if (!et || !ec) {\n            free(et); free(ec);\n            free(out);\n            sqlite3_finalize(stmt);\n            return NULL;\n        }\n\n        char item[64];\n        snprintf(item, sizeof(item), \"%s{\\\"id\\\":%d,\\\"title\\\":\\\"\", first ? \"\" : \",\", id);\n        first = 0;\n\n        if (append_str(&out, &cap, &len, item) != 0 ||\n            append_str(&out, &cap, &len, et) != 0 ||\n            append_str(&out, &cap, &len, \"\\\",\\\"content\\\":\\\"\") != 0 ||\n            append_str(&out, &cap, &len, ec) != 0 ||\n            append_str(&out, &cap, &len, \"\\\"}\") != 0) {\n            free(et); free(ec);\n            free(out);\n            sqlite3_finalize(stmt);\n            return NULL;\n        }\n\n        free(et);\n        free(ec);\n    }\n\n    sqlite3_finalize(stmt);\n\n    if (append_str(&out, &cap, &len, \"]\") != 0) {\n        free(out);\n        return NULL;\n    }\n\n    return out;\n}\n\nchar *get_all_notes_json(void) {\n    return get_notes_paginated_json(1000000, 0);\n}\n\nint get_total_notes_count(void) {\n    if (!db) return 0;\n\n    const char *sql = \"SELECT COUNT(*) FROM notes;\";\n    sqlite3_stmt *stmt = NULL;\n    if (sqlite3_prepare_v2(db, sql, -1, &stmt, NULL) != SQLITE_OK) return 0;\n\n    int total = 0;\n    if (sqlite3_step(stmt) == SQLITE_ROW) total = sqlite3_column_int(stmt, 0);\n    sqlite3_finalize(stmt);\n    return total;\n}\n\nchar *get_note_json(int id) {\n    if (!db) return NULL;\n\n    const char *sql = \"SELECT id, title, content FROM notes WHERE id = ?;\";\n    sqlite3_stmt *stmt = NULL;\n    if (sqlite3_prepare_v2(db, sql, -1, &stmt, NULL) != SQLITE_OK) return NULL;\n    sqlite3_bind_int(stmt, 1, id);\n\n    char *out = NULL;\n    if (sqlite3_step(stmt) == SQLITE_ROW) {\n        int rid = sqlite3_column_int(stmt, 0);\n        const char *title = (const char *)sqlite3_column_text(stmt, 1);\n        const char *content = (const char *)sqlite3_column_text(stmt, 2);\n        char *et = json_escape(title);\n        char *ec = json_escape(content);\n        if (et && ec) {\n            size_t need = strlen(et) + strlen(ec) + 64;\n            out = malloc(need);\n            if (out)\n                snprintf(out, need, \"{\\\"id\\\":%d,\\\"title\\\":\\\"%s\\\",\\\"content\\\":\\\"%s\\\"}\", rid, et, ec);\n        }\n        free(et);\n        free(ec);\n    }\n\n    sqlite3_finalize(stmt);\n    return out;\n}\n\nint note_exists(int id) {\n    if (!db) return 0;\n    const char *sql = \"SELECT 1 FROM notes WHERE id = ?;\";\n    sqlite3_stmt *stmt = NULL;\n    if (sqlite3_prepare_v2(db, sql, -1, &stmt, NULL) != SQLITE_OK) return 0;\n    sqlite3_bind_int(stmt, 1, id);\n    int exists = (sqlite3_step(stmt) == SQLITE_ROW);\n    sqlite3_finalize(stmt);\n    return exists;\n}\n\nint update_note(int id, const char *title, const char *content) {\n    if (!db) return 0;\n\n    const char *sql = \"UPDATE notes SET title = ?, content = ? WHERE id = ?;\";\n    sqlite3_stmt *stmt = NULL;\n    if (sqlite3_prepare_v2(db, sql, -1, &stmt, NULL) != SQLITE_OK) return 0;\n\n    sqlite3_bind_text(stmt, 1, title ? title : \"\", -1, SQLITE_TRANSIENT);\n    sqlite3_bind_text(stmt, 2, content ? content : \"\", -1, SQLITE_TRANSIENT);\n    sqlite3_bind_int(stmt, 3, id);\n\n    int rc = sqlite3_step(stmt);\n    sqlite3_finalize(stmt);\n    if (rc != SQLITE_DONE) return 0;\n\n    return sqlite3_changes(db) > 0;\n}\n\nint delete_note(int id) {\n    if (!db) return 0;\n\n    const char *sql = \"DELETE FROM notes WHERE id = ?;\";\n    sqlite3_stmt *stmt = NULL;\n    if (sqlite3_prepare_v2(db, sql, -1, &stmt, NULL) != SQLITE_OK) return 0;\n    sqlite3_bind_int(stmt, 1, id);\n\n    int rc = sqlite3_step(stmt);\n    sqlite3_finalize(stmt);\n    if (rc != SQLITE_DONE) return 0;\n\n    return sqlite3_changes(db) > 0;\n}\nEOF\n"]
