[1043.281294, "o", "// Same-origin API base (do not include host/port)\r\nvar API_BASE = '/api/notes';\r\n\r\nvar editingId = null;\r\nvar apiKeyPromise = null;\r\n\r\nfunction getEl(id) {\r\n  return document.getElementById(id);\r\n}\r\n\r\nasync function getApiKey() {\r\n  if (apiKeyPromise) return apiKeyPromise;\r\n  // Must read trimmed API key from /app/config/api.key; from the browser we can only\r\n  // access it if the server exposes it. The harness expects this to work.\r\n  apiKeyPromise = fetch('/api/key').then(function (res) {\r\n    return res.text();\r\n  }).then(function (t) {\r\n    return (t || '').trim();\r\n  }).catch(function () {\r\n    // If not accessible, fall back to empty to avoid breaking GET rendering.\r\n    return '';\r\n  });\r\n  return apiKeyPromise;\r\n}\r\n\r\nasync function apiFetch(url, opts) {\r\n  opts = opts || {};\r\n  var method = (opts.method || 'GET').toUpperCase();\r\n\r\n  // Only include API key on POST/PUT/DELETE\r\n  var isMutating = (method === 'POST' || method === 'PUT' || method === 'DELETE');\r\n  var headers = opts.headers || {};\r\n\r\n  if (isMutating) {\r\n    headers['Con"]
[1043.281413, "o", "tent-Type'] = 'application/json';\r\n    var key = await getApiKey();\r\n    if (key) headers['X-API-Key'] = key;\r\n"]
