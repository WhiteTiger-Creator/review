[572.094694, "o", "\u001b[?2004h> "]
[572.095065, "o", "    target = f\"{port:04X}\"\r\n\u001b[?2004l\r\u001b[?2004h>     inodes=set()\r\n\u001b[?2004l\r\u001b[?2004h"]
[572.095111, "o", "> "]
[572.095314, "o", "    with open('/proc/net/tcp','r') as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[572.0954, "o", "> "]
