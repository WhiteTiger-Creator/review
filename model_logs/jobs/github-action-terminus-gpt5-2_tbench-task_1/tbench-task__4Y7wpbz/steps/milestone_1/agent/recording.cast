[789.148706, "o", "   240\t            free(content);\r\n   241\t            return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\r\n   242\t        }\r\n   243\t        if (!update_note(id, title, content ? content : \"\")) {\r\n   244\t            free(title);\r\n   245\t            free(content);\r\n   246\t            return send_json(connection, \"{\\\"error\\\":\\\"server error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR);\r\n   247\t        }\r\n   248\t        free(title);\r\n   249\t        free(content);\r\n   250\t        char *saved = get_note_json(id);\r\n   251\t        if (!saved)\r\n   252\t            return send_json(connection, \"{\\\"error\\\":\\\"server error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR);\r\n   253\t        enum MHD_Result r = send_json(connection, saved, MHD_HTTP_OK);\r\n   254\t        free(saved);\r\n   255\t        return r;\r\n"]
[789.149026, "o", "   256\t    }\r\n   257\t\r\n   258\t    free(title);\r\n   259\t    free(content);\r\n   260\t    return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\r\n   261\t}\r\n   262\t\r\n   263\tenum MHD_Result route_request(struct MHD_Connection *connection, const char *url,\r\n   264\t                              const char *method, const char *upload_data,\r\n   265\t                              size_t *upload_data_size, void **con_cls) {\r\n   266\t    if (strcmp(method, \"OPTIONS\") == 0)\r\n   267\t        return send_json(connection, \"\", MHD_HTTP_OK);\r\n   268\t\r\n   269\t    if (strcmp(url, \"/api/notes\") == 0 && strcmp(method, \"GET\") == 0) {\r\n   270\t        int limit = NOTES_DEFAULT_PAGE_SIZE;\r\n   271\t        int offset = 0;\r\n   272\t        const char *q_limit = MHD_lookup_connection_value(connection, MHD_GET_ARGUMENT_KIND, \"limit\");\r\n   273\t        const char *q_offset = MHD_lookup_connection_value(connection, MHD_GET_ARGUMENT_KIND, \"offset\");\r\n   274\t        if (q_limit) parse_int(q_limit, &limit);\r\n   275\t        if (q_offset) parse_int(q_offset, &offset);\r\n   276\t        if (limit <= 0) limit = NOTES_DEFAULT_PAGE_SIZE;\r\n"]
[789.149212, "o", "   277\t        if (limit > NOTES_MAX_PAGE_SIZE) limit = NOTES_MAX_PAGE_SIZE;\r\n   278\t        if (offset < 0) offset = 0;\r\n   279\t\r\n   280\t        int total = get_total_notes_count();\r\n   281\t        char *json = get_notes_paginated_json(limit, offset);\r\n   282\t        if (!json) return send_json_total(connection, \"[]\", MHD_HTTP_OK, total);\r\n   283\t        enum MHD_Result r = send_json_total(connection, json, MHD_HTTP_OK, total);\r\n   284\t        free(json);\r\n   285\t        return r;\r\n   286\t    }\r\n   287\t\r\n   288\t    int id = 0;\r\n   289\t    if (parse_id_from_url(url, &id) && strcmp(method, \"GET\") == 0) {\r\n   290\t        char *json = get_note_json(id);\r\n   291\t        if (!json) return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\r\n   292\t        enum MHD_Result r = send_json(connection, json, MHD_HTTP_OK);\r\n   293\t        free(json);\r\n   294\t        return r;\r\n   295\t    }\r\n   296\t\r\n   297\t    if (strcmp(method, \"POST\") == 0 && strcmp(url, \"/api/notes\") == 0) {\r\n   298\t        if (!api_key_valid(connection))\r\n   299\t            return send_json(connection, \"{\\\"error\\\":\\\"unauthorized\\\"}\", MHD_HTTP_UNAUTHORIZED);\r\n   300\t\r\n   301\t        const char *cl = MHD_lookup_connection_value(connection, MHD_HEADER_KIND, \"Content-Length\");\r\n   302\t        if (cl) {\r\n   303\t            int v = 0;\r\n   304\t            if (parse_int(cl, &v) && v > NOTES_MAX_BODY_BYTES)\r\n   305\t                return send_json(connection, \"{\\\"error\\\":\\\"payload too large\\\"}\", MHD_HTTP_PAYLOAD_TOO_LARGE);\r\n   306\t        }\r\n   307\t\r\n   308\t        if (*con_cls == NULL) return init_con_info(con_cls);\r\n   309\t        return handle_post_put_body(connection, method, url, upload_data, upload_data_size, con_cls);\r\n   310\t    }\r\n   311\t\r\n   312\t    if (strcmp(method, \"PUT\") == 0 && strncmp(url, \"/api/notes/\", 11) == 0) {\r\n   313\t        if (!api_key_valid(connection))\r\n   314\t            return send_json(connection, \"{\\\"error\\\":\\\"unauthorized\\\"}\", MHD_HTTP_UNAUTHORIZED);\r\n   315\t\r\n   316\t        const char *cl = MHD_lookup_connection_value(connection, MHD_HEADER_KIND, \"Content-Length\");\r\n   317\t        if (cl) {\r\n   318\t            int v = 0;\r\n   319\t            if (parse_int(cl, &v) && v > NOTES_MAX_BODY_BYTES)\r\n   320\t                return send_json(connection, \"{\\\"error\\\":\\\"payload too large\\\"}\", MHD_HTTP_PAYLOAD_TOO_LARGE);\r\n   321\t        }\r\n   322\t\r\n   323\t        if (*con_cls == NULL) return init_con_info(con_cls);\r\n   324\t        return handle_post_put_body(connection, method, url, upload_data, upload_data_size, con_cls);\r\n   325\t    }\r\n   326\t\r\n   327\t    if (strcmp(method, \"DELETE\") == 0 && parse_id_from_url(url, &id)) {\r\n   328\t        if (!api_key_valid(connection))\r\n   329\t            return send_json(connection, \"{\\\"error\\\":\\\"unauthorized\\\"}\", MHD_HTTP_UNAUTHORIZED);\r\n   330\t        if (!note_exists(id))\r\n   331\t            return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\r\n   332\t        if (!delete_note(id))\r\n   333\t            return send_json(connection, \"{\\\"error\\\":\\\"server error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR);\r\n   334\t        return send_json(connection, \"{\\\"status\\\":\\\"deleted\\\"}\", MHD_HTTP_OK);\r\n   335\t    }\r\n   336\t\r\n"]
