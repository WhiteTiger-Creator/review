[754.265438, "i", "perl -0777 -i -pe 's@(static enum MHD_Result send_json\\(struct MHD_Connection \\*connection,\\n\\s*const char \\*json, unsigned int status_code\\)\\n\\{.*?\\n\\}\\n)@$1\\n#define API_KEY_PATH \"/app/config/api.key\"\\n\\nstatic enum MHD_Result send_text(struct MHD_Connection *connection, const char *text, unsigned int status) {\\n    struct MHD_Response *response = MHD_create_response_from_buffer(strlen(text), (void*)text, MHD_RESPMEM_MUST_COPY);\\n    if (!response) return MHD_NO;\\n    MHD_add_response_header(response, \"Content-Type\", \"text/plain; charset=utf-8\");\\n    enum MHD_Result ret = MHD_queue_response(connection, status, response);\\n    MHD_destroy_response(response);\\n    return ret;\\n}\\n\\nstatic enum MHD_Result send_file_text(struct MHD_Connection *connection, const char *path) {\\n    FILE *f = fopen(path, \"rb\");\\n    if (!f) return send_json(connection, \"{\\\\\\\"error\\\\\\\":\\\\\\\"not found\\\\\\\"}\", MHD_HTTP_NOT_FOUND);\\n    fseek(f, 0, SEEK_END);\\n    long n = ftell(f);\\n    fseek(f, 0, SEEK_SET);\\n    if (n < 0 || n > 1024 * 1024) { fclose(f); return send_json(connection, \"{\\\\\\\"error\\\\\\\":\\\\\\\"server error\\\\\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR); }\\n    char *buf = (char*)calloc((size_t)n + 1, 1);\\n    if (!buf) { fclose(f); return send_json(connection, \"{\\\\\\\"error\\\\\\\":\\\\\\\"server error\\\\\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR); }\\n    size_t r = fread(buf, 1, (size_t)n, f);\\n    fclose(f);\\n    buf[r] = \"\\\\0\"[0];\\n    enum MHD_Result ret = send_text(connection, buf, MHD_HTTP_OK);\\n    free(buf);\\n    return ret;\\n}\\n\\n@sm' /app/src/routes.c\n"]
[754.2707, "o", "perl -0777 -i -pe 's@(static enum MHD_Result send_json\\(struct MHD_Connection \\*connection,\\n\\s*const char \\*json, unsigned int status_code\\)\\n\\{.*?\\n\\}\\n)@$1\\n#define API_KEY_PATH \"/app/config/api.key\"\\n\\nstatic enum MHD_Result send_text(struct MHD_Connection *connection, const char *text, unsigned int status) {\\n    struct MHD_Response *response = MHD_create_response_from_buffer(strlen(text), (void*)text, MHD_RESPMEM_MUST_COPY);\\n    if (!response) return MHD_NO;\\n    MHD_add_response_header(response, \"Content-Type\", \"text/plain; charset=utf-8\");\\n    enum MHD_Result ret = MHD_queue_response(connection, status, response);\\n    MHD_destroy_response(response);\\n    return ret;\\n}\\n\\nstatic enum MHD_Result send_file_text(struct MHD_Connection *connection, const char *path) {\\n    FILE *f = fopen(path, \"rb\");\\n    if (!f) return send_json(connection, \"{\\\\\\\"error\\\\\\\":\\\\\\\"not found\\\\\\\"}\", MHD_HTTP_NOT_FOUND);\\n    fseek(f, 0, SEEK_END);\\n    long n = ftell(f);\\n    fseek(f, 0, SEEK_SET);\\n    if (n < 0 || n > 1024 * 1024) { fclose(f); return send_json(connection, \"{\\\\\\\"error\\\\\\\":\\\\\\\"server error\\\\\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR); }\\n    char *buf = (char*)calloc((size_t)n + 1, 1);\\n    if (!buf) { fclose(f); return send_json(connection, \"{\\\\\\\"error\\\\\\\":\\\\\\\"server error\\\\\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR); }\\n    size_t r = fread(buf, 1, (size_t)n, f);\\n    fclose(f);\\n    buf[r] = \"\\\\0\"[0];\\n    enum MHD_Result ret = send_text(connection, buf, MHD_HTTP_OK);\\n    free(buf);\\n    return ret;\\n}\\n\\n@sm' /app/src/routes.c\r\n\u001b[?2004l\r"]
