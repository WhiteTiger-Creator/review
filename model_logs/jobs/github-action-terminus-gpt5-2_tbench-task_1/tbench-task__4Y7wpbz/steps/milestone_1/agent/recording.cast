[189.55155, "o", "     1\t#include <microhttpd.h>\r\n     2\t#include <stdio.h>\r\n     3\t#include <string.h>\r\n     4\t#include <stdlib.h>\r\n     5\t#include <signal.h>\r\n     6\t#include <sys/stat.h>\r\n     7\t#include <strings.h>\r\n     8\t#include \"routes.h\"\r\n     9\t#include \"db.h\"\r\n    10\t\r\n    11\t#define PORT 8080\r\n    12\t#define WWW_DIR \"/app/www\"\r\n    13\t\r\n    14\tstatic struct MHD_Daemon *daemon_handle = NULL;\r\n    15\t\r\n    16\tstatic void handle_signal(int sig) {\r\n    17\t    (void)sig;\r\n    18\t    if (daemon_handle) MHD_stop_daemon(daemon_handle);\r\n    19\t    close_db();\r\n    20\t    exit(0);\r\n    21\t}\r\n    22\t\r\n    23\tstatic const char *get_content_type(const char *path) {\r\n    24\t    const char *ext = strrchr(path, '.');\r\n    25\t    if (!ext) return \"application/octet-stream\";\r\n    26\t    if (strcmp(ext, \".html\") == 0) return \"text/html\";\r\n    27\t    if (strcmp(ext, \".css\") == 0) return \"text/css\";\r\n    28\t    if (strcmp(ext, \".js\") == 0) return \"application/javascript\";\r\n    29\t    return \"application/octet-stream\";\r\n    30\t}\r\n    31\t\r\n"]
[189.5518, "o", "    32\tstatic int url_contains_encoded_dotdot(const char *url) {\r\n    33\t    const char *p = url;\r\n    34\t    while (*p) {\r\n    35\t        if (strncasecmp(p, \"%2e%2e\", 6) == 0)\r\n    36\t            return 1;\r\n    37\t        p++;\r\n    38\t    }\r\n    39\t    return 0;\r\n    40\t}\r\n    41\t\r\n    42\tstatic enum MHD_Result serve_static_file(struct MHD_Connection *connection,\r\n    43\t    const char *url) {\r\n    44\t    if (strstr(url, \"..\") != NULL || url_contains_encoded_dotdot(url)) {\r\n    45\t        struct MHD_Response *r = MHD_create_response_from_buffer(\r\n    46\t            9, (void *)\"Forbidden\", MHD_RESPMEM_PERSISTENT);\r\n    47\t        enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_FORBIDDEN, r);\r\n    48\t        MHD_destroy_response(r);\r\n    49\t        return ret;\r\n    50\t    }\r\n    51\t\r\n    52\t    char filepath[512];\r\n    53\t    const char *path = strcmp(url, \"/\") == 0 ? \"/index.html\" : url;\r\n    54\t    snprintf(filepath, sizeof(filepath), \"%s%s\", WWW_DIR, path);\r\n    55\t\r\n    56\t    struct stat st;\r\n    57\t    if (stat(filepath, &st) != 0) return MHD_NO;\r\n    58\t\r\n    59\t    FILE *f = fopen(filepath, \"rb\");\r\n    60\t    if (!f) return MHD_NO;\r\n    61\t\r\n    62\t    char *buf = malloc(st.st_size);\r\n    63\t    fread(buf, 1, st.st_size, f);\r\n    64\t    fclose(f);\r\n    65\t\r\n    66\t    struct MHD_Response *response = MHD_create_response_from_buffer(\r\n    67\t        st.st_size, buf, MHD_RESPMEM_MUST_FREE);\r\n    68\t    MHD_add_response_header(response, \"Content-Type\", get_content_type(filepath));\r\n    69\t    enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_OK, response);\r\n    70\t    MHD_destroy_response(response);\r\n    71\t    return ret;\r\n    72\t}\r\n    73\t\r\n    74\tstatic void request_completed(void *cls, struct MHD_Connection *connection,\r\n    75\t    void **con_cls, enum MHD_RequestTerminationCode toe) {\r\n    76\t    (void)cls; (void)connection; (void)toe;\r\n    77\t    if (con_cls && *con_cls) {\r\n    78\t        struct connection_info *ci = *con_cls;\r\n    79\t        if (ci->data) free(ci->data);\r\n    80\t        free(ci);\r\n    81\t        *con_cls = NULL;\r\n    82\t    }\r\n    83\t}\r\n    84\t\r\n    85\tstatic enum MHD_Result handle_request(void *cls,\r\n    86\t    struct MHD_Connection *connection,\r\n    87\t    const char *url, const char *method,\r\n    88\t    const char *version,\r\n"]
[189.551933, "o", "    89\t    const char *upload_data, size_t *upload_data_size,\r\n    90\t    void **con_cls) {\r\n    91\t    (void)cls; (void)version;\r\n    92\t\r\n    93\t    if (strncmp(url, \"/api/\", 5) == 0) {\r\n    94\t        return route_request(connection, url, method, upload_data,\r\n    95\t                             upload_data_size, con_cls);\r\n    96\t    }\r\n    97\t\r\n    98\t    if (strcmp(method, \"GET\") == 0) {\r\n    99\t        enum MHD_Result ret = serve_static_file(connection, url);\r\n   100\t        if (ret == MHD_YES) return ret;\r\n   101\t    }\r\n   102\t\r\n   103\t    struct MHD_Response *response = MHD_create_response_from_buffer(\r\n   104\t        9, (void *)\"Not Found\", MHD_RESPMEM_PERSISTENT);\r\n   105\t    enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_NOT_FOUND, response);\r\n   106\t    MHD_destroy_response(response);\r\n   107\t    return ret;\r\n   108\t}\r\n   109\t\r\n   110\tint main(void) {\r\n   111\t    signal(SIGINT, handle_signal);\r\n   112\t    signal(SIGTERM, handle_signal);\r\n   113\t\r\n   114\t    mkdir(\"/app/data\", 0755);\r\n   115\t\r\n   116\t    if (init_db(\"/app/data/notes.db\") != 0) {\r\n   117\t        fprintf(stderr, \"Failed to initialize database\\n\");\r\n   118\t        return 1;\r\n   119\t    }\r\n   120\t\r\n   121\t"]
[189.552098, "o", "    daemon_handle = MHD_start_daemon(\r\n   122\t        MHD_USE_THREAD_PER_CONNECTION,\r\n   123\t        PORT,\r\n   124\t        NULL, NULL,\r\n   125\t        &handle_request, NULL,\r\n   126\t        MHD_OPTION_NOTIFY_COMPLETED, &request_completed, NULL,\r\n   127\t        MHD_OPTION_END\r\n   128\t    );\r\n   129\t\r\n   130\t    if (!daemon_handle) {\r\n   131\t        fprintf(stderr, \"Failed to start server\\n\");\r\n   132\t        return 1;\r\n   133\t    }\r\n   134\t\r\n   135\t    printf(\"Server running on port %d\\n\", PORT);\r\n   136\t    while (1) pause();\r\n   137\t    return 0;\r\n   138\t}\r\n"]
