[426.433555, "i", "python3 - <<'PY'\nimport json\nfrom urllib import request\nfrom urllib.error import HTTPError\n\nurl='http://127.0.0.1:8080/api/notes'\nbody=json.dumps({'title':'t','content':'x'*70000}).encode('utf-8')\nreq=request.Request(url, data=body, method='POST')\nreq.add_header('Content-Type','application/json')\nreq.add_header('X-API-Key','tb3_notes_api_secret_2026')\ntry:\n    with request.urlopen(req) as resp:\n        print('status', resp.status)\n        print(resp.read(200).decode('utf-8','replace'))\nexcept HTTPError as e:\n    print('status', e.code)\n    data=e.read(200).decode('utf-8','replace')\n    print(data)\nPY\n"]
