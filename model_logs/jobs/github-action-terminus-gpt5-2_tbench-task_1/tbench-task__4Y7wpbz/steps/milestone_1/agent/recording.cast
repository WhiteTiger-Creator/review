[258.969183, "i", "cat > /app/src/auth.c <<'EOF'\n#include \"auth.h\"\n\n#include <ctype.h>\n#include <microhttpd.h>\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n\n#define API_KEY_PATH \"/app/config/api.key\"\n\nstatic char *g_api_key = NULL;\nstatic int g_loaded = 0;\n\nstatic void trim_in_place(char *s) {\n    if (!s) return;\n\n    // left trim\n    char *p = s;\n    while (*p && isspace((unsigned char)*p)) p++;\n    if (p != s) memmove(s, p, strlen(p) + 1);\n\n    // right trim\n    size_t n = strlen(s);\n    while (n > 0 && isspace((unsigned char)s[n - 1])) {\n        s[n - 1] = '\\0';\n        n--;\n    }\n}\n\nstatic char *load_api_key(void) {\n    FILE *f = fopen(API_KEY_PATH, \"rb\");\n    if (!f) return NULL;\n\n    char buf[512];\n    size_t n = fread(buf, 1, sizeof(buf) - 1, f);\n    fclose(f);\n    buf[n] = '\\0';\n\n    trim_in_place(buf);\n    if (buf[0] == '\\0') return NULL;\n    return strdup(buf);\n}\n\nint api_key_valid(struct MHD_Connection *connection) {\n    if (!g_loaded) {\n        g_api_key = load_api_key();\n        g_loaded = 1;\n    }\n\n    if (!g_api_key) return 0;\n\n    const char *hdr = MHD_lookup_connection_value(connection, MHD_HEADER_KIND, \"X-API-Key\");\n    if (!hdr) return 0;\n\n    return strcmp(hdr, g_api_key) == 0;\n}\nEOF\n"]
