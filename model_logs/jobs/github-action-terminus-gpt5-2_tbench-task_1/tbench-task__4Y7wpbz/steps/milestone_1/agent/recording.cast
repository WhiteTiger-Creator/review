[655.467596, "o", "#include \"static.h\"\r\n\r\nenum MHD_Result serve_static_file(struct MHD_Connection *connection, const char *url) {\r\n    (void)connection;\r\n    (void)url;\r\n"]
[655.4677, "o", "    return MHD_NO;\r\n}\r\n"]
[655.468001, "o", "\u001b[?2004hroot@ade5f5ea62db:/app# "]
[655.576897, "i", "sed -n '1,220p' /app/src/main.c\n"]
[655.577722, "o", "sed -n '1,220p' /app/src/main.c\r\n\u001b[?2004l\r"]
[655.579637, "o", "#include <microhttpd.h>\r\n#include <stdio.h>\r\n#include <string.h>\r\n#include <stdlib.h>\r\n#include <signal.h>\r\n#include <sys/stat.h>\r\n#include <strings.h>\r\n#include \"routes.h\"\r\n"]
[655.579757, "o", "#include \"db.h\"\r\n\r\n#define PORT 8080\r\n#define WWW_DIR \"/app/www\"\r\n\r\nstatic struct MHD_Daemon *daemon_handle = NULL;\r\n\r\nstatic void handle_signal(int sig) {\r\n    (void)sig;\r\n    if (daemon_handle) MHD_stop_daemon(daemon_handle);\r\n    close_db();\r\n    exit(0);\r\n}\r\n\r\nstatic const char *get_content_type(const char *path) {\r\n    const char *ext = strrchr(path, '.');\r\n    if (!ext) return \"application/octet-stream\";\r\n    if (strcmp(ext, \".html\") == 0) return \"text/html\";\r\n"]
[655.580078, "o", "    if (strcmp(ext, \".css\") == 0) return \"text/css\";\r\n    if (strcmp(ext, \".js\") == 0) return \"application/javascript\";\r\n    return \"application/octet-stream\";\r\n}\r\n\r\nstatic int url_contains_encoded_dotdot(const char *url) {\r\n    const char *p = url;\r\n    while (*p) {\r\n        if (strncasecmp(p, \"%2e%2e\", 6) == 0)\r\n            return 1;\r\n        p++;\r\n    }\r\n    return 0;\r\n}\r\n\r\nstatic enum MHD_Result serve_static_file(struct MHD_Connection *connection,\r\n    const char *url) {\r\n    if (strstr(url, \"..\") != NULL || url_contains_encoded_dotdot(url)) {\r\n        struct MHD_Response *r = MHD_create_response_from_buffer(\r\n            9, (void *)\"Forbidden\", MHD_RESPMEM_PERSISTENT);\r\n        enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_FORBIDDEN, r);\r\n        MHD_destroy_response(r);\r\n        return ret;\r\n    }\r\n\r\n    char filepath[512];\r\n    const char *path = strcmp(url, \"/\") == 0 ? \"/index.html\" : url;\r\n    snprintf(filepath, sizeof(filepath), \"%s%s\", WWW_DIR, path);\r\n\r\n    struct stat st;\r\n    if (stat(filepath, &st) != 0) return MHD_NO;\r\n\r\n    FILE *f = fopen(filepath, \"rb\");\r\n    if (!f) return MHD_NO;\r\n\r\n    char *buf = malloc(st.st_size);\r\n    fread(buf, 1, st.st_size, f);\r\n    fclose(f);\r\n\r\n    struct MHD_Response *response = MHD_create_response_from_buffer(\r\n        st.st_size, buf, MHD_RESPMEM_MUST_FREE);\r\n    MHD_add_response_header(response, \"Content-Type\", get_content_type(filepath));\r\n    enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_OK, response);\r\n    MHD_destroy_response(response);\r\n    return ret;\r\n}\r\n\r\nstatic void request_completed(void *cls, struct MHD_Connection *connection,\r\n    void **con_cls, enum MHD_RequestTerminationCode toe) {\r\n    (void)cls; (void)connection; (void)toe;\r\n    if (con_cls && *con_cls) {\r\n"]
[655.580328, "o", "        struct connection_info *ci = *con_cls;\r\n        if (ci->data) free(ci->data);\r\n        free(ci);\r\n        *con_cls = NULL;\r\n    }\r\n}\r\n\r\nstatic enum MHD_Result handle_request(void *cls,\r\n    struct MHD_Connection *connection,\r\n    const char *url, const char *method,\r\n    const char *version,\r\n    const char *upload_data, size_t *upload_data_size,\r\n    void **con_cls) {\r\n    (void)cls; (void)version;\r\n\r\n    if (strncmp(url, \"/api/\", 5) == 0) {\r\n        return route_request(connection, url, method, upload_data,\r\n                             upload_data_size, con_cls);\r\n    }\r\n\r\n    if (strcmp(method, \"GET\") == 0) {\r\n        enum MHD_Result ret = serve_static_file(connection, url);\r\n        if (ret == MHD_YES) return ret;\r\n    }\r\n\r\n    struct MHD_Response *response = MHD_create_response_from_buffer(\r\n        9, (void *)\"Not Found\", MHD_RESPMEM_PERSISTENT);\r\n    enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_NOT_FOUND, response);\r\n    MHD_destroy_response(response);\r\n    return ret;\r\n}\r\n\r\nint main(void) {\r\n    signal(SIGINT, handle_signal);\r\n    signal(SIGTERM, handle_signal);\r\n    signal(SIGPIPE, SIG_IGN);\r\n\r\n    mkdir(\"/app/data\", 0755);\r\n\r\n    if (init_db(\"/app/data/notes.db\") != 0) {\r\n        fprintf(stderr, \"Failed to initialize database\\n\");\r\n        return 1;\r\n    }\r\n\r\n    daemon_handle = MHD_start_daemon(\r\n        MHD_USE_THREAD_PER_CONNECTION,\r\n        PORT,\r\n        NULL, NULL,\r\n        &handle_request, NULL,\r\n        MHD_OPTION_NOTIFY_COMPLETED, &request_completed, NULL,\r\n        MHD_OPTION_CONNECTION_MEMORY_LIMIT, (unsigned int)65536,\r\n        MHD_OPTION_END\r\n    );\r\n\r\n    if (!daemon_handle) {\r\n        fprintf(stderr, \"Failed to start server\\n\");\r\n        return 1;\r\n    }\r\n\r\n    printf(\"Server running on port %d\\n\", PORT);\r\n    while (1) pause();\r\n    return 0;\r\n}\r\n"]
[655.580629, "o", "\u001b[?2004hroot@ade5f5ea62db:/app# "]
[655.704848, "i", "apply_patch<<'PATCH'\n*** Begin Patch\n*** Update File: src/routes.c\n@@\n #include \"routes.h\"\n #include \"db.h\"\n #include \"auth.h\"\n #include \"static.h\"\n@@\n #include <string.h>\n #include <stdlib.h>\n #include <stdio.h>\n+\n+#define API_KEY_PATH \"/app/config/api.key\"\n+\n+static int send_text(struct MHD_Connection *connection, const char *text, int status) {\n+    struct MHD_Response *response = MHD_create_response_from_buffer(strlen(text), (void*)text, MHD_RESPMEM_MUST_COPY);\n+    if (!response) return MHD_NO;\n+    MHD_add_response_header(response, \"Content-Type\", \"text/plain; charset=utf-8\");\n+    int ret = MHD_queue_response(connection, status, response);\n+    MHD_destroy_response(response);\n+    return ret;\n+}\n+\n+static int send_file_text(struct MHD_Connection *connection, const char *path) {\n+    FILE *f = fopen(path, \"rb\");\n+    if (!f) return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\n+    fseek(f, 0, SEEK_END);\n+    long n = ftell(f);\n+    fseek(f, 0, SEEK_SET);\n+    if (n < 0 || n > 1024 * 1024) { fclose(f); return send_json(connection, \"{\\\"error\\\":\\\"server error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR); }\n+    char *buf = (char*)calloc((size_t)n + 1, 1);\n+    if (!buf) { fclose(f); return send_json(connection, \"{\\\"error\\\":\\\"server error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR); }\n+    size_t r = fread(buf, 1, (size_t)n, f);\n+    fclose(f);\n+    buf[r] = '\\0';\n+    int ret = send_text(connection, buf, MHD_HTTP_OK);\n+    free(buf);\n+    return ret;\n+}\n*** End Patch\nPATCH\n"]
[655.705637, "o", "apply_patch<<'PATCH'\r\n\u001b[?2004l\r\u001b[?2004h> *** Begin Patch\r\n\u001b[?2004l\r\u001b[?2004h> *** Update File: src/routes.c\r\n\u001b[?2004l\r\u001b[?2004h> @@"]
