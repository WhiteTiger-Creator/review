[323.335368, "o", "\u001b[?2004h> "]
[323.335652, "o", "                case '\\\\': c = '\\\\'; break;\r\n\u001b[?2004l\r"]
[323.335679, "o", "\u001b[?2004h"]
[323.340975, "o", ">                 case '/': c = '/'; break;\r\n\u001b[?2004l\r\u001b[?2004h>                 case 'b': c = '\\b'; break;\r\n\u001b[?2004l\r\u001b[?2004h>                 case 'f': c = '\\f'; break;\r\n\u001b[?2004l\r\u001b[?2004h>                 case 'n': c = '\\n'; break;\r\n\u001b[?2004l\r\u001b[?2004h>                 case 'r': c = '\\r'; break;\r\n\u001b[?2004l\r\u001b[?2004h>                 case 't': c = '\\t'; break;\r\n\u001b[?2004l\r\u001b[?2004h>                 case 'u':\r\n\u001b[?2004l\r\u001b[?2004h>                     // minimal: keep as literal 'u' sequence unsupported -> reject\r\n\u001b[?2004l\r\u001b[?2004h>                     free(buf);\r\n\u001b[?2004l\r\u001b[?2004h>                     return 0;\r\n\u001b[?2004l\r\u001b[?2004h>                 default:\r\n\u001b[?2004l\r\u001b[?2004h>                     // unknown escape\r\n\u001b[?2004l\r\u001b[?2004h>                     free(buf);\r\n\u001b[?2004l\r\u001b[?2004h>                     return 0;\r\n\u001b[?2004l\r\u001b[?2004h>             }\r\n\u001b[?2004l\r\u001b[?2004h>             (*p)++;\r\n\u001b[?2004l\r\u001b[?2004h>         } else {\r\n\u001b[?2004l\r\u001b[?2004h>             (*p)++;\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[323.345002, "o", "\u001b[?2004l\r"]
[323.345141, "o", "\u001b[?2004h"]
[323.348983, "o", ">         if (len + 2 > cap) {\r\n\u001b[?2004l\r\u001b[?2004h>             cap *= 2;\r\n\u001b[?2004l\r\u001b[?2004h>             char *nb = realloc(buf, cap);\r\n\u001b[?2004l\r\u001b[?2004h>             if (!nb) {\r\n\u001b[?2004l\r\u001b[?2004h>                 free(buf);\r\n\u001b[?2004l\r\u001b[?2004h>                 return 0;\r\n\u001b[?2004l\r\u001b[?2004h>             }\r\n\u001b[?2004l\r\u001b[?2004h>             buf = nb;\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>         buf[len++] = (char)c;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     free(buf);\r\n\u001b[?2004l\r\u001b[?2004h>     return 0;\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> static int json_get_string_field(const char *json, const char *field, char **out) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[323.349469, "o", "    // Very small extractor: finds \"field\" : \"value\" with optional whitespace.\r\n\u001b[?2004l\r"]
[323.349507, "o", "\u001b[?2004h> "]
[323.349765, "o", "    // Rejects non-string values.\r\n\u001b[?2004l\r"]
[323.349797, "o", "\u001b[?2004h> "]
[323.349978, "o", "    char needle[128];\r\n\u001b[?2004l\r"]
[323.35012, "o", "\u001b[?2004h> "]
[323.350424, "o", "    snprintf(needle, sizeof(needle), \"\\\"%s\\\"\", field);\r\n\u001b[?2004l\r"]
[323.350453, "o", "\u001b[?2004h> "]
[323.350762, "o", "    const char *p = strstr(json, needle);\r\n\u001b[?2004l\r"]
[323.350889, "o", "\u001b[?2004h> "]
[323.35098, "o", "    if (!p) return 0;\r\n\u001b[?2004l\rs\u001b[?2004h"]
[323.351002, "o", "> "]
[323.351181, "o", "    p += strlen(needle);\r\n\u001b[?2004l\r"]
[323.351342, "o", "\u001b[?2004h>     skip_ws(&p);\r\n\u001b[?2004l\r"]
[323.351379, "o", "\u001b[?2004h> "]
[323.35159, "o", "    if (*p != ':') return 0;\r\n\u001b[?2004l\r"]
[323.351718, "o", "\u001b[?2004h>     p++;\r\n\u001b[?2004l\r"]
[323.351755, "o", "\u001b[?2004h> "]
[323.351918, "o", "    skip_ws(&p);\r\n\u001b[?2004l\r"]
[323.351944, "o", "\u001b[?2004h> "]
[323.352236, "o", "    if (*p != '\"') return 0;\r\n\u001b[?2004l\r"]
[323.352402, "o", "\u001b[?2004h> "]
[323.352574, "o", "    return parse_json_string(&p, out);\r\n\u001b[?2004l\r"]
[323.352734, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> "]
