[856.940981, "o", "    13\t\r\n    14\tstatic enum MHD_Result send_json_with_headers(struct MHD_Connection *connection,\r\n    15\t                                             const char *body,\r\n    16\t                                             unsigned int status_code,\r\n    17\t                                             const char *extra_header_name,\r\n    18\t                                             const char *extra_header_value) {\r\n    19\t    struct MHD_Response *response = MHD_create_response_from_buffer(\r\n    20\t        strlen(body), (void *)body, MHD_RESPMEM_MUST_COPY);\r\n    21\t\r\n    22\t    MHD_add_response_header(response, \"Content-Type\", \"application/json\");\r\n    23\t    MHD_add_response_header(response, \"Access-Control-Allow-Origin\", \"*\");\r\n    24\t    MHD_add_response_header(response, \"Access-Control-Allow-Methods\",\r\n    25\t                            \"GET, POST, PUT, DELETE, OPTIONS\");\r\n    26\t    MHD_add_response_header(response, \"Access-Control-Allow-Headers\",\r\n    27\t                            \"Content-Type, X-API-Key\");\r\n    28\t\r\n    29\t    if (extra_header_name && extra_header_value)\r\n    30\t        MHD_add_response_header(response, extra_header_name, extra_header_value);\r\n    31\t\r\n    32\t    enum MHD_Result ret = MHD_queue_response(connection, status_code, response);\r\n    33\t    MHD_destroy_response(response);\r\n    34\t    return ret;\r\n    35\t}\r\n    36\t\r\n    37\tstatic enum MHD_Result send_json(struct MHD_Connection *connection,\r\n    38\t                                const char *body,\r\n    39\t                                unsigned int status_code) {\r\n    40\t    return send_json_with_headers(connection, body, status_code, NULL, NULL);\r\n    41\t}\r\n    42\t\r\n    43\tstatic enum MHD_Result send_json_total(struct MHD_Connection *connection,\r\n    44\t                                      const char *body,\r\n    45\t                                      unsigned int status_code,\r\n    46\t                                      int total) {\r\n    47\t    char count_str[32];\r\n    48\t    snprintf(count_str, sizeof(count_str), \"%d\", total);\r\n    49\t    return send_json_with_headers(connection, body, status_code, \"X-Total-Count\", count_str);\r\n    50\t}\r\n    51\t\r\n    52\tstatic int parse_int(const char *s, int *out) {\r\n    53\t    if (!s || !*s) return 0;\r\n    54\t    char *end = NULL;\r\n    55\t    long v = strtol(s, &end, 10);\r\n    56\t    if (end == s || *end != '\\0') return 0;\r\n    57\t    if (v < 0) v = 0;\r\n    58\t    if (v > 1000000000L) v = 1000000000L;\r\n    59\t    *out = (int)v;\r\n    60\t    return 1;\r\n    61\t}\r\n    62\t\r\n    63\tstatic void skip_ws(const char **p) {\r\n    64\t    while (**p && isspace((unsigned char)**p)) (*p)++;\r\n    65\t}\r\n    66\t\r\n    67\tstatic int parse_json_string(const char **p, char **out) {\r\n    68\t    if (**p != '\"') return 0;\r\n    69\t    (*p)++;\r\n    70\t\r\n    71\t    size_t cap = 64, len = 0;\r\n    72\t    char *buf = malloc(cap);\r\n    73\t    if (!buf) return 0;\r\n    74\t\r\n    75\t    while (**p) {\r\n    76\t        unsigned char c = (unsigned char)**p;\r\n    77\t        if (c == '\"') {\r\n    78\t            (*p)++;\r\n    79\t            buf[len] = '\\0';\r\n    80\t            *out = buf;\r\n    81\t            return 1;\r\n    82\t        }\r\n    83\t\r\n    84\t        if (c == '\\\\') {\r\n    85\t            (*p)++;\r\n    86\t            c = (unsigned char)**p;\r\n    87\t            if (!c) break;\r\n    88\t            switch (c) {\r\n    89\t                case '\"': c = '\"'; break;\r\n    90\t                case '\\\\': c = '\\\\'; break;\r\n    91\t                case '/': c = '/'; break;\r\n    92\t                case 'b': c = '\\b'; break;\r\n    93\t                case 'f': c = '\\f'; break;\r\n    94\t                case 'n': c = '\\n'; break;\r\n    95\t                case 'r': c = '\\r'; break;\r\n    96\t                case 't': c = '\\t'; break;\r\n    97\t                case 'u':\r\n    98\t                    free(buf);\r\n    99\t                    return 0;\r\n   100\t                default:\r\n   101\t                    free(buf);\r\n   102\t                    return 0;\r\n   103\t            }\r\n   104\t            (*p)++;\r\n   105\t        } else {\r\n   106\t            (*p)++;\r\n   107\t "]
[856.941334, "o", "       }\r\n   108\t\r\n   109\t        if (len + 2 > cap) {\r\n   110\t            cap *= 2;\r\n   111\t            char *nb = realloc(buf, cap);\r\n   112\t            if (!nb) {\r\n   113\t                free(buf);\r\n   114\t                return 0;\r\n   115\t            }\r\n   116\t            buf = nb;\r\n   117\t        }\r\n   118\t        buf[len++] = (char)c;\r\n   119\t    }\r\n   120\t\r\n\u001b[?2004hroot@ade5f5ea62db:/app# "]
[857.060996, "i", "perl -0777 -i -pe 's@(static enum MHD_Result send_json\\(struct MHD_Connection \\*connection,\\s*const char \\*json, unsigned int status_code\\)\\s*\\{.*?\\n\\}\\n)@$1\\n#define API_KEY_PATH \"/app/config/api.key\"\\n\\nstatic enum MHD_Result send_text(struct MHD_Connection *connection, const char *text, unsigned int status) {\\n    struct MHD_Response *response = MHD_create_response_from_buffer(strlen(text), (void*)text, MHD_RESPMEM_MUST_COPY);\\n    if (!response) return MHD_NO;\\n    MHD_add_response_header(response, \"Content-Type\", \"text/plain; charset=utf-8\");\\n    enum MHD_Result ret = MHD_queue_response(connection, status, response);\\n    MHD_destroy_response(response);\\n    return ret;\\n}\\n\\nstatic enum MHD_Result send_file_text(struct MHD_Connection *connection, const char *path) {\\n    FILE *f = fopen(path, \"rb\");\\n    if (!f) return send_json(connection, \"{\\\\\\\"error\\\\\\\":\\\\\\\"not found\\\\\\\"}\", MHD_HTTP_NOT_FOUND);\\n    fseek(f, 0, SEEK_END);\\n    long n = ftell(f);\\n    fseek(f, 0, SEEK_SET);\\n    if (n < 0 || n > 1024 * 1024) { fclose(f); return send_json(connection, \"{\\\\\\\"error\\\\\\\":\\\\\\\"server error\\\\\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR); }\\n    char *buf = (char*)calloc((size_t)n + 1, 1);\\n    if (!buf) { fclose(f); return send_json(connection, \"{\\\\\\\"error\\\\\\\":\\\\\\\"server error\\\\\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR); }\\n    size_t r = fread(buf, 1, (size_t)n, f);\\n    fclose(f);\\n    buf[r] = \"\\\\0\"[0];\\n    enum MHD_Result ret = send_text(connection, buf, MHD_HTTP_OK);\\n    free(buf);\\n    return ret;\\n}\\n\\n@sm' /app/src/routes.c\n"]
[857.066217, "o", "perl -0777 -i -pe 's@(static enum MHD_Result send_json\\(struct MHD_Connection \\*connection,\\s*const char \\*json, unsigned int status_code\\)\\s*\\{.*?\\n\\}\\n)@$1\\n#define API_KEY_PATH \"/app/config/api.key\"\\n\\nstatic enum MHD_Result send_text(struct MHD_Connection *connection, const char *text, unsigned int status) {\\n    struct MHD_Response *response = MHD_create_response_from_buffer(strlen(text), (void*)text, MHD_RESPMEM_MUST_COPY);\\n    if (!response) return MHD_NO;\\n    MHD_add_response_header(response, \"Content-Type\", \"text/plain; charset=utf-8\");\\n    enum MHD_Result ret = MHD_queue_response(connection, status, response);\\n    MHD_destroy_response(response);\\n    return ret;\\n}\\n\\nstatic enum MHD_Result send_file_text(struct MHD_Connection *connection, const char *path) {\\n    FILE *f = fopen(path, \"rb\");\\n    if (!f) return send_json(connection, \"{\\\\\\\"error\\\\\\\":\\\\\\\"not found\\\\\\\"}\", MHD_HTTP_NOT_FOUND);\\n    fseek(f, 0, SEEK_END);\\n    long n = ftell(f);\\n    fseek(f, 0, SEEK_SET);\\n    if (n < 0 || n > 1024 * 1024) { fclose(f); return send_json(connection, \"{\\\\\\\"error\\\\\\\":\\\\\\\"server error\\\\\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR); }\\n    char *buf = (char*)calloc((size_t)n + 1, 1);\\n    if (!buf) { fclose(f); return send_json(connection, \"{\\\\\\\"error\\\\\\\":\\\\\\\"server error\\\\\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR); }\\n    size_t r = fread(buf, 1, (size_t)n, f);\\n    fclose(f);\\n    buf[r] = \"\\\\0\"[0];\\n    enum MHD_Result ret = send_text(connection, buf, MHD_HTTP_OK);\\n    free(buf);\\n    return ret;\\n}\\n\\n@sm' /app/src/routes.c\r\n"]
