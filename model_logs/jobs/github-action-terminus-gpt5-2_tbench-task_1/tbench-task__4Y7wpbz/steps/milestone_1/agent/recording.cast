[412.881321, "i", "python3 - <<'PY'\nimport json\nimport concurrent.futures\nimport requests\n\nURL='http://127.0.0.1:8080/api/notes'\nH={'Content-Type':'application/json','X-API-Key':'tb3_notes_api_secret_2026'}\n\ndef post(i):\n    r=requests.post(URL, headers=H, data=json.dumps({'title':f't{i}','content':f'c{i}'}))\n    return r.status_code\n\nwith concurrent.futures.ThreadPoolExecutor(max_workers=15) as ex:\n    codes=list(ex.map(post, range(15)))\nprint('codes', {c:codes.count(c) for c in set(codes)})\n\nr=requests.get(URL)\nprint('get', r.status_code)\nprint('X-Total-Count', r.headers.get('X-Total-Count'))\nprint('len', len(r.json()))\nPY\n"]
