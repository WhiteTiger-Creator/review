[323.355115, "o", "static int parse_id_from_url(const char *url, int *out_id) {\r\n\u001b[?2004l\r"]
[323.355204, "o", "\u001b[?2004h> "]
[323.355473, "o", "    const char *prefix = \"/api/notes/\";\r\n\u001b[?2004l\r"]
[323.355503, "o", "\u001b[?2004h> "]
[323.355754, "o", "    size_t n = strlen(prefix);\r\n\u001b[?2004l\r"]
[323.355797, "o", "\u001b[?2004h> "]
[323.356218, "o", "    if (strncmp(url, prefix, n) != 0) return 0;\r\n\u001b[?2004l\r"]
[323.356257, "o", "\u001b[?2004h> "]
[323.356573, "o", "    const char *idstr = url + n;\r\n\u001b[?2004l\r"]
[323.356614, "o", "\u001b[?2004h> "]
[323.356848, "o", "    if (*idstr == '\\0') return 0;\r\n\u001b[?2004l\r"]
[323.357378, "o", "\u001b[?2004h>     // disallow trailing slash\r\n\u001b[?2004l\r\u001b[?2004h> "]
[323.357412, "o", "    if (strchr(idstr, '/')) return 0;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[323.357725, "o", "    return parse_int(idstr, out_id);\r\n\u001b[?2004l\r\u001b[?2004h> }"]
