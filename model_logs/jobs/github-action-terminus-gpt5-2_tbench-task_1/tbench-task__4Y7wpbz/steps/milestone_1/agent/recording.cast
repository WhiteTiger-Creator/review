[238.013223, "o", "cat /app/include/common.h\r\n"]
[238.013391, "o", "\u001b[?2004l\r"]
[238.014944, "o", "#ifndef NOTES_COMMON_H\r\n#define NOTES_COMMON_H\r\n\r\n#define NOTES_MAX_BODY_BYTES 65536\r\n#define NOTES_DEFAULT_PAGE_SIZE 50\r\n#define NOTES_MAX_PAGE_SIZE 100\r\n\r\n#endif\r\n\u001b[?2004hroot@ade5f5ea62db:/app# "]
[249.589225, "i", "sed -n '1,260p' /app/docs/api_contract.md\n"]
[249.58963, "o", "sed -n '1,260p' /app/docs/api_contract.md\r\n\u001b[?2004l\r"]
[249.591395, "o", "This document is the normative REST contract for the notes API. Automated checks use arbitrary title and content strings in requests; only the behaviors, status codes, headers, and JSON field names here matter.\r\n\r\nStore notes in /app/data/notes.db. Read the shared secret from /app/config/api.key and trim surrounding whitespace before comparing it to the X-API-Key header on mutating requests. The stock api.key file ships with tb3_notes_api_secret_2026. POST, PUT, and DELETE require a matching key or the server responds unauthorized. GET never requires the key; a bad or missing key on a mutating call is unauthorized.\r\n\r\nEvery JSON response must use a JSON content type and include an access-control header that allows any origin. OPTIONS preflight must advertise GET, POST, PUT, DELETE, and OPTIONS, and must allow Content-Type and X-API-Key as request headers. Preflight may return empty or non-empty success.\r\n\r\n"]
[249.591591, "o", "POST /api/notes accepts JSON with string title and content. Title must be present and non-empty; an empty object or missing or blank title is a client error. Success is HTTP 201 with a body containing numeric id plus stored title and content. GET /api/notes returns a JSON array of objects with id, title, and content. Optional limit and offset query parameters are integers: default limit 50, maximum 100, default offset 0. /api/notes?limit=100 returns at most one hundred rows; /api/notes?limit=999 is capped the same way. The total row count before paging goes in the X-Total-Count header.\r\n\r\nGET /api/notes/{id} returns that object. A missing id returns HTTP 404 with JSON {\"error\":\"not found\"} using that exact lowercase message string, including for ids such as /api/notes/99999 on GET, PUT, or DELETE. PUT uses the same field rules as POST, returns HTTP 200 with saved fields when the row exists, or the same not-found JSON when it does not. Successful DELETE returns HTTP 200 with JSON {\"status\":\"deleted\"}; deleting a missing id returns the same not-found JSON as GET. Reject POST or PUT bodies larger than 65536 bytes with HTTP 413 and a JSON error body.\r\n\r\nSQLite access must remain correct under concurrent requests. Verifiers may reset /app/data/notes.db and send bursts of about fifteen parallel POST requests; every stored row must still appear in responses afterward.\r\n"]
[249.591738, "o", "\u001b[?2004hroot@ade5f5ea62db:/app# "]
[249.713954, "i", "apply_patch<<'PATCH'\n*** Begin Patch\n*** Update File: src/auth.c\n@@\n-#include \"auth.h\"\n-\n-int api_key_valid(struct MHD_Connection *connection) {\n-    (void)connection;\n-    return 0;\n-}\n+#include \"auth.h\"\n+\n+#include <ctype.h>\n+#include <stdio.h>\n+#include <stdlib.h>\n+#include <string.h>\n+\n+#define API_KEY_PATH \"/app/config/api.key\"\n+\n+static char *g_api_key = NULL;\n+static int g_loaded = 0;\n+\n+static void rstrip(char *s) {\n+    size_t n = strlen(s);\n+    while (n > 0 && isspace((unsigned char)s[n - 1])) {\n+        s[n - 1] = '\\0';\n+        n--;\n+    }\n+}\n+\n+static char *load_api_key(void) {\n+    FILE *f = fopen(API_KEY_PATH, \"rb\");\n+    if (!f) return NULL;\n+\n+    char buf[512];\n+    size_t n = fread(buf, 1, sizeof(buf) - 1, f);\n+    fclose(f);\n+    buf[n] = '\\0';\n+\n+    // trim leading/trailing whitespace\n+    char *start = buf;\n+    while (*start && isspace((unsigned char)*start)) start++;\n+    rstrip(start);\n+    if (*start == '\\0') return NULL;\n+    return strdup(start);\n+}\n+\n+int api_key_valid(struct MHD_Connection *connection) {\n+    if (!g_loaded) {\n+        g_api_key = load_api_key();\n+        g_loaded = 1;\n+    }\n+\n+    if (!g_api_key) return 0;\n+\n+    const char *hdr = MHD_lookup_connection_value(connection, MHD_HEADER_KIND, \"X-API-Key\");\n+    if (!hdr) return 0;\n+\n+    // header must match exactly (api.key already trimmed)\n+    return strcmp(hdr, g_api_key) == 0;\n+}\n*** End Patch\nPATCH\n"]
