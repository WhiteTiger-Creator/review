[573.097444, "i", "pids=$(python3 - <<'PY'\nimport os\n\ndef pids_listening(port=8080):\n    target=f\"{port:04X}\"\n    inodes=set()\n    with open('/proc/net/tcp','r') as f:\n        next(f)\n        for line in f:\n            parts=line.split()\n            if len(parts) < 10 or parts[3] != '0A':\n                continue\n            _ip,port_hex=parts[1].split(':')\n            if port_hex==target:\n                inodes.add(parts[9])\n    pids=set()\n    for pid in filter(str.isdigit, os.listdir('/proc')):\n        fd_dir=f'/proc/{pid}/fd'\n        try:\n            for fd in os.listdir(fd_dir):\n                try:\n                    link=os.readlink(f'{fd_dir}/{fd}')\n                except OSError:\n                    continue\n                if link.startswith('socket:[') and link[8:-1] in inodes:\n                    pids.add(pid)\n        except OSError:\n            continue\n    return sorted(pids)\n\nprint(' '.join(pids_listening(8080)))\nPY\n); echo \"killing: $pids\"; for p in $pids; do kill -9 $p 2>/dev/null || true; done\n"]
