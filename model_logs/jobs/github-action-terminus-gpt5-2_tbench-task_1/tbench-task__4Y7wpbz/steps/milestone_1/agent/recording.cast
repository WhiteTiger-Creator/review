[583.309306, "i", "python3 - <<'PY'\nimport json, os, subprocess, tempfile\npayload=json.dumps({'title':'t','content':'x'*70000}).encode()\nfd, path = tempfile.mkstemp()\nos.write(fd, payload)\nos.close(fd)\ncmd=['curl','-i','-s','-X','POST','http://127.0.0.1:8080/api/notes','-H','Content-Type: application/json','-H','X-API-Key: tb3_notes_api_secret_2026','--data-binary','@'+path]\nres=subprocess.run(cmd, text=True, capture_output=True)\nprint(res.stdout.split('\\n\\n',1)[0])\nprint(res.stdout.split('\\n\\n',1)[1][:200] if '\\n\\n' in res.stdout else res.stdout[:200])\nos.unlink(path)\nPY\n"]
