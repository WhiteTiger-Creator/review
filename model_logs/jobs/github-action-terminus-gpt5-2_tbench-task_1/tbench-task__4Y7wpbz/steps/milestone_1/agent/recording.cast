[323.326937, "o", "\u001b[?2004h"]
[323.326964, "o", "> "]
[323.327288, "o", "    if (end == s || *end != '\\0') return 0;\r\n\u001b[?2004l\r"]
[323.327323, "o", "\u001b[?2004h"]
[323.327379, "o", "> "]
