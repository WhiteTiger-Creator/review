[124.225748, "o", "HTTP/1.1 200 OK\r\r\nDate: Tue, 26 May 2026 12:43:08 GMT\r\r\nConnection: close\r\r\nContent-Type: text/css\r\r\nContent-Length: 1009\r\r\n\r\r\n* { margin: 0; padding: 0; box-sizing: border-box; }\r\nbody { font-family: sans-serif; background: #f5f5f5; padding: 2rem; }\r\n.container { max-width: 640px; margin: 0 auto; }\r\nh1 { margin-bottom: 1rem; }\r\n#note-form { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1.5rem; }\r\n#note-title, #note-content { padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px; font-size: 1rem; }\r\n#note-content { min-height: 80px; resize: vertical; }\r\nbutton { padding: 0.5rem 1rem; border: none; border-radius: 4px; cursor: pointer; font-size: 1rem; }\r\nbutton[type=\"submit\"] { background: #2563eb; color: #fff; }\r\n.note-card { background: #fff; border: 1px solid #ddd; border-radius: 6px; padding: 1rem; margin-bottom: 0.75rem; }\r\n.note-card h3 { margin-bottom: 0.25rem; }\r\n.note-card p { color: #555; margin-bottom: 0.5rem; }\r\n.note-actions { display: flex; gap: 0.5rem; }\r\n.edit-btn { background: #f59e0b; color: #fff; font-size: 0.85rem; }\r\n"]
