[123.233572, "o", "    <link rel=\"stylesheet\" href=\"/style.css\">\r\n</head>\r\n<body>\r\n    <div class=\"container\">\r\n        <h1>Notes</h1>\r\n        <form id=\"note-form\">\r\n            <input type=\"text\" id=\"note-title\" placeholder=\"Title\" required>\r\n            <textarea id=\"note-content\" placeholder=\"Content\"></textarea>\r\n"]
