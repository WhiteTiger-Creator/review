[571.306286, "o", "\u001b[?2004hroot@ade5f5ea62db:/app# "]
[572.093514, "i", "python3 - <<'PY'\nimport os\n\ndef find_listeners(port=8080):\n    target = f\"{port:04X}\"\n    inodes=set()\n    with open('/proc/net/tcp','r') as f:\n        next(f)\n        for line in f:\n            parts=line.split()\n            if len(parts) < 10:\n                continue\n            local=parts[1]\n            state=parts[3]\n            inode=parts[9]\n            if state!='0A':\n                continue\n            _ip,port_hex=local.split(':')\n            if port_hex==target:\n                inodes.add(inode)\n    pids=set()\n    for pid in filter(str.isdigit, os.listdir('/proc')):\n        fd_dir=f'/proc/{pid}/fd'\n        try:\n            for fd in os.listdir(fd_dir):\n                try:\n                    link=os.readlink(f'{fd_dir}/{fd}')\n                except OSError:\n                    continue\n                if link.startswith('socket:[') and link[8:-1] in inodes:\n                    pids.add(int(pid))\n        except OSError:\n            continue\n    return sorted(pids)\n\npids=find_listeners(8080)\nprint('pids', pids)\nfor pid in pids:\n    try:\n        cmd=open(f'/proc/{pid}/cmdline','rb').read().replace(b'\\0',b' ').decode()\n    except Exception:\n        cmd='?'\n    print(pid, cmd)\nPY\n"]
[572.093878, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r"]
[572.094061, "o", "\u001b[?2004h> import os\r\n\u001b[?2004l\r"]
[572.094253, "o", "\u001b[?2004h> "]
[572.09437, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
