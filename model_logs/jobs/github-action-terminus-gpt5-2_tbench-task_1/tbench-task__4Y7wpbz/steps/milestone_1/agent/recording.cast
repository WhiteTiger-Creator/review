[608.187452, "o", "-rw-r--r--  1 root root  943 May 26 12:40 app.js\r\n-rw-r--r--  1 root root  643 May 26 12:40 index.html\r\n-rw-r--r--  1 root root 1009 May 26 12:40 style.css\r\n"]
