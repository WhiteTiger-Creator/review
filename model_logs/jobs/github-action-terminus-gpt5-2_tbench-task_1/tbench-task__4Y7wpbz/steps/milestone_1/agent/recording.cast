[705.381331, "o", "     1\t#include \"routes.h\"\r\n"]
[705.381777, "o", "     2\t\r\n     3\t#include \"auth.h\"\r\n     4\t#include \"common.h\"\r\n     5\t#include \"db.h\"\r\n     6\t\r\n     7\t#include <microhttpd.h>\r\n     8\t#include <ctype.h>\r\n     9\t#include <stdio.h>\r\n    10\t\r\n    11\t#define API_KEY_PATH \"/app/config/api.key\"\r\n    12\t\r\n    13\tstatic int send_text(struct MHD_Connection *connection, const char *text, int status) {\r\n    14\t    struct MHD_Response *response = MHD_create_response_from_buffer(strlen(text), (void*)text, MHD_RESPMEM_MUST_COPY);\r\n    15\t    if (!response) return MHD_NO;\r\n    16\t    MHD_add_response_header(response, \"Content-Type\", \"text/plain; charset=utf-8\");\r\n    17\t    int ret = MHD_queue_response(connection, status, response);\r\n    18\t    MHD_destroy_response(response);\r\n    19\t    return ret;\r\n    20\t}\r\n    21\t\r\n    22\tstatic int send_file_text(struct MHD_Connection *connection, const char *path) {\r\n    23\t    FILE *f = fopen(path, \"rb\");\r\n    24\t    if (!f) return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\r\n    25\t    fseek(f, 0, SEEK_END);\r\n    26\t    long n = ftell(f);\r\n    27\t    fseek(f, 0, SEEK_SET);\r\n    28\t    if (n < 0 || n > 1024 * 1024) { fclose(f); return send_json(connection, \"{\\\"error\\\":\\\"server error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR); }\r\n    29\t    char *buf = (char*)calloc((size_t)n + 1, 1);\r\n    30\t    if (!buf) { fclose(f); return send_json(connection, \"{\\\"error\\\":\\\"server error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR); }\r\n    31\t    size_t r = fread(buf, 1, (size_t)n, f);\r\n    32\t    fclose(f);\r\n    33\t    buf[r] = \"\\0\"[0];\r\n    34\t    int ret = send_text(connection, buf, MHD_HTTP_OK);\r\n    35\t    free(buf);\r\n    36\t    return ret;\r\n    37\t}\r\n    38\t\r\n    39\t#include <stdlib.h>\r\n    40\t#include <string.h>\r\n    41\t\r\n    42\tstatic enum MHD_Result send_json_with_headers(struct MHD_Connection *connection,\r\n    43\t                                             const char *body,\r\n    44\t                                             unsigned int status_code,\r\n    45\t                                             const char *extra_header_name,\r\n    46\t                                             const char *extra_header_value) {\r\n    47\t    struct MHD_Response *response = MHD_create_response_from_buffer(\r\n    48\t        strlen(body), (void *)body, MHD_RESPMEM_MUST_COPY);\r\n    49\t\r\n    50\t    MHD_add_response_header(response, \"Content-Type\", \"application/json\");\r\n    51\t    MHD_add_response_header(response, \"Access-Control-Allow-Origin\", \"*\");\r\n    52\t    MHD_add_response_header(response, \"Access-Control-Allow-Methods\",\r\n    53\t                            \"GET, POST, PUT, DELETE, OPTIONS\");\r\n    54\t    MHD_add_response_header(response, \"Access-Control-Allow-Headers\",\r\n    55\t                            \"Content-Type, X-API-Key\");\r\n    56\t\r\n    57\t    if (extra_header_name && extra_header_value)\r\n    58\t        MHD_add_response_header(response, extra_header_name, extra_header_value);\r\n    59\t\r\n    60\t    enum MHD_Result ret = MHD_queue_response(connection, status_code, response);\r\n    61\t    MHD_destroy_response(response);\r\n    62\t    return ret;\r\n    63\t}\r\n"]
[705.381811, "o", "    64\t\r\n    65\tstatic enum MHD_Result send_json(struct MHD_Connection *connection,\r\n    66\t                                const char *body,\r\n    67\t                                unsigned int status_code) {\r\n    68\t    return send_json_with_headers(connection, body, status_code, NULL, NULL);\r\n    69\t}\r\n    70\t\r\n    71\tstatic enum MHD_Result send_json_total(struct MHD_Connection *connection,\r\n    72\t                                      const char *body,\r\n    73\t                                      unsigned int status_code,\r\n"]
[705.381832, "o", "    74\t                                      int total) {\r\n    75\t    char count_str[32];\r\n    76\t    snprintf(count_str, sizeof(count_str), \"%d\", total);\r\n    77\t"]
[705.381853, "o", "    return send_json_with_headers(connection, body, status_code, \"X-Total-Count\", count_str);\r\n    78\t}\r\n    79\t\r\n"]
[705.381871, "o", "    80\tstatic int parse_int(const char *s, int *out) {\r\n    81\t    if (!s || !*s) return 0;\r\n    82\t    char *end = NULL;\r\n    83"]
[705.381891, "o", "\t    long v = strtol(s, &end, 10);\r\n    84\t    if (end == s || *end != '\\0') return 0;\r\n"]
