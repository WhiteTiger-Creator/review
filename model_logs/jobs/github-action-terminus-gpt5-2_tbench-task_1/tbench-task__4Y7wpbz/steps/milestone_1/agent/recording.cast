[625.992984, "o", "\u001b[?2004l\r\u001b[?2004h>   return row;\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> async function loadNotes() {\r\n\u001b[?2004l\r\u001b[?2004h>   var res = await apiFetch(API_BASE);\r\n\u001b[?2004l\r\u001b[?2004h>   var notes = await res.json();\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>   var list = getEl('notes-list');\r\n\u001b[?2004l\r\u001b[?2004h>   list.innerHTML = '';\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>   (notes || []).forEach(function (note) {\r\n\u001b[?2004l\r\u001b[?2004h>     list.appendChild(makeRow(note));\r\n\u001b[?2004l\r\u001b[?2004h>   });\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> getEl('note-form').addEventListener('submit', async function (e) {\r\n\u001b[?2004l\r\u001b[?2004h>   e.preventDefault();\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>   var title = (getEl('note-title').value || '').trim();\r\n\u001b[?2004l\r\u001b[?2004h>   var content = (getEl('note-content').value || '').trim();\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>   var body = JSON.stringify({ title: title, content: content });\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>   if (!editingId) {\r\n\u001b[?2004l\r\u001b[?2004h>     await apiFetch(API_BASE, {\r\n\u001b[?2004l\r\u001b[?2004h>       method: 'POST',\r\n\u001b[?2004l\r\u001b[?2004h>       body: body\r\n\u001b[?2004l\r\u001b[?2004h>     });\r\n\u001b[?2004l\r\u001b[?2004h"]
