[641.191244, "o", "#include \"routes.h\"\r\n"]
[641.191366, "o", "\r\n"]
[641.191754, "o", "#include \"auth.h\"\r\n#include \"common.h\"\r\n#include \"db.h\"\r\n\r\n#include <microhttpd.h>\r\n#include <ctype.h>\r\n#include <stdio.h>\r\n#include <stdlib.h>\r\n#include <string.h>\r\n\r\nstatic enum MHD_Result send_json_with_headers(struct MHD_Connection *connection,\r\n                                             const char *body,\r\n                                             unsigned int status_code,\r\n                                             const char *extra_header_name,\r\n                                             const char *extra_header_value) {\r\n    struct MHD_Response *response = MHD_create_response_from_buffer(\r\n        strlen(body), (void *)body, MHD_RESPMEM_MUST_COPY);\r\n\r\n"]
[641.191919, "o", "    MHD_add_response_header(response, \"Content-Type\", \"application/json\");\r\n    MHD_add_response_header(response, \"Access-Control-Allow-Origin\", \"*\");\r\n    MHD_add_response_header(response, \"Access-Control-Allow-Methods\",\r\n                            \"GET, POST, PUT, DELETE, OPTIONS\");\r\n    MHD_add_response_header(response, \"Access-Control-Allow-Headers\",\r\n                            \"Content-Type, X-API-Key\");\r\n\r\n    if (extra_header_name && extra_header_value)\r\n        MHD_add_response_header(response, extra_header_name, extra_header_value);\r\n\r\n    enum MHD_Result ret = MHD_queue_response(connection, status_code, response);\r\n    MHD_destroy_response(response);\r\n    return ret;\r\n}\r\n\r\nstatic enum MHD_Result send_json(struct MHD_Connection *connection,\r\n                                const char *body,\r\n                                unsigned int status_code) {\r\n    return send_json_with_headers(connection, body, status_code, NULL, NULL);\r\n}\r\n\r\nstatic enum MHD_Result send_json_total(struct MHD_Connection *connection,\r\n                                      const char *body,\r\n                                      unsigned int status_code,\r\n                                      int total) {\r\n    char count_str[32];\r\n    snprintf(count_str, sizeof(count_str), \"%d\", total);\r\n    return send_json_with_headers(connection, body, status_code, \"X-Total-Count\", count_str);\r\n}\r\n\r\nstatic int parse_int(const char *s, int *out) {\r\n    if (!s || !*s) return 0;\r\n    char *end = NULL;\r\n    long v = strtol(s, &end, 10);\r\n    if (end == s || *end != '\\0') return 0;\r\n    if (v < 0) v = 0;\r\n    if (v > 1000000000L) v = 1000000000L;\r\n    *out = (int)v;\r\n    return 1;\r\n}\r\n\r\nstatic void skip_ws(const char **p) {\r\n    while (**p && isspace((unsigned char)**p)) (*p)++;\r\n}\r\n\r\nstatic int parse_json_string(const char **p, char **out) {\r\n    if (**p != '\"') return 0;\r\n    (*p)++;\r\n\r\n    size_t cap = 64, len = 0;\r\n    char *buf = malloc(cap);\r\n    if (!buf) return 0;\r\n\r\n    while (**p) {\r\n        unsigned char c = (unsigned char)**p;\r\n        if (c == '\"') {\r\n            (*p)++;\r\n            buf[len] = '\\0';\r\n            *out = buf;\r\n            return 1;\r\n        }\r\n\r\n        if (c == '\\\\') {\r\n            (*p)++;\r\n            c = (unsigned char)**p;\r\n            if (!c) break;\r\n            switch (c) {\r\n                case '\"': c = '\"'; break;\r\n                case '\\\\': c = '\\\\'; break;\r\n                case '/': c = '/'; break;\r\n                case 'b': c = '\\b'; break;\r\n                case 'f': c = '\\f'; break;\r\n                case 'n': c = '\\n'; break;\r\n                case 'r': c = '\\r'; break;\r\n                case 't': c = '\\t'; break;\r\n                case 'u':\r\n                    free(buf);\r\n                    return 0;\r\n                default:\r\n                    free(buf);\r\n                    return 0;\r\n            }\r\n            (*p)++;\r\n        } else {\r\n            (*p)++;\r\n        }\r\n\r\n        if (len + 2 > cap) {\r\n            cap *= 2;\r\n            char *nb = realloc(buf, cap);\r\n            if (!nb) {\r\n                free(buf);\r\n                return 0;\r\n            }\r\n            buf = nb;\r\n        }\r\n        buf[len++] = (char)c;\r\n    }\r\n\r\n    free(buf);\r\n    return 0;\r\n}\r\n\r\nstatic int json_get_string_field(const char *json, const char *field, char **out) {\r\n    char needle[128];\r\n    snprintf(needle, sizeof(needle), \"\\\"%s\\\"\", field);\r\n    const char *p = strstr(json, needle);\r\n    if (!p) return 0;\r\n    p += strlen(needle);\r\n    skip_ws(&p);\r\n    if (*p != ':') return 0;\r\n    p++;\r\n    skip_ws(&p);\r\n    if (*p != '\"') return 0;\r\n    return parse_json_string(&p, out);\r\n}\r\n\r\nstatic int is_blank_title(const char *s) {\r\n    if (!s) return 1;\r\n    const char *p = s;\r\n    while (*p) {\r\n        if (!isspace((unsigned char)*p)) return 0;\r\n        p++;\r\n"]
[641.191944, "o", "    }\r\n    return 1;\r\n}\r\n\r\nstatic int parse_id_from_url(const char *url, int *out_id) {\r\n    const char *prefix = \"/api/notes/\";\r\n    size_t n = strlen(prefix);\r\n    if (strncmp(url, prefix, n) != 0) return 0;\r\n    const char *idstr = url + n;\r\n    if (*idstr == '\\0') return 0;\r\n    if (strchr(idstr, '/')) return 0;"]
[641.191968, "o", "\r\n    return parse_int(idstr, out_id);\r\n}\r\n\r\nstatic enum MHD_Result init_con_info(void **con_cls) {\r\n"]
[641.191988, "o", "    struct connection_info *ci = calloc(1, sizeof(*ci));\r\n    if (!ci) return MHD_NO;\r\n    *con_cls = ci;\r\n    return MHD_YES;\r\n}\r\n\r\n"]
[641.192012, "o", "static enum MHD_Result handle_post_put_body(struct MHD_Connection *connection,\r\n                                           const char *method,\r\n                                           const char *url,\r\n                                           const char *upload_data,\r\n                                           size_t *upload_data_size,\r\n"]
[641.192033, "o", "                                           void **con_cls) {\r\n    struct connection_info *ci = (struct connection_info *)(*con_cls);\r\n    if (!ci) return MHD_NO;\r\n\r\n    if (*upload_data_size != 0) {\r\n        if (ci->too_large) {\r\n"]
[641.192055, "o", "            *upload_data_size = 0;\r\n            return MHD_YES;\r\n        }\r\n\r\n        if (ci->data_size + *upload_data_size > NOTES_MAX_BODY_BYTES) {\r\n"]
[641.192073, "o", "            ci->too_large = 1;\r\n            *upload_data_size = 0;\r\n            return MHD_YES;\r\n        }\r\n\r\n"]
[641.192095, "o", "        char *nb = realloc(ci->data, ci->data_size + *upload_data_size + 1);\r\n        if (!nb) {\r\n            *upload_data_size = 0;\r\n            return MHD_NO;\r\n"]
[641.192115, "o", "        }\r\n        ci->data = nb;\r\n        memcpy(ci->data + ci->data_size, upload_data, *upload_data_size);\r\n        ci->data_size += *upload_data_size;\r\n        ci->data[ci->data_size] = '\\0';\r\n"]
[641.192134, "o", "        *upload_data_size = 0;\r\n        return MHD_YES;\r\n    }\r\n\r\n"]
[641.192154, "o", "    if (ci->too_large) {\r\n        return send_json(connection, \"{\\\"error\\\":\\\"payload too large\\\"}\", MHD_HTTP_PAYLOAD_TOO_LARGE);\r\n    }\r\n\r\n    const char *body = ci->data ? ci->data : \"\";\r\n"]
[641.192173, "o", "\r\n    char *title = NULL;\r\n    char *content = NULL;\r\n    int has_title = json_get_string_field(body, \"title\", &title);\r\n"]
[641.192199, "o", "    (void)json_get_string_field(body, \"content\", &content);\r\n\r\n    if (!has_title || is_blank_title(title)) {\r\n        free(title);\r\n"]
[641.192219, "o", "        free(content);\r\n        return send_json(connection, \"{\\\"error\\\":\\\"bad request\\\"}\", MHD_HTTP_BAD_REQUEST);\r\n    }\r\n\r\n    if (strcmp(method, \"POST\") == 0 && strcmp(url, \"/api/notes\") == 0) {\r\n"]
[641.192243, "o", "        int id = create_note(title, content ? content : \"\");\r\n        free(title);\r\n        free(content);\r\n        if (id < 0)\r\n"]
[641.192262, "o", "            return send_json(connection, \"{\\\"error\\\":\\\"server error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR);\r\n        char *saved = get_note_json(id);\r\n        if (!saved)\r\n            return send_json(connection, \"{\\\"error\\\":\\\"server error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR);\r\n        enum MHD_Result r = send_json(connection, saved, MHD_HTTP_CREATED);\r\n        free(saved);\r\n"]
[641.192285, "o", "        return r;\r\n    }\r\n\r\n    if (strcmp(method, \"PUT\") == 0) {\r\n        int id = 0;\r\n"]
[641.192304, "o", "        if (!parse_id_from_url(url, &id)) {\r\n            free(title);\r\n            free(content);\r\n            return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\r\n        }"]
[641.192324, "o", "\r\n        if (!note_exists(id)) {\r\n            free(title);\r\n            free(content);\r\n            return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\r\n"]
[641.192344, "o", "        }\r\n        if (!update_note(id, title, content ? content : \"\")) {\r\n            free(title);\r\n            free(content);\r\n"]
[641.192365, "o", "            return send_json(connection, \"{\\\"error\\\":\\\"server error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR);\r\n        }\r\n        free(title);\r\n        free(content);\r\n        char *saved = get_note_json(id);\r\n        if (!saved)\r\n"]
[641.192386, "o", "            return send_json(connection, \"{\\\"error\\\":\\\"server error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR);\r\n        enum MHD_Result r = send_json(connection, saved, MHD_HTTP_OK);\r\n        free(saved);\r\n"]
[641.192408, "o", "        return r;\r\n    }\r\n\r\n    free(title);\r\n"]
[641.19243, "o", "    free(content);\r\n    return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\r\n}\r\n"]
[641.193117, "o", "\u001b[?2004hroot@ade5f5ea62db:/app# "]
