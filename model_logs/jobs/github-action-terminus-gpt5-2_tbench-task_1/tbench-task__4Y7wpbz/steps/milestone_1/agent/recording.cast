[752.909149, "o", "     8\t#include <ctype.h>\r\n     9\t#include <stdio.h>\r\n    10\t\r\n    11\t#define API_KEY_PATH \"/app/config/api.key\"\r\n    12\t\r\n    13\t// Forward declaration (send_file_text uses send_json before its definition).\r\n    14\tstatic enum MHD_Result send_json(struct MHD_Connection *connection,\r\n    15\t                                const char *json, unsigned int status_code);\r\n    16\t\r\n    17\tstatic int send_text(struct MHD_Connection *connection, const char *text, int status) {\r\n    18\t    struct MHD_Response *response = MHD_create_response_from_buffer(strlen(text), (void*)text, MHD_RESPMEM_MUST_COPY);\r\n    19\t    if (!response) return MHD_NO;\r\n    20\t    MHD_add_response_header(response, \"Content-Type\", \"text/plain; charset=utf-8\");\r\n    21\t    int ret = MHD_queue_response(connection, status, response);\r\n"]
[752.909289, "o", "    22\t    MHD_destroy_response(response);\r\n    23\t    return ret;\r\n    24\t}\r\n    25\t\r\n    26\tstatic int send_file_text(struct MHD_Connection *connection, const char *path) {\r\n    27\t    FILE *f = fopen(path, \"rb\");\r\n    28\t    if (!f) return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\r\n    29\t    fseek(f, 0, SEEK_END);\r\n    30\t    long n = ftell(f);\r\n    31\t    fseek(f, 0, SEEK_SET);\r\n    32\t    if (n < 0 || n > 1024 * 1024) { fclose(f); return send_json(connection, \"{\\\"error\\\":\\\"server error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR); }\r\n    33\t    char *buf = (char*)calloc((size_t)n + 1, 1);\r\n    34\t    if (!buf) { fclose(f); return send_json(connection, \"{\\\"error\\\":\\\"server error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR); }\r\n    35\t    size_t r = fread(buf, 1, (size_t)n, f);\r\n    36\t    fclose(f);\r\n    37\t    buf[r] = \"\\0\"[0];\r\n    38\t    int ret = send_text(connection, buf, MHD_HTTP_OK);\r\n    39\t    free(buf);\r\n    40\t    return ret;\r\n    41\t}\r\n    42\t\r\n    43\t#include <stdlib.h>\r\n    44\t#include <string.h>\r\n    45\t#include <stdlib.h>\r\n    46\t\r\n    47\tstatic enum MHD_Result send_json_with_headers(struct MHD_Connection *connection,\r\n    48\t                                             const char *body,\r\n    49\t                                             unsigned int status_code,\r\n    50\t                                             const char *extra_header_name,\r\n    51\t                                             const char *extra_header_value) {\r\n    52\t    struct MHD_Response *response = MHD_create_response_from_buffer(\r\n    53\t        strlen(body), (void *)body, MHD_RESPMEM_MUST_COPY);\r\n    54\t\r\n    55\t    MHD_add_response_header(response, \"Content-Type\", \"application/json\");\r\n    56\t    MHD_add_response_header(response, \"Access-Control-Allow-Origin\", \"*\");\r\n    57\t    MHD_add_response_header(response, \"Access-Control-Allow-Methods\",\r\n    58\t                            \"GET, POST, PUT, DELETE, OPTIONS\");\r\n    59\t    MHD_add_response_header(response, \"Access-Control-Allow-Headers\",\r\n    60\t                            \"Content-Type, X-API-Key\");\r\n    61\t\r\n    62\t    if (extra_header_name && extra_header_value)\r\n    63\t        MHD_add_response_header(response, extra_header_name, extra_header_value);\r\n    64\t\r\n    65\t    enum MHD_Result ret = MHD_queue_response(connection, status_code, response);\r\n    66\t    MHD_destroy_response(response);\r\n    67\t    return ret;\r\n    68\t}\r\n    69\t\r\n    70\tstatic enum MHD_Result send_json(struct MHD_Connection *connection,\r\n    71\t                                const char *body,\r\n    72\t                                unsigned int status_code) {\r\n    73\t    return send_json_with_headers(connection, body, status_code, NULL, NULL);\r\n    74\t}\r\n    75\t\r\n    76\tstatic enum MHD_Result send_json_total(struct MHD_Connection *connection,\r\n    77\t                                      const char *body,\r\n    78\t                                      unsigned int status_code,\r\n    79\t                                      int total) {\r\n    80\t    char count_str[32];\r\n    81\t    snprintf(count_str, sizeof(count_str), \"%d\", total);\r\n    82\t    return send_json_with_headers(connection, body, status_code, \"X-Total-Count\", count_str);\r\n    83\t}\r\n    84\t\r\n    85\tstatic int parse_int(const char *s, int *out) {\r\n    86\t    if (!s || !*s) return 0;\r\n    87\t    char *end = NULL;\r\n    88\t    long v = strtol(s, &end, 10);\r\n    89\t    if (end == s || *end != '\\0') return 0;\r\n    90\t    if (v < 0) v = 0;\r\n    91\t    if (v > 1000000000L) v = 1000000000L;\r\n    92\t    *out = (int)v;\r\n    93\t    return 1;\r\n    94\t}\r\n    95\t\r\n    96\tstatic void skip_ws(const char **p) {\r\n    97\t    while (**p && isspace((unsigned char)**p)) (*p)++;\r\n    98\t}\r\n    99\t\r\n   100\tstatic int parse_json_string(const char **p, char **out) {\r\n   101\t    if (**p != '\"') return 0;\r\n   102\t    (*p)++;\r\n   103\t\r\n   104\t    size_t cap = 64, len = 0;\r\n   105\t    char *buf = malloc(cap);\r\n   106\t    if (!buf) return 0;\r\n   107\t\r\n   108\t    while (**p) {\r\n   109\t        unsigned char c = (unsigned char)**p;\r\n   110\t        if (c == "]
