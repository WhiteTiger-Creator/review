[727.000147, "o", "     1\t#include \"routes.h\"\r\n     2\t\r\n     3\t#include \"auth.h\"\r\n     4\t#include \"common.h\"\r\n     5\t#include \"db.h\"\r\n     6\t\r\n     7\t#include <microhttpd.h>\r\n     8\t#include <ctype.h>\r\n     9\t#include <stdio.h>\r\n    10\t\r\n    11\t#define API_KEY_PATH \"/app/config/api.key\"\r\n    12\t\r\n    13\t// Forward declaration (send_file_text uses send_json before its definition).\r\n    14\tstatic enum MHD_Result send_json(struct MHD_Connection *connection,\r\n    15\t                                const char *json, unsigned int status_code);\r\n    16\t\r\n    17\tstatic int send_text(struct MHD_Connection *connection, const char *text, int status) {\r\n    18\t    struct MHD_Response *response = MHD_create_response_from_buffer(strlen(text), (void*)text, MHD_RESPMEM_MUST_COPY);\r\n    19\t    if (!response) return MHD_NO;\r\n    20\t    MHD_add_response_header(response, \"Content-Type\", \"text/plain; charset=utf-8\");\r\n    21\t    int ret = MHD_queue_response(connection, status, response);\r\n    22\t    MHD_destroy_response(response);\r\n    23\t    return ret;\r\n    24\t}\r\n    25\t\r\n    26\tstatic int send_file_text(struct MHD_Connection *connection, const char *path) {\r\n    27\t    FILE *f = fopen(path, \"rb\");\r\n    28\t    if (!f) return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", MHD_HTTP_NOT_FOUND);\r\n    29\t    fseek(f, 0, SEEK_END);\r\n    30\t    long n = ftell(f);\r\n    31\t    fseek(f, 0, SEEK_SET);\r\n    32\t    if (n < 0 || n > 1024 * 1024) { fclose(f); return send_json(connection, \"{\\\"error\\\":\\\"server error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR); }\r\n    33\t    char *buf = (char*)calloc((size_t)n + 1, 1);\r\n    34\t    if (!buf) { fclose(f); return send_json(connection, \"{\\\"error\\\":\\\"server error\\\"}\", MHD_HTTP_INTERNAL_SERVER_ERROR); }\r\n    35\t    size_t r = fread(buf, 1, (size_t)n, f);\r\n    36\t    fclose(f);\r\n    37\t    buf[r] = \"\\0\"[0];\r\n    38\t    int ret = send_text(connection, buf, MHD_HTTP_OK);\r\n    39\t    free(buf);\r\n    40\t    return ret;\r\n\u001b[?2004hroot@ade5f5ea62db:/app# "]
