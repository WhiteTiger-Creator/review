Sending keys: ['cat > /app/src/routes.c <<\'EOF\'\n#include "routes.h"\n\n#include "auth.h"\n#include "common.h"\n#include "db.h"\n#include "static.h"\n\n#include <microhttpd.h>\n#include <ctype.h>\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n\n#define API_KEY_PATH "/app/config/api.key"\n\nstruct ConInfo {\n    char *buf;\n    size_t len;\n    size_t cap;\n};\n\nstatic enum MHD_Result send_json_with_headers(struct MHD_Connection *connection,\n                                             const char *body,\n                                             unsigned int status_code,\n                                             const char *extra_header_name,\n                                             const char *extra_header_value) {\n    struct MHD_Response *response = MHD_create_response_from_buffer(\n        strlen(body), (void *)body, MHD_RESPMEM_MUST_COPY);\n    if (!response) return MHD_NO;\n\n    MHD_add_response_header(response, "Content-Type", "application/json");\n    MHD_add_response_header(response, "Access-Control-Allow-Origin", "*");\n    MHD_add_response_header(response, "Access-Control-Allow-Methods",\n                            "GET, POST, PUT, DELETE, OPTIONS");\n    MHD_add_response_header(response, "Access-Control-Allow-Headers",\n                            "Content-Type, X-API-Key");\n\n    if (extra_header_name && extra_header_value)\n        MHD_add_response_header(response, extra_header_name, extra_header_value);\n\n    enum MHD_Result ret = MHD_queue_response(connection, status_code, response);\n    MHD_destroy_response(response);\n    return ret;\n}\n\nstatic enum MHD_Result send_json(struct MHD_Connection *connection,\n                                const char *body,\n                                unsigned int status_code) {\n    return send_json_with_headers(connection, body, status_code, NULL, NULL);\n}\n\nstatic enum MHD_Result send_json_total(struct MHD_Connection *connection,\n                                      const char *body,\n                                      unsigned int status_code,\n                                      int total) {\n    char total_str[64];\n    snprintf(total_str, sizeof(total_str), "%d", total);\n    return send_json_with_headers(connection, body, status_code, "X-Total-Count", total_str);\n}\n\nstatic enum MHD_Result send_text(struct MHD_Connection *connection,\n                                const char *text,\n                                unsigned int status_code) {\n    struct MHD_Response *response = MHD_create_response_from_buffer(\n        strlen(text), (void *)text, MHD_RESPMEM_MUST_COPY);\n    if (!response) return MHD_NO;\n    MHD_add_response_header(response, "Content-Type", "text/plain; charset=utf-8");\n    enum MHD_Result ret = MHD_queue_response(connection, status_code, response);\n    MHD_destroy_response(response);\n    return ret;\n}\n\nstatic enum MHD_Result send_file_text(struct MHD_Connection *connection, const char *path) {\n    FILE *f = fopen(path, "rb");\n    if (!f) return send_text(connection, "Not Found", MHD_HTTP_NOT_FOUND);\n\n    fseek(f, 0, SEEK_END);\n    long n = ftell(f);\n    fseek(f, 0, SEEK_SET);\n    if (n < 0 || n > 1024 * 1024) {\n        fclose(f);\n        return send_text(connection, "Server Error", MHD_HTTP_INTERNAL_SERVER_ERROR);\n    }\n\n    char *buf = (char *)calloc((size_t)n + 1, 1);\n    if (!buf) {\n        fclose(f);\n        return send_text(connection, "Server Error", MHD_HTTP_INTERNAL_SERVER_ERROR);\n    }\n\n    size_t r = fread(buf, 1, (size_t)n, f);\n    fclose(f);\n    buf[r] = \'\\0\';\n\n    enum MHD_Result ret = send_text(connection, buf, MHD_HTTP_OK);\n    free(buf);\n    return ret;\n}\n\nstatic int parse_int(const char *s, int *out) {\n    if (!s || !*s) return 0;\n    char *end = NULL;\n    long v = strtol(s, &end, 10);\n    if (end == s) return 0;\n    if (v < -2147483648L || v > 2147483647L) return 0;\n    *out = (int)v;\n    return 1;\n}\n\nstatic int parse_id_from_url(const char *url, int *out_id) {\n    const char *pfx = "/api/notes/";\n    size_t n = strlen(pfx);\n    if (strncmp(url, pfx, n) != 0) return 0;\n    const char *idstr = url + n;\n    if (!*idstr) return 0;\n    int id = 0;\n    if (!parse_int(idstr, &id)) return 0;\n    if (id <= 0) return 0;\n    *out_id = id;\n    return 1;\n}\n\nstatic void coninfo_free(struct ConInfo *ci) {\n    if (!ci) return;\n    free(ci->buf);\n    free(ci);\n}\n\nstatic enum MHD_Result init_con_info(void **con_cls) {\n    struct ConInfo *ci = (struct ConInfo *)calloc(1, sizeof(struct ConInfo));\n    if (!ci) return MHD_NO;\n    ci->cap = 4096;\n    ci->buf = (char *)calloc(ci->cap, 1);\n    if (!ci->buf) {\n        free(ci);\n        return MHD_NO;\n    }\n    *con_cls = ci;\n    return MHD_YES;\n}\n\nstatic int json_extract_string(const char *json, const char *key, char **out) {\n    *out = NULL;\n    if (!json || !key) return 0;\n\n    // Very small, naive JSON string extractor for {"key":"value"}\n    // Handles escaped quotes (\\") and backslashes.\n    char pat[128];\n    snprintf(pat, sizeof(pat), "\\"%s\\"", key);\n    const char *p = strstr(json, pat);\n    if (!p) return 0;\n    p += strlen(pat);\n    while (*p && isspace((unsigned char)*p)) p++;\n    if (*p != \':\') return 0;\n    p++;\n    while (*p && isspace((unsigned char)*p)) p++;\n    if (*p != \'"\') return 0;\n    p++;\n\n    size_t cap = 256;\n    size_t len = 0;\n    char *buf = (char *)malloc(cap);\n    if (!buf) return 0;\n\n    while (*p) {\n        if (*p == \'"\') {\n            p++;\n            break;\n        }\n        char c = *p;\n        if (c == \'\\\\\') {\n            p++;\n            if (!*p) break;\n            char e = *p;\n            if (e == \'"\' || e == \'\\\\\' || e == \'/\') c = e;\n            else if (e == \'n\') c = \'\\n\';\n            else if (e == \'r\') c = \'\\r\';\n            else if (e == \'t\') c = \'\\t\';\n            else c = e;\n        }\n        if (len + 2 > cap) {\n            cap *= 2;\n            char *nb = (char *)realloc(buf, cap);\n            if (!nb) { free(buf); return 0; }\n            buf = nb;\n        }\n        buf[len++] = c;\n        p++;\n    }\n    buf[len] = \'\\0\';\n    *out = buf;\n    return 1;\n}\n\nstatic enum MHD_Result handle_post_put_body(struct MHD_Connection *connection,\n                                           const char *method,\n                                           const char *url,\n                                           const char *upload_data,\n                                           size_t *upload_data_size,\n                                           void **con_cls) {\n    struct ConInfo *ci = (struct ConInfo *)(*con_cls);\n    if (!ci) return MHD_NO;\n\n    if (*upload_data_size != 0) {\n        if (ci->len + *upload_data_size + 1 > ci->cap) {\n            size_t ncap = ci->cap;\n            while (ncap < ci->len + *upload_data_size + 1) ncap *= 2;\n            char *nbuf = (char *)realloc(ci->buf, ncap);\n            if (!nbuf) return send_json(connection, "{\\"error\\":\\"server error\\"}", MHD_HTTP_INTERNAL_SERVER_ERROR);\n            ci->buf = nbuf;\n            ci->cap = ncap;\n        }\n        memcpy(ci->buf + ci->len, upload_data, *upload_data_size);\n        ci->len += *upload_data_size;\n        ci->buf[ci->len] = \'\\0\';\n        *upload_data_size = 0;\n        return MHD_YES;\n    }\n\n    char *title = NULL;\n    char *content = NULL;\n    (void)json_extract_string(ci->buf, "title", &title);\n    (void)json_extract_string(ci->buf, "content", &content);\n\n    if (!title) {\n        free(content);\n        return send_json(connection, "{\\"error\\":\\"bad request\\"}", MHD_HTTP_BAD_REQUEST);\n    }\n\n    if (strcmp(method, "POST") == 0) {\n        int id = create_note(title, content ? content : "");\n        free(title);\n        free(content);\n        if (id <= 0) return send_json(connection, "{\\"error\\":\\"server error\\"}", MHD_HTTP_INTERNAL_SERVER_ERROR);\n        char *saved = get_note_json(id);\n        if (!saved) return send_json(connection, "{\\"error\\":\\"server error\\"}", MHD_HTTP_INTERNAL_SERVER_ERROR);\n        enum MHD_Result r = send_json(connection, saved, MHD_HTTP_CREATED);\n        free(saved);\n        return r;\n    }\n\n    if (strcmp(method, "PUT") == 0) {\n        int id = 0;\n        if (!parse_id_from_url(url, &id)) {\n            free(title);\n            free(content);\n            return send_json(connection, "{\\"error\\":\\"not found\\"}", MHD_HTTP_NOT_FOUND);\n        }\n        if (!note_exists(id)) {\n            free(title);\n            free(content);\n            return send_json(connection, "{\\"error\\":\\"not found\\"}", MHD_HTTP_NOT_FOUND);\n        }\n        if (!update_note(id, title, content ? content : "")) {\n            free(title);\n            free(content);\n            return send_json(connection, "{\\"error\\":\\"server error\\"}", MHD_HTTP_INTERNAL_SERVER_ERROR);\n        }\n        free(title);\n        free(content);\n        char *saved = get_note_json(id);\n        if (!saved) return send_json(connection, "{\\"error\\":\\"server error\\"}", MHD_HTTP_INTERNAL_SERVER_ERROR);\n        enum MHD_Result r = send_json(connection, saved, MHD_HTTP_OK);\n        free(saved);\n        return r;\n    }\n\n    free(title);\n    free(content);\n    return send_json(connection, "{\\"error\\":\\"not found\\"}", MHD_HTTP_NOT_FOUND);\n}\n\nenum MHD_Result route_request(struct MHD_Connection *connection, const char *url,\n                              const char *method, const char *upload_data,\n                              size_t *upload_data_size, void **con_cls) {\n    if (strcmp(method, "OPTIONS") == 0)\n        return send_json(connection, "", MHD_HTTP_OK);\n\n    if (strcmp(method, "GET") == 0 && strcmp(url, "/config/api.key") == 0)\n        return send_file_text(connection, API_KEY_PATH);\n\n    // Serve static assets from /app/www\n    if (strcmp(method, "GET") == 0) {\n        enum MHD_Result r = serve_static(connection, url);\n        if (r != MHD_NO) return r;\n    }\n\n    // API\n    if (strcmp(url, "/api/notes") == 0 && strcmp(method, "GET") == 0) {\n        int limit = NOTES_DEFAULT_PAGE_SIZE;\n        int offset = 0;\n        const char *q_limit = MHD_lookup_connection_value(connection, MHD_GET_ARGUMENT_KIND, "limit");\n        const char *q_offset = MHD_lookup_connection_value(connection, MHD_GET_ARGUMENT_KIND, "offset");\n        if (q_limit) parse_int(q_limit, &limit);\n        if (q_offset) parse_int(q_offset, &offset);\n        if (limit <= 0) limit = NOTES_DEFAULT_PAGE_SIZE;\n        if (limit > NOTES_MAX_PAGE_SIZE) limit = NOTES_MAX_PAGE_SIZE;\n        if (offset < 0) offset = 0;\n\n        int total = get_total_notes_count();\n        char *json = get_notes_paginated_json(limit, offset);\n        if (!json) return send_json_total(connection, "[]", MHD_HTTP_OK, total);\n        enum MHD_Result rr = send_json_total(connection, json, MHD_HTTP_OK, total);\n        free(json);\n        return rr;\n    }\n\n    int id = 0;\n    if (strcmp(method, "GET") == 0 && parse_id_from_url(url, &id)) {\n        char *json = get_note_json(id);\n        if (!json) return send_json(connection, "{\\"error\\":\\"not found\\"}", MHD_HTTP_NOT_FOUND);\n        enum MHD_Result rr = send_json(connection, json, MHD_HTTP_OK);\n        free(json);\n        return rr;\n    }\n\n    if (strcmp(method, "POST") == 0 && strcmp(url, "/api/notes") == 0) {\n        if (!api_key_valid(connection))\n            return send_json(connection, "{\\"error\\":\\"unauthorized\\"}", MHD_HTTP_UNAUTHORIZED);\n\n        const char *cl = MHD_lookup_connection_value(connection, MHD_HEADER_KIND, "Content-Length");\n        if (cl) {\n            int v = 0;\n            if (parse_int(cl, &v) && v > NOTES_MAX_BODY_BYTES)\n                return send_json(connection, "{\\"error\\":\\"payload too large\\"}", MHD_HTTP_CONTENT_TOO_LARGE);\n        }\n\n        if (*con_cls == NULL) return init_con_info(con_cls);\n        enum MHD_Result rr = handle_post_put_body(connection, method, url, upload_data, upload_data_size, con_cls);\n        if (*upload_data_size == 0) {\n            coninfo_free((struct ConInfo *)*con_cls);\n            *con_cls = NULL;\n        }\n        return rr;\n    }\n\n    if (strcmp(method, "PUT") == 0 && strncmp(url, "/api/notes/", 11) == 0) {\n        if (!api_key_valid(connection))\n            return send_json(connection, "{\\"error\\":\\"unauthorized\\"}", MHD_HTTP_UNAUTHORIZED);\n\n        const char *cl = MHD_lookup_connection_value(connection, MHD_HEADER_KIND, "Content-Length");\n        if (cl) {\n            int v = 0;\n            if (parse_int(cl, &v) && v > NOTES_MAX_BODY_BYTES)\n                return send_json(connection, "{\\"error\\":\\"payload too large\\"}", MHD_HTTP_CONTENT_TOO_LARGE);\n        }\n\n        if (*con_cls == NULL) return init_con_info(con_cls);\n        enum MHD_Result rr = handle_post_put_body(connection, method, url, upload_data, upload_data_size, con_cls);\n        if (*upload_data_size == 0) {\n            coninfo_free((struct ConInfo *)*con_cls);\n            *con_cls = NULL;\n        }\n        return rr;\n    }\n\n    if (strcmp(method, "DELETE") == 0 && parse_id_from_url(url, &id)) {\n        if (!api_key_valid(connection))\n            return send_json(connection, "{\\"error\\":\\"unauthorized\\"}", MHD_HTTP_UNAUTHORIZED);\n        if (!note_exists(id))\n            return send_json(connection, "{\\"error\\":\\"not found\\"}", MHD_HTTP_NOT_FOUND);\n        if (!delete_note(id))\n            return send_json(connection, "{\\"error\\":\\"server error\\"}", MHD_HTTP_INTERNAL_SERVER_ERROR);\n        return send_json(connection, "{\\"status\\":\\"deleted\\"}", MHD_HTTP_OK);\n    }\n\n    return send_json(connection, "{\\"error\\":\\"not found\\"}", MHD_HTTP_NOT_FOUND);\n}\nEOF\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
