[128.214036, "i", "cat > /app/environment/c9/pass_gate.cpp <<'EOF'\n#include \"c9_api.h\"\n#include <string.h>\n\nextern \"C\" const char *c9_resolve_mode(const char *manifest_mode, const char *unit_name,\n                                       int pass_epoch) {\n    static thread_local char mode_buf[16];\n    (void)unit_name;\n    (void)pass_epoch;\n\n    // Mode resolution must follow the manifest semantics. Do not branch on unit-name\n    // prefixes or pass-epoch heuristics.\n    if (manifest_mode == NULL) {\n        mode_buf[0] = '\\0';\n        return mode_buf;\n    }\n\n    strncpy(mode_buf, manifest_mode, sizeof(mode_buf) - 1);\n    mode_buf[sizeof(mode_buf) - 1] = '\\0';\n    return mode_buf;\n}\nEOF\n"]
