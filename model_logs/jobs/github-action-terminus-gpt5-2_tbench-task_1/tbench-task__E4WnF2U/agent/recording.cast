[172.899747, "i", "cat > /app/environment/f12/extra_f2.cpp <<'EOF'\n#include \"types.h\"\n#include <cstdint>\n#include <cstdlib>\n#include <vector>\n\nnamespace forge {\n\nint64_t f12_drift_total(const std::vector<UnitRun> &units) {\n    // Sum of absolute drift_bytes across the requested units.\n    int64_t total = 0;\n    for (const auto &unit : units) {\n        int64_t d = unit.drift_bytes;\n        total += (d < 0) ? -d : d;\n    }\n    return total;\n}\n\n} // namespace forge\nEOF\n"]
