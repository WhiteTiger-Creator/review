[128.326068, "i", "cat > /app/environment/n21/q5_pack_stamp.cpp <<'EOF'\n#include \"types.h\"\n#include <sstream>\n#include <string>\n\nnamespace forge {\n\nstd::string q5_row_serial(const UnitRun &run) {\n    std::ostringstream os;\n    // Values-only serialization for the digest accumulator.\n    // name|manifest_bytes|record_bytes|drift_bytes|order_rank|order_weight\n    os << run.name << '|' << run.manifest_bytes << '|' << run.record_bytes << '|' << run.drift_bytes\n       << '|' << run.order_rank << '|' << run.order_weight;\n    return os.str();\n}\n\nstd::string unit_row_serial(const UnitRun &run) {\n    return q5_row_serial(run);\n}\n\n} // namespace forge\nEOF\n"]
