[63.404487, "o", "    run.mode = forge_lane_mode(spec.mode.c_str(), spec.name.c_str(), pass_epoch);\r\n    run.manifest_bytes = spec.manifest_bytes;\r\n    run.record_bytes = read_record_bytes(record_path);\r\n"]
[63.404499, "o", "    run.drift_bytes = run.record_bytes - static_cast<int64_t>(run.manifest_bytes);\r\n    run.order_rank = order_rank;\r\n\r\n"]
