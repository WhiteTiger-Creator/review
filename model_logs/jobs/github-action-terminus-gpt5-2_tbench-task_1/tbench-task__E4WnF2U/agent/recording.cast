[50.622366, "o", "sed -n '1,220p' /app/environment/m14/token_bridge.cpp\r\n\u001b[?2004l\r"]
[50.624572, "o", "#include \"m14_api.h\"\r\n#include \"store_bridge.h\"\r\n\r\nconst char *forge_lane_fingerprint(const forge::UnitSpec *units, size_t count) {\r\n    return m14_lane_token(units, count);\r\n}\r\n"]
[50.624803, "o", "\u001b[?2004hroot@88f399caa06f:/app# "]
[50.734466, "i", "sed -n '1,260p' /app/environment/m14/lane_store.cpp\n"]
[50.73507, "o", "sed -n '1,260p' /app/environment/m14/lane_store.cpp"]
[50.735219, "o", "\r\n\u001b[?2004l\r"]
[50.736251, "o", "#include \"constants.h\"\r\n#include \"m14_api.h\"\r\n#include \"types.h\"\r\n#include <algorithm>\r\n#include <cctype>\r\n#include <fstream>\r\n"]
[50.73629, "o", "#include <sstream>\r\n#include <stdexcept>\r\n#include <string>\r\n#include <vector>\r\n\r\nnamespace {\r\n\r\nstd::uint64_t digest_update(std::uint64_t h, const std::string &text) {\r\n    for (unsigned char ch : text) {\r\n        h ^= static_cast<std::uint64_t>(ch);\r\n        h = (h * forge::kDigestStep) & forge::kDigestMask;\r\n    }\r\n"]
[50.736301, "o", "    return h;\r\n}\r\n\r\nstd::string digest_hex(const std::string &text) {\r\n    std::uint64_t h = digest_update(forge::kDigestSeed, text);\r\n    std::ostringstream os;\r\n"]
[50.736313, "o", "    os << std::hex << std::nouppercase;\r\n    os.width(16);\r\n    os.fill('0');\r\n"]
[50.736323, "o", "    os << h;\r\n    return os.str();\r\n}\r\n"]
[50.736331, "o", "\r\nstd::string descriptor_line(const forge::UnitSpec &unit) {\r\n"]
[50.736341, "o", "    std::ostringstream os;\r\n    os << unit.name << '|' << unit.mode << '|' << unit.record << '|' << unit.manifest_bytes << '|'\r\n"]
[50.736356, "o", "       << unit.start_pass;\r\n    return os.str();\r\n}\r\n\r\n"]
[50.736367, "o", "std::string pick_string(const std::string &block, const std::string &key) {\r\n    std::string needle = \"\\\"\" + key + \"\\\"\";\r\n    size_t k = block.find(needle);\r\n"]
[50.736377, "o", "    if (k == std::string::npos) {\r\n        return \"\";\r\n    }\r\n"]
[50.736387, "o", "    size_t q = block.find('\"', block.find(':', k) + 1);\r\n    size_t e = block.find('\"', q + 1);\r\n    return block.substr(q + 1, e - q - 1);\r\n"]
[50.736399, "o", "}\r\n\r\nint pick_int(const std::string &block, const std::string &key) {\r\n"]
[50.736408, "o", "    std::string needle = \"\\\"\" + key + \"\\\"\";\r\n    size_t k = block.find(needle);\r\n    if (k == std::string::npos) {\r\n"]
[50.736419, "o", "        return 0;\r\n    }\r\n    size_t p = block.find(':', k) + 1;\r\n"]
[50.736431, "o", "    while (p < block.size() && !std::isdigit(static_cast<unsigned char>(block[p])) && block[p] != '-') {\r\n        ++p;\r\n    }\r\n"]
[50.736442, "o", "    size_t e = p;\r\n    while (e < block.size() && (std::isdigit(static_cast<unsigned char>(block[e])) || block[e] == '-')) {\r\n        ++e;\r\n"]
[50.736451, "o", "    }\r\n    return std::stoi(block.substr(p, e - p));\r\n}\r\n"]
[50.736462, "o", "\r\nint64_t pick_int64(const std::string &block, const std::string &key) {\r\n    return static_cast<int64_t>(pick_int(block, key));\r\n"]
[50.736471, "o", "}\r\n\r\nstd::vector<std::string> split_object_blocks(const std::string &array_text) {\r\n"]
[50.736485, "o", "    std::vector<std::string> out;\r\n    int depth = 0;\r\n    size_t start = std::string::npos;\r\n    for (size_t i = 0; i < array_text.size(); ++i) {\r\n"]
[50.736497, "o", "        if (array_text[i] == '{') {\r\n            if (depth == 0) {\r\n                start = i;\r\n"]
[50.736509, "o", "            }\r\n            ++depth;\r\n        } else if (array_text[i] == '}') {\r\n            --depth;"]
[50.736519, "o", "\r\n            if (depth == 0 && start != std::string::npos) {\r\n"]
[50.73653, "o", "                out.push_back(array_text.substr(start, i - start + 1));\r\n                start = std::string::npos;\r\n            }\r\n"]
[50.736541, "o", "        }\r\n    }\r\n    return out;\r\n"]
[50.736553, "o", "}\r\n\r\n}  // namespace\r\n\r\n"]
[50.736565, "o", "extern \"C\" const char *m14_lane_token(const forge::UnitSpec *units, size_t count) {\r\n    static std::string cached;\r\n    std::ostringstream joined;\r\n"]
[50.736576, "o", "    for (size_t i = 0; i < count; ++i) {\r\n        if (i) {\r\n            joined << '\\n';\r\n"]
[50.736586, "o", "        }\r\n        joined << descriptor_line(units[i]);\r\n    }\r\n"]
[50.736597, "o", "    cached = digest_hex(joined.str());\r\n    return cached.c_str();\r\n}\r\n"]
[50.736605, "o", "\r\nextern \"C\" int m14_checkpoint_valid(const char *on_disk_token, const char *expected_token) {\r\n    if (on_disk_token == nullptr || expected_token == nullptr) {\r\n"]
[50.736614, "o", "        return 0;\r\n    }\r\n"]
[50.736624, "o", "    return std::string(on_disk_token) == std::string(expected_token) ? 1 : 0;\r\n}\r\n\r\n"]
[50.736633, "o", "forge::LaneCheckpoint m14_read_checkpoint(const std::filesystem::path &path,\r\n                                                   const std::string &expected_token) {\r\n"]
[50.736643, "o", "    forge::LaneCheckpoint state;\r\n    std::ifstream in(path);\r\n    if (!in) {\r\n"]
[50.736654, "o", "        return state;\r\n    }\r\n    std::ostringstream buffer;\r\n"]
[50.736665, "o", "    buffer << in.rdbuf();\r\n    const std::string doc = buffer.str();\r\n    if (doc.find(\"\\\"schema_version\\\"\") == std::string::npos) {\r\n"]
[50.736675, "o", "        return state;\r\n    }\r\n    state.lane_token = pick_string(doc, \"lane_token\");\r\n"]
[50.736686, "o", "    if (!m14_checkpoint_valid(state.lane_token.c_str(), expected_token.c_str())) {\r\n        return state;\r\n    }\r\n"]
[50.736695, "o", "    size_t units_pos = doc.find(\"\\\"units\\\"\");\r\n    if (units_pos == std::string::npos) {\r\n        return state;\r\n    }\r\n"]
[50.736706, "o", "    size_t arr_start = doc.find('[', units_pos);\r\n    size_t arr_end = doc.find(']', arr_start);\r\n"]
[50.736728, "o", "    if (arr_start == std::string::npos || arr_end == std::string::npos) {\r\n        return state;\r\n    }\r\n    const std::string arr = doc.substr(arr_start, arr_end - arr_start + 1);\r\n    for (const auto &block : split_object_blocks(arr)) {\r\n        forge::UnitCheckpoint entry;\r\n        entry.name = pick_string(block, \"name\");\r\n        entry.next_pass = pick_int(block, \"next_pass\");\r\n        entry.carry_weight = pick_int64(block, \"carry_weight\");\r\n"]
[50.736741, "o", "        entry.carry_drift = pick_int64(block, \"carry_drift\");\r\n        if (!entry.name.empty()) {\r\n            state.units[entry.name] = entry;\r\n"]
[50.736752, "o", "        }\r\n    }\r\n"]
[50.736767, "o", "    state.valid = true;\r\n    return state;\r\n}\r\n\r\nstd::vector<forge::UnitCheckpoint> m14_merge_entries(\r\n"]
[50.736779, "o", "    const forge::LaneCheckpoint &existing, const std::vector<forge::UnitCheckpoint> &updated,\r\n    const std::vector<std::string> &requested_resume) {\r\n    (void)existing;\r\n    (void)requested_resume;\r\n    std::vector<forge::UnitCheckpoint> out = updated;\r\n"]
[50.73679, "o", "    std::sort(out.begin(), out.end(),\r\n              [](const forge::UnitCheckpoint &a, const forge::UnitCheckpoint &b) {\r\n                  return a.name < b.name;\r\n"]
[50.736802, "o", "              });\r\n    return out;\r\n}\r\n"]
[50.736818, "o", "\r\nvoid m14_write_checkpoint(const std::filesystem::path &path, const char *lane_token,\r\n                                     const std::vector<forge::UnitCheckpoint> &entries) {\r\n    std::filesystem::create_directories(path.parent_path());\r\n"]
[50.73684, "o", "    std::ostringstream out;\r\n    out << \"{\\\"schema_version\\\":\" << forge::kSchemaVersion << \",\\\"lane_token\\\":\\\"\" << lane_token\r\n        << \"\\\",\\\"units\\\":[\";\r\n    for (size_t i = 0; i < entries.size(); ++i) {\r\n        if (i) {\r\n            out << ',';\r\n        }\r\n        const auto &entry = entries[i];\r\n"]
[50.736854, "o", "        out << \"{\\\"name\\\":\\\"\" << entry.name << \"\\\",\\\"next_pass\\\":\" << entry.next_pass\r\n            << \",\\\"carry_weight\\\":\" << entry.carry_weight << \",\\\"carry_drift\\\":\"\r\n            << entry.carry_drift << '}';\r\n    }\r\n"]
[50.736866, "o", "    out << \"]}\\n\";\r\n    std::ofstream file(path, std::ios::binary);\r\n    file << out.str();\r\n"]
[50.736879, "o", "}\r\n"]
