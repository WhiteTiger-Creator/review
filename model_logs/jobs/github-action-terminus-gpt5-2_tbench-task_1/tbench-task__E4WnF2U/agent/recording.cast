[90.925431, "o", "\u001b[?2004h> "]
[90.925643, "o", "+    // - Apply updated entries for any requested resume units.\r\n\u001b[?2004l\r"]
[90.925692, "o", "\u001b[?2004h> "]
[90.925923, "o", "+    // - The output list must be sorted alphabetically by unit name.\r\n\u001b[?2004l\r"]
[90.92599, "o", "\u001b[?2004h> "]
[90.926078, "o", "+    (void)requested_resume;\r\n\u001b[?2004l\r"]
[90.926099, "o", "\u001b[?2004h"]
[90.926196, "o", "> +\r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.926373, "o", "+    std::map<std::string, forge::UnitCheckpoint> merged;\r\n\u001b[?2004l\r"]
[90.926445, "o", "\u001b[?2004h"]
[90.926492, "o", "> "]
[90.926609, "o", "+    if (existing.valid) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.926764, "o", "+        for (const auto &kv : existing.units) {\r\n\u001b[?2004l\r"]
[90.926782, "o", "\u001b[?2004h"]
[90.926793, "o", "> "]
[90.926959, "o", "+            merged[kv.first] = kv.second;\r\n\u001b[?2004l\r"]
[90.926978, "o", "\u001b[?2004h"]
[90.92706, "o", "> +        }\r\n\u001b[?2004l\r"]
[90.927151, "o", "\u001b[?2004h> +    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[90.927169, "o", "> "]
[90.927323, "o", "+    for (const auto &e : updated) {\r\n\u001b[?2004l\r"]
[90.927345, "o", "\u001b[?2004h"]
[90.927417, "o", "> "]
[90.927491, "o", "+        if (!e.name.empty()) {\r\n\u001b[?2004l\r"]
[90.927549, "o", "\u001b[?2004h> "]
[90.927706, "o", "+            merged[e.name] = e;\r\n\u001b[?2004l\r"]
[90.927771, "o", "\u001b[?2004h"]
[90.927884, "o", "> +        }\r\n\u001b[?2004l\r\u001b[?2004h> +    }\r\n\u001b[?2004l\r"]
[90.927905, "o", "\u001b[?2004h"]
[90.927989, "o", "> +\r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.928156, "o", "+    std::vector<forge::UnitCheckpoint> out;\r\n\u001b[?2004l\r"]
[90.928229, "o", "\u001b[?2004h> "]
[90.928456, "o", "+    out.reserve(merged.size());\r\n\u001b[?2004l\r"]
[90.928478, "o", "\u001b[?2004h"]
[90.928533, "o", "> "]
[90.928726, "o", "+    for (const auto &kv : merged) {\r\n\u001b[?2004l\r"]
[90.928812, "o", "\u001b[?2004h"]
[90.9289, "o", "> "]
[90.92902, "o", "+        out.push_back(kv.second);\r\n\u001b[?2004l\r"]
[90.929067, "o", "\u001b[?2004h> "]
[90.929105, "o", "+    }\r\n\u001b[?2004l\r"]
[90.929121, "o", "\u001b[?2004h"]
[90.929132, "o", "> "]
[90.929281, "o", "     std::sort(out.begin(), out.end(),\r\n\u001b[?2004l\r"]
[90.929298, "o", "\u001b[?2004h"]
[90.929349, "o", "> "]
[90.929619, "o", "               [](const forge::UnitCheckpoint &a, const forge::UnitCheckpoint &b) {\r\n\u001b[?2004l\r"]
[90.92964, "o", "\u001b[?2004h"]
[90.929709, "o", "> "]
[90.929962, "o", "                   return a.name < b.name;\r\n\u001b[?2004l\r"]
[90.93003, "o", "\u001b[?2004h"]
[90.930104, "o", "> "]
[90.930209, "o", "               });\r\n\u001b[?2004l\r"]
[90.930295, "o", "\u001b[?2004h> "]
[90.930403, "o", "     return out;\r\n\u001b[?2004l\r"]
[90.930455, "o", "\u001b[?2004h"]
[90.930528, "o", "> "]
[90.930599, "o", " }\r\n\u001b[?2004l\r"]
[90.930664, "o", "\u001b[?2004h"]
[90.930733, "o", "> "]
[90.930794, "o", "*** End Patch\r\n\u001b[?2004l\r"]
[90.930835, "o", "\u001b[?2004h> "]
