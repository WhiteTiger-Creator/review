[66.386412, "i", "python3 - <<'PY'\nimport json\np='/app/output/report.json'\nwith open(p) as f: r=json.load(f)\nprint('scenario',r.get('scenario'),'profile',r.get('profile'))\ne=r['events']\nprint('events',len(e))\nfrom collections import Counter\nc=Counter(x['kind'] for x in e)\nprint('kinds',c)\n# basic invariants\nseen=set(); du=[]\nfor x in e:\n k,i=x['kind'],x['id']\n if (k,i) in seen: du.append((k,i))\n seen.add((k,i))\nprint('dupes',len(du), du[:10])\nsub=[x['id'] for x in e if x['kind']=='submit']\nprint('submits',len(sub),'min',min(sub),'max',max(sub),'contig',sub==list(range(1,max(sub)+1)))\nPY\n"]
