[472.890163, "o", "    pos[ev['id']][ev['kind']]=idx\r\n\u001b[?2004l\r"]
[472.890251, "o", "\u001b[?2004h> "]
[472.890312, "o", "  for i,d in pos.items():\r\n\u001b[?2004l\r"]
[472.890409, "o", "\u001b[?2004h> "]
[472.890518, "o", "    if set(d)!={'submit','complete','notify'}:\r\n\u001b[?2004l\r"]
[472.890574, "o", "\u001b[?2004h> "]
[472.890778, "o", "      return False,f'missing kind for id {i}: {d}'\r\n\u001b[?2004l\r"]
[472.890805, "o", "\u001b[?2004h> "]
[472.890981, "o", "    if not (d['submit']<d['complete']<d['notify']):\r\n\u001b[?2004l\r"]
[472.89104, "o", "\u001b[?2004h> "]
[472.891197, "o", "      return False,f'order violation for id {i}: {d}'\r\n\u001b[?2004l\r"]
[472.891258, "o", "\u001b[?2004h> "]
[472.891412, "o", "  return True,f'OK ids={len(pos)} events={len(e)}'\r\n\u001b[?2004l\r"]
[472.891457, "o", "\u001b[?2004h"]
[472.891502, "o", "> \r\n\u001b[?2004l\r"]
[472.89152, "o", "\u001b[?2004h> "]
[472.891656, "o", "ok,msg=check('/app/output/report.json')\r\n\u001b[?2004l\r"]
[472.891699, "o", "\u001b[?2004h> "]
[472.891765, "o", "print(msg)\r\n\u001b[?2004l\r"]
[472.891819, "o", "\u001b[?2004h> "]
[472.891925, "o", "raise SystemExit(0 if ok else 1)\r\n\u001b[?2004l\r"]
[472.891972, "o", "\u001b[?2004h> "]
[472.891988, "o", "PY\r\n\u001b[?2004l\r"]
