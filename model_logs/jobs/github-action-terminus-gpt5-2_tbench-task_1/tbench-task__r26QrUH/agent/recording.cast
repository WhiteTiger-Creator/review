[78.38817, "o", "# duplicates by (kind,id)\r\n\u001b[?2004l\r"]
[78.388251, "o", "\u001b[?2004h> "]
[78.388336, "o", "seen=set(); dup=[]\r\n\u001b[?2004l\r\u001b[?2004h"]
[78.388419, "o", "> for x in e:\r\n\u001b[?2004l\r"]
[78.388505, "o", "\u001b[?2004h> "]
[78.388558, "o", " t=(x['kind'],x['id'])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[78.388638, "o", " if t in seen: dup.append(t)\r\n\u001b[?2004l\r"]
[78.388707, "o", "\u001b[?2004h> "]
[78.388788, "o", " seen.add(t)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[78.388934, "o", "print('dup_count',len(dup),'sample',dup[:10])\r\n\u001b[?2004l\r"]
[78.388998, "o", "\u001b[?2004h> "]
[78.389041, "o", "# ids coverage\r\n"]
[78.389107, "o", "\u001b[?2004l\r"]
[78.389179, "o", "\u001b[?2004h> "]
[78.389297, "o", "subs=[x['id'] for x in e if x['kind']=='submit']\r\n\u001b[?2004l\r"]
[78.389315, "o", "\u001b[?2004h"]
[78.389326, "o", "> "]
[78.389424, "o", "mx=max(subs) if subs else 0\r\n\u001b[?2004l\r"]
[78.389472, "o", "\u001b[?2004h"]
[78.389491, "o", "> "]
[78.389664, "o", "print('submit_ids_contig',subs==list(range(1,mx+1)),'N',mx)\r\n\u001b[?2004l\r"]
[78.38968, "o", "\u001b[?2004h"]
[78.389751, "o", "> "]
[78.389814, "o", "# missing complete/notify per id\r\n\u001b[?2004l\r"]
[78.389861, "o", "\u001b[?2004h> "]
[78.389936, "o", "by=defaultdict(set)\r\n\u001b[?2004l\r"]
[78.390007, "o", "\u001b[?2004h> "]
[78.390107, "o", "for x in e: by[x['id']].add(x['kind'])\r\n\u001b[?2004l\r"]
[78.390126, "o", "\u001b[?2004h"]
[78.390188, "o", "> "]
[78.390455, "o", "miss=[(i,{'submit','complete','notify'}-k) for i,k in by.items() if k!={'submit','complete','notify'}]\r\n\u001b[?2004l\r"]
[78.390498, "o", "\u001b[?2004h> "]
[78.390684, "o", "print('missing_rows',len(miss),'sample',miss[:10])\r\n\u001b[?2004l\r"]
[78.390804, "o", "\u001b[?2004h> "]
[78.390889, "o", "# ordering violations\r\n\u001b[?2004l\r\u001b[?2004h"]
[78.390981, "o", "> "]
[78.391068, "o", "pos=defaultdict(dict)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[78.391187, "o", "for idx,x in enumerate(e): pos[x['id']][x['kind']]=idx\r\n\u001b[?2004l\r"]
[78.391253, "o", "\u001b[?2004h"]
[78.391327, "o", "> "]
[78.391604, "o", "bad=[i for i,d in pos.items() if set(d)=={'submit','complete','notify'} and not (d['submit']<d['complete']<d['notify'])]\r\n\u001b[?2004l\r"]
[78.391675, "o", "\u001b[?2004h> "]
[78.391808, "o", "print('order_bad',len(bad),'sample',bad[:10])\r\n\u001b[?2004l\r"]
[78.391877, "o", "\u001b[?2004h"]
[78.391992, "o", "> PY\r\n\u001b[?2004l\r"]
[78.408206, "o", "events 377 Counter({'submit': 140, 'notify': 119, 'complete': 118})\r\n"]
[78.408356, "o", "dup_count 24 sample [('submit', 57), ('submit', 58), ('submit', 59), ('submit', 60), ('submit', 61), ('submit', 62), ('submit', 63), ('submit', 64), ('submit', 65), ('submit', 66)]\r\n"]
[78.408416, "o", "submit_ids_contig False N 118\r\n"]
[78.40857, "o", "missing_rows 1 sample [(55, {'notify'})]\r\n"]
[78.408787, "o", "order_bad 22 sample [57, 58, 59, 60, 61, 62, 63, 64, 65, 66]\r\n"]
[78.411758, "o", "\u001b[?2004h"]
[78.411826, "o", "root@7ae5e2ee926b:/app# "]
[80.377206, "i", "sed -n '1,200p' /app/src/logic/link.c\n"]
[80.377576, "o", "sed -n '1,200p' /app/src/logic/link.c\r\n\u001b[?2004l\r"]
[80.379439, "o", "#include \"logic/link.h\"\r\n"]
[80.379606, "o", "\r\n#include \"io/journal.h\"\r\n\r\n#include <string.h>\r\n\r\ntb_status tb_link_detach(tb_rt *rt, uint32_t tick) {\r\n  (void)tick;\r\n  if (!rt)\r\n    return TB_ERR_BAD_ARG;\r\n  if (!rt->attached)\r\n    return TB_OK;\r\n\r\n  rt->attached = false;\r\n\r\n  tb_stamp s = {.gen = rt->gen, .cursor = rt->cursor};\r\n  tb_status st = journal_append_stamp(rt->journal_path, s);\r\n  if (st != TB_OK)\r\n    return st;\r\n"]
[80.379721, "o", "\r\n  // A \"device-side\" queue continues to exist while detached; the notifier doesn't.\r\n  tb_q64_clear(&rt->notify_q);\r\n  return TB_OK;\r\n}\r\n\r\ntb_status tb_link_attach(tb_rt *rt, uint32_t tick) {\r\n  (void)tick;\r\n  if (!rt)\r\n    return TB_ERR_BAD_ARG;\r\n  if (rt->attached)\r\n    return TB_OK;\r\n\r\n  tb_stamp last = {0};\r\n  bool found = false;\r\n  tb_status st = journal_load_last(rt->journal_path, &last, &found);\r\n  if (st != TB_OK)\r\n    return st;\r\n  if (found) {\r\n    rt->gen = last.gen + 1;\r\n    rt->cursor = last.cursor;\r\n  }\r\n\r\n  rt->attached = true;\r\n  return TB_OK;\r\n}\r\n\r\n"]
[80.379881, "o", "\u001b[?2004h"]
[80.379966, "o", "root@7ae5e2ee926b:/app# "]
