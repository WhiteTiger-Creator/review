[67.369791, "i", "python3 - <<'PY'\nimport json\nfrom collections import defaultdict\np='/app/output/report.json'\nr=json.load(open(p))\ne=r['events']\npos=defaultdict(dict)\nviol=[]\nfor idx,x in enumerate(e):\n pos[x['id']][x['kind']]=idx\nfor i,d in pos.items():\n if set(d)!= {'submit','complete','notify'}:\n  viol.append(('missing_kind',i,sorted(d)))\n  continue\n if not (d['submit']<d['complete']<d['notify']):\n  viol.append(('order',i,d))\nprint('ids',len(pos),'violations',len(viol))\nprint('sample',viol[:10])\nPY\n"]
