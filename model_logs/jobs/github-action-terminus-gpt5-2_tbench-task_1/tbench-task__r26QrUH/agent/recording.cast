[472.885125, "i", "python3 - <<'PY'\nimport json\nfrom collections import defaultdict\n\ndef check(path):\n  r=json.load(open(path))\n  e=r['events']\n  seen=set();\n  for ev in e:\n    t=(ev['kind'],ev['id'])\n    if t in seen:\n      return False,f'duplicate {t}'\n    seen.add(t)\n  subs=[ev['id'] for ev in e if ev['kind']=='submit']\n  if subs!=list(range(1,max(subs)+1)):\n    return False,'submit ids not contiguous'\n  pos=defaultdict(dict)\n  for idx,ev in enumerate(e):\n    pos[ev['id']][ev['kind']]=idx\n  for i,d in pos.items():\n    if set(d)!={'submit','complete','notify'}:\n      return False,f'missing kind for id {i}: {d}'\n    if not (d['submit']<d['complete']<d['notify']):\n      return False,f'order violation for id {i}: {d}'\n  return True,f'OK ids={len(pos)} events={len(e)}'\n\nok,msg=check('/app/output/report.json')\nprint(msg)\nraise SystemExit(0 if ok else 1)\nPY\n"]
[472.886067, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r\u001b[?2004h> import json\r\n\u001b[?2004l\r\u001b[?2004h> from collections import defaultdict\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def check(path):\r\n\u001b[?2004l\r\u001b[?2004h"]
