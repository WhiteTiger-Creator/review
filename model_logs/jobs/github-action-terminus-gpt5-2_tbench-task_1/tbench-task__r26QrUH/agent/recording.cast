[78.38284, "i", "rm -f /app/output/report.json\n/usr/local/bin/arena --scenario stress2 --profile burst --order a_then_b --out /app/output/report.json --seed 2\npython3 - <<'PY'\nimport json\nfrom collections import Counter,defaultdict\nr=json.load(open('/app/output/report.json'))\ne=r['events']\nprint('events',len(e),Counter(x['kind'] for x in e))\n# duplicates by (kind,id)\nseen=set(); dup=[]\nfor x in e:\n t=(x['kind'],x['id'])\n if t in seen: dup.append(t)\n seen.add(t)\nprint('dup_count',len(dup),'sample',dup[:10])\n# ids coverage\nsubs=[x['id'] for x in e if x['kind']=='submit']\nmx=max(subs) if subs else 0\nprint('submit_ids_contig',subs==list(range(1,mx+1)),'N',mx)\n# missing complete/notify per id\nby=defaultdict(set)\nfor x in e: by[x['id']].add(x['kind'])\nmiss=[(i,{'submit','complete','notify'}-k) for i,k in by.items() if k!={'submit','complete','notify'}]\nprint('missing_rows',len(miss),'sample',miss[:10])\n# ordering violations\npos=defaultdict(dict)\nfor idx,x in enumerate(e): pos[x['id']][x['kind']]=idx\nbad=[i for i,d in pos.items() if"]
[78.382893, "i", " set(d)=={'submit','complete','notify'} and not (d['submit']<d['complete']<d['notify'])]\nprint('order_bad',len(bad),'sample',bad[:10])\nPY\n"]
