[95.370164, "o", "\r\n\u001b[?2004l\r"]
[95.37173, "o", "#include \"core/idgen.h\"\r\n\r\n"]
[95.371907, "o", "void tb_idgen_init(tb_idgen *g, uint64_t seed) { g->x = seed ? seed : 0x9e3779b97f4a7c15ULL; }\r\n"]
[95.371998, "o", "\r\n"]
[95.372086, "o", "uint64_t tb_idgen_next(tb_idgen *g) {\r\n"]
[95.372253, "o", "  // xorshift64*\r\n  uint64_t x = g->x;\r\n  x ^= x >> 12;\r\n  x ^= x << 25;\r\n"]
[95.372344, "o", "  x ^= x >> 27;\r\n  g->x = x;\r\n  return x * 2685821657736338717ULL;\r\n}\r\n\r\n"]
