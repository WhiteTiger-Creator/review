[68.366136, "i", "for sc in basic stress stress2; do for pr in burst steady; do for ord in a_then_b b_then_a; do rm -f /app/output/report.json; /usr/local/bin/arena --scenario $sc --profile $pr --order $ord --out /app/output/report.json --seed 1 >/dev/null; echo $sc $pr $ord exit:$? events:$(python3 -c \"import json;print(len(json.load(open('/app/output/report.json'))['events']))\" 2>/dev/null || echo NA); done; done; done\n"]
[68.367725, "o", "for sc in basic stress stress2; do for pr in burst steady; do for ord in a_then_b b_then_a; do rm -f /app/output/report.json; /usr/local/bin/arena --scenario $sc --profile $pr --order $ord --out /app/output/report.json --seed 1 >/dev/null; echo $sc $pr $ord exit:$? events:$(python3 -c \"import json;print(len(json.load(open('/app/output/report.json'))['events']))\" 2>/dev/null || echo NA); done; done; done\r\n\u001b[?2004l\r"]
