[140.999587, "o", "#include <errno.h>\r\n#include <stdio.h>\r\n\r\nstatic tb_status append_rec(FILE *f, tb_stamp s) {\r\n  if (!fs_write_u32(f, s.gen))\r\n    return TB_ERR_IO;\r\n\r\n  // stamp format: u32 generation + u64 cursor (12 bytes)\r\n\r\n  uint32_t lo = (uint32_t)(s.cursor & 0xffffffffu);\r\n  uint32_t hi = (uint32_t)((s.cursor >> 32) & 0xffffffffu);\r\n  if (!fs_write_u32(f, lo))\r\n    return TB_ERR_IO;\r\n  if (!fs_write_u32(f, hi))\r\n    return TB_ERR_IO;\r\n\r\n  return TB_OK;\r\n}\r\n\r\nstatic bool read_rec(FILE *f, tb_stamp *out) {\r\n  uint32_t gen = 0;\r\n  if (!fs_read_u32(f, &gen))\r\n    return false;\r\n\r\n  uint32_t lo = 0;\r\n  if (!fs_read_u32(f, &lo))\r\n    return false;\r\n\r\n  uint32_t hi = 0;\r\n  if (!fs_read_u32(f, &hi))\r\n    return false;\r\n\r\n  out->gen = gen;\r\n  out->cursor = ((uint64_t)hi << 32) | (uint64_t)lo;\r\n  return true;\r\n}\r\n\r\ntb_status journal_append_stamp(const char *path, tb_stamp s) {\r\n  FILE *f = fopen(path, \"ab\");\r\n  if (!f)\r\n    return TB_ERR_IO;\r\n  tb_status st = append_rec(f, s);\r\n  if (fclose(f) != 0)\r\n    return TB_ERR_IO;\r\n  re"]
[140.999655, "o", "turn st;\r\n}\r\n\r\ntb_status journal_load_last(const char *path, tb_stamp *out, bool *found) {\r\n  if (!out || !found)\r\n    return TB_ERR_BAD_ARG;\r\n\r\n  FILE *f = fopen(path, \"rb\");\r\n  if (!f) {\r\n    if (errno == ENOENT) {\r\n      *found = false;\r\n      return TB_OK;\r\n    }\r\n    return TB_ERR_IO;\r\n  }\r\n\r\n  tb_stamp cur = {0};\r\n  bool any = false;\r\n  while (read_rec(f, &cur)) {\r\n    any = true;\r\n  }\r\n  fclose(f);\r\n  if (!any) {\r\n    *found = false;\r\n    return TB_OK;\r\n  }\r\n  *found = true;\r\n  *out = cur;\r\n  return TB_OK;\r\n}\r\n"]
