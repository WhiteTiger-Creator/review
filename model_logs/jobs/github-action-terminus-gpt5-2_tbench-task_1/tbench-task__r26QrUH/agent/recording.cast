[95.710033, "o", "\r\n"]
[95.710179, "o", "\u001b[?2004l\r"]
[95.711678, "o", "#include \"logic/nudge.h\"\r\n\r\n#include \"core/ev.h\"\r\n\r\ntb_status tb_nudge_drain(tb_rt *rt, uint32_t tick) {\r\n  (void)tick;\r\n"]
[95.711709, "o", "  if (!rt)\r\n    return TB_ERR_BAD_ARG;\r\n\r\n  uint64_t token = 0;\r\n  while (tb_q64_pop(&rt->notify_q, &token)) {\r\n    uint64_t key = (uint32_t)token;\r\n    if (!tb_map_u64_has(&rt->token_done, key)) {\r\n      continue;\r\n"]
[95.711723, "o", "    }\r\n    uint64_t id64 = 0;\r\n"]
[95.711736, "o", "    if (!tb_map_u64_get(&rt->token_to_id, token, &id64))\r\n      continue;\r\n    tb_event ev = {.kind = TB_EV_POKE, .id = (uint32_t)id64};\r\n"]
[95.711969, "o", "    (void)tb_vec_ev_push(&rt->evlog, ev);\r\n  }\r\n  return TB_OK;\r\n}\r\n\u001b[?2004h"]
[95.71199, "o", "root@7ae5e2ee926b:/app# "]
[95.821294, "i", "apply_patch <<'PATCH'\n*** Begin Patch\n*** Update File: /app/src/io/journal.c\n@@\n static tb_status append_rec(FILE *f, tb_stamp s) {\n   if (!fs_write_u32(f, s.gen))\n     return TB_ERR_IO;\n-\n-  uint32_t lo = (uint32_t)s.cursor;\n-  if (!fs_write_u32(f, lo))\n-    return TB_ERR_IO;\n+\n+  // stamp format: u32 generation + u64 cursor (12 bytes)\n+  uint32_t lo = (uint32_t)(s.cursor & 0xffffffffu);\n+  uint32_t hi = (uint32_t)((s.cursor >> 32) & 0xffffffffu);\n+  if (!fs_write_u32(f, lo))\n+    return TB_ERR_IO;\n+  if (!fs_write_u32(f, hi))\n+    return TB_ERR_IO;\n@@\n static bool read_rec(FILE *f, tb_stamp *out) {\n   uint32_t gen = 0;\n   if (!fs_read_u32(f, &gen))\n     return false;\n@@\n   uint32_t lo = 0;\n   if (!fs_read_u32(f, &lo))\n     return false;\n+\n+  uint32_t hi = 0;\n+  if (!fs_read_u32(f, &hi))\n+    return false;\n@@\n   out->gen = gen;\n-  out->cursor = (uint64_t)lo;\n+  out->cursor = ((uint64_t)hi << 32) | (uint64_t)lo;\n   return true;\n }\n*** End Patch\nPATCH\n"]
[95.821464, "o", "apply_patch <<'PATCH'\r\n"]
