[?2004l#pragma once

#include "tb_err.h"

#include <stdbool.h>
#include <stdint.h>

typedef struct {
  uint32_t gen;
  uint64_t cursor;
} tb_stamp;

tb_status journal_append_stamp(const char *path, tb_stamp s);
tb_status journal_load_last(const char *path, tb_stamp *out, bool *found);

[?2004hroot@7ae5e2ee926b:/app# sed -n '1,260p' /app/src/runtime/runtime.c
[?2004l#include "runtime/runtime.h"

#include "core/idgen.h"
#include "logic/ingest.h"
#include "logic/link.h"
#include "logic/merge.h"
#include "logic/nudge.h"
#include "logic/settle.h"

#include <stdio.h>
#include <string.h>

tb_status tb_rt_init(tb_rt *rt, const char *journal_path) {
  if (!rt || !journal_path)
    return TB_ERR_BAD_ARG;
  memset(rt, 0, sizeof(*rt));

  if (!tb_map_u64_init(&rt->token_to_id, 128))
    return TB_ERR_OOM;
  if (!tb_map_u64_init(&rt->token_done, 128))
    return TB_ERR_OOM;
  if (!tb_q64_init(&rt->in_q, 4096))
    return TB_ERR_OOM;
  if (!tb_q64_init(&rt->done_a, 4096))
    return TB_ERR_OOM;
  if (!tb_q64_init(&rt->done_b, 4096))
    return TB_ERR_OOM;
  if (!tb_q64_init(&rt->notify_q, 4096))
    return TB_ERR_OOM;
  if (!tb_vec_ev_init(&rt->evlog, 2048))
    return TB_ERR_OOM;

  rt->gen = 1;
  rt->cursor = 1;
  rt->attached = true;
  rt->journal_path = journal_path;
  return TB_OK;
}

void tb_rt_free(tb_rt *rt) {
  if (!rt)
    return;
  tb_map_u64_free(&rt->token_to_id);
  tb_map_u64_free(&rt->token_done);
  tb_q64_free(&rt->in_q);
  tb_q64_free(&rt->done_a);
  tb_q64_free(&rt->done_b);
  tb_q64_free(&rt->notify_q);
  tb_vec_ev_free(&rt->evlog);
}

const tb_vec_ev *tb_rt_events(const tb_rt *rt) { return &rt->evlog; }

static tb_status maybe_detach_attach(tb_rt *rt, const tb_script *sc, uint32_t tick) {
  if (sc->detach_at && tick == sc->detach_at) {
    return tb_link_detach(rt, tick);
  }
  if (sc->detach_at && tick == sc->detach_at + sc->detach_len) {
    return tb_link_attach(rt, tick);
  }
  if (sc->detach2_at && tick == sc->detach2_at) {
    return tb_link_detach(rt, tick);
  }
  if (sc->detach2_at && tick == sc->detach2_at + sc->detach2_len) {
    return tb_link_attach(rt, tick);
  }
  return TB_OK;
}

tb_status tb_rt_run(tb_rt *rt, tb_scenario scn, tb_profile prof, tb_order ord, uint32_t seed) {
  (void)seed;
  if (!rt)
    return TB_ERR_BAD_ARG;

  tb_script sc = {0};
  if (!tb_script_for(scn, &sc))
    return TB_ERR_BAD_ARG;

  tb_stamp last = {0};
  bool found = false;
  tb_status st = journal_load_last(rt->journal_path, &last, &found);
  if (st != TB_OK)
    return st;
  if (found) {
    rt->gen = last.gen + 1;
    rt->cursor = last.cursor;
  }

  for (uint32_t tick = 0; tick < sc.ticks; tick++) {
    st = maybe_detach_attach(rt, &sc, tick);
    if (st != TB_OK)
      return st;

    uint32_t submitted = 0;
    st = tb_ingest_tick(rt, prof, tick, &submitted);
    if (st != TB_OK)
      return st;

    st = tb_settle_tick(rt, tick);
    if (st != TB_OK)
      return st;

    st = tb_merge_drain(rt, tick, ord);
    if (st != TB_OK)
      return st;

    st = tb_nudge_drain(rt, tick);
    if (st != TB_OK)
      return st;
  }

  // Final drain to avoid leaving work in queues.
  for (uint32_t i = 0; i < 16; i++) {
    st = tb_settle_tick(rt, sc.ticks + i);
    if (st != TB_OK)
      return st;
    st = tb_merge_drain(rt, sc.ticks + i, ord);
    if (st != TB_OK)
      return st;
    st = tb_nudge_drain(rt, sc.ticks + i);
    if (st != TB_OK)
      return st;
  }

  return TB_OK;
}

[?2004hroot@7ae5e2ee926b:/app# sed -n '1,260p' /app/src/logic/ingest.c
[?2004l#include "logic/ingest.h"

#include "core/ev.h"
#include "runtime/profile.h"

static uint64_t make_token(uint32_t gen, uint64_t cursor) { return (((uint64_t)gen) << 32) ^ cursor; }

tb_status tb_ingest_tick(tb_rt *rt, tb_profile prof, uint32_t tick, uint32_t *submitted_out) {
  if (!rt || !submitted_out)
    return TB_ERR_BAD_ARG;

  uint32_t n = tb_profile_should_submit(prof, tick);
  *submitted_out = n;

  for (uint32_t i = 0; i < n; i++) {
    uint32_t id = (uint32_t)(rt->cursor & 0xffffffffu);
    uint64_t token = make_token(rt->gen, rt->cursor);
    rt->cursor++;

    if (!tb_map_u64_put(&rt->token_to_id, token, (uint64_t)id))
      return TB_ERR_OOM;
    if (!tb_q64_push(&rt->in_q, token))
      return TB_ERR_CORRUPT;

    tb_event ev = {.kind = TB_EV_SUBMIT, .id = id};
    if (!tb_vec_ev_push(&rt->evlog, ev))
      return TB_ERR_OOM;
  }

  return TB_OK;
}

[?2004hroot@7ae5e2ee926b:/app# sed -n '1,260p' /app/src/core/idgen.c
[?2004l#include "core/idgen.h"

void tb_idgen_init(tb_idgen *g, uint64_t seed) { g->x = seed ? seed : 0x9e3779b97f4a7c15ULL; }

uint64_t tb_idgen_next(tb_idgen *g) {
  // xorshift64*
  uint64_t x = g->x;
  x ^= x >> 12;
  x ^= x << 25;
  x ^= x >> 27;
  g->x = x;
  return x * 2685821657736338717ULL;
}

[?2004hroot@7ae5e2ee926b:/app# sed -n '1,320p' /app/src/logic/settle.c
[?2004l#include "logic/settle.h"

#include "runtime/runtime.h"

// Deterministic "work takes time": only move certain tokens each tick.
static bool ready(uint64_t token, uint32_t tick) {
  // spread completion across ticks, but deterministic and input-dependent
  return (((uint32_t)token) ^ tick) % 3 == 0;
}

static bool lane_a(uint64_t token, uint32_t tick) {
  // Choose which completion source produced the "done" record.
  return ((((uint32_t)(token >> 32)) + (uint32_t)token + tick) & 1u) == 0u;
}

tb_status tb_settle_tick(tb_rt *rt, uint32_t tick) {
  if (!rt)
    return TB_ERR_BAD_ARG;

  // rotate through at most a bounded number so runs are stable
  size_t spins = rt->in_q.len;
  for (size_t i = 0; i < spins; i++) {
    uint64_t token = 0;
    if (!tb_q64_pop(&rt->in_q, &token))
      break;

    if (ready(token, tick)) {
      if (lane_a(token, tick)) {
        if (!tb_q64_push(&rt->done_a, token))
          return TB_ERR_CORRUPT;
      } else {
        if (!tb_q64_push(&rt->done_b, token))
          return TB_ERR_CORRUPT;
      }
      if (rt->attached) {
        // The notifier is only live while attached.
        if (!tb_q64_push(&rt->notify_q, token))
          return TB_ERR_CORRUPT;
      }
    } else {
      // not ready, requeue at tail
      if (!tb_q64_push(&rt->in_q, token))
        return TB_ERR_CORRUPT;
    }
  }

  return TB_OK;
}

