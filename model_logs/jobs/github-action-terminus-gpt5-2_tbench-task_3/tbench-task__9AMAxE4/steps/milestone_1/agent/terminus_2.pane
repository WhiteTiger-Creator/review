    70	static int parse_int(const char *s, int *out) {
    71	    if (!s || !*s) return 0;
    72	    char *end = NULL;
    73	    long v = strtol(s, &end, 10);
    74	    if (!end || *end != '\0') return 0;
    75	    if (v < 0 || v > 1000000000L) return 0;
    76	    *out = (int)v;
    77	    return 1;
    78	}
