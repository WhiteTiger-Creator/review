    int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);
    if (rc != SQLITE_OK) {
        pthread_mutex_unlock(&db_mu);
        return 0;
    }

    int total = 0;
    if (sqlite3_step(stmt) == SQLITE_ROW) {
        total = sqlite3_column_int(stmt, 0);
    }
    sqlite3_finalize(stmt);

    pthread_mutex_unlock(&db_mu);
    return total;
}

int note_exists(int id) {
    pthread_mutex_lock(&db_mu);

    const char *sql = "SELECT 1 FROM notes WHERE id=?;";
    sqlite3_stmt *stmt = NULL;
    int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);
    if (rc != SQLITE_OK) {
        pthread_mutex_unlock(&db_mu);
        return 0;
    }
    sqlite3_bind_int(stmt, 1, id);
    int exists = (sqlite3_step(stmt) == SQLITE_ROW);
    sqlite3_finalize(stmt);

    pthread_mutex_unlock(&db_mu);
    return exists;
}

char *get_note_json(int id) {
    pthread_mutex_lock(&db_mu);

    const char *sql = "SELECT id, title, content FROM notes WHERE id=?;";
    sqlite3_stmt *stmt = NULL;
    int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);
    if (rc != SQLITE_OK) {
        pthread_mutex_unlock(&db_mu);
        return NULL;
    }
    sqlite3_bind_int(stmt, 1, id);

    char *out = NULL;
    if (sqlite3_step(stmt) == SQLITE_ROW) {
        int rid = sqlite3_column_int(stmt, 0);
        const char *title = (const char *)sqlite3_column_text(stmt, 1);
        const char *content = (const char *)sqlite3_column_text(stmt, 2);
        char *et = json_escape(title);
        char *ec = json_escape(content);
        if (et && ec) {
            size_t needed = strlen(et) + strlen(ec) + 64;
            out = malloc(needed);
            if (out)
                snprintf(out, needed,
                         "{\"id\":%d,\"title\":\"%s\",\"content\":\"%s\"}",
                         rid, et, ec);
        }
        free(et);
        free(ec);
    }

    sqlite3_finalize(stmt);
    pthread_mutex_unlock(&db_mu);
    return out;
}

int update_note(int id, const char *title, const char *content) {
    pthread_mutex_lock(&db_mu);

    sqlite3_exec(db, "BEGIN IMMEDIATE;", NULL, NULL, NULL);

    const char *sql = "UPDATE notes SET title=?, content=? WHERE id=?;";
    sqlite3_stmt *stmt = NULL;
    int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);
    if (rc != SQLITE_OK) {
        sqlite3_exec(db, "ROLLBACK;", NULL, NULL, NULL);
        pthread_mutex_unlock(&db_mu);
        return 0;
    }

    sqlite3_bind_text(stmt, 1, title ? title : "", -1, SQLITE_TRANSIENT);
    sqlite3_bind_text(stmt, 2, content ? content : "", -1, SQLITE_TRANSIENT);
    sqlite3_bind_int(stmt, 3, id);

    rc = sqlite3_step(stmt);
    int changed = sqlite3_changes(db);
    sqlite3_finalize(stmt);

    if (rc != SQLITE_DONE) {
        sqlite3_exec(db, "ROLLBACK;", NULL, NULL, NULL);
        pthread_mutex_unlock(&db_mu);
        return 0;
    }

    sqlite3_exec(db, "COMMIT;", NULL, NULL, NULL);
    pthread_mutex_unlock(&db_mu);
    return changed > 0;
}

int delete_note(int id) {
    pthread_mutex_lock(&db_mu);

    sqlite3_exec(db, "BEGIN IMMEDIATE;", NULL, NULL, NULL);

    const char *sql = "DELETE FROM notes WHERE id=?;";
    sqlite3_stmt *stmt = NULL;
    int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);
    if (rc != SQLITE_OK) {
        sqlite3_exec(db, "ROLLBACK;", NULL, NULL, NULL);
        pthread_mutex_unlock(&db_mu);
        return 0;
    }

    sqlite3_bind_int(stmt, 1, id);
    rc = sqlite3_step(stmt);
    int changed = sqlite3_changes(db);
    sqlite3_finalize(stmt);

    if (rc != SQLITE_DONE) {
        sqlite3_exec(db, "ROLLBACK;", NULL, NULL, NULL);
        pthread_mutex_unlock(&db_mu);
        return 0;
    }

    sqlite3_exec(db, "COMMIT;", NULL, NULL, NULL);
    pthread_mutex_unlock(&db_mu);
    return changed > 0;
}

// Legacy function, not used by the contract but kept for completeness.
char *get_all_notes_json(void) {
    return get_notes_paginated_json(1000000, 0);
}
[?2004hroot@08d5c4164ec3:/app# sed -n '130,220p' /app/src/main.c
[?2004lstatic void request_completed(void *cls, struct MHD_Connection *connection,
    void **con_cls, enum MHD_RequestTerminationCode toe) {
    (void)cls; (void)connection; (void)toe;
    if (con_cls && *con_cls) {
        struct connection_info *ci = *con_cls;
        if (ci->data) free(ci->data);
        free(ci);
        *con_cls = NULL;
    }
}

static enum MHD_Result handle_request(void *cls,
    struct MHD_Connection *connection,
    const char *url, const char *method,
    const char *version,
    const char *upload_data, size_t *upload_data_size,
    void **con_cls) {
    (void)cls; (void)version;

    if (strncmp(url, "/api/", 5) == 0) {
        return route_request(connection, url, method, upload_data,
                             upload_data_size, con_cls);
    }

    if (strcmp(method, "GET") == 0) {
        enum MHD_Result ret = serve_static_file(connection, url);
        if (ret == MHD_YES) return ret;
    }

    struct MHD_Response *response = MHD_create_response_from_buffer(
        9, (void *)"Not Found", MHD_RESPMEM_PERSISTENT);
    enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_NOT_FOUND, response);
    MHD_destroy_response(response);
    return ret;
}

int main(void) {
    signal(SIGINT, handle_signal);
    signal(SIGTERM, handle_signal);

    mkdir("/app/data", 0755);

    if (init_db("/app/data/notes.db") != 0) {
        fprintf(stderr, "Failed to initialize database\n");
        return 1;
    }

    daemon_handle = MHD_start_daemon(
        MHD_USE_THREAD_PER_CONNECTION,
        PORT,
        NULL, NULL,
        &handle_request, NULL,
        MHD_OPTION_NOTIFY_COMPLETED, &request_completed, NULL,
        MHD_OPTION_END
    );

    if (!daemon_handle) {
        fprintf(stderr, "Failed to start server\n");
        return 1;
    }

    printf("Server running on port %d\n", PORT);
    while (1) pause();
    return 0;
}
