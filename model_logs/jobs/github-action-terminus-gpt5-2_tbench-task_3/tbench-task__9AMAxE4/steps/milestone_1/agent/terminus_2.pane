static char *json_escape(const char *s) {
    if (!s) s = "";
    size_t extra = 0;
    for (const unsigned char *p = (const unsigned char *)s; *p; p++) {
        switch (*p) {
        case '"':
        case '\\':
            extra++;
            break;
        case '\b':
        case '\f':
        case '\n':
        case '\r':
        case '\t':
            extra++;
            break;
        default:
            if (*p < 0x20) extra += 5; // \u00XX
            break;
        }
    }

    size_t len = strlen(s);
    char *out = malloc(len + extra + 1);
    if (!out) return NULL;

    char *o = out;
    for (const unsigned char *p = (const unsigned char *)s; *p; p++) {
        switch (*p) {
        case '"':
            *o++ = '\\';
            *o++ = '"';
            break;
        case '\\':
            *o++ = '\\';
            *o++ = '\\';
            break;
        case '\b':
            *o++ = '\\';
            *o++ = 'b';
