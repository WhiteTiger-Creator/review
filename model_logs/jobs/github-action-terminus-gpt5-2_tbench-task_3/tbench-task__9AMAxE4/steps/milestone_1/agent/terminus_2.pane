    80	static void trim_ws_in_place(char *s) {
    81	    if (!s) return;
    82	    size_t len = strlen(s);
    83	    while (len > 0 && isspace((unsigned char)s[len - 1])) {
    84	        s[len - 1] = '\0';
    85	        len--;
    86	    }
    87	    size_t i = 0;
    88	    while (s[i] && isspace((unsigned char)s[i])) i++;
    89	    if (i > 0) memmove(s, s + i, strlen(s + i) + 1);
    90	}
