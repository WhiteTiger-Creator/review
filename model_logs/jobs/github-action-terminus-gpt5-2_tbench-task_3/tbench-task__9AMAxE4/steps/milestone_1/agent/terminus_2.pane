   197	static int parse_id_from_path(const char *url, int *out_id) {
   198	    const char *prefix = "/api/notes/";
   199	    size_t prelen = strlen(prefix);
   200	    if (strncmp(url, prefix, prelen) != 0) return 0;
   201	    const char *idstr = url + prelen;
   202	    if (*idstr == '\0') return 0;
   203	    if (strchr(idstr, '/')) return 0;
   204	    return parse_int(idstr, out_id);
   205	}
