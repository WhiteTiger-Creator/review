        sqlite3_free(err_msg);
        pthread_mutex_unlock(&db_mu);
        return -1;
    }

    pthread_mutex_unlock(&db_mu);
    return 0;
}

void close_db(void) {
    pthread_mutex_lock(&db_mu);
    if (db) sqlite3_close(db);
    db = NULL;
    pthread_mutex_unlock(&db_mu);
}

static char *json_escape(const char *s) {
    if (!s) s = "";
    size_t extra = 0;
    for (const unsigned char *p = (const unsigned char *)s; *p; p++) {
        switch (*p) {
        case '"':
        case '\\':
            extra++;
            break;
        case '\b':
        case '\f':
        case '\n':
        case '\r':
        case '\t':
            extra++;
            break;
        default:
            if (*p < 0x20) extra += 5; // \u00XX
            break;
        }
    }

    size_t len = strlen(s);
    char *out = malloc(len + extra + 1);
    if (!out) return NULL;

    char *o = out;
    for (const unsigned char *p = (const unsigned char *)s; *p; p++) {
        switch (*p) {
        case '"':
            *o++ = '\\';
            *o++ = '"';
            break;
        case '\\':
            *o++ = '\\';
            *o++ = '\\';
            break;
        case '\b':
            *o++ = '\\';
            *o++ = 'b';
            break;
        case '\f':
            *o++ = '\\';
            *o++ = 'f';
            break;
        case '\n':
            *o++ = '\\';
            *o++ = 'n';
            break;
        case '\r':
            *o++ = '\\';
            *o++ = 'r';
            break;
        case '\t':
            *o++ = '\\';
            *o++ = 't';
            break;
        default:
            if (*p < 0x20) {
                sprintf(o, "\\u%04x", (unsigned int)(*p));
                o += 6;
            } else {
                *o++ = (char)(*p);
            }
            break;
        }
    }
    *o = '\0';
    return out;
}

