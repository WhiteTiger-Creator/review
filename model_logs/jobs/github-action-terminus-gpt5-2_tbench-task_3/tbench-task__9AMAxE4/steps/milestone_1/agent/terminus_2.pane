    13	static enum MHD_Result send_json(struct MHD_Connection *connection,
    14	                                const char *body, unsigned int status_code) {
    15	    struct MHD_Response *response = MHD_create_response_from_buffer(
    16	        strlen(body), (void *)body, MHD_RESPMEM_MUST_COPY);
    17	    MHD_add_response_header(response, "Content-Type", "application/json");
    18	    MHD_add_response_header(response, "Access-Control-Allow-Origin", "*");
    19	    MHD_add_response_header(response, "Access-Control-Allow-Methods",
    20	                            "GET, POST, PUT, DELETE, OPTIONS");
    21	    MHD_add_response_header(response, "Access-Control-Allow-Headers",
    22	                            "Content-Type, X-API-Key");
    23	    enum MHD_Result ret = MHD_queue_response(connection, status_code, response);
    24	    MHD_destroy_response(response);
    25	    return ret;
    26	}
    27	
    28	static enum MHD_Result send_json_total(struct MHD_Connection *connection,
    29	                                      const char *body,
    30	                                      unsigned int status_code,
    31	                                      int total) {
    32	    struct MHD_Response *response = MHD_create_response_from_buffer(
    33	        strlen(body), (void *)body, MHD_RESPMEM_MUST_COPY);
    34	    MHD_add_response_header(response, "Content-Type", "application/json");
    35	    MHD_add_response_header(response, "Access-Control-Allow-Origin", "*");
    36	    MHD_add_response_header(response, "Access-Control-Allow-Methods",
    37	                            "GET, POST, PUT, DELETE, OPTIONS");
    38	    MHD_add_response_header(response, "Access-Control-Allow-Headers",
    39	                            "Content-Type, X-API-Key");
    40	
    41	    char count_str[32];
    42	    snprintf(count_str, sizeof(count_str), "%d", total);
    43	    MHD_add_response_header(response, "X-Total-Count", count_str);
    44	
    45	    enum MHD_Result ret = MHD_queue_response(connection, status_code, response);
    46	    MHD_destroy_response(response);
    47	    return ret;
    48	}
