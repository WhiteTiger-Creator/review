int create_note(const char *title, const char *content) {
    pthread_mutex_lock(&db_mu);

    sqlite3_exec(db, "BEGIN IMMEDIATE;", NULL, NULL, NULL);

    const char *sql = "INSERT INTO notes (title, content) VALUES (?, ?);";
    sqlite3_stmt *stmt = NULL;
    int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);
    if (rc != SQLITE_OK) {
        sqlite3_exec(db, "ROLLBACK;", NULL, NULL, NULL);
        pthread_mutex_unlock(&db_mu);
        return -1;
    }

    sqlite3_bind_text(stmt, 1, title ? title : "", -1, SQLITE_TRANSIENT);
    sqlite3_bind_text(stmt, 2, content ? content : "", -1, SQLITE_TRANSIENT);

    rc = sqlite3_step(stmt);
    sqlite3_finalize(stmt);
    if (rc != SQLITE_DONE) {
        sqlite3_exec(db, "ROLLBACK;", NULL, NULL, NULL);
        pthread_mutex_unlock(&db_mu);
        return -1;
    }

    int id = (int)sqlite3_last_insert_rowid(db);
    sqlite3_exec(db, "COMMIT;", NULL, NULL, NULL);

    pthread_mutex_unlock(&db_mu);
    return id;
}

static char *appendf(char *buf, size_t *cap, size_t *len, const char *fmt, ...) {
    va_list ap;
    while (1) {
        if (*cap - *len < 256) {
            *cap = (*cap == 0) ? 1024 : (*cap * 2);
            buf = realloc(buf, *cap);
            if (!buf) return NULL;
        }
        va_start(ap, fmt);
        int n = vsnprintf(buf + *len, *cap - *len, fmt, ap);
        va_end(ap);
        if (n < 0) return NULL;
        if ((size_t)n < *cap - *len) {
            *len += (size_t)n;
            return buf;
        }
        *cap += (size_t)n + 1;
        buf = realloc(buf, *cap);
        if (!buf) return NULL;
    }
}

char *get_notes_paginated_json(int limit, int offset) {
    pthread_mutex_lock(&db_mu);

    const char *sql =
        "SELECT id, title, content FROM notes ORDER BY id LIMIT ? OFFSET ?;";
    sqlite3_stmt *stmt = NULL;
    int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);
    if (rc != SQLITE_OK) {
        pthread_mutex_unlock(&db_mu);
        return NULL;
    }

    sqlite3_bind_int(stmt, 1, limit);
    sqlite3_bind_int(stmt, 2, offset);

    char *out = NULL;
    size_t cap = 0, len = 0;
    out = appendf(out, &cap, &len, "[");
    int first = 1;

    while ((rc = sqlite3_step(stmt)) == SQLITE_ROW) {
        int id = sqlite3_column_int(stmt, 0);
        const char *title = (const char *)sqlite3_column_text(stmt, 1);
        const char *content = (const char *)sqlite3_column_text(stmt, 2);
        char *et = json_escape(title);
        char *ec = json_escape(content);
        if (!et || !ec) {
            free(et);
            free(ec);
            free(out);
            sqlite3_finalize(stmt);
            pthread_mutex_unlock(&db_mu);
            return NULL;
        }

        out = appendf(out, &cap, &len,
                      "%s{\"id\":%d,\"title\":\"%s\",\"content\":\"%s\"}",
                      first ? "" : ",", id, et, ec);
        first = 0;
        free(et);
        free(ec);
        if (!out) {
            sqlite3_finalize(stmt);
            pthread_mutex_unlock(&db_mu);
            return NULL;
        }
    }

    sqlite3_finalize(stmt);
    out = appendf(out, &cap, &len, "]");

    pthread_mutex_unlock(&db_mu);
    return out;
}

int get_total_notes_count(void) {
    pthread_mutex_lock(&db_mu);

    const char *sql = "SELECT COUNT(*) FROM notes;";
    sqlite3_stmt *stmt = NULL;
    int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);
    if (rc != SQLITE_OK) {
        pthread_mutex_unlock(&db_mu);
        return 0;
    }

    int total = 0;
    if (sqlite3_step(stmt) == SQLITE_ROW) {
        total = sqlite3_column_int(stmt, 0);
    }
    sqlite3_finalize(stmt);

    pthread_mutex_unlock(&db_mu);
    return total;
}

int note_exists(int id) {
    pthread_mutex_lock(&db_mu);

    const char *sql = "SELECT 1 FROM notes WHERE id=?;";
    sqlite3_stmt *stmt = NULL;
    int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);
    if (rc != SQLITE_OK) {
        pthread_mutex_unlock(&db_mu);
        return 0;
    }
    sqlite3_bind_int(stmt, 1, id);
    int exists = (sqlite3_step(stmt) == SQLITE_ROW);
    sqlite3_finalize(stmt);

    pthread_mutex_unlock(&db_mu);
    return exists;
}

