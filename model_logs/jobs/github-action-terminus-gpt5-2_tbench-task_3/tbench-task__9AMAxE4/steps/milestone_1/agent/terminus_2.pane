        va_end(ap);
        if (n < 0) return NULL;
        if ((size_t)n < *cap - *len) {
            *len += (size_t)n;
            return buf;
        }
        *cap += (size_t)n + 1;
        buf = realloc(buf, *cap);
        if (!buf) return NULL;
    }
}

