   179	static char *appendf(char *buf, size_t *cap, size_t *len, const char *fmt, ...) {
   180	    va_list ap;
   181	    while (1) {
   182	        if (*cap - *len < 256) {
   183	            *cap = (*cap == 0) ? 1024 : (*cap * 2);
   184	            buf = realloc(buf, *cap);
   185	            if (!buf) return NULL;
   186	        }
   187	        va_start(ap, fmt);
   188	        int n = vsnprintf(buf + *len, *cap - *len, fmt, ap);
   189	        va_end(ap);
   190	        if (n < 0) return NULL;
   191	        if ((size_t)n < *cap - *len) {
   192	            *len += (size_t)n;
   193	            return buf;
   194	        }
   195	        *cap += (size_t)n + 1;
   196	        buf = realloc(buf, *cap);
   197	        if (!buf) return NULL;
   198	    }
   199	}
