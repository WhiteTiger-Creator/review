   147	int create_note(const char *title, const char *content) {
   148	    pthread_mutex_lock(&db_mu);
   149	
   150	    sqlite3_exec(db, "BEGIN IMMEDIATE;", NULL, NULL, NULL);
   151	
   152	    const char *sql = "INSERT INTO notes (title, content) VALUES (?, ?);";
   153	    sqlite3_stmt *stmt = NULL;
   154	    int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);
   155	    if (rc != SQLITE_OK) {
   156	        sqlite3_exec(db, "ROLLBACK;", NULL, NULL, NULL);
   157	        pthread_mutex_unlock(&db_mu);
   158	        return -1;
   159	    }
   160	
   161	    sqlite3_bind_text(stmt, 1, title ? title : "", -1, SQLITE_TRANSIENT);
   162	    sqlite3_bind_text(stmt, 2, content ? content : "", -1, SQLITE_TRANSIENT);
   163	
   164	    rc = sqlite3_step(stmt);
   165	    sqlite3_finalize(stmt);
   166	    if (rc != SQLITE_DONE) {
   167	        sqlite3_exec(db, "ROLLBACK;", NULL, NULL, NULL);
   168	        pthread_mutex_unlock(&db_mu);
   169	        return -1;
   170	    }
   171	
   172	    int id = (int)sqlite3_last_insert_rowid(db);
   173	    sqlite3_exec(db, "COMMIT;", NULL, NULL, NULL);
   174	
   175	    pthread_mutex_unlock(&db_mu);
   176	    return id;
   177	}
