[639.90731, "o", "     1\t#include \"db.h\"\r\n     2\t\r\n     3\t#include <pthread.h>\r\n     4\t#include <sqlite3.h>\r\n     5\t#include <stdio.h>\r\n     6\t#include <stdarg.h>\r\n     7\t#include <stdlib.h>\r\n     8\t#include <string.h>\r\n     9\t\r\n    10\tstatic sqlite3 *db = NULL;\r\n    11\tstatic pthread_mutex_t db_mu = PTHREAD_MUTEX_INITIALIZER;\r\n    12\t\r\n    13\tstatic int exec_pragma(const char *sql) {\r\n    14\t    char *err = NULL;\r\n    15\t    int rc = sqlite3_exec(db, sql, NULL, NULL, &err);\r\n    16\t    if (rc != SQLITE_OK) {\r\n    17\t        fprintf(stderr, \"SQLite pragma error: %s (%s)\\n\", err ? err : \"?\", sql);\r\n    18\t        sqlite3_free(err);\r\n    19\t        return -1;\r\n    20\t    }\r\n    21\t    return 0;\r\n    22\t}\r\n    23\t\r\n    24\tint init_db(const char *path) {\r\n    25\t    pthread_mutex_lock(&db_mu);\r\n    26\t\r\n    27\t    if (sqlite3_open_v2(path, &db,\r\n    28\t                        SQLITE_OPEN_READWRITE | SQLITE_OPEN_CREATE |\r\n    29\t                            SQLITE_OPEN_FULLMUTEX,\r\n    30\t                        NULL) != SQLITE_OK) {\r\n    31\t        fprintf(stderr, \"Cannot open database: %s\\n\", sqlite3_errmsg(db));\r\n    32\t        pthread_mutex_unlock(&db_mu);\r\n    33\t        return -1;\r\n    34\t    }\r\n    35\t\r\n    36\t    // Concurrency / durability tuning suitable for test workloads.\r\n    37\t    if (exec_pragma(\"PRAGMA journal_mode=WAL;\") != 0) {\r\n    38\t        pthread_mutex_unlock(&db_mu);\r\n    39\t        return -1;\r\n    40\t    }\r\n    41\t    if (exec_pragma(\"PRAGMA synchronous=NORMAL;\") != 0) {\r\n    42\t        pthread_mutex_unlock(&db_mu);\r\n    43\t        return -1;\r\n    44\t    }\r\n    45\t    if (exec_pragma(\"PRAGMA busy_timeout=5000;\") != 0) {\r\n    46\t        pthread_mutex_unlock(&db_mu);\r\n    47\t        return -1;\r\n    48\t    }\r\n    49\t\r\n    50\t    const char *sql =\r\n    51\t        \"CREATE TABLE IF NOT EXISTS notes (\"\r\n    52\t        \"id INTEGER PRIMARY KEY AUTOINCREMENT,\"\r\n    53\t        \"title TEXT NOT NULL,\"\r\n    54\t        \"content TEXT NOT NULL DEFAULT ''\"\r\n    55\t        \");\";\r\n    56\t\r\n    57\t    char *err_msg = NULL;\r\n    58\t    if (sqlite3_exec(db, sql, NULL, NULL, &err_msg) != SQLITE_OK) {\r\n    59\t        fprintf(stderr, \"SQL error: %s\\n\", err_msg);\r\n    60\t        sqlite3_free(err_msg);\r\n    61\t        pthread_mutex_unlock(&db_mu);\r\n    62\t        return -1;\r\n    63\t    }\r\n    64\t\r\n    65\t    pthread_mutex_unlock(&db_mu);\r\n    66\t    return 0;\r\n    67\t}\r\n    68\t\r\n    69\tvoid close_db(void) {\r\n    70\t    pthread_mutex_lock(&db_mu);\r\n    71\t    if (db) sqlite3_close(db);\r\n    72\t    db = NULL;\r\n    73\t    pthread_mutex_unlock(&db_mu);\r\n    74\t}\r\n    75\t\r\n    76\tstatic char *json_escape(const char *s) {\r\n    77\t    if (!s) s = \"\";\r\n    78\t    size_t extra = 0;\r\n    79\t    for (const unsigned char *p = (const unsigned char *)s; *p; p++) {\r\n    80\t        switch (*p) {\r\n    81\t        case '\"':\r\n    82\t        case '\\\\':\r\n    83\t            extra++;\r\n    84\t            break;\r\n    85\t        case '\\b':\r\n    86\t        case '\\f':\r\n    87\t        case '\\n':\r\n    88\t        case '\\r':\r\n    89\t        case '\\t':\r\n    90\t            extra++;\r\n    91\t            break;\r\n    92\t        default:\r\n    93\t            if (*p < 0x20) extra += 5; // \\u00XX\r\n    94\t            break;\r\n    95\t        }\r\n    96\t    }\r\n    97\t\r\n    98\t    size_t len = strlen(s);\r\n    99\t    char *out = malloc(len + extra + 1);\r\n   100\t    if (!out) return NULL;\r\n   101\t\r\n   102\t    char *o = out;\r\n   103\t    for (const unsigned char *p = (const unsigned char *)s; *p; p++) {\r\n   104\t        switch (*p) {\r\n   105\t        case '\"':\r\n   106\t            *o++ = '\\\\';\r\n   107\t            *o++ = '\"';\r\n   108\t            break;\r\n   109\t        case '\\\\':\r\n   110\t            *o++ = '\\\\';\r\n   111\t            *o++ = '\\\\';\r\n   112\t            break;\r\n   113\t        case '\\b':\r\n   114\t            *o++ = '\\\\';\r\n   115\t            *o++ = 'b';\r\n   116\t            break;\r\n   117\t        case '\\f':\r\n   118\t            *o++ = '\\\\';\r\n   119\t            *o++ = 'f';\r\n   120\t            break;\r\n"]
