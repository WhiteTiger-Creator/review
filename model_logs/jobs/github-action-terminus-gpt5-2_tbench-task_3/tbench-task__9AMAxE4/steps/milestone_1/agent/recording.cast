[677.210903, "o", "\r\n   130\t            case 't': c = '\\t'; break;\r\n   131\t            default:\r\n   132\t                free(buf);\r\n   133\t                return 0;\r\n   134\t            }\r\n   135\t        }\r\n   136\t        if (len + 2 > cap) {\r\n   137\t            cap *= 2;\r\n   138\t            char *nb = realloc(buf, cap);\r\n   139\t            if (!nb) {\r\n   140\t                free(buf);\r\n   141\t                return 0;\r\n   142\t            }\r\n   143\t            buf = nb;\r\n"]
