[351.564214, "o", "   190\tstatic enum MHD_Result not_found(struct MHD_Connection *connection) {\r\n   191\t    return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\",\r\n   192\t                     MHD_HTTP_NOT_FOUND);\r\n   193\t}\r\n   194\t\r\n   195\tstatic int parse_id_from_path(const char *url, int *out_id) {\r\n   196\t    const char *prefix = \"/api/notes/\";\r\n   197\t    size_t prelen = strlen(prefix);\r\n   198\t    if (strncmp(url, prefix, prelen) != 0) return 0;\r\n   199\t    const char *idstr = url + prelen;\r\n   200\t    if (*idstr == '\\0') return 0;\r\n   201\t    // No extra path segments.\r\n   202\t    if (strchr(idstr, '/')) return 0;\r\n   203\t    return parse_int(idstr, out_id);\r\n   204\t}\r\n   205\t\r\n   206\tenum MHD_Result route_request(struct MHD_Connection *connection, const char *url,\r\n   207\t                             const char *method, const char *upload_data,\r\n   208\t                             size_t *upload_data_size, void **con_cls) {\r\n   209\t\r\n   210\t    if (strcmp(method, \"OPTIONS\") == 0) return send_json(connection, \"\", MHD_HTTP_OK);\r\n   211\t\r\n   212\t    // Collect request body for POST/PUT.\r\n   213\t    if ((strcmp(method, \"POST\") == 0 || strcmp(method, \"PUT\") == 0)) {\r\n   214\t        enum MHD_Result r = ensure_body_collected(method, upload_data,\r\n   215\t                                                 upload_data_size, con_cls);\r\n   216\t        if (r != MHD_YES) return r;\r\n   217\t        // MHD calls us again when *upload_data_size == 0.\r\n   218\t        if (*upload_data_size != 0) return MHD_YES;\r\n   219\t    } else {\r\n   220\t        if (*con_cls == NULL) {\r\n   221\t            struct connection_info *ci = calloc(1, sizeof(struct connection_info));\r\n   222\t            if (!ci) return MHD_NO;\r\n   223\t            *con_cls = ci;\r\n   224\t            return MHD_YES;\r\n   225\t        }\r\n   226\t    }\r\n   227\t\r\n   228\t    struct connection_info *ci = *con_cls;\r\n   229\t\r\n   230\t    if ((strcmp(method, \"POST\") == 0 || strcmp(method, \"PUT\") == 0) &&\r\n   231\t        ci && ci->data_size > NOTES_MAX_BODY_BYTES) {\r\n   232\t        return too_large(connection);\r\n   233\t    }\r\n   234\t\r\n   235\t    // Collection\r\n   236\t    if (strcmp(url, \"/api/notes\") == 0 && strcmp(method, \"GET\") == 0) {\r\n   237\t        int limit = NOTES_DEFAULT_PAGE_SIZE;\r\n   238\t        int offset = 0;\r\n   239\t\r\n   240\t        const char *limit_s = MHD_lookup_connection_value(connection, MHD_GET_ARGUMENT_KIND, \"limit\");\r\n   241\t        const char *offset_s = MHD_lookup_connection_value(connection, MHD_GET_ARGUMENT_KIND, \"offset\");\r\n   242\t        if (limit_s) {\r\n   243\t            int v;\r\n   244\t            if (parse_int(limit_s, &v)) limit = v;\r\n   245\t        }\r\n   246\t        if (offset_s) {\r\n   247\t            int v;\r\n   248\t            if (parse_int(offset_s, &v)) offset = v;\r\n   249\t        }\r\n   250\t        if (limit <= 0) limit = NOTES_DEFAULT_PAGE_SIZE;\r\n"]
