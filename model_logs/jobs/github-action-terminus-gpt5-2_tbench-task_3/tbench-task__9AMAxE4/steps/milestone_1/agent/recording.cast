[124.98788, "o", "\u001b[?2004h"]
[124.987905, "o", "> "]
[124.988086, "o", "        if ((len == 1 && seg[0] == '.') ||\r\n\u001b[?2004l\r"]
[124.98812, "o", "\u001b[?2004h> "]
[124.988342, "o", "            (len == 2 && seg[0] == '.' && seg[1] == '.'))\r\n\u001b[?2004l\r"]
[124.988373, "o", "\u001b[?2004h> "]
