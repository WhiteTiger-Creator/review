[689.341144, "i", "apply_patch<<'PATCH'\n*** Begin Patch\n*** Update File: src/db.c\n@@\n static sqlite3 *db = NULL;\n static pthread_mutex_t db_mu = PTHREAD_MUTEX_INITIALIZER;\n+\n+static void log_sqlite_err(const char *where) {\n+    FILE *f = fopen(\"/app/data/db_errors.log\", \"a\");\n+    if (!f) return;\n+    fprintf(f, \"%s: %s\\n\", where ? where : \"?\", db ? sqlite3_errmsg(db) : \"(no db)\");\n+    fclose(f);\n+}\n@@\n int create_note(const char *title, const char *content) {\n     pthread_mutex_lock(&db_mu);\n \n-    sqlite3_exec(db, \"BEGIN IMMEDIATE;\", NULL, NULL, NULL);\n+    if (sqlite3_exec(db, \"BEGIN IMMEDIATE;\", NULL, NULL, NULL) != SQLITE_OK) {\n+        log_sqlite_err(\"create_note BEGIN\");\n+        pthread_mutex_unlock(&db_mu);\n+        return -1;\n+    }\n@@\n     int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);\n     if (rc != SQLITE_OK) {\n+        log_sqlite_err(\"create_note prepare\");\n         sqlite3_exec(db, \"ROLLBACK;\", NULL, NULL, NULL);\n         pthread_mutex_unlock(&db_mu);\n         return -1;\n     }\n@@\n     sqlite3_finalize(stmt);\n     if (rc != SQLITE_DONE) {\n+        log_sqlite_err(\"create_note step\");\n         sqlite3_exec(db, \"ROLLBACK;\", NULL, NULL, NULL);\n         pthread_mutex_unlock(&db_mu);\n         return -1;\n     }\n \n     int id = (int)sqlite3_last_insert_rowid(db);\n-    sqlite3_exec(db, \"COMMIT;\", NULL, NULL, NULL);\n+    if (sqlite3_exec(db, \"COMMIT;\", NULL, NULL, NULL) != SQLITE_OK) {\n+        log_sqlite_err(\"create_note COMMIT\");\n+        sqlite3_exec(db, \"ROLLBACK;\", NULL, NULL, NULL);\n+        pthread_mutex_unlock(&db_mu);\n+        return -1;\n+    }\n*** End Patch\nPATCH\n"]
