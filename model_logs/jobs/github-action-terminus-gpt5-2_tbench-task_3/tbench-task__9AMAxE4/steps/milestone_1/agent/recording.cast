[351.816448, "i", "cat > /app/src/routes.c <<'EOF'\n#include \"routes.h\"\n\n#include \"auth.h\"\n#include \"common.h\"\n#include \"db.h\"\n\n#include <ctype.h>\n#include <microhttpd.h>\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n\nstatic enum MHD_Result send_json(struct MHD_Connection *connection,\n                                const char *body, unsigned int status_code) {\n    struct MHD_Response *response = MHD_create_response_from_buffer(\n        strlen(body), (void *)body, MHD_RESPMEM_MUST_COPY);\n    MHD_add_response_header(response, \"Content-Type\", \"application/json\");\n    MHD_add_response_header(response, \"Access-Control-Allow-Origin\", \"*\");\n    MHD_add_response_header(response, \"Access-Control-Allow-Methods\",\n                            \"GET, POST, PUT, DELETE, OPTIONS\");\n    MHD_add_response_header(response, \"Access-Control-Allow-Headers\",\n                            \"Content-Type, X-API-Key\");\n    enum MHD_Result ret = MHD_queue_response(connection, status_code, response);\n    MHD_destroy_response(response);\n    return ret;\n}\n\nstatic enum MHD_Result send_json_total(struct MHD_Connection *connection,\n                                      const char *body,\n                                      unsigned int status_code,\n                                      int total) {\n    struct MHD_Response *response = MHD_create_response_from_buffer(\n        strlen(body), (void *)body, MHD_RESPMEM_MUST_COPY);\n    MHD_add_response_header(response, \"Content-Type\", \"application/json\");\n    MHD_add_response_header(response, \"Access-Control-Allow-Origin\", \"*\");\n    MHD_add_response_header(response, \"Access-Control-Allow-Methods\",\n                            \"GET, POST, PUT, DELETE, OPTIONS\");\n    MHD_add_response_header(response, \"Access-Control-Allow-Headers\",\n                            \"Content-Type, X-API-Key\");\n\n    char count_str[32];\n    snprintf(count_str, sizeof(count_str), \"%d\", total);\n    MHD_add_response_header(response, \"X-Total-Count\", count_str);\n\n    enum MHD_Result ret = MHD_queue_response(connection, status_code, response);\n    MHD_destroy_response(response);\n    return ret;\n}\n\nstatic enum MHD_Result unauthorized(struct MHD_Connection *connection) {\n    return send_json(connection, \"{\\\"error\\\":\\\"unauthorized\\\"}\",\n                     MHD_HTTP_UNAUTHORIZED);\n}\n\nstatic enum MHD_Result too_large(struct MHD_Connection *connection) {\n    return send_json(connection, \"{\\\"error\\\":\\\"too large\\\"}\",\n                     MHD_HTTP_CONTENT_TOO_LARGE);\n}\n\nstatic enum MHD_Result bad_request(struct MHD_Connection *connection) {\n    return send_json(connection, \"{\\\"error\\\":\\\"bad request\\\"}\",\n                     MHD_HTTP_BAD_REQUEST);\n}\n\nstatic enum MHD_Result not_found(struct MHD_Connection *connection) {\n    return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\",\n                     MHD_HTTP_NOT_FOUND);\n}\n\nstatic int parse_int(const char *s, int *out) {\n    if (!s || !*s) return 0;\n    char *end = NULL;\n    long v = strtol(s, &end, 10);\n    if (!end || *end != '\\0') return 0;\n    if (v < 0 || v > 1000000000L) return 0;\n    *out = (int)v;\n    return 1;\n}\n\nstatic void trim_ws_in_place(char *s) {\n    if (!s) return;\n    size_t len = strlen(s);\n    while (len > 0 && isspace((unsigned char)s[len - 1])) {\n        s[len - 1] = '\\0';\n        len--;\n    }\n    size_t i = 0;\n    while (s[i] && isspace((unsigned char)s[i])) i++;\n    if (i > 0) memmove(s, s + i, strlen(s + i) + 1);\n}\n\nstatic int parse_json_string_value(const char *json, const char *key,\n                                  char **out) {\n    *out = NULL;\n    if (!json || !key) return 0;\n\n    char needle[64];\n    snprintf(needle, sizeof(needle), \"\\\"%s\\\"\", key);\n    const char *p = strstr(json, needle);\n    if (!p) return 0;\n    p += strlen(needle);\n\n    while (*p && isspace((unsigned char)*p)) p++;\n    if (*p != ':') return 0;\n    p++;\n    while (*p && isspace((unsigned char)*p)) p++;\n    if (*p != '\"') return 0;\n    p++;\n\n    size_t cap = 128, len = 0;\n    char *buf = malloc(cap);\n    if (!buf) return 0;\n\n    while (*p) {\n        if (*p == '\"') {\n            p++;\n            break;\n        }\n  "]
[351.816605, "i", "      unsigned char c = (unsigned char)*p++;\n        if (c == '\\\\') {\n            unsigned char e = (unsigned char)*p++;\n            switch (e) {\n            case '\"': c = '\"'; break;\n            case '\\\\': c = '\\\\'; break;\n            case '/': c = '/'; break;\n            case 'b': c = '\\b'; break;\n            case 'f': c = '\\f'; break;\n            case 'n': c = '\\n'; break;\n            case 'r': c = '\\r'; break;\n            case 't': c = '\\t'; break;\n            default:\n                free(buf);\n                return 0;\n            }\n        }\n        if (len + 2 > cap) {\n            cap *= 2;\n            char *nb = realloc(buf, cap);\n            if (!nb) {\n                free(buf);\n                return 0;\n            }\n            buf = nb;\n        }\n        buf[len++] = (char)c;\n    }\n    buf[len] = '\\0';\n    *out = buf;\n    return 1;\n}\n\nstatic int parse_note_body(const char *json, char **title, char **content) {\n    *title = NULL;\n    *content = NULL;\n\n    if (!parse_json_string_value(json, \"title\", title)) return 0;\n    if (!parse_json_string_value(json, \"content\", content)) {\n        *content = strdup(\"\");\n        if (!*content) {\n            free(*title);\n            *title = NULL;\n            return 0;\n        }\n    }\n\n    trim_ws_in_place(*title);\n    if ((*title)[0] == '\\0') return 0;\n    return 1;\n}\n\nstatic void append_body_or_mark_oversize(const char *method,\n                                        const char *upload_data,\n                                        size_t *upload_data_size,\n                                        struct connection_info *ci) {\n    if (*upload_data_size == 0) return;\n\n    if ((strcmp(method, \"POST\") == 0 || strcmp(method, \"PUT\") == 0) &&\n        ci->data_size + *upload_data_size > NOTES_MAX_BODY_BYTES) {\n        ci->data_size = NOTES_MAX_BODY_BYTES + 1;\n        *upload_data_size = 0;\n        return;\n    }\n\n    char *nb = realloc(ci->data, ci->data_size + *upload_data_size + 1);\n    if (!nb) {\n        *upload_data_size = 0;\n        return;\n    }\n\n    ci->data = nb;\n    memcpy(ci->data + ci->data_size, upload_data, *upload_data_size);\n    ci->data_size += *upload_data_size;\n    ci->data[ci->data_size] = '\\0';\n    *upload_data_size = 0;\n}\n\nstatic int parse_id_from_path(const char *url, int *out_id) {\n    const char *prefix = \"/api/notes/\";\n    size_t prelen = strlen(prefix);\n    if (strncmp(url, prefix, prelen) != 0) return 0;\n    const char *idstr = url + prelen;\n    if (*idstr == '\\0') return 0;\n    if (strchr(idstr, '/')) return 0;\n    return parse_int(idstr, out_id);\n}\n\nenum MHD_Result route_request(struct MHD_Connection *connection, const char *url,\n                             const char *method, const char *upload_data,\n                             size_t *upload_data_size, void **con_cls) {\n\n    if (strcmp(method, \"OPTIONS\") == 0) return send_json(connection, \"\", MHD_HTTP_OK);\n\n    // MHD pattern: first call allocates per-connection state.\n    if (*con_cls == NULL) {\n        struct connection_info *ci0 = calloc(1, sizeof(struct connection_info));\n        if (!ci0) return MHD_NO;\n        *con_cls = ci0;\n        return MHD_YES;\n    }\n\n    struct connection_info *ci = *con_cls;\n\n    // Collect body for POST/PUT.\n    if ((strcmp(method, \"POST\") == 0 || strcmp(method, \"PUT\") == 0) &&\n        *upload_data_size > 0) {\n        append_body_or_mark_oversize(method, upload_data, upload_data_size, ci);\n        return MHD_YES;\n    }\n\n    if ((strcmp(method, \"POST\") == 0 || strcmp(method, \"PUT\") == 0) &&\n        ci->data_size > NOTES_MAX_BODY_BYTES) {\n        return too_large(connection);\n    }\n\n    // Collection routes\n    if (strcmp(url, \"/api/notes\") == 0 && strcmp(method, \"GET\") == 0) {\n        int limit = NOTES_DEFAULT_PAGE_SIZE;\n        int offset = 0;\n\n        const char *limit_s = MHD_lookup_connection_value(connection,\n                                                         MHD_GET_ARGUMENT_KIND,\n                                                         \"limit\");\n        const char *offset_s = MHD_lookup_connection_value(connection,\n                                        "]
[351.817166, "o", "cat > /app/src/routes.c <<'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> #include \"routes.h\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[351.817199, "i", "                  MHD_GET_ARGUMENT_KIND,\n                                                          \"offset\");\n        if (limit_s) {\n            int v;\n            if (parse_int(limit_s, &v)) limit = v;\n        }\n        if (offset_s) {\n            int v;\n            if (parse_int(offset_s, &v)) offset = v;\n        }\n        if (limit <= 0) limit = NOTES_DEFAULT_PAGE_SIZE;\n        if (limit > NOTES_MAX_PAGE_SIZE) limit = NOTES_MAX_PAGE_SIZE;\n        if (offset < 0) offset = 0;\n\n        int total = get_total_notes_count();\n        char *json = get_notes_paginated_json(limit, offset);\n        if (!json) return send_json_total(connection, \"[]\", MHD_HTTP_OK, total);\n        enum MHD_Result r = send_json_total(connection, json, MHD_HTTP_OK, total);\n        free(json);\n        return r;\n    }\n\n    if (strcmp(url, \"/api/notes\") == 0 && strcmp(method, \"POST\") == 0) {\n        if (!api_key_valid(connection)) return unauthorized(connection);\n\n        char *title = NULL;\n        char *content = NULL;\n        if (!ci->data || !parse_note_body(ci->data, &title, &content)) {\n            free(title);\n            free(content);\n            return bad_request(connection);\n        }\n\n        int id = create_note(title, content);\n        free(title);\n        free(content);\n\n        if (id <= 0)\n            return send_json(connection, \"{\\\"error\\\":\\\"server error\\\"}\",\n                             MHD_HTTP_INTERNAL_SERVER_ERROR);\n\n        char *row = get_note_json(id);\n        if (!row)\n            return send_json(connection, \"{\\\"error\\\":\\\"server error\\\"}\",\n                             MHD_HTTP_INTERNAL_SERVER_ERROR);\n        enum MHD_Result r = send_json(connection, row, MHD_HTTP_CREATED);\n        free(row);\n        return r;\n    }\n\n    // Item routes\n    int id = 0;\n    if (parse_id_from_path(url, &id)) {\n        if (strcmp(method, \"GET\") == 0) {\n            char *row = get_note_json(id);\n            if (!row) return not_found(connection);\n            enum MHD_Result r = send_json(connection, row, MHD_HTTP_OK);\n            free(row);\n            return r;\n        }\n\n        if (strcmp(method, \"PUT\") == 0) {\n            if (!api_key_valid(connection)) return unauthorized(connection);\n            if (!note_exists(id)) return not_found(connection);\n\n            char *title = NULL;\n            char *content = NULL;\n            if (!ci->data || !parse_note_body(ci->data, &title, &content)) {\n                free(title);\n                free(content);\n                return bad_request(connection);\n            }\n\n            int ok = update_note(id, title, content);\n            free(title);\n            free(content);\n            if (!ok)\n                return send_json(connection, \"{\\\"error\\\":\\\"server error\\\"}\",\n                                 MHD_HTTP_INTERNAL_SERVER_ERROR);\n\n            char *row = get_note_json(id);\n            if (!row)\n                return send_json(connection, \"{\\\"error\\\":\\\"server error\\\"}\",\n                                 MHD_HTTP_INTERNAL_SERVER_ERROR);\n            enum MHD_Result r = send_json(connection, row, MHD_HTTP_OK);\n            free(row);\n            return r;\n        }\n\n        if (strcmp(method, \"DELETE\") == 0) {\n            if (!api_key_valid(connection)) return unauthorized(connection);\n            if (!note_exists(id)) return not_found(connection);\n\n            int ok = delete_note(id);\n            if (!ok)\n                return send_json(connection, \"{\\\"error\\\":\\\"server error\\\"}\",\n                                 MHD_HTTP_INTERNAL_SERVER_ERROR);\n            return send_json(connection, \"{\\\"status\\\":\\\"deleted\\\"}\",\n                             MHD_HTTP_OK);\n        }\n\n        return not_found(connection);\n    }\n\n    return not_found(connection);\n}\nEOF\n"]
