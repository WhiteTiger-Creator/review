[176.560696, "o", "apply_patch<<'PATCH'\r\n\u001b[?2004l\r\u001b[?2004h"]
[176.560904, "o", "> *** Begin Patch\r\n\u001b[?2004l\r\u001b[?2004h> "]
[176.561653, "o", "*** Delete File: src/auth.c\r\n\u001b[?2004l\r\u001b[?2004h"]
[176.561988, "o", "> *** End Patch\r\n\u001b[?2004l\r\u001b[?2004h> PATCH\r\n\u001b[?2004l\rbash: apply_patch: command not found\r\n"]
[176.562025, "o", "\u001b[?2004hroot@08d5c4164ec3:/app# "]
[177.568288, "i", "apply_patch<<'PATCH'\n*** Begin Patch\n*** Add File: src/auth.c\n+#include \"auth.h\"\n+\n+#include <ctype.h>\n+#include <stdio.h>\n+#include <stdlib.h>\n+#include <string.h>\n+\n+#define API_KEY_PATH \"/app/config/api.key\"\n+\n+static char *cached_key = NULL;\n+\n+static void trim_in_place(char *s) {\n+    if (!s) return;\n+\n+    size_t len = strlen(s);\n+    while (len > 0 && isspace((unsigned char)s[len - 1])) {\n+        s[len - 1] = '\\0';\n+        len--;\n+    }\n+    size_t i = 0;\n+    while (s[i] && isspace((unsigned char)s[i])) i++;\n+    if (i > 0) memmove(s, s + i, strlen(s + i) + 1);\n+}\n+\n+static const char *get_api_key(void) {\n+    if (cached_key) return cached_key;\n+\n+    FILE *f = fopen(API_KEY_PATH, \"rb\");\n+    if (!f) return NULL;\n+\n+    char buf[256];\n+    size_t n = fread(buf, 1, sizeof(buf) - 1, f);\n+    fclose(f);\n+    buf[n] = '\\0';\n+    trim_in_place(buf);\n+\n+    cached_key = strdup(buf);\n+    return cached_key;\n+}\n+\n+int api_key_valid(struct MHD_Connection *connection) {\n+    const char *expected = get_api_key();\n+    if (!expected || expected[0] == '\\0') return 0;\n+\n+    const char *provided = MHD_lookup_connection_value(connection,\n+                                                       MHD_HEADER_KIND,\n+                                                       \"X-API-Key\");\n+    if (!provided) return 0;\n+    return strcmp(provided, expected) == 0;\n+}\n+\n*** End Patch\nPATCH\n"]
