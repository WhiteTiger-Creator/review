[185.911534, "o", "    while (len > 0 && isspace((unsigned char)s[len - 1])) {\r\n        s[len - 1] = '\\0';\r\n        len--;\r\n    }\r\n\r\n    size_t i = 0;\r\n    while (s[i] && isspace((unsigned char)s[i])) i++;\r\n    if (i > 0) memmove(s, s + i, strlen(s + i) + 1);\r\n}\r\n\r\nstatic const char *get_api_key(void) {\r\n    if (cached_key) return cached_key;\r\n\r\n    FILE *f = fopen(API_KEY_PATH, \"rb\");\r\n    if (!f) return NULL;\r\n\r\n    char buf[256];\r\n    size_t n = fread(buf, 1, sizeof(buf) - 1, f);\r\n    fclose(f);\r\n    buf[n] = '\\0';\r\n\r\n    trim_in_place(buf);\r\n    cached_key = strdup(buf);\r\n    return cached_key;\r\n}\r\n\r\nint api_key_valid(struct MHD_Connection *connection) {\r\n    const char *expected = get_api_key();\r\n    if (!expected || expected[0] == '\\0') return 0;\r\n\r\n    const char *provided = MHD_lookup_connection_value(connection,\r\n                                                       MHD_HEADER_KIND,\r\n                                                       \"X-API-Key\");\r\n    if (!provided) return 0;\r\n\r\n    return strcmp(provided, expected) == 0;\r\n}\r\n\u001b[?2004hroot@08d5c4164ec3:/app# "]
[216.572161, "i", "cat > /app/src/db.c <<'EOF'\n#include \"db.h\"\n\n#include <pthread.h>\n#include <sqlite3.h>\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n\nstatic sqlite3 *db = NULL;\nstatic pthread_mutex_t db_mu = PTHREAD_MUTEX_INITIALIZER;\n\nstatic int exec_pragma(const char *sql) {\n    char *err = NULL;\n    int rc = sqlite3_exec(db, sql, NULL, NULL, &err);\n    if (rc != SQLITE_OK) {\n        fprintf(stderr, \"SQLite pragma error: %s (%s)\\n\", err ? err : \"?\", sql);\n        sqlite3_free(err);\n        return -1;\n    }\n    return 0;\n}\n\nint init_db(const char *path) {\n    pthread_mutex_lock(&db_mu);\n\n    if (sqlite3_open_v2(path, &db,\n                        SQLITE_OPEN_READWRITE | SQLITE_OPEN_CREATE |\n                            SQLITE_OPEN_FULLMUTEX,\n                        NULL) != SQLITE_OK) {\n        fprintf(stderr, \"Cannot open database: %s\\n\", sqlite3_errmsg(db));\n        pthread_mutex_unlock(&db_mu);\n        return -1;\n    }\n\n    // Concurrency / durability tuning suitable for test workloads.\n    if (exec_pragma(\"PRAGMA journal_mode=WAL;\") != 0) {\n        pthread_mutex_unlock(&db_mu);\n        return -1;\n    }\n    if (exec_pragma(\"PRAGMA synchronous=NORMAL;\") != 0) {\n        pthread_mutex_unlock(&db_mu);\n        return -1;\n    }\n    if (exec_pragma(\"PRAGMA busy_timeout=5000;\") != 0) {\n        pthread_mutex_unlock(&db_mu);\n        return -1;\n    }\n\n    const char *sql =\n        \"CREATE TABLE IF NOT EXISTS notes (\"\n        \"id INTEGER PRIMARY KEY AUTOINCREMENT,\"\n        \"title TEXT NOT NULL,\"\n        \"content TEXT NOT NULL DEFAULT ''\"\n        \");\";\n\n    char *err_msg = NULL;\n    if (sqlite3_exec(db, sql, NULL, NULL, &err_msg) != SQLITE_OK) {\n        fprintf(stderr, \"SQL error: %s\\n\", err_msg);\n        sqlite3_free(err_msg);\n        pthread_mutex_unlock(&db_mu);\n        return -1;\n    }\n\n    pthread_mutex_unlock(&db_mu);\n    return 0;\n}\n\nvoid close_db(void) {\n    pthread_mutex_lock(&db_mu);\n    if (db) sqlite3_close(db);\n    db = NULL;\n    pthread_mutex_unlock(&db_mu);\n}\n\nstatic char *json_escape(const char *s) {\n    if (!s) s = \"\";\n    size_t extra = 0;\n    for (const unsigned char *p = (const unsigned char *)s; *p; p++) {\n        switch (*p) {\n        case '\"':\n        case '\\\\':\n            extra++;\n            break;\n        case '\\b':\n        case '\\f':\n        case '\\n':\n        case '\\r':\n        case '\\t':\n            extra++;\n            break;\n        default:\n            if (*p < 0x20) extra += 5; // \\u00XX\n            break;\n        }\n    }\n\n    size_t len = strlen(s);\n    char *out = malloc(len + extra + 1);\n    if (!out) return NULL;\n\n    char *o = out;\n    for (const unsigned char *p = (const unsigned char *)s; *p; p++) {\n        switch (*p) {\n        case '\"':\n            *o++ = '\\\\';\n            *o++ = '\"';\n            break;\n        case '\\\\':\n            *o++ = '\\\\';\n            *o++ = '\\\\';\n            break;\n        case '\\b':\n            *o++ = '\\\\';\n            *o++ = 'b';\n            break;\n        case '\\f':\n            *o++ = '\\\\';\n            *o++ = 'f';\n            break;\n        case '\\n':\n            *o++ = '\\\\';\n            *o++ = 'n';\n            break;\n        case '\\r':\n            *o++ = '\\\\';\n            *o++ = 'r';\n            break;\n        case '\\t':\n            *o++ = '\\\\';\n            *o++ = 't';\n            break;\n        default:\n            if (*p < 0x20) {\n                sprintf(o, \"\\\\u%04x\", (unsigned int)(*p));\n                o += 6;\n            } else {\n                *o++ = (char)(*p);\n            }\n            break;\n        }\n    }\n    *o = '\\0';\n    return out;\n}\n\nint create_note(const char *title, const char *content) {\n    pthread_mutex_lock(&db_mu);\n\n    sqlite3_exec(db, \"BEGIN IMMEDIATE;\", NULL, NULL, NULL);\n\n    const char *sql = \"INSERT INTO notes (title, content) VALUES (?, ?);\";\n    sqlite3_stmt *stmt = NULL;\n    int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);\n    if (rc != SQLITE_OK) {\n        sqlite3_exec(db, \"ROLLBACK;\", NULL, NULL, NULL);\n        pthread_mutex_unlock(&db_mu);\n        return -1;\n    }\n\n    sqlite3_bind_text(stmt, 1, title ? title : \"\", -1, SQ"]
[216.572342, "i", "LITE_TRANSIENT);\n    sqlite3_bind_text(stmt, 2, content ? content : \"\", -1, SQLITE_TRANSIENT);\n\n    rc = sqlite3_step(stmt);\n    sqlite3_finalize(stmt);\n    if (rc != SQLITE_DONE) {\n        sqlite3_exec(db, \"ROLLBACK;\", NULL, NULL, NULL);\n        pthread_mutex_unlock(&db_mu);\n        return -1;\n    }\n\n    int id = (int)sqlite3_last_insert_rowid(db);\n    sqlite3_exec(db, \"COMMIT;\", NULL, NULL, NULL);\n\n    pthread_mutex_unlock(&db_mu);\n    return id;\n}\n\nstatic char *appendf(char *buf, size_t *cap, size_t *len, const char *fmt, ...) {\n    va_list ap;\n    while (1) {\n        if (*cap - *len < 256) {\n            *cap = (*cap == 0) ? 1024 : (*cap * 2);\n            buf = realloc(buf, *cap);\n            if (!buf) return NULL;\n        }\n        va_start(ap, fmt);\n        int n = vsnprintf(buf + *len, *cap - *len, fmt, ap);\n        va_end(ap);\n        if (n < 0) return NULL;\n        if ((size_t)n < *cap - *len) {\n            *len += (size_t)n;\n            return buf;\n        }\n        *cap += (size_t)n + 1;\n        buf = realloc(buf, *cap);\n        if (!buf) return NULL;\n    }\n}\n\nchar *get_notes_paginated_json(int limit, int offset) {\n    pthread_mutex_lock(&db_mu);\n\n    const char *sql =\n        \"SELECT id, title, content FROM notes ORDER BY id LIMIT ? OFFSET ?;\";\n    sqlite3_stmt *stmt = NULL;\n    int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);\n    if (rc != SQLITE_OK) {\n        pthread_mutex_unlock(&db_mu);\n        return NULL;\n    }\n\n    sqlite3_bind_int(stmt, 1, limit);\n    sqlite3_bind_int(stmt, 2, offset);\n\n    char *out = NULL;\n    size_t cap = 0, len = 0;\n    out = appendf(out, &cap, &len, \"[\");\n    int first = 1;\n\n    while ((rc = sqlite3_step(stmt)) == SQLITE_ROW) {\n        int id = sqlite3_column_int(stmt, 0);\n        const char *title = (const char *)sqlite3_column_text(stmt, 1);\n        const char *content = (const char *)sqlite3_column_text(stmt, 2);\n        char *et = json_escape(title);\n        char *ec = json_escape(content);\n        if (!et || !ec) {\n            free(et);\n            free(ec);\n            free(out);\n            sqlite3_finalize(stmt);\n            pthread_mutex_unlock(&db_mu);\n            return NULL;\n        }\n\n        out = appendf(out, &cap, &len,\n                      \"%s{\\\"id\\\":%d,\\\"title\\\":\\\"%s\\\",\\\"content\\\":\\\"%s\\\"}\",\n                      first ? \"\" : \",\", id, et, ec);\n        first = 0;\n        free(et);\n        free(ec);\n        if (!out) {\n            sqlite3_finalize(stmt);\n            pthread_mutex_unlock(&db_mu);\n            return NULL;\n        }\n    }\n\n    sqlite3_finalize(stmt);\n    out = appendf(out, &cap, &len, \"]\");\n\n    pthread_mutex_unlock(&db_mu);\n    return out;\n}\n\nint get_total_notes_count(void) {\n    pthread_mutex_lock(&db_mu);\n\n    const char *sql = \"SELECT COUNT(*) FROM notes;\";\n    sqlite3_stmt *stmt = NULL;\n    int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);\n    if (rc != SQLITE_OK) {\n        pthread_mutex_unlock(&db_mu);\n        return 0;\n    }\n\n    int total = 0;\n    if (sqlite3_step(stmt) == SQLITE_ROW) {\n        total = sqlite3_column_int(stmt, 0);\n    }\n    sqlite3_finalize(stmt);\n\n    pthread_mutex_unlock(&db_mu);\n    return total;\n}\n\nint note_exists(int id) {\n    pthread_mutex_lock(&db_mu);\n\n    const char *sql = \"SELECT 1 FROM notes WHERE id=?;\";\n    sqlite3_stmt *stmt = NULL;\n    int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);\n    if (rc != SQLITE_OK) {\n        pthread_mutex_unlock(&db_mu);\n        return 0;\n    }\n    sqlite3_bind_int(stmt, 1, id);\n    int exists = (sqlite3_step(stmt) == SQLITE_ROW);\n    sqlite3_finalize(stmt);\n\n    pthread_mutex_unlock(&db_mu);\n    return exists;\n}\n\nchar *get_note_json(int id) {\n    pthread_mutex_lock(&db_mu);\n\n    const char *sql = \"SELECT id, title, content FROM notes WHERE id=?;\";\n    sqlite3_stmt *stmt = NULL;\n    int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);\n    if (rc != SQLITE_OK) {\n        pthread_mutex_unlock(&db_mu);\n        return NULL;\n    }\n    sqlite3_bind_int(stmt, 1, id);\n\n    char *out = NULL;\n    if (sqlite3_step(stmt) == SQLITE_ROW) {\n        int rid = sqlite3_column_int(stmt"]
[216.572817, "o", "cat > /app/src/db.c <<'EOF'\r\n\u001b[?2004l\r\u001b[?2004h"]
[216.572846, "i", ", 0);\n        const char *title = (const char *)sqlite3_column_text(stmt, 1);\n        const char *content = (const char *)sqlite3_column_text(stmt, 2);\n        char *et = json_escape(title);\n        char *ec = json_escape(content);\n        if (et && ec) {\n            size_t needed = strlen(et) + strlen(ec) + 64;\n            out = malloc(needed);\n            if (out)\n                snprintf(out, needed,\n                         \"{\\\"id\\\":%d,\\\"title\\\":\\\"%s\\\",\\\"content\\\":\\\"%s\\\"}\",\n                         rid, et, ec);\n        }\n        free(et);\n        free(ec);\n    }\n\n    sqlite3_finalize(stmt);\n    pthread_mutex_unlock(&db_mu);\n    return out;\n}\n\nint update_note(int id, const char *title, const char *content) {\n    pthread_mutex_lock(&db_mu);\n\n    sqlite3_exec(db, \"BEGIN IMMEDIATE;\", NULL, NULL, NULL);\n\n    const char *sql = \"UPDATE notes SET title=?, content=? WHERE id=?;\";\n    sqlite3_stmt *stmt = NULL;\n    int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);\n    if (rc != SQLITE_OK) {\n        sqlite3_exec(db, \"ROLLBACK;\", NULL, NULL, NULL);\n        pthread_mutex_unlock(&db_mu);\n        return 0;\n    }\n\n    sqlite3_bind_text(stmt, 1, title ? title : \"\", -1, SQLITE_TRANSIENT);\n    sqlite3_bind_text(stmt, 2, content ? content : \"\", -1, SQLITE_TRANSIENT);\n    sqlite3_bind_int(stmt, 3, id);\n\n    rc = sqlite3_step(stmt);\n    int changed = sqlite3_changes(db);\n    sqlite3_finalize(stmt);\n\n    if (rc != SQLITE_DONE) {\n        sqlite3_exec(db, \"ROLLBACK;\", NULL, NULL, NULL);\n        pthread_mutex_unlock(&db_mu);\n        return 0;\n    }\n\n    sqlite3_exec(db, \"COMMIT;\", NULL, NULL, NULL);\n    pthread_mutex_unlock(&db_mu);\n    return changed > 0;\n}\n\nint delete_note(int id) {\n    pthread_mutex_lock(&db_mu);\n\n    sqlite3_exec(db, \"BEGIN IMMEDIATE;\", NULL, NULL, NULL);\n\n    const char *sql = \"DELETE FROM notes WHERE id=?;\";\n    sqlite3_stmt *stmt = NULL;\n    int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);\n    if (rc != SQLITE_OK) {\n        sqlite3_exec(db, \"ROLLBACK;\", NULL, NULL, NULL);\n        pthread_mutex_unlock(&db_mu);\n        return 0;\n    }\n\n    sqlite3_bind_int(stmt, 1, id);\n    rc = sqlite3_step(stmt);\n    int changed = sqlite3_changes(db);\n    sqlite3_finalize(stmt);\n\n    if (rc != SQLITE_DONE) {\n        sqlite3_exec(db, \"ROLLBACK;\", NULL, NULL, NULL);\n        pthread_mutex_unlock(&db_mu);\n        return 0;\n    }\n\n    sqlite3_exec(db, \"COMMIT;\", NULL, NULL, NULL);\n    pthread_mutex_unlock(&db_mu);\n    return changed > 0;\n}\n\n// Legacy function, not used by the contract but kept for completeness.\nchar *get_all_notes_json(void) {\n    return get_notes_paginated_json(1000000, 0);\n}\nEOF\n"]
