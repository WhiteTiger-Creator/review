[176.307105, "o", "    const char *upload_data, size_t *upload_data_size,\r\n    void **con_cls);\r\n\r\n#endif\r\n#include \"static.h\"\r\n\r\nenum MHD_Result serve_static_file(struct MHD_Connection *connection, const char *url) {\r\n    (void)connection;\r\n    (void)url;\r\n    return MHD_NO;\r\n}\r\n"]
