[620.271468, "o", "#include \"db.h\"\r\n\r\n#include <pthread.h>\r\n#include <sqlite3.h>\r\n#include <stdio.h>\r\n#include <stdarg.h>\r\n#include <stdlib.h>\r\n#include <string.h>\r\n\r\nstatic sqlite3 *db = NULL;\r\n"]
[620.271791, "o", "static pthread_mutex_t db_mu = PTHREAD_MUTEX_INITIALIZER;\r\n\r\nstatic int exec_pragma(const char *sql) {\r\n    char *err = NULL;\r\n    int rc = sqlite3_exec(db, sql, NULL, NULL, &err);\r\n    if (rc != SQLITE_OK) {\r\n        fprintf(stderr, \"SQLite pragma error: %s (%s)\\n\", err ? err : \"?\", sql);\r\n        sqlite3_free(err);\r\n        return -1;\r\n    }\r\n    return 0;\r\n}\r\n\r\nint init_db(const char *path) {\r\n    pthread_mutex_lock(&db_mu);\r\n"]
[620.271836, "o", "\r\n    if (sqlite3_open_v2(path, &db,\r\n                        SQLITE_OPEN_READWRITE | SQLITE_OPEN_CREATE |\r\n                            SQLITE_OPEN_FULLMUTEX,\r\n                        NULL) != SQLITE_OK) {\r\n        fprintf(stderr, \"Cannot open database: %s\\n\", sqlite3_errmsg(db));\r\n        pthread_mutex_unlock(&db_mu);\r\n        return -1;\r\n    }\r\n\r\n    // Concurrency / durability tuning suitable for test workloads.\r\n    if (exec_pragma(\"PRAGMA journal_mode=WAL;\") != 0) {\r\n        pthread_mutex_unlock(&db_mu);\r\n        return -1;\r\n    }\r\n    if (exec_pragma(\"PRAGMA synchronous=NORMAL;\") != 0) {\r\n        pthread_mutex_unlock(&db_mu);\r\n        return -1;\r\n    }\r\n    if (exec_pragma(\"PRAGMA busy_timeout=5000;\") != 0) {\r\n        pthread_mutex_unlock(&db_mu);\r\n        return -1;\r\n    }\r\n\r\n    const char *sql =\r\n        \"CREATE TABLE IF NOT EXISTS notes (\"\r\n        \"id INTEGER PRIMARY KEY AUTOINCREMENT,\"\r\n        \"title TEXT NOT NULL,\"\r\n        \"content TEXT NOT NULL DEFAULT ''\"\r\n        \");\";\r\n\r\n    char *err_msg = NULL;\r\n    if (sqlite3_exec(db, sql, NULL, NULL, &err_msg) != SQLITE_OK) {\r\n        fprintf(stderr, \"SQL error: %s\\n\", err_msg);\r\n        sqlite3_free(err_msg);\r\n        pthread_mutex_unlock(&db_mu);\r\n        return -1;\r\n    }\r\n\r\n    pthread_mutex_unlock(&db_mu);\r\n    return 0;\r\n}\r\n\r\nvoid close_db(void) {\r\n    pthread_mutex_lock(&db_mu);\r\n    if (db) sqlite3_close(db);\r\n    db = NULL;\r\n    pthread_mutex_unlock(&db_mu);\r\n}\r\n\r\nstatic char *json_escape(const char *s) {\r\n    if (!s) s = \"\";\r\n    size_t extra = 0;\r\n    for (const unsigned char *p = (const unsigned char *)s; *p; p++) {\r\n        switch (*p) {\r\n        case '\"':\r\n        case '\\\\':\r\n            extra++;\r\n            break;\r\n        case '\\b':\r\n"]
[620.271858, "o", "        case '\\f':\r\n        case '\\n':\r\n        case '\\r':\r\n        case '\\t':\r\n            extra++;\r\n            break;\r\n        default:\r\n            if (*p < 0x20) extra += 5; // \\u00XX\r\n"]
[620.271878, "o", "            break;\r\n        }\r\n    }\r\n"]
[620.272266, "o", "\r\n    size_t len = strlen(s);\r\n    char *out = malloc(len + extra + 1);\r\n    if (!out) return NULL;\r\n"]
[620.2723, "o", "\r\n    char *o = out;\r\n    for (const unsigned char *p = (const unsigned char *)s; *p; p++) {\r\n        switch (*p) {\r\n        case '\"':\r\n            *o++ = '\\\\';\r\n            *o++ = '\"';\r\n            break;\r\n        case '\\\\':\r\n            *o++ = '\\\\';\r\n            *o++ = '\\\\';\r\n            break;\r\n        case '\\b':\r\n            *o++ = '\\\\';\r\n            *o++ = 'b';\r\n            break;\r\n        case '\\f':\r\n            *o++ = '\\\\';\r\n            *o++ = 'f';\r\n            break;\r\n        case '\\n':\r\n            *o++ = '\\\\';\r\n            *o++ = 'n';\r\n            break;\r\n        case '\\r':\r\n            *o++ = '\\\\';\r\n            *o++ = 'r';\r\n            break;\r\n        case '\\t':\r\n            *o++ = '\\\\';\r\n            *o++ = 't';\r\n            break;\r\n        default:\r\n            if (*p < 0x20) {\r\n                sprintf(o, \"\\\\u%04x\", (unsigned int)(*p));\r\n                o += 6;\r\n            } else {\r\n                *o++ = (char)(*p);\r\n            }\r\n            break;\r\n        }\r\n    }\r\n    *o = '\\0';\r\n    return out;\r\n}\r\n\r\nint create_note(const char *title, const char *content) {\r\n    pthread_mutex_lock(&db_mu);\r\n\r\n    sqlite3_exec(db, \"BEGIN IMMEDIATE;\", NULL, NULL, NULL);\r\n\r\n    const char *sql = \"INSERT INTO notes (title, content) VALUES (?, ?);\";\r\n    sqlite3_stmt *stmt = NULL;\r\n    int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);\r\n    if (rc != SQLITE_OK) {\r\n        sqlite3_exec(db, \"ROLLBACK;\", NULL, NULL, NULL);\r\n        pthread_mutex_unlock(&db_mu);\r\n        return -1;\r\n    }\r\n\r\n    sqlite3_bind_text(stmt, 1, title ? title : \"\", -1, SQLITE_TRANSIENT);\r\n    sqlite3_bind_text(stmt, 2, content ? content : \"\", -1, SQLITE_TRANSIENT);\r\n\r\n    rc = sqlite3_step(stmt);\r\n    sqlite3_finalize(stmt);\r\n    if (rc != SQLITE_DONE) {\r\n        sqlite3_exec(db, \"ROLLBACK;\", NULL, NULL, NULL);\r\n        pthread_mutex_unlock(&db_mu);\r\n        return -1;\r\n    }\r\n\r\n    int id = (int)sqlite3_last_insert_rowid(db);\r\n    sqlite3_exec(db, \"COMMIT;\", NULL, NULL, NULL);\r\n\r\n    pthread_mutex_unlock(&db_mu);\r\n    return id;\r\n}\r\n\r\nstatic char *appendf(char *buf, size_t *cap, size_t *len, const char *fmt, ...) {\r\n    va_list ap;\r\n    while (1) {\r\n        if (*cap - *len < 256) {\r\n            *cap = (*cap == 0) ? 1024 : (*cap * 2);\r\n            buf = realloc(buf, *cap);\r\n            if (!buf) return NULL;\r\n        }\r\n        va_start(ap, fmt);\r\n        int n = vsnprintf(buf + *len, *cap - *len, fmt, ap);\r\n        va_end(ap);\r\n        if (n < 0) return NULL;\r\n        if ((size_t)n < *cap - *len) {\r\n            *len += (size_t)n;\r\n"]
[620.27232, "o", "            return buf;\r\n        }\r\n        *cap += (size_t)n + 1;\r\n        buf = realloc(buf, *cap);\r\n        if (!buf) return NULL;\r\n    }\r\n}\r\n"]
[620.27234, "o", "\r\nchar *get_notes_paginated_json(int limit, int offset) {\r\n    pthread_mutex_lock(&db_mu);\r\n\r\n    const char *sql =\r\n        \"SELECT id, title, content FROM notes ORDER BY id LIMIT ? OFFSET ?;\";\r\n    sqlite3_stmt *stmt = NULL;"]
[620.27236, "o", "\r\n    int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);\r\n    if (rc != SQLITE_OK) {\r\n        pthread_mutex_unlock(&db_mu);\r\n        return NULL;\r\n"]
[620.272378, "o", "    }\r\n\r\n    sqlite3_bind_int(stmt, 1, limit);\r\n    sqlite3_bind_int(stmt, 2, offset);\r\n\r\n"]
[620.272399, "o", "    char *out = NULL;\r\n    size_t cap = 0, len = 0;\r\n    out = appendf(out, &cap, &len, \"[\");\r\n    int first = 1;\r\n"]
[620.272649, "o", "\r\n    while ((rc = sqlite3_step(stmt)) == SQLITE_ROW) {\r\n        int id = sqlite3_column_int(stmt, 0);\r\n        const char *title = (const char *)sqlite3_column_text(stmt, 1);\r\n"]
[620.272701, "o", "        const char *content = (const char *)sqlite3_column_text(stmt, 2);\r\n        char *et = json_escape(title);\r\n        char *ec = json_escape(content);\r\n        if (!et || !ec) {\r\n            free(et);\r\n            free(ec);\r\n            free(out);\r\n            sqlite3_finalize(stmt);\r\n            pthread_mutex_unlock(&db_mu);\r\n            return NULL;\r\n        }\r\n\r\n        out = appendf(out, &cap, &len,\r\n                      \"%s{\\\"id\\\":%d,\\\"title\\\":\\\"%s\\\",\\\"content\\\":\\\"%s\\\"}\",\r\n                      first ? \"\" : \",\", id, et, ec);\r\n        first = 0;\r\n        free(et);\r\n        free(ec);\r\n        if (!out) {\r\n            sqlite3_finalize(stmt);\r\n            pthread_mutex_unlock(&db_mu);\r\n            return NULL;\r\n        }\r\n    }\r\n\r\n    sqlite3_finalize(stmt);\r\n    out = appendf(out, &cap, &len, \"]\");\r\n\r\n    pthread_mutex_unlock(&db_mu);\r\n    return out;\r\n}\r\n\r\nint get_total_notes_count(void) {\r\n    pthread_mutex_lock(&db_mu);\r\n\r\n    const char *sql = \"SELECT COUNT(*) FROM notes;\";\r\n    sqlite3_stmt *stmt = NULL;\r\n"]
[620.273911, "o", "\u001b[?2004hroot@08d5c4164ec3:/app# "]
[620.408688, "i", "sed -n '260,520p' /app/src/db.c\n"]
[620.409134, "o", "sed -n '260,520p' /app/src/db.c\r\n\u001b[?2004l\r"]
[620.413019, "o", "    sqlite3_stmt *stmt = NULL;\r\n    int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);\r\n    if (rc != SQLITE_OK) {\r\n        pthread_mutex_unlock(&db_mu);\r\n        return 0;\r\n    }\r\n\r\n    int total = 0;\r\n    if (sqlite3_step(stmt) == SQLITE_ROW) {\r\n        total = sqlite3_column_int(stmt, 0);\r\n    }\r\n    sqlite3_finalize(stmt);\r\n\r\n    pthread_mutex_unlock(&db_mu);\r\n    return total;\r\n}\r\n\r\nint note_exists(int id) {\r\n    pthread_mutex_lock(&db_mu);\r\n\r\n    const char *sql = \"SELECT 1 FROM notes WHERE id=?;\";\r\n    sqlite3_stmt *stmt = NULL;\r\n    int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);\r\n    if (rc != SQLITE_OK) {\r\n        pthread_mutex_unlock(&db_mu);\r\n        return 0;\r\n    }\r\n    sqlite3_bind_int(stmt, 1, id);\r\n    int exists = (sqlite3_step(stmt) == SQLITE_ROW);\r\n    sqlite3_finalize(stmt);\r\n\r\n    pthread_mutex_unlock(&db_mu);\r\n    return exists;\r\n}\r\n\r\nchar *get_note_json(int id) {\r\n    pthread_mutex_lock(&db_mu);\r\n\r\n    const char *sql = \"SELECT id, title, content FROM notes WHERE id=?;\";\r\n    sqlite3_stmt *stmt = NULL;\r\n    int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);\r\n    if (rc != SQLITE_OK) {\r\n        pthread_mutex_unlock(&db_mu);\r\n        return NULL;\r\n    }\r\n    sqlite3_bind_int(stmt, 1, id);\r\n\r\n    char *out = NULL;\r\n    if (sqlite3_step(stmt) == SQLITE_ROW) {\r\n        int rid = sqlite3_column_int(stmt, 0);\r\n        const char *title = (const char *)sqlite3_column_text(stmt, 1);\r\n        const char *content = (const char *)sqlite3_column_text(stmt, 2);\r\n        char *et = json_escape(title);\r\n"]
[620.413436, "o", "        char *ec = json_escape(content);\r\n        if (et && ec) {\r\n            size_t needed = strlen(et) + strlen(ec) + 64;\r\n            out = malloc(needed);\r\n            if (out)\r\n                snprintf(out, needed,\r\n                         \"{\\\"id\\\":%d,\\\"title\\\":\\\"%s\\\",\\\"content\\\":\\\"%s\\\"}\",\r\n                         rid, et, ec);\r\n        }\r\n        free(et);\r\n        free(ec);\r\n    }\r\n\r\n    sqlite3_finalize(stmt);\r\n    pthread_mutex_unlock(&db_mu);\r\n    return out;\r\n}\r\n\r\nint update_note(int id, const char *title, const char *content) {\r\n    pthread_mutex_lock(&db_mu);\r\n\r\n"]
[620.413488, "o", "    sqlite3_exec(db, \"BEGIN IMMEDIATE;\", NULL, NULL, NULL);\r\n\r\n    const char *sql = \"UPDATE notes SET title=?, content=? WHERE id=?;\";\r\n    sqlite3_stmt *stmt = NULL;\r\n    int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);\r\n    if (rc != SQLITE_OK) {\r\n        sqlite3_exec(db, \"ROLLBACK;\", NULL, NULL, NULL);\r\n        pthread_mutex_unlock(&db_mu);\r\n        return 0;\r\n    }\r\n\r\n    sqlite3_bind_text(stmt, 1, title ? title : \"\", -1, SQLITE_TRANSIENT);\r\n    sqlite3_bind_text(stmt, 2, content ? content : \"\", -1, SQLITE_TRANSIENT);\r\n    sqlite3_bind_int(stmt, 3, id);\r\n\r\n    rc = sqlite3_step(stmt);\r\n    int changed = sqlite3_changes(db);\r\n    sqlite3_finalize(stmt);\r\n\r\n    if (rc != SQLITE_DONE) {\r\n        sqlite3_exec(db, \"ROLLBACK;\", NULL, NULL, NULL);\r\n        pthread_mutex_unlock(&db_mu);\r\n        return 0;\r\n    }\r\n\r\n    sqlite3_exec(db, \"COMMIT;\", NULL, NULL, NULL);\r\n    pthread_mutex_unlock(&db_mu);\r\n    return changed > 0;\r\n}\r\n\r\nint delete_note(int id) {\r\n    pthread_mutex_lock(&db_mu);\r\n\r\n    sqlite3_exec(db, \"BEGIN IMMEDIATE;\", NULL, NULL, NULL);\r\n\r\n    const char *sql = \"DELETE FROM notes WHERE id=?;\";\r\n    sqlite3_stmt *stmt = NULL;\r\n    int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);\r\n    if (rc != SQLITE_OK) {\r\n        sqlite3_exec(db, \"ROLLBACK;\", NULL, NULL, NULL);\r\n        pthread_mutex_unlock(&db_mu);\r\n        return 0;\r\n    }\r\n\r\n    sqlite3_bind_int(stmt, 1, id);\r\n    rc = sqlite3_step(stmt);\r\n    int changed = sqlite3_changes(db);\r\n    sqlite3_finalize(stmt);\r\n\r\n    if (rc != SQLITE_DONE) {\r\n        sqlite3_exec(db, \"ROLLBACK;\", NULL, NULL, NULL);\r\n        pthread_mutex_unlock(&db_mu);\r\n        return 0;\r\n    }\r\n\r\n    sqlite3_exec(db, \"COMMIT;\", NULL, NULL, NULL);\r\n    pthread_mutex_unlock(&db_mu);\r\n    return changed > 0;\r\n}\r\n\r\n// Legacy function, not used by the contract but kept for completeness.\r\nchar *get_all_notes_json(void) {\r\n    return get_notes_paginated_json(1000000, 0);\r\n}\r\n"]
[620.413557, "o", "\u001b[?2004h"]
[620.413837, "o", "root@08d5c4164ec3:/app# "]
[620.532681, "i", "sed -n '130,220p' /app/src/main.c\n"]
[620.533607, "o", "sed -n '130,220p' /app/src/main.c\r\n\u001b[?2004l\r"]
[620.535152, "o", "static void request_completed(void *cls, struct MHD_Connection *connection,\r\n    void **con_cls, enum MHD_RequestTerminationCode toe) {\r\n    (void)cls; (void)connection; (void)toe;\r\n    if (con_cls && *con_cls) {\r\n        struct connection_info *ci = *con_cls;\r\n        if (ci->data) free(ci->data);\r\n        free(ci);\r\n        *con_cls = NULL;\r\n    }\r\n}\r\n\r\nstatic enum MHD_Result handle_request(void *cls,\r\n    struct MHD_Connection *connection,\r\n    const char *url, const char *method,\r\n    const char *version,\r\n    const char *upload_data, size_t *upload_data_size,\r\n    void **con_cls) {\r\n    (void)cls; (void)version;\r\n\r\n    if (strncmp(url, \"/api/\", 5) == 0) {\r\n        return route_request(connection, url, method, upload_data,\r\n                             upload_data_size, con_cls);\r\n    }\r\n\r\n    if (strcmp(method, \"GET\") == 0) {\r\n        enum MHD_Result ret = serve_static_file(connection, url);\r\n        if (ret == MHD_YES) return ret;\r\n    }\r\n\r\n    struct MHD_Response *response = MHD_create_response_from_buffer(\r\n        9, (void *)\"Not Found\", MHD_RESPMEM_PERSISTENT);\r\n    enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_NOT_FOUND, response);\r\n    MHD_destroy_response(response);\r\n    return ret;\r\n}\r\n\r\nint main(void) {\r\n    signal(SIGINT, handle_signal);\r\n    signal(SIGTERM, handle_signal);\r\n\r\n    mkdir(\"/app/data\", 0755);\r\n\r\n    if (init_db(\"/app/data/notes.db\") != 0) {\r\n        fprintf(stderr, \"Failed to initialize database\\n\");\r\n        return 1;\r\n    }\r\n\r\n    daemon_handle = MHD_start_daemon(\r\n        MHD_USE_THREAD_PER_CONNECTION,\r\n        PORT,"]
[620.535219, "o", "\r\n        NULL, NULL,\r\n        &handle_request, NULL,\r\n        MHD_OPTION_NOTIFY_COMPLETED, &request_completed, NULL,\r\n        MHD_OPTION_END\r\n    );\r\n\r\n    if (!daemon_handle) {\r\n        fprintf(stderr, \"Failed to start server\\n\");\r\n        return 1;\r\n    }\r\n\r\n    printf(\"Server running on port %d\\n\", PORT);\r\n    while (1) pause();\r\n    return 0;\r\n}\r\n"]
