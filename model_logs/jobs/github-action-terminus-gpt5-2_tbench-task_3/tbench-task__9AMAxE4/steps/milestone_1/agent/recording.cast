[649.837539, "o", "    if (!s) s = \"\";\r\n    size_t extra = 0;\r\n    for (const unsigned char *p = (const unsigned char *)s; *p; p++) {\r\n        switch (*p) {\r\n        case '\"':\r\n        case '\\\\':\r\n            extra++;\r\n"]
[649.837557, "o", "            break;\r\n        case '\\b':\r\n        case '\\f':\r\n        case '\\n':\r\n        case '\\r':\r\n        case '\\t':\r\n"]
