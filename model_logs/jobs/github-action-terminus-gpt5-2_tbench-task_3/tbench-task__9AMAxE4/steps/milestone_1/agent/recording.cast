[548.113133, "o", "<!DOCTYPE html>\r\n<html lang=\"en\">\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>Notes App</title>\r\n    <link rel=\"stylesheet\" href=\"/style.css\">\r\n</head>\r\n<body>\r\n"]
[548.113231, "o", "    <div class=\"container\">\r\n        <h1>Notes</h1>\r\n        <form id=\"note-form\">\r\n            <input type=\"text\" id=\"note-title\" placeholder=\"Title\" required>\r\n            <textarea id=\"note-content\" placeholder=\"Content\"></textarea>\r\n            <button type=\"submit\" id=\"btn-submit\">Save</button>\r\n        </form>\r\n        <div id=\"notes-list\"></div>\r\n    </div>\r\n    <script src=\"/app.js\"></script>\r\n</body>\r\n</html>\r\n"]
