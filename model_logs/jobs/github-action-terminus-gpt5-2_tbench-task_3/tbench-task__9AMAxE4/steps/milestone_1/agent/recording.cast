[631.547197, "o", "\r\n    pthread_mutex_unlock(&db_mu);\r\n    return total;\r\n}\r\n\r\nint note_exists(int id) {\r\n    pthread_mutex_lock(&db_mu);\r\n\r\n    const char *sql = \"SELECT 1 FROM notes WHERE id=?;\";\r\n    sqlite3_stmt *stmt = NULL;\r\n    int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);\r\n    if (rc != SQLITE_OK) {\r\n        pthread_mutex_unlock(&db_mu);\r\n        return 0;\r\n    }\r\n    sqlite3_bind_int(stmt, 1, id);\r\n    int exists = (sqlite3_step(stmt) == SQLITE_ROW);\r\n"]
[631.548019, "o", "    sqlite3_finalize(stmt);\r\n\r\n    pthread_mutex_unlock(&db_mu);\r\n    return exists;\r\n}\r\n\r\nchar *get_note_json(int id) {\r\n    pthread_mutex_lock(&db_mu);\r\n\r\n    const char *sql = \"SELECT id, title, content FROM notes WHERE id=?;\";\r\n    sqlite3_stmt *stmt = NULL;\r\n    int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);\r\n    if (rc != SQLITE_OK) {\r\n        pthread_mutex_unlock(&db_mu);\r\n        return NULL;\r\n    }\r\n    sqlite3_bind_int(stmt, 1, id);\r\n\r\n    char *out = NULL;\r\n    if (sqlite3_step(stmt) == SQLITE_ROW) {\r\n        int rid = sqlite3_column_int(stmt, 0);\r\n        const char *title = (const char *)sqlite3_column_text(stmt, 1);\r\n        const char *content = (const char *)sqlite3_column_text(stmt, 2);\r\n        char *et = json_escape(title);\r\n        char *ec = json_escape(content);\r\n        if (et && ec) {\r\n            size_t needed = strlen(et) + strlen(ec) + 64;\r\n            out = malloc(needed);\r\n            if (out)\r\n                snprintf(out, needed,\r\n                         \"{\\\"id\\\":%d,\\\"title\\\":\\\"%s\\\",\\\"content\\\":\\\"%s\\\"}\",\r\n                         rid, et, ec);\r\n        }\r\n        free(et);\r\n        free(ec);\r\n    }\r\n\r\n    sqlite3_finalize(stmt);\r\n    pthread_mutex_unlock(&db_mu);\r\n    return out;\r\n}\r\n\r\nint update_note(int id, const char *title, const char *content) {\r\n    pthread_mutex_lock(&db_mu);\r\n\r\n    sqlite3_exec(db, \"BEGIN IMMEDIATE;\", NULL, NULL, NULL);\r\n\r\n    const char *sql = \"UPDATE notes SET title=?, content=? WHERE id=?;\";\r\n    sqlite3_stmt *stmt = NULL;\r\n    int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);\r\n    if (rc != SQLITE_OK) {\r\n        sqlite3_exec(db, \"ROLLBACK;\", NULL, NULL, NULL);\r\n        pthread_mutex_unlock(&db_mu);\r\n        return 0;\r\n    }\r\n\r\n    sqlite3_bind_text(stmt, 1, title ? title : \"\", -1, SQLITE_TRANSIENT);\r\n    sqlite3_bind_text(stmt, 2, content ? content : \"\", -1, SQLITE_TRANSIENT);\r\n    sqlite3_bind_int(stmt, 3, id);\r\n\r\n    rc = sqlite3_step(stmt);\r\n    int changed = sqlite3_changes(db);\r\n    sqlite3_finalize(stmt);\r\n\r\n    if (rc != SQLITE_DONE) {\r\n        sqlite3_exec(db, \"ROLLBACK;\", NULL, NULL, NULL);\r\n        pthread_mutex_unlock(&db_mu);\r\n        return 0;\r\n    }\r\n\r\n    sqlite3_exec(db, \"COMMIT;\", NULL, NULL, NULL);\r\n    pthread_mutex_unlock(&db_mu);\r\n    return changed > 0;\r\n}\r\n\r\nint delete_note(int id) {\r\n    pthread_mutex_lock(&db_mu);\r\n\r\n    sqlite3_exec(db, \"BEGIN IMMEDIATE;\", NULL, NULL, NULL);\r\n\r\n    const char *sql = \"DELETE FROM notes WHERE id=?;\";\r\n    sqlite3_stmt *stmt = NULL;\r\n    int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, NULL);\r\n    if (rc != SQLITE_OK) {\r\n        sqlite3_exec(db, \"ROLLBACK;\", NULL, NULL, NULL);\r\n        pthread_mutex_unlock(&db_mu);\r\n        return 0;\r\n    }\r\n\r\n    sqlite3_bind_int(stmt, 1, id);\r\n    rc = sqlite3_step(stmt);\r\n    int changed = sqlite3_changes(db);\r\n    sqlite3_finalize(stmt);\r\n\r\n    if (rc != SQLITE_DONE) {\r\n        sqlite3_exec(db, \"ROLLBACK;\", NULL, NULL, NULL);\r\n        pthread_mutex_unlock(&db_mu);\r\n        return 0;\r\n    }\r\n\r\n    sqlite3_exec(db, \"COMMIT;\", NULL, NULL, NULL);\r\n    pthread_mutex_unlock(&db_mu);\r\n    return changed > 0;\r\n}\r\n\r\n// Legacy function, not used by the contract but kept for completeness.\r\nchar *get_all_notes_json(void) {\r\n    return get_notes_paginated_json(1000000, 0);\r\n}\r\n"]
