limit, offset);\r\n   260\t        if (!json) return send_json_total(connection, \"[]\", MHD_HTTP_OK, total);\r\n   261\t        enum MHD_Result r = send_json_total(connection, json, MHD_HTTP_OK, total);\r\n   262\t        free(json);\r\n   263\t        return r;\r\n   264\t    }\r\n   265\t\r\n   266\t    if (strcmp(url, \"/api/notes\") == 0 && strcmp(method, \"POST\") == 0) {\r\n   267\t        if (!api_key_valid(connection)) return unauthorized(connection);\r\n   268\t\r\n   269\t        char *title = NULL;\r\n   270\t        char *content = NULL;\r\n   271\t        if (!ci->data || !parse_note_body(ci->data, &title, &content)) {\r\n   272\t            free(title);\r\n   273\t            free(content);\r\n   274\t            return bad_request(connection);\r\n   275\t        }\r\n   276\t\r\n   277\t        int id = create_note(title, content);\r\n   278\t        free(title);\r\n   279\t        free(content);\r\n   280\t\r\n   281\t        if (id <= 0)\r\n   282\t            return send_json(connection, \"{\\\"error\\\":\\\"server error\\\"}\",\r\n   283\t                             MHD_HTTP_INTERNAL_SERVER_ERROR);\r\n   284\t\r\n   285\t        char *row = get_note_json(id);\r\n   286\t        if (!row)\r\n   287\t            return send_json(connection, \"{\\\"error\\\":\\\"server error\\\"}\",\r\n   288\t                             MHD_HTTP_INTERNAL_SERVER_ERROR);\r\n   289\t        enum MHD_Result r = send_json(connection, row, MHD_HTTP_CREATED);\r\n   290\t        free(row);\r\n   291\t        return r;\r\n   292\t    }\r\n   293\t\r\n   294\t    // Item routes\r\n   295\t    int id = 0;\r\n   296\t    if (parse_id_from_path(url, &id)) {\r\n   297\t        if (strcmp(method, \"GET\") == 0) {\r\n   298\t            char *row = get_note_json(id);\r\n   299\t            if (!row) return not_found(connection);\r\n   300\t            enum MHD_Result r = send_json(connection, row, MHD_HTTP_OK);\r\n   301\t            free(row);\r\n   302\t            return r;\r\n   303\t        }\r\n   304\t\r\n   305\t        if (strcmp(method, \"PUT\") == 0) {\r\n   306\t            if (!api_key_valid(connection)) return unauthorized(connection);\r\n   307\t            if (!note_exists(id)) return not_found(connection);\r\n   308\t\r\n   309\t            char *title = NULL;\r\n   310\t            char *content = NULL;\r\n   311\t            if (!ci->data || !parse_note_body(ci->data, &title, &content)"]
