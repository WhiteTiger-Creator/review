    45	func (h *Handler) getJob(w http.ResponseWriter, r *http.Request) {
    46		id, err := strconv.Atoi(mux.Vars(r)["id"])
    47		if err != nil {
    48			writeError(w, http.StatusBadRequest, "invalid job id")
    49			return
    50		}
    51		job, err := h.svc.GetJob(id)
    52		if errors.Is(err, ErrNotFound) {
    53			writeError(w, http.StatusNotFound, "job not found")
    54			return
    55		}
    56		if err != nil {
    57			writeError(w, http.StatusInternalServerError, err.Error())
    58			return
    59		}
    60		writeJSON(w, http.StatusOK, job)
    61	}
