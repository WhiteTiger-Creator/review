   109	func (s *Service) CancelJob(id int) (*Job, error) {
   110		job, err := s.GetJob(id)
   111		if err != nil {
   112			return nil, err
   113		}
   114		if job.Status != "pending" {
   115			return nil, fmt.Errorf("%w: job status is %q", ErrConflict, job.Status)
   116		}
