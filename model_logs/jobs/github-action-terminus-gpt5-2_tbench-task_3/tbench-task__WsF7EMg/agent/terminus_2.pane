    40	func (s *Service) GetJob(id int) (*Job, error) {
    41		var j Job
    42		var workerID sql.NullInt64
    43		var workerName sql.NullString
    44	
    45		err := s.db.QueryRow(`
    46			SELECT j.id, j.type, j.payload, j.status, j.priority,
    47			       j.created_at, j.updated_at, j.worker_id, w.name
    48			FROM jobs j
    49			LEFT JOIN workers w ON j.worker_id = w.id
    50			WHERE j.id = ?
    51		`, id).Scan(
    52			&j.ID, &j.Type, &j.Payload, &j.Status, &j.Priority,
    53			&j.CreatedAt, &j.UpdatedAt, &workerID, &workerName,
    54		)
    55		if errors.Is(err, sql.ErrNoRows) {
    56			return nil, ErrNotFound
    57		}
    58		if err != nil {
    59			return nil, err
    60		}
    61		if workerID.Valid {
    62			wid := int(workerID.Int64)
    63			j.WorkerID = &wid
    64		}
    65		j.WorkerName = workerName.String
    66		return &j, nil
    67	}
