    27	func (h *Handler) createJob(w http.ResponseWriter, r *http.Request) {
    28		var req CreateJobRequest
    29		if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
    30			writeError(w, http.StatusBadRequest, "invalid JSON body")
    31			return
    32		}
    33		if req.Type == "" {
    34			writeError(w, http.StatusBadRequest, "type is required")
    35			return
    36		}
    37		job, err := h.svc.CreateJob(req)
    38		if err != nil {
    39			writeError(w, http.StatusInternalServerError, err.Error())
    40			return
    41		}
    42		writeJSON(w, http.StatusCreated, job)
    43	}
