    65		if err != nil {
    66			writeError(w, http.StatusInternalServerError, err.Error())
    67			return
    68		}
    69		if jobs == nil {
    70			jobs = []Job{}
    71		}
    72		writeJSON(w, http.StatusOK, jobs)
    73	}
    74	
