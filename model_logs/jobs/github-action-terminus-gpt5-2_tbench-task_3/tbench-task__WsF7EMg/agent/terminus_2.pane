   109	func (s *Service) CancelJob(id int) (*Job, error) {
   110		job, err := s.GetJob(id)
   111		if err != nil {
   112			return nil, err
   113		}
   114		if job.Status != "pending" {
   115			return nil, fmt.Errorf("%w: job status is %q", ErrConflict, job.Status)
   116		}
   117		res, err := s.db.Exec("UPDATE jobs SET status='cancelled', updated_at=? WHERE id=? AND status='pending'", time.Now(), id)
   118		if err != nil {
   119			return nil, err
   120		}
   121		aff, _ := res.RowsAffected()
   122		if aff == 0 {
   123			return nil, fmt.Errorf("%w: job is not in a cancellable state", ErrConflict)
   124		}
   125		return s.GetJob(id)
   126	}
   127	
   128	func (s *Service) CompleteJob(id int) (*Job, error) {
   129		job, err := s.GetJob(id)
   130		if err != nil {
   131			return nil, err
   132		}
   133		if job.Status != "running" {
   134			return nil, fmt.Errorf("%w: job must be running to complete, got %q", ErrConflict, job.Status)
   135		}
   136		res, err := s.db.Exec("UPDATE jobs SET status='completed', updated_at=? WHERE id=? AND status='running'", time.Now(), id)
   137		if err != nil {
   138			return nil, err
   139		}
   140		aff, _ := res.RowsAffected()
   141		if aff == 0 {
   142			return nil, fmt.Errorf("%w: job is not running", ErrConflict)
   143		}
   144		return s.GetJob(id)
   145	}
   146	
   147	func (s *Service) FailJob(id int) (*Job, error) {
   148		job, err := s.GetJob(id)
   149		if err != nil {
   150			return nil, err
   151		}
   152		if job.Status != "running" {
   153			return nil, fmt.Errorf("%w: job must be running to fail, got %q", ErrConflict, job.Status)
   154		}
   155		res, err := s.db.Exec("UPDATE jobs SET status='failed', updated_at=? WHERE id=? AND status='running'", time.Now(), id)
   156		if err != nil {
   157			return nil, err
   158		}
   159		aff, _ := res.RowsAffected()
   160		if aff == 0 {
   161			return nil, fmt.Errorf("%w: job is not running", ErrConflict)
   162		}
   163		return s.GetJob(id)
   164	}
