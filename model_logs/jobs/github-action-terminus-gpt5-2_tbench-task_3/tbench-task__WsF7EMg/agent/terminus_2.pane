    16	func writeJSON(w http.ResponseWriter, code int, v any) {
    17		w.Header().Set("Content-Type", "application/json")
    18		w.WriteHeader(code)
    19		json.NewEncoder(w).Encode(v)
    20	}
    21	
    22	func writeError(w http.ResponseWriter, code int, msg string) {
    23		writeJSON(w, code, map[string]string{"error": msg})
    24	}
    25	
    26	func (h *Handler) createJob(w http.ResponseWriter, r *http.Request) {
    27		var req CreateJobRequest
    28		if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
    29			writeError(w, http.StatusBadRequest, "invalid JSON body")
    30			return
    31		}
    32		if req.Type == "" {
    33			writeError(w, http.StatusBadRequest, "type is required")
    34			return
    35		}
    36		job, err := h.svc.CreateJob(req)
    37		if err != nil {
    38			writeError(w, http.StatusInternalServerError, err.Error())
    39			return
    40		}
    41		writeJSON(w, http.StatusCreated, job)
    42	}
    43	
    44	func (h *Handler) getJob(w http.ResponseWriter, r *http.Request) {
    45		id, err := strconv.Atoi(mux.Vars(r)["id"])
    46		if err != nil {
    47			writeError(w, http.StatusBadRequest, "invalid job id")
    48			return
    49		}
    50		job, err := h.svc.GetJob(id)
    51		if errors.Is(err, ErrNotFound) {
    52			writeError(w, http.StatusNotFound, "job not found")
    53			return
    54		}
    55		if err != nil {
    56			writeError(w, http.StatusInternalServerError, err.Error())
    57			return
    58		}
    59		writeJSON(w, http.StatusCreated, job)
    60	}
