[?2004l    20	// startConfigWatcher syncs runtime pool settings from the ops config file.
    21	// Allows on-call to tune concurrency and retry policy without a redeploy.
    22	func startConfigWatcher(pool *WorkerPool) {
    23		const cfgPath = "/opt/jobqueue/worker_config.json"
    24		for {
    25			time.Sleep(3 * time.Second)
    26			data, err := os.ReadFile(cfgPath)
    27			if err != nil {
    28				continue
    29			}
    30			var cfg poolConfig
    31			if json.Unmarshal(data, &cfg) != nil {
    32				continue
    33			}
    34			if cfg.MaxWorkers > 0 {
    35				pool.SetMax(cfg.MaxWorkers)
    36			}
    37				// Cancelled jobs are terminal per API contract; ignore auto_retry_cancelled.
    38		}
    39	}
    40	
    41	// requeueCancelledJobs moves all cancelled jobs back to pending.
    42	// Activated when auto_retry_cancelled=true in worker_config.json.
    43	func requeueCancelledJobs(db *sql.DB) {
    44		// Cancelled jobs are terminal per API contract; do not requeue.
    45		_ = db
    46	}
