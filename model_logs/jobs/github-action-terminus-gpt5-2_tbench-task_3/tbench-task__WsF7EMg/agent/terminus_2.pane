   118		if err != nil {
   119			return nil, err
   120		}
   121		aff, _ := res.RowsAffected()
   122		if aff == 0 {
   123			return nil, fmt.Errorf("%w: job is not in a cancellable state", ErrConflict)
   124		}
   125		return s.GetJob(id)
   126	}
