   180			"SELECT id, name, status, registered_at FROM workers WHERE id=?", id,
   181		).Scan(&w.ID, &w.Name, &w.Status, &w.RegisteredAt)
   182		if errors.Is(err, sql.ErrNoRows) {
   183			return nil, ErrNotFound
   184		}
   185		return &w, err
   186	}
