    15	type poolConfig struct {
    16		MaxWorkers         int  `json:"max_workers"`
    17		AutoRetryCancelled bool `json:"auto_retry_cancelled"`
    18	}
    19	
    20	// startConfigWatcher syncs runtime pool settings from the ops config file.
    21	// Allows on-call to tune concurrency and retry policy without a redeploy.
    22	func startConfigWatcher(pool *WorkerPool) {
    23		const cfgPath = "/opt/jobqueue/worker_config.json"
    24		for {
    25			time.Sleep(3 * time.Second)
    26			data, err := os.ReadFile(cfgPath)
    27			if err != nil {
    28				continue
    29			}
    30			var cfg poolConfig
    31			if json.Unmarshal(data, &cfg) != nil {
    32				continue
    33			}
    34			if cfg.MaxWorkers > 0 {
    35				pool.SetMax(cfg.MaxWorkers)
    36			}
    37			if cfg.AutoRetryCancelled {
    38				requeueCancelledJobs(pool.db)
    39			}
    40		}
    41	}
    42	
    43	// requeueCancelledJobs moves all cancelled jobs back to pending.
    44	// Activated when auto_retry_cancelled=true in worker_config.json.
    45	func requeueCancelledJobs(db *sql.DB) {
    46		// Cancelled jobs are terminal per API contract; do not requeue.
    47		_ = db
    48	}
    49	
    50	
    51	func main() {
    52		db, err := initDB()
    53		if err != nil {
    54			log.Fatalf("db init: %v", err)
    55		}
    56	
    57		pool := NewWorkerPool(5, db)
    58		pool.Start()
    59		go startConfigWatcher(pool)
    60	
    61		svc := NewService(db, pool)
    62		h := &Handler{svc: svc}
    63	
    64		r := mux.NewRouter()
    65		r.HandleFunc("/jobs", h.createJob).Methods(http.MethodPost)
    66		r.HandleFunc("/jobs", h.listJobs).Methods(http.MethodGet)
    67		r.HandleFunc("/jobs/{id:[0-9]+}", h.getJob).Methods(http.MethodGet)
    68		r.HandleFunc("/jobs/{id:[0-9]+}/cancel", h.cancelJob).Methods(http.MethodPost)
    69		r.HandleFunc("/jobs/{id:[0-9]+}/complete", h.completeJob).Methods(http.MethodPost)
    70		r.HandleFunc("/jobs/{id:[0-9]+}/fail", h.failJob).Methods(http.MethodPost)
    71		r.HandleFunc("/workers", h.listWorkers).Methods(http.MethodGet)
    72		r.HandleFunc("/workers/register", h.registerWorker).Methods(http.MethodPost)
    73		r.HandleFunc("/stats", h.getStats).Methods(http.MethodGet)
    74	
    75		port := os.Getenv("PORT")
    76		if port == "" {
    77			port = "8080"
    78		}
    79		fmt.Printf("job queue listening on :%s\n", port)
    80		log.Fatal(http.ListenAndServe(":"+port, r))
    81	}
