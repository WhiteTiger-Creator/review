   166	func (s *Service) RegisterWorker(name string) (*Worker, error) {
   167		if name == "" {
   168			return nil, fmt.Errorf("name is required")
   169		}
   170		res, err := s.db.Exec("INSERT INTO workers (name) VALUES (?)", name)
   171		if err != nil {
   172			return nil, fmt.Errorf("insert worker: %w", err)
   173		}
   174		id, _ := res.LastInsertId()
   175		return s.GetWorker(int(id))
   176	}
   177	
   178	func (s *Service) GetWorker(id int) (*Worker, error) {
   179		var w Worker
   180		err := s.db.QueryRow(
   181			"SELECT id, name, status, registered_at FROM workers WHERE id=?", id,
   182		).Scan(&w.ID, &w.Name, &w.Status, &w.RegisteredAt)
   183		if errors.Is(err, sql.ErrNoRows) {
   184			return nil, ErrNotFound
   185		}
   186		return &w, err
   187	}
   188	
   189	func (s *Service) ListWorkers() ([]Worker, error) {
   190		rows, err := s.db.Query("SELECT id, name, status, registered_at FROM workers ORDER BY id")
   191		if err != nil {
   192			return nil, err
   193		}
   194		defer rows.Close()
   195	
   196		var workers []Worker
   197		for rows.Next() {
   198			var w Worker
   199			if err := rows.Scan(&w.ID, &w.Name, &w.Status, &w.RegisteredAt); err != nil {
   200				return nil, err
   201			}
   202			workers = append(workers, w)
   203		}
   204		return workers, rows.Err()
   205	}
   206	
   207	func (s *Service) GetStats() (*QueueStats, error) {
   208		stats := &QueueStats{}
   209		rows, err := s.db.Query("SELECT status, COUNT(*) FROM jobs GROUP BY status")
   210		if err != nil {
   211			return nil, err
   212		}
   213		defer rows.Close()
   214		for rows.Next() {
   215			var status string
   216			var count int
   217			if err := rows.Scan(&status, &count); err != nil {
   218				return nil, err
   219			}
   220			switch status {
   221			case "pending":
   222				stats.Pending = count
   223			case "running":
   224				stats.Running = count
   225			case "completed":
   226				stats.Completed = count
   227			case "failed":
   228				stats.Failed = count
   229			case "cancelled":
   230				stats.Cancelled = count
   231			}
   232		}
   233		return stats, rows.Err()
   234	}
