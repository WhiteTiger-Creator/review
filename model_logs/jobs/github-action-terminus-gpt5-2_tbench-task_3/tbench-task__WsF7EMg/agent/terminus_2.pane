    69	func (s *Service) ListJobs(status string) ([]Job, error) {
    70		var (
    71			rows *sql.Rows
    72			err  error
    73		)
    74		if status == "" {
    75			rows, err = s.db.Query(`
    76				SELECT id, type, payload, status, priority, created_at, updated_at, worker_id
    77				FROM jobs ORDER BY priority DESC, created_at ASC
    78			`)
    79		} else {
    80			rows, err = s.db.Query(`
    81				SELECT id, type, payload, status, priority, created_at, updated_at, worker_id
    82				FROM jobs WHERE status = ? ORDER BY priority DESC, created_at ASC
    83			`, status)
    84		}
    85		if err != nil {
    86			return nil, err
    87		}
    88		defer rows.Close()
    89	
    90		var jobs []Job
    91		for rows.Next() {
    92			var j Job
    93			var workerID sql.NullInt64
    94			if err := rows.Scan(
    95				&j.ID, &j.Type, &j.Payload, &j.Status, &j.Priority,
    96				&j.CreatedAt, &j.UpdatedAt, &workerID,
    97			); err != nil {
    98				return nil, err
    99			}
   100			if workerID.Valid {
   101				wid := int(workerID.Int64)
   102				j.WorkerID = &wid
   103			}
   104			jobs = append(jobs, j)
   105		}
   106		return jobs, rows.Err()
   107	}
