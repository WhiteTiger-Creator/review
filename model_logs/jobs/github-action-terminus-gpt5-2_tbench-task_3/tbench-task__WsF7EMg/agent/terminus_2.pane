    52		db, err := initDB()
    53		if err != nil {
    54			log.Fatalf("db init: %v", err)
    55		}
    56	
    57		pool := NewWorkerPool(5, db)
    58		pool.Start()
    59		go startConfigWatcher(pool)
    60	
    61		svc := NewService(db, pool)
    62		h := &Handler{svc: svc}
    63	
    64		r := mux.NewRouter()
    65		r.HandleFunc("/jobs", h.createJob).Methods(http.MethodPost)
    66		r.HandleFunc("/jobs", h.listJobs).Methods(http.MethodGet)
    67		r.HandleFunc("/jobs/{id:[0-9]+}", h.getJob).Methods(http.MethodGet)
    68		r.HandleFunc("/jobs/{id:[0-9]+}/cancel", h.cancelJob).Methods(http.MethodPost)
    69		r.HandleFunc("/jobs/{id:[0-9]+}/complete", h.completeJob).Methods(http.MethodPost)
    70		r.HandleFunc("/jobs/{id:[0-9]+}/fail", h.failJob).Methods(http.MethodPost)
    71		r.HandleFunc("/workers", h.listWorkers).Methods(http.MethodGet)
    72		r.HandleFunc("/workers/register", h.registerWorker).Methods(http.MethodPost)
    73		r.HandleFunc("/stats", h.getStats).Methods(http.MethodGet)
    74	
    75		port := os.Getenv("PORT")
    76		if port == "" {
    77			port = "8080"
