[154.589541, "o", "        }\r\n"]
[154.589558, "o", "\u001b[?2004l\r"]
[154.589572, "o", "\u001b[?2004h"]
[154.589633, "o", "> "]
[154.589747, "o", "        joined << descriptor_line(*sorted[i]);\r\n\u001b[?2004l\r"]
[154.589816, "o", "\u001b[?2004h> "]
[154.589836, "o", "    }\r\n\u001b[?2004l\r"]
