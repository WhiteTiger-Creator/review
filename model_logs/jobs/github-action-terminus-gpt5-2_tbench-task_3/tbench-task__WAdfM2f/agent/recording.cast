[78.635928, "o", "/app/environment/include/m14_api.h:22:std::vector<forge::UnitCheckpoint> m14_merge_entries(\r\n/app/environment/include/m14_api.h:25:void m14_write_checkpoint(const std::filesystem::path &path, const char *lane_token,\r\n/app/environment/include/store_bridge.h:10:std::vector<forge::UnitCheckpoint> forge_lane_merge_checkpoint(\r\n/app/environment/include/store_bridge.h:13:void forge_lane_save_checkpoint(const std::filesystem::path &path, const char *lane_token,\r\n/app/environment/m14/lane_store.cpp:155:std::vector<forge::UnitCheckpoint> m14_merge_entries(\r\n/app/environment/m14/lane_store.cpp:168:void m14_write_checkpoint(const std::filesystem::path &path, const char *lane_token,\r\n/app/environment/m14/store_bridge.cpp:4:std::vector<forge::UnitCheckpoint> forge_lane_merge_checkpoint(\r\n/app/environment/m14/store_bridge.cpp:7:    return m14_merge_entries(existing, updated, requested_resume);\r\n/app/environment/m14/store_bridge.cpp:10:void forge_lane_save_checkpoint(const std::filesystem::path &path, const char *lane_token"]
[78.636009, "o", ",\r\n/app/environment/m14/store_bridge.cpp:12:    m14_write_checkpoint(path, lane_token, entries);\r\n/app/environment/runner/emit_pipeline.cpp:190:    return pick_int(doc, \"pass_epoch\");\r\n/app/environment/runner/emit_pipeline.cpp:354:        forge_lane_merge_checkpoint(checkpoint, updated_entries, requested_resume);\r\n/app/environment/runner/emit_pipeline.cpp:355:    forge_lane_save_checkpoint(checkpoint_path, lane_token, merged);\r\n"]
