[154.583556, "o", "\u001b[?2004h"]
[154.583565, "o", "> "]
[154.583944, "o", "            if (depth == 0 && start != std::string::npos) {\r\n\u001b[?2004l\r"]
[154.583994, "o", "\u001b[?2004h"]
[154.584039, "o", "> "]
[154.584404, "o", "                out.push_back(array_text.substr(start, i - start + 1));\r\n\u001b[?2004l\r"]
[154.584454, "o", "\u001b[?2004h"]
[154.584491, "o", "> "]
[154.584727, "o", "                start = std::string::npos;\r\n\u001b[?2004l\r"]
