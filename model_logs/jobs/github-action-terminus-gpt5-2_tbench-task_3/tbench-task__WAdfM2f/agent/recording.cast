[154.586174, "o", "extern \"C\" const char *m14_lane_token(const forge::UnitSpec *units, size_t count) {\r\n\u001b[?2004l\r"]
[154.586258, "o", "\u001b[?2004h> "]
[154.586731, "o", "    // Lane token digest over newline-joined descriptor lines sorted by unit name.\r\n\u001b[?2004l\r"]
