[154.590662, "o", "extern \"C\" int m14_checkpoint_valid(const char *on_disk_token, const char *expected_token) {\r\n\u001b[?2004l\r"]
[154.590727, "o", "\u001b[?2004h"]
[154.590747, "o", "> "]
[154.590913, "o", "    if (on_disk_token == nullptr || expected_token == nullptr) {\r\n\u001b[?2004l\r"]
[154.590933, "o", "\u001b[?2004h"]
