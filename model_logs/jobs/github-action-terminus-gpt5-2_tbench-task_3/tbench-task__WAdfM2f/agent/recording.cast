[154.599541, "o", "\u001b[?2004h> "]
[154.599687, "o", "    const std::vector<std::string> &requested_resume) {\r\n\u001b[?2004l\r"]
[154.599752, "o", "\u001b[?2004h"]
[154.599824, "o", "> "]
[154.59999, "o", "    // Preserve existing entries; apply updates only for requested resume units.\r\n\u001b[?2004l\r"]
[154.600112, "o", "\u001b[?2004h> "]
[154.60022, "o", "    std::map<std::string, forge::UnitCheckpoint> merged;\r\n\u001b[?2004l\r"]
[154.600281, "o", "\u001b[?2004h"]
[154.6003, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[154.600314, "o", "> "]
[154.600463, "o", "    for (const auto &kv : existing.units) {\r\n\u001b[?2004l\r"]
[154.600556, "o", "\u001b[?2004h> "]
