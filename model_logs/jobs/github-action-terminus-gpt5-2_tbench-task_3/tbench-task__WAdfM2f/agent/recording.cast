[154.594109, "o", "    state.lane_token = pick_string(doc, \"lane_token\");\r\n\u001b[?2004l\r"]
[154.594218, "o", "\u001b[?2004h> "]
[154.594426, "o", "    if (!m14_checkpoint_valid(state.lane_token.c_str(), expected_token.c_str())) {\r\n\u001b[?2004l\r"]
[154.594517, "o", "\u001b[?2004h> "]
