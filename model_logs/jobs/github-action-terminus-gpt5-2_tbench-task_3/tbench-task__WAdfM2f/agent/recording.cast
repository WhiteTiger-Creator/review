[154.595471, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[154.59557, "o", "    size_t arr_start = doc.find('[', units_pos);\r\n\u001b[?2004l\r"]
[154.59563, "o", "\u001b[?2004h"]
[154.59569, "o", "> "]
