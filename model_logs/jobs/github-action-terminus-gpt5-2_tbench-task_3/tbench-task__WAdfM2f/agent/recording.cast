[154.601157, "o", "\u001b[?2004h> "]
[154.60125, "o", "    for (const auto &u : updated) {\r\n\u001b[?2004l\r"]
[154.601309, "o", "\u001b[?2004h> "]
[154.601487, "o", "        if (requested_set.find(u.name) != requested_set.end()) {\r\n\u001b[?2004l\r"]
[154.601538, "o", "\u001b[?2004h> "]
[154.601641, "o", "            merged[u.name] = u;\r\n\u001b[?2004l\r"]
[154.601692, "o", "\u001b[?2004h> "]
[154.601733, "o", "        }\r\n\u001b[?2004l\r"]
