[154.602715, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[154.602827, "o", "    std::sort(out.begin(), out.end(),\r\n\u001b[?2004l\r"]
[154.602889, "o", "\u001b[?2004h> "]
[154.603137, "o", "              [](const forge::UnitCheckpoint &a, const forge::UnitCheckpoint &b) {\r\n\u001b[?2004l\r"]
[154.603161, "o", "\u001b[?2004h"]
