[154.581259, "o", "> "]
[154.581369, "o", "    int depth = 0;\r\n\u001b[?2004l\r"]
[154.58143, "o", "\u001b[?2004h> "]
[154.581646, "o", "    size_t start = std::string::npos;\r\n\u001b[?2004l\r"]
[154.581751, "o", "\u001b[?2004h> "]
[154.582036, "o", "    for (size_t i = 0; i < array_text.size(); ++i) {\r\n\u001b[?2004l\r"]
[154.582069, "o", "\u001b[?2004h"]
