[154.59486, "o", "\u001b[?2004h> "]
[154.595011, "o", "    size_t units_pos = doc.find(\"\\\"units\\\"\");\r\n\u001b[?2004l\r"]
[154.595033, "o", "\u001b[?2004h"]
