[154.587631, "o", "\u001b[?2004h"]
[154.587696, "o", "> "]
[154.587904, "o", "    for (size_t i = 0; i < count; ++i) {\r\n\u001b[?2004l\r"]
[154.587962, "o", "\u001b[?2004h> "]
[154.588164, "o", "        sorted.push_back(&units[i]);\r\n\u001b[?2004l\r"]
[154.588254, "o", "\u001b[?2004h> "]
[154.588328, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[154.588431, "o", "    std::sort(sorted.begin(), sorted.end(),\r\n\u001b[?2004l\r"]
[154.588498, "o", "\u001b[?2004h> "]
[154.588768, "o", "              [](const forge::UnitSpec *a, const forge::UnitSpec *b) { return a->name < b->name; });\r\n\u001b[?2004l\r"]
[154.588839, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[154.588908, "o", "\u001b[?2004h> "]
[154.588989, "o", "    std::ostringstream joined;\r\n\u001b[?2004l\r"]
[154.589052, "o", "\u001b[?2004h> "]
[154.589192, "o", "    for (size_t i = 0; i < sorted.size(); ++i) {\r\n\u001b[?2004l\r"]
[154.58924, "o", "\u001b[?2004h> "]
[154.589312, "o", "        if (i) {\r\n\u001b[?2004l\r"]
[154.589374, "o", "\u001b[?2004h> "]
[154.589449, "o", "            joined << '\\n';\r\n\u001b[?2004l\r"]
