[154.591084, "o", "        return 0;\r\n\u001b[?2004l\r\u001b[?2004h"]
[154.591151, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[154.59137, "o", "    return std::string(on_disk_token) == std::string(expected_token) ? 1 : 0;\r\n\u001b[?2004l\r\u001b[?2004h"]
