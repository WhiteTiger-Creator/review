[154.593277, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[154.593301, "o", "> "]
[154.593401, "o", "    // Basic shape check\r\n\u001b[?2004l\r\u001b[?2004h"]
[154.593465, "o", "> "]
[154.593618, "o", "    if (doc.find(\"\\\"schema_version\\\"\") == std::string::npos) {\r\n\u001b[?2004l\r"]
[154.593639, "o", "\u001b[?2004h"]
[154.593653, "o", "> "]
[154.593744, "o", "        return state;\r\n\u001b[?2004l\r"]
[154.593827, "o", "\u001b[?2004h>     }\r\n"]
