[154.582288, "o", "        if (array_text[i] == '{') {\r\n\u001b[?2004l\r"]
[154.582344, "o", "\u001b[?2004h> "]
[154.582507, "o", "            if (depth == 0) {\r\n\u001b[?2004l\r"]
[154.582553, "o", "\u001b[?2004h> "]
[154.582725, "o", "                start = i;\r\n\u001b[?2004l\r"]
[154.582754, "o", "\u001b[?2004h"]
[154.582793, "o", "> "]
[154.582872, "o", "            }\r\n\u001b[?2004l\r"]
