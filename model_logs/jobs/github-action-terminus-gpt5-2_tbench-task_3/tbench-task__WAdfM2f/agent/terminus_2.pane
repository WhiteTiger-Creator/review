    94	extern "C" const char *m14_lane_token(const forge::UnitSpec *units, size_t count) {
    95	    static std::string cached;
    96	    std::ostringstream joined;
    97	    for (size_t i = 0; i < count; ++i) {
    98	        if (i) {
    99	            joined << '\n';
   100	        }
   101	        joined << descriptor_line(units[i]);
   102	    }
   103	    cached = digest_hex(joined.str());
   104	    return cached.c_str();
   105	}
   106	
   107	extern "C" int m14_checkpoint_valid(const char *on_disk_token, const char *expected_token) {
   108	    if (on_disk_token == nullptr || expected_token == nullptr) {
   109	        return 0;
   110	    }
   111	    return std::string(on_disk_token) == std::string(expected_token) ? 1 : 0;
   112	}
   113	
   114	forge::LaneCheckpoint m14_read_checkpoint(const std::filesystem::path &path,
   115	                                                   const std::string &expected_token) {
   116	    forge::LaneCheckpoint state;
   117	    std::ifstream in(path);
   118	    if (!in) {
   119	        return state;
   120	    }
   121	    std::ostringstream buffer;
   122	    buffer << in.rdbuf();
   123	    const std::string doc = buffer.str();
   124	    if (doc.find("\"schema_version\"") == std::string::npos) {
   125	        return state;
   126	    }
   127	    state.lane_token = pick_string(doc, "lane_token");
   128	    if (!m14_checkpoint_valid(state.lane_token.c_str(), expected_token.c_str())) {
   129	        return state;
   130	    }
   131	    size_t units_pos = doc.find("\"units\"");
   132	    if (units_pos == std::string::npos) {
   133	        return state;
   134	    }
   135	    size_t arr_start = doc.find('[', units_pos);
   136	    size_t arr_end = doc.find(']', arr_start);
   137	    if (arr_start == std::string::npos || arr_end == std::string::npos) {
   138	        return state;
   139	    }
   140	    const std::string arr = doc.substr(arr_start, arr_end - arr_start + 1);
   141	    for (const auto &block : split_object_blocks(arr)) {
   142	        forge::UnitCheckpoint entry;
   143	        entry.name = pick_string(block, "name");
   144	        entry.next_pass = pick_int(block, "next_pass");
   145	        entry.carry_weight = pick_int64(block, "carry_weight");
   146	        entry.carry_drift = pick_int64(block, "carry_drift");
   147	        if (!entry.name.empty()) {
   148	            state.units[entry.name] = entry;
   149	        }
   150	    }
   151	    state.valid = true;
   152	    return state;
   153	}
   154	
   155	std::vector<forge::UnitCheckpoint> m14_merge_entries(
   156	    const forge::LaneCheckpoint &existing, const std::vector<forge::UnitCheckpoint> &updated,
   157	    const std::vector<std::string> &requested_resume) {
   158	    (void)existing;
   159	    (void)requested_resume;
   160	    std::vector<forge::UnitCheckpoint> out = updated;
   161	    std::sort(out.begin(), out.end(),
   162	              [](const forge::UnitCheckpoint &a, const forge::UnitCheckpoint &b) {
   163	                  return a.name < b.name;
   164	              });
   165	    return out;
   166	}
   167	
   168	void m14_write_checkpoint(const std::filesystem::path &path, const char *lane_token,
   169	                                     const std::vector<forge::UnitCheckpoint> &entries) {
   170	    std::filesystem::create_directories(path.parent_path());
   171	    std::ostringstream out;
   172	    out << "{\"schema_version\":" << forge::kSchemaVersion << ",\"lane_token\":\"" << lane_token
   173	        << "\",\"units\":[";
   174	    for (size_t i = 0; i < entries.size(); ++i) {
   175	        if (i) {
   176	            out << ',';
   177	        }
   178	        const auto &entry = entries[i];
   179	        out << "{\"name\":\"" << entry.name << "\",\"next_pass\":" << entry.next_pass
   180	            << ",\"carry_weight\":" << entry.carry_weight << ",\"carry_drift\":"
   181	            << entry.carry_drift << '}';
   182	    }
   183	    out << "]}\n";
   184	    std::ofstream file(path, std::ios::binary);
   185	    file << out.str();
   186	}
