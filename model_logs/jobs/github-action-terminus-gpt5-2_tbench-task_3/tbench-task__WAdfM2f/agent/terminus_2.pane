    14	std::uint64_t digest_update(std::uint64_t h, const std::string &text) {
    15	    for (unsigned char ch : text) {
    16	        h ^= static_cast<std::uint64_t>(ch);
    17	        h = (h * forge::kDigestStep) & forge::kDigestMask;
    18	    }
    19	    return h;
    20	}
    21	
    22	std::string digest_hex(const std::string &text) {
    23	    std::uint64_t h = digest_update(forge::kDigestSeed, text);
    24	    std::ostringstream os;
    25	    os << std::hex << std::nouppercase;
    26	    os.width(16);
    27	    os.fill('0');
    28	    os << h;
    29	    return os.str();
    30	}
