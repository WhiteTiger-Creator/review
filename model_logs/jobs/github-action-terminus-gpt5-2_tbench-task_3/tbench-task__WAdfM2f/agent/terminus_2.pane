    32	std::string descriptor_line(const forge::UnitSpec &unit) {
    33	    std::ostringstream os;
    34	    os << unit.name << '|' << unit.mode << '|' << unit.record << '|' << unit.manifest_bytes << '|'
    35	       << unit.start_pass;
    36	    return os.str();
    37	}
