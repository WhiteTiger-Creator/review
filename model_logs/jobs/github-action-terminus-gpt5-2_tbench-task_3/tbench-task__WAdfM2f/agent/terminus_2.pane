    39	std::string pick_string(const std::string &block, const std::string &key) {
    40	    std::string needle = "\"" + key + "\"";
    41	    size_t k = block.find(needle);
    42	    if (k == std::string::npos) {
    43	        return "";
    44	    }
    45	    size_t q = block.find('"', block.find(':', k) + 1);
    46	    size_t e = block.find('"', q + 1);
    47	    return block.substr(q + 1, e - q - 1);
    48	}
    49	
    50	int pick_int(const std::string &block, const std::string &key) {
    51	    std::string needle = "\"" + key + "\"";
    52	    size_t k = block.find(needle);
    53	    if (k == std::string::npos) {
    54	        return 0;
    55	    }
    56	    size_t p = block.find(':', k) + 1;
    57	    while (p < block.size() && !std::isdigit(static_cast<unsigned char>(block[p])) && block[p] != '-') {
    58	        ++p;
    59	    }
    60	    size_t e = p;
    61	    while (e < block.size() && (std::isdigit(static_cast<unsigned char>(block[e])) || block[e] == '-')) {
    62	        ++e;
    63	    }
    64	    return std::stoi(block.substr(p, e - p));
    65	}
    66	
    67	int64_t pick_int64(const std::string &block, const std::string &key) {
    68	    return static_cast<int64_t>(pick_int(block, key));
    69	}
    70	
    71	std::vector<std::string> split_object_blocks(const std::string &array_text) {
    72	    std::vector<std::string> out;
    73	    int depth = 0;
    74	    size_t start = std::string::npos;
    75	    for (size_t i = 0; i < array_text.size(); ++i) {
    76	        if (array_text[i] == '{') {
    77	            if (depth == 0) {
    78	                start = i;
    79	            }
    80	            ++depth;
    81	        } else if (array_text[i] == '}') {
    82	            --depth;
    83	            if (depth == 0 && start != std::string::npos) {
    84	                out.push_back(array_text.substr(start, i - start + 1));
    85	                start = std::string::npos;
    86	            }
    87	        }
    88	    }
    89	    return out;
    90	}
