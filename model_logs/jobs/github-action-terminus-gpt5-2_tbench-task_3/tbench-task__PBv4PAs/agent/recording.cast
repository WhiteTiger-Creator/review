[58.853748, "i", "python3 - <<'PY'\nimport json,hashlib\n\ndef sig(path):\n  r=json.load(open(path))\n  ev=r['events']\n  # signature includes full event stream\n  h=hashlib.sha256(json.dumps(ev,separators=(',',':')).encode()).hexdigest()\n  subs=[e['id'] for e in ev if e['kind']=='submit']\n  return len(ev), (max(subs) if subs else 0), h\nfor p in ['/app/output/report_a.json','/app/output/report_b.json']:\n  print(p, sig(p))\nra=json.load(open('/app/output/report_a.json'))\nrb=json.load(open('/app/output/report_b.json'))\nsuba=[e['id'] for e in ra['events'] if e['kind']=='submit']\nsubb=[e['id'] for e in rb['events'] if e['kind']=='submit']\nprint('same submit coverage',suba==subb,'N',len(suba))\nprint('event stream identical',ra['events']==rb['events'])\nPY\n"]
