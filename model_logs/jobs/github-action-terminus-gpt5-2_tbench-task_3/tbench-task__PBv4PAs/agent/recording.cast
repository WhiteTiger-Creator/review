[149.87533, "o", "\u001b[?2004l\r\u001b[?2004h>       return 'dup',t\r\n\u001b[?2004l\r\u001b[?2004h>     seen.add(t)\r\n\u001b[?2004l\r\u001b[?2004h>   subs=[e['id'] for e in ev if e['kind']=='submit']\r\n\u001b[?2004l\r\u001b[?2004h>   comps=[e['id'] for e in ev if e['kind']=='complete']\r\n\u001b[?2004l\r\u001b[?2004h>   notifs=[e['id'] for e in ev if e['kind']=='notify']\r\n\u001b[?2004l\r\u001b[?2004h>   if not subs:\r\n\u001b[?2004l\r\u001b[?2004h>     return 'no_submits',None\r\n\u001b[?2004l\r\u001b[?2004h>   mx=max(subs)\r\n\u001b[?2004l\r\u001b[?2004h>   if subs!=list(range(1,mx+1)):\r\n\u001b[?2004l\r\u001b[?2004h>     return 'noncontig', (subs[:20],mx)\r\n\u001b[?2004l\r\u001b[?2004h>   if set(subs)!=set(comps):\r\n\u001b[?2004l\r\u001b[?2004h>     return 'comp_mismatch', (len(set(subs)-set(comps)), len(set(comps)-set(subs)))\r\n\u001b[?2004l\r\u001b[?2004h>   if set(subs)!=set(notifs):\r\n\u001b[?2004l\r\u001b[?2004h>     return 'notif_mismatch', (len(set(subs)-set(notifs)), len(set(notifs)-set(subs)))\r\n\u001b[?2004l\r\u001b[?2004h>   pos={}\r\n\u001b[?2004l\r\u001b[?2004h>   for i,e in enumerate(ev):\r\n\u001b[?2004l\r\u001b[?2004h>     pos[(e['kind'],e['id'])]=i\r\n\u001b[?2004l\r\u001b[?2004h>   for i in range(1,mx+1):\r\n\u001b[?2004l\r\u001b[?2004"]
[149.875417, "o", "h>     s=pos.get(('submit',i)); c=pos.get(('complete',i)); n=pos.get(('notify',i))\r\n\u001b[?2004l\r\u001b[?2004h>     if not (s is not None and c is not None and n is not None and s<c<n):\r\n\u001b[?2004l\r\u001b[?2004h>       return 'order', (i,s,c,n)\r\n\u001b[?2004l\r\u001b[?2004h>   return None,None\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> scenarios=['basic','stress','stress2']\r\n\u001b[?2004l\r\u001b[?2004h> profiles=['burst','steady']\r\n\u001b[?2004l\r\u001b[?2004h> orders=['a_then_b','b_then_a']\r\n\u001b[?2004l\r\u001b[?2004h> for sc in scenarios:\r\n\u001b[?2004l\r\u001b[?2004h>   for pr in profiles:\r\n\u001b[?2004l\r\u001b[?2004h>     for od in orders:\r\n\u001b[?2004l\r\u001b[?2004h>       out=f'/app/output/{sc}_{pr}_{od}.json'\r\n\u001b[?2004l\r\u001b[?2004h>       if os.path.exists(out): os.remove(out)\r\n\u001b[?2004l\r\u001b[?2004h>       subprocess.check_call(['/usr/local/bin/arena','--scenario',sc,'--profile',pr,'--order',od,'--out',out])\r\n\u001b[?2004l\r\u001b[?2004h>       err,info=check(out)\r\n\u001b[?2004l\r\u001b[?2004h>       if err:\r\n\u001b[?2004l\r\u001b[?2004h>         print('FAIL',sc,pr,od,err,info)\r\n\u001b[?2004l\r\u001b[?2004h>         raise SystemExit(1)\r\n\u001b[?"]
[149.87544, "o", "2004l\r\u001b[?2004h> print('ALL_OK')\r\n\u001b[?2004l\r\u001b[?2004h> PY\r\n\u001b[?2004l\r"]
[149.907392, "o", "ALL_OK\r\n"]
[149.911077, "o", "\u001b[?2004hroot@b0eb78f960ec:/app# "]
[159.870769, "i", "python3 - <<'PY'\nimport json, subprocess, os, hashlib\n\ndef run(sc,pr,od,out):\n  if os.path.exists(out): os.remove(out)\n  subprocess.check_call(['/usr/local/bin/arena','--scenario',sc,'--profile',pr,'--order',od,'--out',out,'--seed','123'])\n  ev=json.load(open(out))['events']\n  return hashlib.sha256(json.dumps(ev,separators=(',',':')).encode()).hexdigest(), [e['id'] for e in ev if e['kind']=='submit']\n\nh1,s1=run('stress2','burst','a_then_b','/app/output/r1.json')\nh2,s2=run('stress2','burst','a_then_b','/app/output/r2.json')\nprint('deterministic',h1==h2,'N',len(s1))\nha,sa=run('stress2','burst','a_then_b','/app/output/ra.json')\nhb,sb=run('stress2','burst','b_then_a','/app/output/rb.json')\nprint('same_id_coverage',sa==sb,'seq_diff',ha!=hb)\nPY\n"]
[159.871029, "o", "python3 - <<'PY'\r\n"]
