[149.866193, "i", "python3 - <<'PY'\nimport json, subprocess, os, hashlib\n\ndef check(path):\n  r=json.load(open(path))\n  ev=r['events']\n  seen=set();\n  for e in ev:\n    t=(e['kind'],e['id'])\n    if t in seen:\n      return 'dup',t\n    seen.add(t)\n  subs=[e['id'] for e in ev if e['kind']=='submit']\n  comps=[e['id'] for e in ev if e['kind']=='complete']\n  notifs=[e['id'] for e in ev if e['kind']=='notify']\n  if not subs:\n    return 'no_submits',None\n  mx=max(subs)\n  if subs!=list(range(1,mx+1)):\n    return 'noncontig', (subs[:20],mx)\n  if set(subs)!=set(comps):\n    return 'comp_mismatch', (len(set(subs)-set(comps)), len(set(comps)-set(subs)))\n  if set(subs)!=set(notifs):\n    return 'notif_mismatch', (len(set(subs)-set(notifs)), len(set(notifs)-set(subs)))\n  pos={}\n  for i,e in enumerate(ev):\n    pos[(e['kind'],e['id'])]=i\n  for i in range(1,mx+1):\n    s=pos.get(('submit',i)); c=pos.get(('complete',i)); n=pos.get(('notify',i))\n    if not (s is not None and c is not None and n is not None and s<c<n):\n      return 'order', (i,s,c,n)\n  "]
[149.866242, "i", "return None,None\n\nscenarios=['basic','stress','stress2']\nprofiles=['burst','steady']\norders=['a_then_b','b_then_a']\nfor sc in scenarios:\n  for pr in profiles:\n    for od in orders:\n      out=f'/app/output/{sc}_{pr}_{od}.json'\n      if os.path.exists(out): os.remove(out)\n      subprocess.check_call(['/usr/local/bin/arena','--scenario',sc,'--profile',pr,'--order',od,'--out',out])\n      err,info=check(out)\n      if err:\n        print('FAIL',sc,pr,od,err,info)\n        raise SystemExit(1)\nprint('ALL_OK')\nPY\n"]
[149.866409, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r"]
[149.866704, "o", "\u001b[?2004h> "]
[149.867044, "o", "import json, subprocess, os, hashlib"]
[149.867284, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[149.867349, "o", "> \r\n"]
