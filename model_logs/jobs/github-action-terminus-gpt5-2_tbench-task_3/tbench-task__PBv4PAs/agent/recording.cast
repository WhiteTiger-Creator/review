[164.88605, "i", "set -e\nrm -f /app/output/bad.json\nif /usr/local/bin/arena --scenario stress2 --profile steady --order z_then_y --out /app/output/bad.json; then echo 'UNEXPECTED_SUCCESS'; exit 1; else echo 'rejected_bad_order_ok'; fi\ntest ! -e /app/output/bad.json && echo 'no_output_on_failure_ok'\nrm -f /app/output/bad.json\nif /usr/local/bin/arena --scenario unknown --profile steady --order a_then_b --out /app/output/bad.json; then echo 'UNEXPECTED_SUCCESS'; exit 1; else echo 'rejected_bad_scenario_ok'; fi\ntest ! -e /app/output/bad.json && echo 'no_output_on_failure_ok'\nrm -f /app/output/bad.json\nif /usr/local/bin/arena --scenario stress2 --profile nope --order a_then_b --out /app/output/bad.json; then echo 'UNEXPECTED_SUCCESS'; exit 1; else echo 'rejected_bad_profile_ok'; fi\ntest ! -e /app/output/bad.json && echo 'no_output_on_failure_ok'\n"]
