[89.393276, "i", "apply_patch<<'PATCH'\n*** Begin Patch\n*** Update File: src/logic/link.c\n@@\n   if (st != TB_OK)\n     return st;\n \n-  // A \"device-side\" queue continues to exist while detached; the notifier doesn't.\n-  tb_q64_clear(&rt->notify_q);\n+  // A \"device-side\" completion/notification backlog continues to exist while detached.\n+  // We must not drop pending notifications, otherwise completions that happen while\n+  // detached will never be notified after reattach.\n   return TB_OK;\n }\n@@\n   if (found) {\n     rt->gen = last.gen + 1;\n-    rt->cursor = last.cursor;\n+    // Never move the cursor backwards; it is used to generate request ids.\n+    // Reattaching should advance generation but preserve monotonic cursor.\n+    if (rt->cursor < last.cursor)\n+      rt->cursor = last.cursor;\n   }\n*** End Patch\nPATCH\n"]
