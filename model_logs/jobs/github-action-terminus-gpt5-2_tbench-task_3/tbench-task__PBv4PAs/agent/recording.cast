[54.833627, "i", "python3 - <<'PY'\nimport json\nfrom collections import defaultdict\np='/app/output/report.json'\nr=json.load(open(p))\nev=r.get('events',[])\nprint('scenario',r.get('scenario'),'profile',r.get('profile'),'events',len(ev))\n# duplicates\nseen=set(); dups=[]\nfor e in ev:\n  t=(e.get('kind'),e.get('id'))\n  if t in seen: dups.append(t)\n  seen.add(t)\nprint('dups',len(dups),dups[:20])\nsubs=[e['id'] for e in ev if e['kind']=='submit']\ncomps=[e['id'] for e in ev if e['kind']=='complete']\nnotifs=[e['id'] for e in ev if e['kind']=='notify']\nprint('counts',len(subs),len(comps),len(notifs))\nif subs:\n  mx=max(subs)\n  print('submit min/max',min(subs),mx,'contiguous',subs==list(range(1,mx+1)))\n  # coverage\n  miss_comp=sorted(set(subs)-set(comps))\n  miss_not=sorted(set(subs)-set(notifs))\n  extra_comp=sorted(set(comps)-set(subs))\n  extra_not=sorted(set(notifs)-set(subs))\n  print('miss_comp',len(miss_comp),'miss_not',len(miss_not),'extra_comp',len(extra_comp),'extra_not',len(extra_not))\n  print('miss_comp head',miss_comp[:20])\n  print("]
[54.834199, "i", "'extra_comp head',extra_comp[:20])\n# order constraints\npos=defaultdict(dict)\nfor idx,e in enumerate(ev):\n  pos[e['id']][e['kind']]=idx\nviol=[]\nfor i in range(1,(max(subs) if subs else 0)+1):\n  d=pos.get(i,{})\n  s=d.get('submit'); c=d.get('complete'); n=d.get('notify')\n  if s is None or c is None or n is None:\n    viol.append(('missing',i,s,c,n))\n  elif not (s<c<n):\n    viol.append(('order',i,s,c,n))\nprint('viol',len(viol),'head',viol[:10])\n# ensure not all completes clumped at end\nif comps:\n  last_submit=max(i for i,e in enumerate(ev) if e['kind']=='submit')\n  first_complete=min(i for i,e in enumerate(ev) if e['kind']=='complete')\n  print('first_complete_idx',first_complete,'last_submit_idx',last_submit,'complete_before_last_submit',first_complete<last_submit)\nPY\n"]
