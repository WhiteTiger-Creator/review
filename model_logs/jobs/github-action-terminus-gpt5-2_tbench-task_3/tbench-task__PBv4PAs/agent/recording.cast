[133.825749, "i", "python3 - <<'PY'\nimport json\nfrom collections import defaultdict\np='/app/output/report.json'\nr=json.load(open(p))\nev=r.get('events',[])\nseen=set(); dups=[]\nfor e in ev:\n  t=(e['kind'],e['id'])\n  if t in seen: dups.append(t)\n  seen.add(t)\nsubs=[e['id'] for e in ev if e['kind']=='submit']\ncomps=[e['id'] for e in ev if e['kind']=='complete']\nnotifs=[e['id'] for e in ev if e['kind']=='notify']\nmx=max(subs) if subs else 0\nprint('events',len(ev),'subs',len(subs),'comps',len(comps),'notifs',len(notifs),'mx',mx)\nprint('dups',len(dups),dups[:10])\nprint('submit contiguous',subs==list(range(1,mx+1)))\nprint('missing complete',len(set(subs)-set(comps)), sorted(set(subs)-set(comps))[:10])\nprint('missing notify',len(set(subs)-set(notifs)), sorted(set(subs)-set(notifs))[:10])\npos=defaultdict(dict)\nfor idx,e in enumerate(ev):\n  pos[e['id']][e['kind']]=idx\nviol=[]\nfor i in range(1,mx+1):\n  d=pos[i]\n  s=d.get('submit'); c=d.get('complete'); n=d.get('notify')\n  if s is None or c is None or n is None: viol.append(('missing',i,s,c"]
[133.826099, "i", ",n))\n  elif not (s<c<n): viol.append(('order',i,s,c,n))\nprint('viol',len(viol),viol[:10])\nPY\n"]
