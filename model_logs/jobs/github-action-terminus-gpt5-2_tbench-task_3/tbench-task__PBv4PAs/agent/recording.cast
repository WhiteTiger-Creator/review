[27.845786, "i", "python3 - <<'PY'\nimport json\np='/app/output/report.json'\nwith open(p) as f: r=json.load(f)\nev=r.get('events',[])\nprint('scenario',r.get('scenario'),'profile',r.get('profile'),'events',len(ev))\n# basic checks\nseen=set(); dup=[]\nfor e in ev:\n  k=e['kind']; i=e['id']\n  if (k,i) in seen: dup.append((k,i))\n  seen.add((k,i))\nprint('dup kind/id',dup[:20])\nsubs=[e['id'] for e in ev if e['kind']=='submit']\ncomps=[e['id'] for e in ev if e['kind']=='complete']\nnotifs=[e['id'] for e in ev if e['kind']=='notify']\nprint('counts submit/complete/notify',len(subs),len(comps),len(notifs))\nif subs:\n  ok = subs==list(range(1,max(subs)+1))\n  print('submit contiguous',ok,'max',max(subs))\n# order constraints\npos={}\nviol=[]\nfor idx,e in enumerate(ev):\n  pos[(e['kind'],e['id'])]=idx\nfor i in set(subs):\n  s=pos.get(('submit',i)); c=pos.get(('complete',i)); n=pos.get(('notify',i))\n  if s is None or c is None or n is None: viol.append(('missing',i,s,c,n))\n  elif not (s<c<n): viol.append(('order',i,s,c,n))\nprint('violations',viol[:20], '"]
[27.846072, "i", "total',len(viol))\n# coverage\nmiss_comp=sorted(set(subs)-set(comps))[:20]\nmiss_not=sorted(set(subs)-set(notifs))[:20]\nextra_comp=sorted(set(comps)-set(subs))[:20]\nextra_not=sorted(set(notifs)-set(subs))[:20]\nprint('miss_comp',miss_comp,'miss_not',miss_not,'extra_comp',extra_comp,'extra_not',extra_not)\nPY\n"]
