[103.430497, "i", "python3 - <<'PY'\nimport json\nfrom collections import defaultdict\np='/app/output/report.json'\nr=json.load(open(p))\nev=r.get('events',[])\nprint('events',len(ev))\nseen=set(); dups=[]\nfor e in ev:\n  t=(e['kind'],e['id'])\n  if t in seen: dups.append(t)\n  seen.add(t)\nprint('dups',len(dups),dups[:20])\nsubs=[e['id'] for e in ev if e['kind']=='submit']\ncomps=[e['id'] for e in ev if e['kind']=='complete']\nnotifs=[e['id'] for e in ev if e['kind']=='notify']\nprint('counts',len(subs),len(comps),len(notifs))\nmx=max(subs) if subs else 0\nprint('submit contiguous',subs==list(range(1,mx+1)),'mx',mx)\nprint('missing complete',sorted(set(subs)-set(comps))[:20])\nprint('missing notify',sorted(set(subs)-set(notifs))[:20])\npos=defaultdict(dict)\nfor idx,e in enumerate(ev):\n  pos[e['id']][e['kind']]=idx\nviol=[]\nfor i in range(1,mx+1):\n  d=pos[i]\n  s=d.get('submit'); c=d.get('complete'); n=d.get('notify')\n  if s is None or c is None or n is None: viol.append(('missing',i,s,c,n))\n  elif not (s<c<n): viol.append(('order',i,s,c,n))\nprint('"]
[103.430654, "i", "viol',len(viol),viol[:10])\nPY\n"]
