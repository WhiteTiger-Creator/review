[108.769223, "i", "cat > /app/src/io/journal.c <<'EOF'\n#include \"io/journal.h\"\n\n#include \"io/fs.h\"\n\n#include <errno.h>\n#include <stdio.h>\n\n// Record format (12 bytes):\n//   u32 gen\n//   u64 cursor (little-endian as two u32 words)\n\nstatic tb_status append_rec(FILE *f, tb_stamp s) {\n  if (!fs_write_u32(f, s.gen))\n    return TB_ERR_IO;\n\n  uint32_t lo = (uint32_t)(s.cursor & 0xffffffffu);\n  uint32_t hi = (uint32_t)((s.cursor >> 32) & 0xffffffffu);\n  if (!fs_write_u32(f, lo))\n    return TB_ERR_IO;\n  if (!fs_write_u32(f, hi))\n    return TB_ERR_IO;\n\n  return TB_OK;\n}\n\nstatic bool read_rec(FILE *f, tb_stamp *out) {\n  uint32_t gen = 0;\n  if (!fs_read_u32(f, &gen))\n    return false;\n\n  uint32_t lo = 0;\n  if (!fs_read_u32(f, &lo))\n    return false;\n\n  uint32_t hi = 0;\n  if (!fs_read_u32(f, &hi))\n    return false;\n\n  out->gen = gen;\n  out->cursor = ((uint64_t)hi << 32) | (uint64_t)lo;\n  return true;\n}\n\ntb_status journal_append_stamp(const char *path, tb_stamp s) {\n  FILE *f = fopen(path, \"ab\");\n  if (!f)\n    return TB_ERR_IO;\n  tb_status s"]
[108.76927, "i", "t = append_rec(f, s);\n  if (fclose(f) != 0)\n    return TB_ERR_IO;\n  return st;\n}\n\ntb_status journal_load_last(const char *path, tb_stamp *out, bool *found) {\n  if (!out || !found)\n    return TB_ERR_BAD_ARG;\n\n  FILE *f = fopen(path, \"rb\");\n  if (!f) {\n    if (errno == ENOENT) {\n      *found = false;\n      return TB_OK;\n    }\n    return TB_ERR_IO;\n  }\n\n  tb_stamp cur = {0};\n  bool any = false;\n  while (read_rec(f, &cur)) {\n    any = true;\n  }\n  fclose(f);\n\n  if (!any) {\n    *found = false;\n    return TB_OK;\n  }\n  *found = true;\n  *out = cur;\n  return TB_OK;\n}\nEOF\n"]
[108.770291, "o", "cat > /app/src/io/journal.c <<'EOF'"]
