[47.467242, "o", "#include \"cli.h\"\r\n#include \"report.h\"\r\n#include \"runtime/runtime.h\"\r\n#include \"tb_err.h\"\r\n\r\n#include <stdio.h>\r\n\r\nint main(int argc, char **argv) {\r\n"]
[47.46747, "o", "  tb_cli cli = {0};\r\n  tb_status st = tb_cli_parse(&cli, argc, argv);\r\n  if (st != TB_OK) {\r\n    fprintf(stderr, \"cli: %s\\n\", tb_status_str(st));\r\n    return 2;\r\n  }\r\n\r\n  // Per-invocation: persistence is only meant to model detach/reattach inside a run.\r\n  (void)remove(\"/app/run/state.bin\");\r\n\r\n  tb_rt rt = {0};\r\n"]
[47.467546, "o", "  st = tb_rt_init(&rt, \"/app/run/state.bin\");\r\n  if (st != TB_OK) {\r\n    fprintf(stderr, \"init: %s\\n\", tb_status_str(st));\r\n    return 2;\r\n  }\r\n\r\n  st = tb_rt_run(&rt, cli.scenario, cli.profile, cli.order, cli.seed);\r\n  if (st != TB_OK) {\r\n    fprintf(stderr, \"run: %s\\n\", tb_status_str(st));\r\n    tb_rt_free(&rt);\r\n    return 1;\r\n  }\r\n\r\n"]
[47.468369, "o", "  int rc = tb_report_write_json(cli.out_path, cli.scenario, cli.profile, tb_rt_events(&rt));\r\n  tb_rt_free(&rt);\r\n  return rc;\r\n}\r\n\r\n"]
