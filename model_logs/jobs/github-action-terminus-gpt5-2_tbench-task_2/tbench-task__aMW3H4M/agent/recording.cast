[150.467309, "o", "\u001b[?2004hroot@e252228b7510:/app# "]
[183.052769, "i", "cat > /app/src/logic/link.c <<'EOF'\n#include \"logic/link.h\"\n\n#include \"io/journal.h\"\n\n#include <string.h>\n\n// Detach/attach models a client disconnect/reconnect within a single run.\n// Submissions continue while detached (load profile fires every tick), so the\n// runtime's cursor (next request id) must remain monotonic across the whole run.\n\ntb_status tb_link_detach(tb_rt *rt, uint32_t tick) {\n  (void)tick;\n  if (!rt)\n    return TB_ERR_BAD_ARG;\n  if (!rt->attached)\n    return TB_OK;\n\n  rt->attached = false;\n\n  tb_stamp s = {.gen = rt->gen, .cursor = rt->cursor};\n  tb_status st = journal_append_stamp(rt->journal_path, s);\n  if (st != TB_OK)\n    return st;\n\n  // While detached the notifier is offline, but notification *delivery* must\n  // resume after reattach. Keep the pending notify queue intact.\n  return TB_OK;\n}\n\ntb_status tb_link_attach(tb_rt *rt, uint32_t tick) {\n  (void)tick;\n  if (!rt)\n    return TB_ERR_BAD_ARG;\n  if (rt->attached)\n    return TB_OK;\n\n  // Load the last detach stamp to advance generation"]
[183.052817, "i", ".\n  // IMPORTANT: do NOT rewind rt->cursor to the stamped cursor. Submissions\n  // continue while detached, so rewinding would reuse ids and duplicate events.\n  tb_stamp last = {0};\n  bool found = false;\n  tb_status st = journal_load_last(rt->journal_path, &last, &found);\n  if (st != TB_OK)\n    return st;\n  if (found) {\n    rt->gen = last.gen + 1;\n    // Defensive: if something went backwards, clamp forward.\n    if (rt->cursor < last.cursor)\n      rt->cursor = last.cursor;\n  }\n\n  rt->attached = true;\n  return TB_OK;\n}\nEOF\n"]
[183.053182, "o", "cat > /app/src/logic/link.c <<'EOF'"]
