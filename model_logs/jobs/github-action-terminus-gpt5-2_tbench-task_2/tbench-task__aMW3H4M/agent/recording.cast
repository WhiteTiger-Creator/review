[47.254136, "o", "#pragma once\r\n\r\n#include \"runtime/profile.h\"\r\n#include \"runtime/runtime.h\"\r\n#include \"runtime/script.h\"\r\n#include \"tb_err.h\"\r\n\r\n#include <stdint.h>\r\n\r\ntypedef struct {\r\n  tb_scenario scenario;\r\n  tb_profile profile;\r\n  tb_order order;\r\n  const char *out_path;\r\n  uint32_t seed;\r\n} tb_cli;\r\n\r\ntb_status tb_cli_parse(tb_cli *out, int argc, char **argv);\r\n\r\n"]
