[139.981357, "o", "#include \"core/map_u64.h\"\r\n\r\n#include <stdlib.h>\r\n#include <string.h>\r\n\r\nstatic uint64_t mix(uint64_t x) {\r\n  x ^= x >> 33;\r\n  x *= 0xff51afd7ed558ccdULL;\r\n"]
[139.981384, "o", "  x ^= x >> 33;\r\n  x *= 0xc4ceb9fe1a85ec53ULL;\r\n  x ^= x >> 33;\r\n  return x;\r\n}\r\n\r\nstatic bool grow(tb_map_u64 *m);\r\n\r\nbool tb_map_u64_init(tb_map_u64 *m, size_t cap) {\r\n  if (!m)\r\n    return false;\r\n"]
[139.981406, "o", "  if (cap < 16)\r\n    cap = 16;\r\n  size_t pow2 = 1;\r\n  while (pow2 < cap)\r\n    pow2 <<= 1;\r\n"]
[139.981572, "o", "  m->ents = (tb_map_u64_ent *)calloc(pow2, sizeof(tb_map_u64_ent));\r\n  if (!m->ents)\r\n    return false;\r\n"]
[139.981589, "o", "  m->cap = pow2;\r\n  m->len = 0;\r\n  return true;\r\n}\r\n\r\nvoid tb_map_u64_free(tb_map_u64 *m) {\r\n  if (!m)\r\n    return;\r\n  free(m->ents);\r\n  m->ents = NULL;\r\n  m->cap = 0;\r\n  m->len = 0;\r\n}\r\n\r\nstatic size_t probe(const tb_map_u64 *m, uint64_t k) {\r\n  return (size_t)mix(k) & (m->cap - 1);\r\n}\r\n\r\nstatic tb_map_u64_ent *find_ent(tb_map_u64 *m, uint64_t k) {\r\n  size_t i = probe(m, k);\r\n  for (;;) {\r\n    tb_map_u64_ent *e = &m->ents[i];\r\n    if (!e->used || e->k == k)\r\n      return e;\r\n    i = (i + 1) & (m->cap - 1);\r\n  }\r\n}\r\n\r\nstatic const tb_map_u64_ent *find_ent_c(const tb_map_u64 *m, uint64_t k) {\r\n  size_t i = probe(m, k);\r\n  for (;;) {\r\n    const tb_map_u64_ent *e = &m->ents[i];\r\n    if (!e->used)\r\n      return NULL;\r\n    if (e->k == k)\r\n      return e;\r\n    i = (i + 1) & (m->cap - 1);\r\n  }\r\n}\r\n\r\nbool tb_map_u64_put(tb_map_u64 *m, uint64_t k, uint64_t v) {\r\n  if (!m || !m->ents)\r\n    return false;\r\n"]
[139.981729, "o", "  if ((m->len + 1) * 10 >= m->cap * 7) {\r\n    if (!grow(m))\r\n      return false;\r\n  }\r\n"]
[139.981742, "o", "  tb_map_u64_ent *e = find_ent(m, k);\r\n  if (!e->used) {\r\n    e->used = 1;\r\n    e->k = k;\r\n    m->len++;\r\n  }\r\n  e->v = v;\r\n  return true;\r\n}\r\n\r\nbool tb_map_u64_get(const tb_map_u64 *m, uint64_t k, uint64_t *out_v) {\r\n  if (!m || !m->ents || !out_v)\r\n    return false;\r\n  const tb_map_u64_ent *e = find_ent_c(m, k);\r\n  if (!e)\r\n    return false;\r\n  *out_v = e->v;\r\n  return true;\r\n}\r\n\r\nbool tb_map_u64_has(const tb_map_u64 *m, uint64_t k) {\r\n  uint64_t tmp = 0;\r\n  return tb_map_u64_get(m, k, &tmp);\r\n}\r\n\r\nvoid tb_map_u64_clear(tb_map_u64 *m) {\r\n  if (!m || !m->ents)\r\n    return;\r\n  memset(m->ents, 0, m->cap * sizeof(tb_map_u64_ent));\r\n  m->len = 0;\r\n}\r\n\r\nstatic bool grow(tb_map_u64 *m) {\r\n"]
[139.98175, "o", "  size_t ncap = m->cap * 2;\r\n  tb_map_u64_ent *nents = (tb_map_u64_ent *)calloc(ncap, sizeof(tb_map_u64_ent));\r\n  if (!nents)\r\n"]
[139.98176, "o", "    return false;\r\n\r\n"]
[139.981774, "o", "  tb_map_u64_ent *old = m->ents;\r\n  size_t old_cap = m->cap;\r\n  m->ents = nents;\r\n  m->cap = ncap;\r\n"]
[139.981782, "o", "  m->len = 0;\r\n\r\n  for (size_t i = 0; i < old_cap; i++) {\r\n"]
[139.981791, "o", "    if (!old[i].used)\r\n      continue;\r\n"]
