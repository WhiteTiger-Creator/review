[63.844703, "i", "rm -f /app/output/report_b.json\n/usr/local/bin/arena --scenario stress2 --profile burst --order b_then_a --out /app/output/report_b.json\npython3 - <<'PY'\nimport json\nfor p in ['/app/output/report.json','/app/output/report_b.json']:\n    r=json.load(open(p))\n    ev=r['events']\n    seen=set(); dups=0\n    for e in ev:\n        k=(e['kind'],e['id'])\n        if k in seen: dups+=1\n        else: seen.add(k)\n    subs=[e['id'] for e in ev if e['kind']=='submit']\n    print(p,'events',len(ev),'submits',len(subs),'maxid',max(subs) if subs else None,'dups',dups)\nPY\n"]
