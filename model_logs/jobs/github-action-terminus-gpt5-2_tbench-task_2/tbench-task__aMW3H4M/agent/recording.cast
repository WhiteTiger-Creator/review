[140.19611, "i", "perl -0777 -i -pe 's/\\n      if \\(rt->attached\\) \\{\\n        \\/\\/ The notifier is only live while attached\\.\\n        if \\(!tb_q64_push\\(&rt->notify_q, token\\)\\)\\n          return TB_ERR_CORRUPT;\\n      \\}\\n/\\n      \\/\\/ Notifications are queued regardless of attachment; delivery happens in nudge.\\n      if (!tb_q64_push(&rt->notify_q, token))\\n        return TB_ERR_CORRUPT;\\n/s' /app/src/logic/settle.c\n"]
[140.198598, "o", "perl -0777 -i -pe 's/\\n      if \\(rt->attached\\) \\{\\n        \\/\\/ The notifier is only live while attached\\.\\n        if \\(!tb_q64_push\\(&rt->notify_q, token\\)\\)\\n          return TB_ERR_CORRUPT;\\n      \\}\\n/\\n      \\/\\/ Notifications are queued regardless of attachment; delivery happens in nudge.\\n      if (!tb_q64_push(&rt->notify_q, token))\\n        return TB_ERR_CORRUPT;\\n/s' /app/src/logic/settle.c"]
