[79.119967, "i", "sed -n '1,260p' /app/include/core/ev.h\nsed -n '1,260p' /app/src/report.c\n"]
[79.120298, "o", "sed -n '1,260p' /app/include/core/ev.h\r\n\u001b[?2004l\r"]
[79.122275, "o", "#pragma once\r\n\r\n#include <stdint.h>\r\n\r\ntypedef enum {\r\n  TB_EV_SUBMIT = 1,\r\n  TB_EV_DONE = 2,\r\n  TB_EV_POKE = 3,\r\n} tb_ev_kind;\r\n\r\n"]
[79.122308, "o", "typedef struct {\r\n  tb_ev_kind kind;\r\n  uint32_t id;\r\n} tb_event;\r\n\r\n"]
[79.122499, "o", "\u001b[?2004h"]
[79.122528, "o", "root@e252228b7510:/app# "]
[79.122665, "o", "sed -n '1,260p' /app/src/report.c\r\n\u001b[?2004l\r"]
[79.12402, "o", "#include \"report.h\"\r\n\r\n#include <stdio.h>\r\n\r\nstatic const char *kind_str(tb_ev_kind k) {\r\n  switch (k) {\r\n  case TB_EV_SUBMIT:\r\n    return \"submit\";\r\n  case TB_EV_DONE:\r\n    return \"complete\";\r\n  case TB_EV_POKE:\r\n    return \"notify\";\r\n  default:\r\n    return \"unknown\";\r\n  }\r\n}\r\n\r\nint tb_report_write_json(const char *path, tb_scenario scn, tb_profile prof, const tb_vec_ev *evs) {\r\n  FILE *f = fopen(path, \"wb\");\r\n  if (!f)\r\n    return 1;\r\n\r\n  fprintf(f, \"{\\n\");\r\n  fprintf(f, \"  \\\"scenario\\\": \\\"%s\\\",\\n\", tb_scenario_str(scn));\r\n  fprintf(f, \"  \\\"profile\\\": \\\"%s\\\",\\n\", tb_profile_str(prof));\r\n  fprintf(f, \"  \\\"events\\\": [\\n\");\r\n  for (size_t i = 0; i < evs->len; i++) {\r\n    const tb_event *ev = &evs->v[i];\r\n    fprintf(f, \"    {\\\"kind\\\": \\\"%s\\\", \\\"id\\\": %u}%s\\n\", kind_str(ev->kind), ev->id,\r\n            (i + 1 == evs->len) ? \"\" : \",\");\r\n  }\r\n  fprintf(f, \"  ]\\n\");\r\n  fprintf(f, \"}\\n\");\r\n  fclose(f);\r\n  return 0;\r\n}\r\n\r\n\u001b[?2004hroot@e252228b7510:/app# "]
[79.227719, "i", "sed -n '1,260p' /app/include/logic/ingest.h\nsed -n '1,360p' /app/src/logic/ingest.c\n"]
[79.22795, "o", "sed -n '1,260p' /app/include/logic/ingest.h\r\n\u001b[?2004l\r"]
[79.229193, "o", "#pragma once\r\n\r\n#include \"tb_err.h\"\r\n#include \"runtime/runtime.h\"\r\n\r\ntb_status tb_ingest_tick(tb_rt *rt, tb_profile prof, uint32_t tick, uint32_t *submitted_out);\r\n\r\n"]
[79.229467, "o", "\u001b[?2004hroot@e252228b7510:/app# "]
[79.229545, "o", "sed -n '1,360p' /app/src/logic/ingest.c\r\n\u001b[?2004l\r"]
[79.231216, "o", "#include \"logic/ingest.h\"\r\n\r\n#include \"core/ev.h\"\r\n#include \"runtime/profile.h\"\r\n\r\nstatic uint64_t make_token(uint32_t gen, uint64_t cursor) { return (((uint64_t)gen) << 32) ^ cursor; }\r\n\r\ntb_status tb_ingest_tick(tb_rt *rt, tb_profile prof, uint32_t tick, uint32_t *submitted_out) {\r\n  if (!rt || !submitted_out)\r\n"]
[79.231243, "o", "    return TB_ERR_BAD_ARG;\r\n\r\n  uint32_t n = tb_profile_should_submit(prof, tick);\r\n  *submitted_out = n;\r\n\r\n  for (uint32_t i = 0; i < n; i++) {\r\n    uint32_t id = (uint32_t)(rt->cursor & 0xffffffffu);\r\n    uint64_t token = make_token(rt->gen, rt->cursor);\r\n    rt->cursor++;\r\n\r\n    if (!tb_map_u64_put(&rt->token_to_id, token, (uint64_t)id))\r\n      return TB_ERR_OOM;\r\n"]
[79.231335, "o", "    if (!tb_q64_push(&rt->in_q, token))\r\n      return TB_ERR_CORRUPT;\r\n\r\n    tb_event ev = {.kind = TB_EV_SUBMIT, .id = id};\r\n    if (!tb_vec_ev_push(&rt->evlog, ev))"]
[79.231382, "o", "\r\n      return TB_ERR_OOM;\r\n  }\r\n\r\n  return TB_OK;\r\n}\r\n\r\n"]
[79.231509, "o", "\u001b[?2004h"]
[79.231529, "o", "root@e252228b7510:/app# "]
[79.331802, "i", "sed -n '1,360p' /app/include/logic/link.h\nsed -n '1,460p' /app/src/logic/link.c\n"]
[79.332069, "o", "sed -n '1,360p' /app/include/logic/link.h\r\n\u001b[?2004l\r"]
[79.333848, "o", "#pragma once\r\n\r\n#include \"tb_err.h\"\r\n#include \"runtime/runtime.h\"\r\n\r\ntb_status tb_link_detach(tb_rt *rt, uint32_t tick);\r\ntb_status tb_link_attach(tb_rt *rt, uint32_t tick);\r\n\r\n\u001b[?2004hroot@e252228b7510:/app# "]
[79.334011, "o", "sed -n '1,460p' /app/src/logic/link.c\r\n\u001b[?2004l\r"]
[79.335035, "o", "#include \"logic/link.h\"\r\n\r\n#include \"io/journal.h\"\r\n\r\n"]
[79.33506, "o", "#include <string.h>\r\n\r\ntb_status tb_link_detach(tb_rt *rt, uint32_t tick) {\r\n  (void)tick;\r\n  if (!rt)\r\n    return TB_ERR_BAD_ARG;\r\n  if (!rt->attached)\r\n"]
[79.335069, "o", "    return TB_OK;\r\n\r\n  rt->attached = false;\r\n\r\n"]
[79.335078, "o", "  tb_stamp s = {.gen = rt->gen, .cursor = rt->cursor};\r\n  tb_status st = journal_append_stamp(rt->journal_path, s);\r\n  if (st != TB_OK)\r\n"]
[79.335086, "o", "    return st;\r\n\r\n"]
[79.3351, "o", "  // A \"device-side\" queue continues to exist while detached; the notifier doesn't.\r\n  tb_q64_clear(&rt->notify_q);\r\n"]
[79.335109, "o", "  return TB_OK;\r\n}\r\n\r\ntb_status tb_link_attach(tb_rt *rt, uint32_t tick) {\r\n  (void)tick;\r\n"]
[79.335117, "o", "  if (!rt)\r\n    return TB_ERR_BAD_ARG;\r\n  if (rt->attached)\r\n"]
[79.335125, "o", "    return TB_OK;\r\n\r\n"]
[79.335135, "o", "  tb_stamp last = {0};\r\n  bool found = false;\r\n  tb_status st = journal_load_last(rt->journal_path, &last, &found);\r\n"]
[79.335144, "o", "  if (st != TB_OK)\r\n"]
[79.335157, "o", "    return st;\r\n  if (found) {\r\n"]
[79.335165, "o", "    rt->gen = last.gen + 1;\r\n    rt->cursor = last.cursor;\r\n  }\r\n\r\n  rt->attached = true;\r\n"]
[79.335173, "o", "  return TB_OK;\r\n}\r\n"]
[79.335184, "o", "\r\n"]
[79.335587, "o", "\u001b[?2004hroot@e252228b7510:/app# "]
[79.452852, "i", "sed -n '1,360p' /app/include/logic/merge.h\nsed -n '1,520p' /app/src/logic/merge.c\n"]
[79.453105, "o", "sed -n '1,360p' /app/include/logic/merge.h"]
[79.453198, "o", "\r\n"]
[79.453268, "o", "\u001b[?2004l\r"]
[79.454567, "o", "#pragma once\r\n"]
[79.454683, "o", "\r\n"]
[79.454753, "o", "#include \"tb_err.h\"\r\n"]
[79.454819, "o", "#include \"runtime/runtime.h\"\r\n"]
[79.454881, "o", "\r\n"]
[79.454949, "o", "tb_status tb_merge_drain(tb_rt *rt, uint32_t tick, tb_order ord);\r\n"]
[79.455029, "o", "\r\n"]
[79.455272, "o", "\u001b[?2004h"]
[79.455353, "o", "root@e252228b7510:/app# "]
[79.45558, "o", "sed -n '1,520p' /app/src/logic/merge.c\r\n\u001b[?2004l\r"]
[79.45654, "o", "#include \"logic/merge.h\"\r\n"]
[79.456622, "o", "\r\n"]
[79.456679, "o", "#include \"core/ev.h\"\r\n"]
[79.457, "o", "\r\nstatic bool drain_one(tb_rt *rt, tb_q64 *q, uint32_t tick) {\r\n  (void)tick;\r\n  uint64_t token = 0;\r\n  if (!tb_q64_pop(q, &token))\r\n    return false;\r\n\r\n  uint64_t key = (uint32_t)token;\r\n\r\n  if (!tb_map_u64_has(&rt->token_done, key)) {\r\n    uint64_t id64 = 0;\r\n    if (!tb_map_u64_get(&rt->token_to_id, token, &id64)) {\r\n      return true;\r\n"]
[79.457187, "o", "    }\r\n    (void)tb_map_u64_put(&rt->token_done, key, 1);\r\n    tb_event ev = {.kind = TB_EV_DONE, .id = (uint32_t)id64};\r\n    (void)tb_vec_ev_push(&rt->evlog, ev);\r\n  }\r\n  return true;\r\n}\r\n\r\ntb_status tb_merge_drain(tb_rt *rt, uint32_t tick, tb_order ord) {\r\n  if (!rt)\r\n    return TB_ERR_BAD_ARG;\r\n\r\n  tb_q64 *a = &rt->done_a;\r\n  tb_q64 *b = &rt->done_b;\r\n\r\n  if (ord == TB_ORDER_A_THEN_B) {\r\n    while (drain_one(rt, a, tick)) {\r\n    }\r\n    while (drain_one(rt, b, tick)) {\r\n    }\r\n  } else {\r\n    while (drain_one(rt, b, tick)) {\r\n    }\r\n    while (drain_one(rt, a, tick)) {\r\n    }\r\n  }\r\n\r\n  return TB_OK;\r\n}\r\n\u001b[?2004h"]
[79.457279, "o", "root@e252228b7510:/app# "]
[79.564146, "i", "sed -n '1,360p' /app/include/logic/nudge.h\nsed -n '1,420p' /app/src/logic/nudge.c\n"]
[79.564939, "o", "sed -n '1,360p' /app/include/logic/nudge.h\r\n\u001b[?2004l\r"]
[79.56574, "o", "#pragma once\r\n\r\n#include \"tb_err.h\"\r\n#include \"runtime/runtime.h\"\r\n\r\ntb_status tb_nudge_drain(tb_rt *rt, uint32_t tick);\r\n"]
[79.567631, "o", "\r\n\u001b[?2004hroot@e252228b7510:/app# sed -n '1,420p' /app/src/logic/nudge.c\r\n\u001b[?2004l\r#include \"logic/nudge.h\"\r\n"]
[79.567795, "o", "\r\n#include \"core/ev.h\"\r\n\r\ntb_status tb_nudge_drain(tb_rt *rt, uint32_t tick) {\r\n  (void)tick;\r\n  if (!rt)\r\n    return TB_ERR_BAD_ARG;\r\n\r\n  uint64_t token = 0;\r\n  while (tb_q64_pop(&rt->notify_q, &token)) {\r\n    uint64_t key = (uint32_t)token;\r\n    if (!tb_map_u64_has(&rt->token_done, key)) {\r\n      continue;\r\n    }\r\n    uint64_t id64 = 0;\r\n    if (!tb_map_u64_get(&rt->token_to_id, token, &id64))\r\n      continue;\r\n    tb_event ev = {.kind = TB_EV_POKE, .id = (uint32_t)id64};\r\n    (void)tb_vec_ev_push(&rt->evlog, ev);\r\n  }\r\n  return TB_OK;\r\n}\r\n"]
[79.567868, "o", "\u001b[?2004h"]
[79.567888, "o", "root@e252228b7510:/app# "]
[79.676252, "i", "sed -n '1,360p' /app/include/logic/settle.h\nsed -n '1,520p' /app/src/logic/settle.c\n"]
[79.676508, "o", "sed -n '1,360p' /app/include/logic/settle.h\r\n\u001b[?2004l\r"]
[79.679296, "o", "#pragma once\r\n\r\n#include \"tb_err.h\"\r\n#include \"runtime/runtime.h\"\r\n\r\ntb_status tb_settle_tick(tb_rt *rt, uint32_t tick);\r\n\r\n"]
[79.679496, "o", "\u001b[?2004h"]
[79.67952, "o", "root@e252228b7510:/app# "]
[79.679699, "o", "sed -n '1,520p' /app/src/logic/settle.c\r\n\u001b[?2004l\r"]
[79.680483, "o", "#include \"logic/settle.h\"\r\n\r\n#include \"runtime/runtime.h\"\r\n"]
[79.680508, "o", "\r\n// Deterministic \"work takes time\": only move certain tokens each tick.\r\nstatic bool ready(uint64_t token, uint32_t tick) {\r\n  // spread completion across ticks, but deterministic and input-dependent\r\n  return (((uint32_t)token) ^ tick) % 3 == 0;\r\n}\r\n\r\nstatic bool lane_a(uint64_t token, uint32_t tick) {\r\n"]
[79.680517, "o", "  // Choose which completion source produced the \"done\" record.\r\n  return ((((uint32_t)(token >> 32)) + (uint32_t)token + tick) & 1u) == 0u;\r\n}\r\n"]
[79.680527, "o", "\r\ntb_status tb_settle_tick(tb_rt *rt, uint32_t tick) {\r\n  if (!rt)\r\n    return TB_ERR_BAD_ARG;\r\n"]
[79.680539, "o", "\r\n  // rotate through at most a bounded number so runs are stable\r\n"]
[79.680548, "o", "  size_t spins = rt->in_q.len;\r\n  for (size_t i = 0; i < spins; i++) {\r\n    uint64_t token = 0;\r\n"]
[79.680557, "o", "    if (!tb_q64_pop(&rt->in_q, &token))\r\n      break;\r\n\r\n"]
[79.680568, "o", "    if (ready(token, tick)) {\r\n      if (lane_a(token, tick)) {\r\n        if (!tb_q64_push(&rt->done_a, token))\r\n"]
[79.680578, "o", "          return TB_ERR_CORRUPT;\r\n      } else {\r\n        if (!tb_q64_push(&rt->done_b, token))\r\n"]
[79.680587, "o", "          return TB_ERR_CORRUPT;\r\n      }\r\n      if (rt->attached) {\r\n"]
[79.680597, "o", "        // The notifier is only live while attached.\r\n        if (!tb_q64_push(&rt->notify_q, token))\r\n          return TB_ERR_CORRUPT;\r\n"]
[79.680745, "o", "      }\r\n    } else {\r\n      // not ready, requeue at tail\r\n"]
[79.680812, "o", "      if (!tb_q64_push(&rt->in_q, token))\r\n        return TB_ERR_CORRUPT;\r\n    }\r\n  }\r\n\r\n  return TB_OK;\r\n}\r\n\r\n"]
[79.680833, "o", "\u001b[?2004hroot@e252228b7510:/app# "]
[79.784807, "i", "apply_patch <<'PATCH'\n*** Begin Patch\n*** Update File: /app/src/io/journal.c\n@@\n static tb_status append_rec(FILE *f, tb_stamp s) {\n   if (!fs_write_u32(f, s.gen))\n     return TB_ERR_IO;\n-\n-  uint32_t lo = (uint32_t)s.cursor;\n-  if (!fs_write_u32(f, lo))\n-    return TB_ERR_IO;\n+\n+  // Cursor is a full 64-bit value.\n+  uint32_t lo = (uint32_t)(s.cursor & 0xffffffffu);\n+  uint32_t hi = (uint32_t)((s.cursor >> 32) & 0xffffffffu);\n+  if (!fs_write_u32(f, lo))\n+    return TB_ERR_IO;\n+  if (!fs_write_u32(f, hi))\n+    return TB_ERR_IO;\n@@\n static bool read_rec(FILE *f, tb_stamp *out) {\n   uint32_t gen = 0;\n   if (!fs_read_u32(f, &gen))\n     return false;\n@@\n   uint32_t lo = 0;\n   if (!fs_read_u32(f, &lo))\n     return false;\n+\n+  uint32_t hi = 0;\n+  if (!fs_read_u32(f, &hi))\n+    return false;\n@@\n   out->gen = gen;\n-  out->cursor = (uint64_t)lo;\n+  out->cursor = ((uint64_t)hi << 32) | (uint64_t)lo;\n   return true;\n }\n*** End Patch\nPATCH\n"]
[79.784859, "o", "apply_patch <<'PATCH'"]
