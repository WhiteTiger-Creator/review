[37.072542, "i", "python3 - <<'PY'\nimport json\np='/app/output/report.json'\nwith open(p) as f: r=json.load(f)\nev=r['events']\nseen=set(); kinds={}\nids=set(); subs=[]\nlast_submit=0\nbad=[]\nfor i,e in enumerate(ev):\n    k=e['kind']; id=e['id']\n    if (k,id) in seen: bad.append(('dup',(k,id),i));\n    seen.add((k,id))\n    kinds.setdefault(id,[]).append(k)\n    if k=='submit': subs.append(id)\nfor id,ks in sorted(kinds.items()):\n    if ks.count('submit')!=1 or ks.count('complete')!=1 or ks.count('notify')!=1:\n        bad.append(('counts',id,ks))\n# ordering within log\npos={(e['kind'],e['id']):i for i,e in enumerate(ev)}\nfor id in kinds:\n    if pos[('submit',id)]>pos[('complete',id)] or pos[('complete',id)]>pos[('notify',id)]:\n        bad.append(('order',id,(pos[('submit',id)],pos[('complete',id)],pos[('notify',id)])))\n# contiguous ids\nif subs:\n    if subs!=list(range(1,len(subs)+1)):\n        bad.append(('id_sequence',subs[:20],len(subs)))\nprint('events',len(ev),'submits',len(subs),'maxid',max(subs) if subs else None)\nprint('bad',bad[:20]"]
[37.072594, "i", ")\nPY\n"]
