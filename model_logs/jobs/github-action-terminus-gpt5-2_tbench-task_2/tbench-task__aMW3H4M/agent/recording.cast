[62.40715, "o", "#pragma once\r\n\r\n#include <stdint.h>\r\n\r\ntypedef struct {\r\n  uint64_t x;\r\n} tb_idgen;\r\n\r\nvoid tb_idgen_init(tb_idgen *g, uint64_t seed);\r\n"]
[62.407333, "o", "uint64_t tb_idgen_next(tb_idgen *g);\r\n\r\n"]
[62.40737, "o", "\u001b[?2004hroot@e252228b7510:/app# "]
[62.407534, "o", "sed -n '1,220p' /app/src/core/idgen.c\r\n\u001b[?2004l\r"]
[62.408478, "o", "#include \"core/idgen.h\"\r\n\r\nvoid tb_idgen_init(tb_idgen *g, uint64_t seed) { g->x = seed ? seed : 0x9e3779b97f4a7c15ULL; }\r\n\r\nuint64_t tb_idgen_next(tb_idgen *g) {\r\n  // xorshift64*\r\n"]
[62.408499, "o", "  uint64_t x = g->x;\r\n  x ^= x >> 12;\r\n  x ^= x << 25;\r\n  x ^= x >> 27;\r\n  g->x = x;\r\n  return x * 2685821657736338717ULL;\r\n}\r\n"]
