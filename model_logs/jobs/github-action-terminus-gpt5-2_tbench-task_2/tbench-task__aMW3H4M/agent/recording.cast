[62.516606, "o", "\r\n"]
[62.516678, "o", "\u001b[?2004l\r"]
[62.517471, "o", "#pragma once\r\n\r\n#include \"tb_err.h\"\r\n\r\n"]
[62.5175, "o", "#include <stdbool.h>\r\n#include <stdint.h>\r\n\r\ntypedef struct {\r\n  uint32_t gen;\r\n  uint64_t cursor;\r\n} tb_stamp;\r\n\r\ntb_status journal_append_stamp(const char *path, tb_stamp s);\r\ntb_status journal_load_last(const char *path, tb_stamp *out, bool *found);\r\n"]
[62.517513, "o", "\r\n"]
[62.517854, "o", "\u001b[?2004h"]
[62.517959, "o", "root@e252228b7510:/app# "]
[62.518087, "o", "sed -n '1,360p' /app/src/io/journal.c\r\n\u001b[?2004l\r"]
[62.518954, "o", "#include \"io/journal.h\"\r\n\r\n#include \"io/fs.h\"\r\n\r\n"]
[62.519037, "o", "#include <errno.h>\r\n#include <stdio.h>\r\n"]
[62.519058, "o", "\r\nstatic tb_status append_rec(FILE *f, tb_stamp s) {\r\n  if (!fs_write_u32(f, s.gen))\r\n    return TB_ERR_IO;\r\n\r\n  uint32_t lo = (uint32_t)s.cursor;\r\n  if (!fs_write_u32(f, lo))\r\n    return TB_ERR_IO;\r\n\r\n  return TB_OK;\r\n}\r\n\r\n"]
[62.519074, "o", "static bool read_rec(FILE *f, tb_stamp *out) {\r\n  uint32_t gen = 0;\r\n  if (!fs_read_u32(f, &gen))\r\n    return false;\r\n\r\n  uint32_t lo = 0;\r\n  if (!fs_read_u32(f, &lo))\r\n    return false;\r\n\r\n  out->gen = gen;\r\n  out->cursor = (uint64_t)lo;\r\n"]
[62.519083, "o", "  return true;\r\n}\r\n\r\n"]
[62.519093, "o", "tb_status journal_append_stamp(const char *path, tb_stamp s) {\r\n  FILE *f = fopen(path, \"ab\");\r\n  if (!f)\r\n"]
[62.519103, "o", "    return TB_ERR_IO;\r\n  tb_status st = append_rec(f, s);\r\n  if (fclose(f) != 0)"]
[62.519115, "o", "\r\n"]
[62.519348, "o", "    return TB_ERR_IO;\r\n  return st;\r\n}\r\n\r\ntb_status journal_load_last(const char *path, tb_stamp *out, bool *found) {\r\n  if (!out || !found)\r\n    return TB_ERR_BAD_ARG;\r\n\r\n  FILE *f = fopen(path, \"rb\");\r\n  if (!f) {\r\n    if (errno == ENOENT) {\r\n      *found = false;\r\n      return TB_OK;\r\n    }\r\n    return TB_ERR_IO;\r\n  }\r\n\r\n  tb_stamp cur = {0};\r\n  bool any = false;\r\n  while (read_rec(f, &cur)) {\r\n    any = true;\r\n  }\r\n  fclose(f);\r\n  if (!any) {\r\n    *found = false;\r\n    return TB_OK;\r\n  }\r\n  *found = true;\r\n"]
[62.519488, "o", "  *out = cur;\r\n  return TB_OK;\r\n}\r\n"]
[62.519985, "o", "\u001b[?2004hroot@e252228b7510:/app# "]
[62.624245, "i", "sed -n '1,260p' /app/include/runtime/runtime.h\nsed -n '1,420p' /app/src/runtime/runtime.c\n"]
[62.624489, "o", "sed -n '1,260p' /app/include/runtime/runtime.h"]
[62.624707, "o", "\r\n\u001b[?2004l\r"]
[62.625818, "o", "#pragma once\r\n"]
[62.625913, "o", "\r\n#include \"core/ev.h\"\r\n#include \"core/map_u64.h\"\r\n#include \"core/queue.h\"\r\n#include \"core/vec_ev.h\"\r\n#include \"io/journal.h\"\r\n#include \"runtime/profile.h\"\r\n"]
[62.62613, "o", "#include \"runtime/script.h\"\r\n#include \"tb_err.h\"\r\n\r\n#include <stdbool.h>\r\n#include <stdint.h>\r\n\r\ntypedef enum {\r\n  TB_ORDER_A_THEN_B = 1,\r\n  TB_ORDER_B_THEN_A = 2,\r\n} tb_order;\r\n\r\ntb_order tb_order_parse(const char *s);\r\nconst char *tb_order_str(tb_order o);\r\n\r\ntypedef struct {\r\n  // \"in-flight\" handles are 64-bit tokens; external ids are stable u32.\r\n  tb_map_u64 token_to_id; // token -> id\r\n  tb_map_u64 token_done;  // canonical done-set, key depends on reconciliation\r\n"]
[62.626206, "o", "\r\n  tb_q64 in_q;\r\n  tb_q64 done_a;\r\n  tb_q64 done_b;\r\n  tb_q64 notify_q;\r\n\r\n  tb_vec_ev evlog;\r\n\r\n  uint32_t gen;\r\n  uint64_t cursor;\r\n  bool attached;\r\n\r\n  const char *journal_path;\r\n} tb_rt;\r\n\r\ntb_status tb_rt_init(tb_rt *rt, const char *journal_path);\r\nvoid tb_rt_free(tb_rt *rt);\r\n\r\ntb_status tb_rt_run(tb_rt *rt, tb_scenario scn, tb_profile prof, tb_order ord, uint32_t seed);\r\n\r\n// report extraction\r\nconst tb_vec_ev *tb_rt_events(const tb_rt *rt);\r\n\r\n"]
[62.62645, "o", "\u001b[?2004hroot@e252228b7510:/app# sed -n '1,420p' /app/src/runtime/runtime.c"]
[62.62652, "o", "\r\n\u001b[?2004l\r"]
[62.627428, "o", "#include \"runtime/runtime.h\"\r\n\r\n#include \"core/idgen.h\"\r\n#include \"logic/ingest.h\"\r\n#include \"logic/link.h\"\r\n#include \"logic/merge.h\"\r\n#include \"logic/nudge.h\""]
[62.627455, "o", "\r\n#include \"logic/settle.h\"\r\n\r\n#include <stdio.h>\r\n#include <string.h>\r\n\r\ntb_status tb_rt_init(tb_rt *rt, const char *journal_path) {\r\n  if (!rt || !journal_path)\r\n    return TB_ERR_BAD_ARG;\r\n  memset(rt, 0, sizeof(*rt));\r\n"]
[62.627465, "o", "\r\n"]
[62.627477, "o", "  if (!tb_map_u64_init(&rt->token_to_id, 128))\r\n    return TB_ERR_OOM;\r\n  if (!tb_map_u64_init(&rt->token_done, 128))\r\n    return TB_ERR_OOM;\r\n"]
[62.627487, "o", "  if (!tb_q64_init(&rt->in_q, 4096))\r\n    return TB_ERR_OOM;\r\n  if (!tb_q64_init(&rt->done_a, 4096))\r\n"]
[62.627498, "o", "    return TB_ERR_OOM;\r\n  if (!tb_q64_init(&rt->done_b, 4096))\r\n    return TB_ERR_OOM;\r\n  if (!tb_q64_init(&rt->notify_q, 4096))\r\n"]
[62.627509, "o", "    return TB_ERR_OOM;\r\n  if (!tb_vec_ev_init(&rt->evlog, 2048))\r\n    return TB_ERR_OOM;\r\n"]
[62.627521, "o", "\r\n  rt->gen = 1;\r\n  rt->cursor = 1;\r\n  rt->attached = true;\r\n"]
[62.62753, "o", "  rt->journal_path = journal_path;\r\n  return TB_OK;\r\n}\r\n"]
[62.627539, "o", "\r\nvoid tb_rt_free(tb_rt *rt) {\r\n  if (!rt)\r\n    return;\r\n"]
[62.627548, "o", "  tb_map_u64_free(&rt->token_to_id);\r\n  tb_map_u64_free(&rt->token_done);\r\n  tb_q64_free(&rt->in_q);\r\n"]
[62.627563, "o", "  tb_q64_free(&rt->done_a);\r\n  tb_q64_free(&rt->done_b);\r\n  tb_q64_free(&rt->notify_q);\r\n  tb_vec_ev_free(&rt->evlog);\r\n}"]
[62.627574, "o", "\r\n\r\nconst tb_vec_ev *tb_rt_events(const tb_rt *rt) { return &rt->evlog; }\r\n\r\n"]
[62.627588, "o", "static tb_status maybe_detach_attach(tb_rt *rt, const tb_script *sc, uint32_t tick) {\r\n  if (sc->detach_at && tick == sc->detach_at) {\r\n    return tb_link_detach(rt, tick);\r\n  }"]
[62.627602, "o", "\r\n  if (sc->detach_at && tick == sc->detach_at + sc->detach_len) {\r\n    return tb_link_attach(rt, tick);\r\n  }\r\n"]
[62.627612, "o", "  if (sc->detach2_at && tick == sc->detach2_at) {\r\n    return tb_link_detach(rt, tick);\r\n  }\r\n  if (sc->detach2_at && tick == sc->detach2_at + sc->detach2_len) {\r\n"]
[62.627623, "o", "    return tb_link_attach(rt, tick);\r\n  }\r\n  return TB_OK;\r\n"]
[62.627633, "o", "}\r\n\r\ntb_status tb_rt_run(tb_rt *rt, tb_scenario scn, tb_profile prof, tb_order ord, uint32_t seed) {\r\n"]
[62.627642, "o", "  (void)seed;\r\n  if (!rt)\r\n    return TB_ERR_BAD_ARG;\r\n"]
[62.627653, "o", "\r\n  tb_script sc = {0};\r\n  if (!tb_script_for(scn, &sc))\r\n"]
[62.627661, "o", "    return TB_ERR_BAD_ARG;\r\n\r\n  tb_stamp last = {0};\r\n"]
[62.627671, "o", "  bool found = false;\r\n  tb_status st = journal_load_last(rt->journal_path, &last, &found);\r\n  if (st != TB_OK)\r\n"]
[62.627686, "o", "    return st;\r\n  if (found) {\r\n    rt->gen = last.gen + 1;\r\n    rt->cursor = last.cursor;\r\n"]
[62.627695, "o", "  }\r\n\r\n  for (uint32_t tick = 0; tick < sc.ticks; tick++) {\r\n    st = maybe_detach_attach(rt, &sc, tick);\r\n"]
[62.627704, "o", "    if (st != TB_OK)\r\n      return st;\r\n\r\n"]
[62.627717, "o", "    uint32_t submitted = 0;\r\n    st = tb_ingest_tick(rt, prof, tick, &submitted);\r\n    if (st != TB_OK)\r\n      return st;\r\n\r\n"]
[62.627728, "o", "    st = tb_settle_tick(rt, tick);\r\n    if (st != TB_OK)\r\n      return st;\r\n\r\n"]
[62.627739, "o", "    st = tb_merge_drain(rt, tick, ord);\r\n    if (st != TB_OK)\r\n      return st;\r\n"]
[62.627753, "o", "\r\n    st = tb_nudge_drain(rt, tick);\r\n    if (st != TB_OK)\r\n      return st;\r\n  }"]
[62.627764, "o", "\r\n\r\n  // Final drain to avoid leaving work in queues.\r\n  for (uint32_t i = 0; i < 16; i++) {\r\n"]
[62.627773, "o", "    st = tb_settle_tick(rt, sc.ticks + i);\r\n    if (st != TB_OK)\r\n      return st;\r\n"]
[62.627785, "o", "    st = tb_merge_drain(rt, sc.ticks + i, ord);\r\n    if (st != TB_OK)\r\n      return st;\r\n"]
[62.627795, "o", "    st = tb_nudge_drain(rt, sc.ticks + i);\r\n    if (st != TB_OK)\r\n      return st;\r\n  }\r\n"]
[62.62781, "o", "\r\n  return TB_OK;\r\n}\r\n\r\n"]
[62.628273, "o", "\u001b[?2004hroot@e252228b7510:/app# "]
[62.732262, "i", "sed -n '1,260p' /app/include/runtime/script.h\nsed -n '1,420p' /app/src/runtime/script.c\n"]
[62.73262, "o", "sed -n '1,260p' /app/include/runtime/script.h\r\n\u001b[?2004l\r"]
[62.735071, "o", "#pragma once\r\n\r\n#include <stdbool.h>\r\n#include <stdint.h>\r\n\r\ntypedef enum {\r\n"]
[62.73519, "o", "  TB_SCN_BASIC = 1,\r\n  TB_SCN_STRESS = 2,\r\n  TB_SCN_STRESS2 = 3,\r\n} tb_scenario;\r\n\r\ntb_scenario tb_scenario_parse(const char *s);\r\nconst char *tb_scenario_str(tb_scenario scn);\r\n\r\n"]
[62.735274, "o", "typedef struct {\r\n"]
[62.735331, "o", "  uint32_t ticks;\r\n  uint32_t detach_at;   // 0 means never\r\n  uint32_t detach_len;  // number of ticks detached\r\n  uint32_t detach2_at;  // optional second detach\r\n"]
[62.735348, "o", "  uint32_t detach2_len;\r\n} tb_script;\r\n\r\n"]
[62.735356, "o", "bool tb_script_for(tb_scenario scn, tb_script *out);\r\n"]
[62.73538, "o", "\r\n"]
[62.735628, "o", "\u001b[?2004h"]
[62.735651, "o", "root@e252228b7510:/app# "]
[62.735872, "o", "sed -n '1,420p' /app/src/runtime/script.c\r\n\u001b[?2004l\r"]
[62.736719, "o", "#include \"runtime/script.h\"\r\n\r\n#include <string.h>\r\n\r\ntb_scenario tb_scenario_parse(const char *s) {\r\n  if (!s)\r\n    return 0;\r\n"]
[62.736742, "o", "  if (strcmp(s, \"basic\") == 0)\r\n    return TB_SCN_BASIC;\r\n  if (strcmp(s, \"stress\") == 0)\r\n    return TB_SCN_STRESS;\r\n  if (strcmp(s, \"stress2\") == 0)\r\n    return TB_SCN_STRESS2;\r\n  return 0;\r\n}\r\n"]
[62.736755, "o", "\r\n"]
[62.736764, "o", "const char *tb_scenario_str(tb_scenario scn) {\r\n  switch (scn) {\r\n"]
[62.736772, "o", "  case TB_SCN_BASIC:\r\n"]
[62.736783, "o", "    return \"basic\";\r\n"]
[62.736794, "o", "  case TB_SCN_STRESS:\r\n    return \"stress\";\r\n"]
[62.736802, "o", "  case TB_SCN_STRESS2:\r\n"]
[62.73681, "o", "    return \"stress2\";\r\n"]
[62.736819, "o", "  default:\r\n"]
[62.73683, "o", "    return \"unknown\";\r\n"]
[62.736839, "o", "  }\r\n}\r\n"]
[62.736887, "o", "\r\n"]
[62.737106, "o", "bool tb_script_for(tb_scenario scn, tb_script *out) {\r\n  if (!out)\r\n"]
[62.737243, "o", "    return false;\r\n  tb_script s = {0};\r\n  switch (scn) {\r\n  case TB_SCN_BASIC:\r\n    s.ticks = 40;"]
[62.737305, "o", "\r\n"]
[62.737448, "o", "    s.detach_at = 0;\r\n    s.detach_len = 0;\r\n    s.detach2_at = 0;\r\n    s.detach2_len = 0;\r\n    break;\r\n"]
[62.737575, "o", "  case TB_SCN_STRESS:\r\n    s.ticks = 80;\r\n    s.detach_at = 22;\r\n    s.detach_len = 10;\r\n    s.detach2_at = 0;\r\n    s.detach2_len = 0;\r\n    break;\r\n  case TB_SCN_STRESS2:\r\n    s.ticks = 110;\r\n    s.detach_at = 26;\r\n    s.detach_len = 10;\r\n    s.detach2_at = 68;\r\n    s.detach2_len = 12;\r\n    break;\r\n  default:\r\n    return false;\r\n  }\r\n  *out = s;\r\n  return true;\r\n}\r\n\r\n"]
[62.737648, "o", "\u001b[?2004h"]
