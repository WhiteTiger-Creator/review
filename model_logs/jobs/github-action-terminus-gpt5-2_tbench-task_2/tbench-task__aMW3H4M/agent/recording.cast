[50.800575, "i", "python3 - <<'PY'\nimport json\np='/app/output/report.json'\nr=json.load(open(p))\nev=r['events']\nseen=set(); kinds={}; subs=[]; bad=[]\nfor i,e in enumerate(ev):\n    k=e['kind']; id=e['id']\n    if (k,id) in seen: bad.append(('dup',(k,id),i))\n    seen.add((k,id))\n    kinds.setdefault(id,[]).append(k)\n    if k=='submit': subs.append(id)\n# per-id counts\nfor id,ks in sorted(kinds.items()):\n    if ks.count('submit')!=1 or ks.count('complete')!=1 or ks.count('notify')!=1:\n        bad.append(('counts',id,ks))\n# ordering constraints\npos={(e['kind'],e['id']):i for i,e in enumerate(ev)}\nfor id in kinds:\n    if pos.get(('submit',id),10**9) > pos.get(('complete',id),-1) or pos.get(('complete',id),10**9) > pos.get(('notify',id),-1):\n        bad.append(('order',id,(pos.get(('submit',id)),pos.get(('complete',id)),pos.get(('notify',id)))))\n# contiguous submit ids\nif subs and subs!=list(range(1,len(subs)+1)):\n    bad.append(('id_sequence',subs[:30],len(subs)))\nprint('events',len(ev),'submits',len(subs),'maxid',max(subs) if subs el"]
[50.80558, "i", "se None)\nprint('first20',ev[:20])\nprint('bad_count',len(bad))\nprint('bad_first',bad[:20])\nPY\n"]
