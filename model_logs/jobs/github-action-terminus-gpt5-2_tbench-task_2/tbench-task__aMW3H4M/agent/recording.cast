[62.840154, "i", "python3 - <<'PY'\nimport json\np='/app/output/report.json'\nev=json.load(open(p))['events']\n# find first duplicate (kind,id)\nseen=set()\nfor i,e in enumerate(ev):\n    k=(e['kind'],e['id'])\n    if k in seen:\n        start=max(0,i-20); end=min(len(ev),i+20)\n        print('first_dup_at',i,'dup',k,'window',start,end)\n        for j in range(start,end):\n            print(j,ev[j])\n        break\n    seen.add(k)\nPY\n"]
