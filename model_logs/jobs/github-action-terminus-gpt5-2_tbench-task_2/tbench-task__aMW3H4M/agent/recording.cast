[211.344706, "i", "python3 - <<'PY'\nimport json, subprocess, os, hashlib\n\ndef run(scn, prof, ord_, out):\n    subprocess.check_call(['/usr/local/bin/arena','--scenario',scn,'--profile',prof,'--order',ord_,'--out',out])\n    r=json.load(open(out))\n    return r\n\ndef inv_check(r):\n    ev=r['events']\n    seen=set(); kinds={}; subs=[]\n    for i,e in enumerate(ev):\n        k=e['kind']; id=e['id']\n        if (k,id) in seen:\n            return False, f'dup {(k,id)}'\n        seen.add((k,id))\n        kinds.setdefault(id,[]).append(k)\n        if k=='submit': subs.append(id)\n    if subs!=list(range(1,len(subs)+1)):\n        return False, 'id_sequence'\n    for id,ks in kinds.items():\n        if ks.count('submit')!=1 or ks.count('complete')!=1 or ks.count('notify')!=1:\n            return False, f'counts {id} {ks}'\n    pos={(e['kind'],e['id']):i for i,e in enumerate(ev)}\n    for id in kinds:\n        if pos[('submit',id)]>pos[('complete',id)] or pos[('complete',id)]>pos[('notify',id)]:\n            return False, f'order {id}'\n    return True, f'ok"]
[211.344866, "i", " submits={len(subs)}'\n\ndef digest(path):\n    h=hashlib.sha256()\n    h.update(open(path,'rb').read())\n    return h.hexdigest()\n\nscenarios=['basic','stress','stress2']\nprofiles=['burst','steady']\norders=['a_then_b','b_then_a']\n\nfor scn in scenarios:\n  for prof in profiles:\n    for ord_ in orders:\n      out=f'/app/output/tmp_{scn}_{prof}_{ord_}.json'\n      r=run(scn,prof,ord_,out)\n      ok,msg=inv_check(r)\n      print(scn,prof,ord_,'inv',ok,msg,'events',len(r['events']))\n\n# determinism: same flags twice should be byte-identical\nout1='/app/output/tmp_det1.json'\nout2='/app/output/tmp_det2.json'\nsubprocess.check_call(['/usr/local/bin/arena','--scenario','stress2','--profile','burst','--order','a_then_b','--out',out1,'--seed','1'])\nsubprocess.check_call(['/usr/local/bin/arena','--scenario','stress2','--profile','burst','--order','a_then_b','--out',out2,'--seed','1'])\nprint('determinism_same',digest(out1)==digest(out2))\n\n# order should change sequence but keep id coverage\nouta='/app/output/tmp_ord_a.json'\noutb='/app/"]
[211.344948, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r\u001b[?2004h"]
[211.344988, "i", "output/tmp_ord_b.json'\nsubprocess.check_call(['/usr/local/bin/arena','--scenario','stress2','--profile','burst','--order','a_then_b','--out',outa])\nsubprocess.check_call(['/usr/local/bin/arena','--scenario','stress2','--profile','burst','--order','b_then_a','--out',outb])\nra=json.load(open(outa)); rb=json.load(open(outb))\nidsa=[e['id'] for e in ra['events'] if e['kind']=='submit']\nidsb=[e['id'] for e in rb['events'] if e['kind']=='submit']\nprint('order_same_id_coverage',idsa==idsb,'sequence_diff',open(outa,'rb').read()!=open(outb,'rb').read())\nPY\n"]
