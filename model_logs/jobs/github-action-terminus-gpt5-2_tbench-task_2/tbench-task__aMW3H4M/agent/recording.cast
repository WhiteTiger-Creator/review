[140.316204, "i", "perl -0777 -i -pe 's/while \\(tb_q64_pop\\(&rt->notify_q, &token\\)\\) \\{\\n    uint64_t key = token;\\n/while (tb_q64_pop(&rt->notify_q, &token)) {\\n    uint64_t key = token;\\n    if (!rt->attached) {\\n      \\/\\/ notifier offline; keep token queued for later delivery\\n      (void)tb_q64_push(&rt->notify_q, token);\\n      break;\\n    }\\n/s' /app/src/logic/nudge.c\n"]
[140.317639, "o", "perl -0777 -i -pe 's/while \\(tb_q64_pop\\(&rt->notify_q, &token\\)\\) \\{\\n    uint64_t key = token;\\n/while (tb_q64_pop(&rt->notify_q, &token)) {\\n    uint64_t key = token;\\n    if (!rt->attached) {\\n      \\/\\/ notifier offline; keep token queued for later delivery\\n      (void)tb_q64_push(&rt->notify_q, token);\\n      break;\\n    }\\n/s' /app/src/logic/nudge.c\r\n"]
