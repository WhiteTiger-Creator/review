[193.168622, "i", "rm -f /app/output/report.json /app/output/report_b.json /app/run/state.bin\n/usr/local/bin/arena --scenario stress2 --profile burst --order a_then_b --out /app/output/report.json\n/usr/local/bin/arena --scenario stress2 --profile burst --order b_then_a --out /app/output/report_b.json\npython3 - <<'PY'\nimport json\n\ndef check(p):\n    r=json.load(open(p))\n    ev=r['events']\n    seen=set(); kinds={}; subs=[]; bad=[]\n    for i,e in enumerate(ev):\n        k=e['kind']; id=e['id']\n        if (k,id) in seen: bad.append(('dup',(k,id),i))\n        seen.add((k,id))\n        kinds.setdefault(id,[]).append(k)\n        if k=='submit': subs.append(id)\n    for id,ks in kinds.items():\n        if ks.count('submit')!=1 or ks.count('complete')!=1 or ks.count('notify')!=1:\n            bad.append(('counts',id,ks))\n    pos={(e['kind'],e['id']):i for i,e in enumerate(ev)}\n    for id in kinds:\n        if pos.get(('submit',id),10**9) > pos.get(('complete',id),-1) or pos.get(('complete',id),10**9) > pos.get(('notify',id),-1):\n            bad."]
[193.168669, "i", "append(('order',id,(pos.get(('submit',id)),pos.get(('complete',id)),pos.get(('notify',id)))))\n    if subs and subs!=list(range(1,len(subs)+1)):\n        bad.append(('id_sequence',subs[:30],len(subs),max(subs)))\n    return len(ev), len(subs), (max(subs) if subs else None), bad[:10], len(bad)\n\nfor p in ['/app/output/report.json','/app/output/report_b.json']:\n    evn,sn,mx,bad10,nb=check(p)\n    print(p,'events',evn,'submits',sn,'maxid',mx,'bad',nb)\n    if nb:\n        print('bad_first',bad10)\nPY\n"]
