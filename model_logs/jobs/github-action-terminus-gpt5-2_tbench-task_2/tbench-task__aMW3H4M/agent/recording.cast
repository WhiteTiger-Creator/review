[183.060633, "o", "\u001b[?2004h> "]
[183.060884, "o", "  // continue while detached, so rewinding would reuse ids and duplicate events.\r\n\u001b[?2004l\r"]
[183.06099, "o", "\u001b[?2004h>   tb_stamp last = {0};\r\n\u001b[?2004l\r"]
[183.061066, "o", "\u001b[?2004h> "]
[183.061142, "o", "  bool found = false;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[183.061341, "o", "  tb_status st = journal_load_last(rt->journal_path, &last, &found);\r\n\u001b[?2004l\r"]
[183.061438, "o", "\u001b[?2004h>   if (st != TB_OK)\r\n"]
[183.061513, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[183.061589, "o", "    return st;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[183.061659, "o", "  if (found) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[183.061769, "o", "    rt->gen = last.gen + 1;\r\n\u001b[?2004l\r"]
[183.061826, "o", "\u001b[?2004h> "]
[183.061989, "o", "    // Defensive: if something went backwards, clamp forward.\r\n\u001b[?2004l\r"]
[183.062052, "o", "\u001b[?2004h> "]
[183.062142, "o", "    if (rt->cursor < last.cursor)\r\n\u001b[?2004l\r"]
[183.06219, "o", "\u001b[?2004h> "]
[183.062288, "o", "      rt->cursor = last.cursor;\r\n\u001b[?2004l\r"]
[183.062335, "o", "\u001b[?2004h> "]
[183.062417, "o", "  }\r\n\u001b[?2004l\r\u001b[?2004h"]
[183.062457, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[183.062522, "o", "  rt->attached = true;\r\n\u001b[?2004l\r"]
[183.062563, "o", "\u001b[?2004h> "]
[183.062632, "o", "  return TB_OK;\r\n\u001b[?2004l\r"]
[183.062686, "o", "\u001b[?2004h"]
[183.062742, "o", "> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
