[203.698313, "o", "\u001b[?2004h"]
[203.698352, "o", "> "]
[203.698475, "o", "    size_t units_pos = doc.find(\"\\\"units\\\"\");\r\n\u001b[?2004l\r"]
[203.698524, "o", "\u001b[?2004h"]
[203.698559, "o", "> "]
[203.698673, "o", "    if (units_pos == std::string::npos) {\r\n\u001b[?2004l\r"]
[203.698713, "o", "\u001b[?2004h"]
[203.698742, "o", "> "]
[203.698811, "o", "        return state;\r\n\u001b[?2004l\r"]
[203.69886, "o", "\u001b[?2004h"]
[203.69892, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[203.698941, "o", "> "]
[203.699098, "o", "    size_t arr_start = doc.find('[', units_pos);\r\n"]
[203.699117, "o", "\u001b[?2004l\r"]
[203.699133, "o", "\u001b[?2004h"]
[203.699162, "o", "> "]
[203.699319, "o", "    size_t arr_end = doc.find(']', arr_start);\r\n\u001b[?2004l\r"]
[203.699369, "o", "\u001b[?2004h"]
[203.699404, "o", "> "]
[203.699609, "o", "    if (arr_start == std::string::npos || arr_end == std::string::npos) {\r\n\u001b[?2004l\r"]
[203.699647, "o", "\u001b[?2004h"]
[203.699676, "o", "> "]
