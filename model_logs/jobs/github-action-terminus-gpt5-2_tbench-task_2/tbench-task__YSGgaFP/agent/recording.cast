[203.697462, "o", "\u001b[?2004h"]
[203.697516, "o", "> "]
[203.697682, "o", "    state.lane_token = pick_string(doc, \"lane_token\");\r\n\u001b[?2004l\r"]
[203.697713, "o", "\u001b[?2004h"]
[203.697754, "o", "> "]
[203.697998, "o", "    if (!m14_checkpoint_valid(state.lane_token.c_str(), expected_token.c_str())) {\r\n\u001b[?2004l\r"]
[203.698037, "o", "\u001b[?2004h"]
[203.698067, "o", "> "]
