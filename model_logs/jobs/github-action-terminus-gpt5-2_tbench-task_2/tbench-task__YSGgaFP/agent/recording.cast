[203.711041, "o", "\u001b[?2004h> "]
[203.711382, "o", "        out << \"{\\\"name\\\":\\\"\" << entry.name << \"\\\",\\\"next_pass\\\":\" << entry.next_pass\r\n\u001b[?2004l\r"]
[203.711456, "o", "\u001b[?2004h> "]
[203.7117, "o", "            << \",\\\"carry_weight\\\":\" << entry.carry_weight << \",\\\"carry_drift\\\":\"\r\n\u001b[?2004l\r"]
[203.711774, "o", "\u001b[?2004h> "]
[203.711923, "o", "            << entry.carry_drift << '}';\r\n\u001b[?2004l\r"]
[203.712055, "o", "\u001b[?2004h> "]
