[206.784793, "i", "perl -0777 -i -pe 's/\\n\\s*int pass_index = spec\\.start_pass;\\s*int64_t seeded_weight = 0;.*?\\(void\\)carry_weight;\\n/\\n    int pass_index = spec.start_pass;\\n    bool resumed = false;\\n    if (run.mode == \"resume\" && checkpoint != nullptr && checkpoint->valid) {\\n        auto it = checkpoint->units.find(spec.name);\\n        if (it != checkpoint->units.end()) {\\n            pass_index = it->second.next_pass;\\n            carry_weight = it->second.carry_weight;\\n            resumed = true;\\n        }\\n    }\\n\\n    if (run.mode == \"resume\" && resumed) {\\n        run.order_weight = carry_weight + static_cast<int64_t>(order_weight_base) + run.record_bytes;\\n    } else {\\n        run.order_weight = static_cast<int64_t>(order_weight_base) * (order_rank + 1) + run.record_bytes;\\n    }\\n    (void)names;\\n    (void)name_count;\\n/sms' /app/environment/runner/emit_pipeline.cpp\n"]
[206.788471, "o", "perl -0777 -i -pe 's/\\n\\s*int pass_index = spec\\.start_pass;\\s*int64_t seeded_weight = 0;.*?\\(void\\)carry_weight;\\n/\\n    int pass_index = spec.start_pass;\\n    bool resumed = false;\\n    if (run.mode == \"resume\" && checkpoint != nullptr && checkpoint->valid) {\\n        auto it = checkpoint->units.find(spec.name);\\n        if (it != checkpoint->units.end()) {\\n            pass_index = it->second.next_pass;\\n            carry_weight = it->second.carry_weight;\\n            resumed = true;\\n        }\\n    }\\n\\n    if (run.mode == \"resume\" && resumed) {\\n        run.order_weight = carry_weight + static_cast<int64_t>(order_weight_base) + run.record_bytes;\\n    } else {\\n        run.order_weight = static_cast<int64_t>(order_weight_base) * (order_rank + 1) + run.record_bytes;\\n    }\\n    (void)names;\\n    (void)name_count;\\n/sms' /app/environment/runner/emit_pipeline.cpp\r\n\u001b[?2004l\r"]
