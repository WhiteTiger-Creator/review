[203.700956, "o", "\u001b[?2004h"]
[203.701052, "o", "> "]
[203.701373, "o", "    const std::string arr = doc.substr(arr_start, arr_end - arr_start + 1);\r\n\u001b[?2004l\r"]
[203.701481, "o", "\u001b[?2004h> "]
[203.701695, "o", "    for (const auto &block : split_object_blocks(arr)) {\r\n\u001b[?2004l\r"]
[203.70183, "o", "\u001b[?2004h> "]
[203.701993, "o", "        forge::UnitCheckpoint entry;\r\n\u001b[?2004l\r"]
[203.702108, "o", "\u001b[?2004h> "]
[203.702243, "o", "        entry.name = pick_string(block, \"name\");\r\n\u001b[?2004l\r"]
[203.702319, "o", "\u001b[?2004h> "]
[203.70241, "o", "        entry.next_pass = pick_int(block, \"next_pass\");\r\n\u001b[?2004l\r"]
[203.702511, "o", "\u001b[?2004h> "]
[203.702698, "o", "        entry.carry_weight = pick_int64(block, \"carry_weight\");\r\n\u001b[?2004l\r"]
[203.702722, "o", "\u001b[?2004h"]
[203.70288, "o", "> "]
[203.702981, "o", "        entry.carry_drift = pick_int64(block, \"carry_drift\");\r\n\u001b[?2004l\r"]
[203.703129, "o", "\u001b[?2004h> "]
[203.703281, "o", "        if (!entry.name.empty()) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.703389, "o", "            state.units[entry.name] = entry;\r\n"]
[203.703503, "o", "\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r"]
[203.70367, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
