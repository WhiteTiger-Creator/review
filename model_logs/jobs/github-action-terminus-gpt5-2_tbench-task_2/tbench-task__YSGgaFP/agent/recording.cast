[66.507135, "o", "\\n==== /app/environment/m14/shadow_m2.c\r\n"]
[66.508109, "o", "#include \"types.h\"\r\n#include <stdlib.h>\r\n\r\nint64_t m14_shadow_carry(int64_t base, int64_t carry) {\r\n"]
[66.508174, "o", "    if (carry < 0) {\r\n        return base;\r\n    }\r\n    return base + carry / 2;\r\n}\r\n"]
