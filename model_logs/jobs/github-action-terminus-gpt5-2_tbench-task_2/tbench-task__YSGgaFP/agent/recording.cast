[66.50354, "o", "#include \"types.h\"\r\n#include <sstream>\r\n#include <string>\r\n#include <vector>\r\n\r\nnamespace forge {\r\n\r\n"]
[66.503632, "o", "std::string m14_token_manifest_order(const std::vector<UnitSpec> &units) {\r\n    std::ostringstream joined;\r\n    for (size_t i = 0; i < units.size(); ++i) {\r\n        if (i) {\r\n            joined << '\\n';\r\n        }\r\n        joined << units[i].name << '|' << units[i].mode << '|' << units[i].record << '|'\r\n               << units[i].manifest_bytes << '|' << units[i].start_pass;\r\n    }\r\n    return joined.str();"]
[66.503682, "o", "\r\n}\r\n\r\n}\r\n"]
