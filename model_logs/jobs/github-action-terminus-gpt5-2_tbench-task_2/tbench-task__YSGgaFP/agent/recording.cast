[203.696493, "o", "\u001b[?2004h"]
[203.696509, "o", "> "]
[203.696633, "o", "    std::ostringstream buffer;\r\n\u001b[?2004l\r"]
[203.696688, "o", "\u001b[?2004h"]
[203.696724, "o", "> "]
[203.696781, "o", "    buffer << in.rdbuf();\r\n"]
[203.696822, "o", "\u001b[?2004l\r"]
[203.696858, "o", "\u001b[?2004h> "]
