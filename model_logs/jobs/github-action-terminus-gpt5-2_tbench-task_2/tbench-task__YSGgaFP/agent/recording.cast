[203.709659, "o", "> "]
[203.710662, "o", "    out << \"{\\\"schema_version\\\":\" << forge::kSchemaVersion << \",\\\"lane_token\\\":\\\"\" << lane_token\r\n\u001b[?2004l\r\u001b[?2004h>         << \"\\\",\\\"pass_epoch\\\":\" << pass_epoch << \",\\\"units\\\":[\";\r\n\u001b[?2004l\r\u001b[?2004h>     for (size_t i = 0; i < entries.size(); ++i) {\r\n\u001b[?2004l\r\u001b[?2004h>         if (i) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.71074, "o", "            out << ',';\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.710804, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h"]
[203.710855, "o", "> "]
