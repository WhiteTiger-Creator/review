[203.695242, "o", "\u001b[?2004h> "]
[203.695331, "o", "    if (!in) {\r\n\u001b[?2004l\r"]
[203.696283, "o", "\u001b[?2004h> "]
[203.696387, "o", "        return state;\r\n\u001b[?2004l\r"]
