[203.696995, "o", "\u001b[?2004l\r"]
[203.697036, "o", "\u001b[?2004h> "]
[203.697241, "o", "    if (doc.find(\"\\\"schema_version\\\"\") == std::string::npos) {\r\n\u001b[?2004l\r"]
[203.697256, "o", "\u001b[?2004h"]
