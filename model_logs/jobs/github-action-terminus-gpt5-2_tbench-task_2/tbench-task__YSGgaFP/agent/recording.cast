[203.704731, "o", "\u001b[?2004h> "]
[203.704923, "o", "    const std::vector<std::string> &requested_resume) {\r\n\u001b[?2004l\r"]
[203.705023, "o", "\u001b[?2004h> "]
[203.705119, "o", "    (void)requested_resume;\r\n\u001b[?2004l\r\u001b[?2004h"]
[203.705319, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.705456, "o", "    std::map<std::string, forge::UnitCheckpoint> merged;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.705562, "o", "    if (existing.valid) {\r\n\u001b[?2004l\r"]
[203.705642, "o", "\u001b[?2004h> "]
[203.705767, "o", "        merged = existing.units;\r\n\u001b[?2004l\r"]
[203.705943, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.70606, "o", "    for (const auto &e : updated) {\r\n\u001b[?2004l\r"]
[203.706243, "o", "\u001b[?2004h>         merged[e.name] = e;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.706359, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.706522, "o", "    std::vector<forge::UnitCheckpoint> out;\r\n"]
[203.706603, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[203.706788, "o", "    out.reserve(merged.size());\r\n\u001b[?2004l\r\u001b[?2004h"]
[203.70692, "o", "> "]
[203.707017, "o", "    for (const auto &kv : merged) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.707128, "o", "        out.push_back(kv.second);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.707225, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.707362, "o", "    std::sort(out.begin(), out.end(),\r\n\u001b[?2004l\r"]
[203.707502, "o", "\u001b[?2004h> "]
[203.707728, "o", "              [](const forge::UnitCheckpoint &a, const forge::UnitCheckpoint &b) {\r\n\u001b[?2004l\r"]
[203.707883, "o", "\u001b[?2004h> "]
[203.70795, "o", "                  return a.name < b.name;\r\n\u001b[?2004l\r"]
[203.708108, "o", "\u001b[?2004h> "]
[203.708268, "o", "              });\r\n\u001b[?2004l\r\u001b[?2004h>     return out;\r\n"]
[203.708427, "o", "\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h"]
