[984.111352, "o", "        free(req);\r\n        return;\r\n    }\r\n\r\n    if (is_api) {\r\n        send_json(fd, 404, \"Not Found\", \"{\\\"error\\\":\\\"not found\\\"}\");\r\n        free(req);\r\n        return;\r\n    }\r\n\r\n    // Static serving supports GET and HEAD\r\n    int is_head = (strcmp(method, \"HEAD\") == 0);\r\n    if (!(strcmp(method, \"GET\") == 0 || is_head)) {\r\n        send_simple(fd, 405, \"Method Not Allowed\", \"text/plain\", \"Method Not Allowed\");\r\n        free(req);\r\n        return;\r\n    }\r\n\r\n    // For static, reject percent-encoding to satisfy traversal constraints.\r\n    if (strchr(target, '%') != NULL) {\r\n        send_simple(fd, 403, \"Forbidden\", \"text/plain\", \"Forbidden\");\r\n        free(req);\r\n        return;\r\n    }\r\n\r\n    char decoded[2048];\r\n    if (percent_decode(target, decoded, sizeof(decoded)) != 0) {\r\n        send_simple(fd, 403, \"Forbidden\", \"text/plain\", \"Forbidden\");\r\n        free(req);\r\n        return;\r\n    }\r\n\r\n    if (strstr(target, \"..\") != NULL || strstr(decoded, \"..\") != NULL ||\r\n        has_dot_segments_or_backslash(target) || has_dot_segments_or_backslash(decoded)) {\r\n        send_simple(fd, 403, \"Forbidden\", \"text/plain\", \"Forbidden\");\r\n        free(req);\r\n"]
