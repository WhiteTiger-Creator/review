[136.652606, "i", "apply_patch <<'PATCH'\n*** Begin Patch\n*** Update File: src/main.c\n@@\n-static int url_contains_encoded_dotdot(const char *url) {\n-    const char *p = url;\n-    while (*p) {\n-        if (strncasecmp(p, \"%2e%2e\", 6) == 0)\n-            return 1;\n-        p++;\n-    }\n-    return 0;\n-}\n+static int hexval(char c) {\n+    if (c >= '0' && c <= '9') return c - '0';\n+    if (c >= 'a' && c <= 'f') return 10 + (c - 'a');\n+    if (c >= 'A' && c <= 'F') return 10 + (c - 'A');\n+    return -1;\n+}\n+\n+/* Percent-decode into dst, NUL-terminated. Returns 0 on success. */\n+static int percent_decode(const char *src, char *dst, size_t dstsz) {\n+    size_t di = 0;\n+    for (size_t si = 0; src[si] != '\\0'; si++) {\n+        if (di + 1 >= dstsz)\n+            return -1;\n+        if (src[si] == '%' && src[si + 1] && src[si + 2]) {\n+            int hi = hexval(src[si + 1]);\n+            int lo = hexval(src[si + 2]);\n+            if (hi >= 0 && lo >= 0) {\n+                dst[di++] = (char)((hi << 4) | lo);\n+                si += 2;\n+                continue;\n+            }\n+        }\n+        dst[di++] = src[si];\n+    }\n+    dst[di] = '\\0';\n+    return 0;\n+}\n+\n+/* Reject any '.' or '..' path segments to prevent escaping WWW_DIR.\n+   Also reject backslashes.\n+*/\n+static int has_dot_segments_or_backslash(const char *path) {\n+    if (strchr(path, '\\\\') != NULL)\n+        return 1;\n+\n+    const char *p = path;\n+    while (*p) {\n+        while (*p == '/') p++;\n+        const char *seg = p;\n+        while (*p && *p != '/') p++;\n+        size_t len = (size_t)(p - seg);\n+        if (len == 1 && seg[0] == '.')\n+            return 1;\n+        if (len == 2 && seg[0] == '.' && seg[1] == '.')\n+            return 1;\n+    }\n+    return 0;\n+}\n@@\n static enum MHD_Result serve_static_file(struct MHD_Connection *connection,\n     const char *url) {\n-    if (strstr(url, \"..\") != NULL || url_contains_encoded_dotdot(url)) {\n+    /* Handle mixed-case percent encodings by decoding and checking dot-segments\n+       in both raw and decoded forms. */\n+    char decoded[1024];\n+    if (percent_decode(url, decoded, sizeof(decoded)) != 0) {\n+        struct MHD_Response *r = MHD_create_response_from_buffer(\n+            9, (void *)\"Forbidden\", MHD_RESPMEM_PERSISTENT);\n+        enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_FORBIDDEN, r);\n+        MHD_destroy_response(r);\n+        return ret;\n+    }\n+\n+    if (has_dot_segments_or_backslash(url) || has_dot_segments_or_backslash(decoded)) {\n         struct MHD_Response *r = MHD_create_response_from_buffer(\n             9, (void *)\"Forbidden\", MHD_RESPMEM_PERSISTENT);\n         enum MHD_Result ret = MHD_queue_response(connection, MHD_HTTP_FORBIDDEN, r);\n         MHD_destroy_response(r);\n         return ret;\n     }\n*** End Patch\nPATCH\n"]
