[664.147125, "o", "   121\t    int n = snprintf(hdr, sizeof(hdr),\r\n   122\t                     \"HTTP/1.1 200 OK\\r\\n\"\r\n   123\t                     \"Connection: close\\r\\n\"\r\n   124\t                     \"Content-Type: %s\\r\\n\"\r\n   125\t                     \"Content-Length: %zu\\r\\n\"\r\n   126\t                     \"\\r\\n\",\r\n   127\t                     ct, (size_t)st.st_size);\r\n   128\t    if (n > 0) write_all(fd, hdr, (size_t)n);\r\n   129\t\r\n   130\t    char buf[4096];\r\n   131\t    size_t r;\r\n   132\t    while ((r = fread(buf, 1, sizeof(buf), f)) > 0) {\r\n   133\t        if (write_all(fd, buf, r) != 0) break;\r\n   134\t    }\r\n   135\t    fclose(f);\r\n   136\t}\r\n   137\t\r\n   138\tstatic void handle_client(int fd) {\r\n   139\t    char req[8192];\r\n   140\t    ssize_t n = read(fd, req, sizeof(req) - 1);\r\n   141\t    if (n <= 0) return;\r\n   142\t    req[n] = '\\0';\r\n   143\t\r\n   144\t    char *line_end = strstr(req, \"\\r\\n\");\r\n   145\t    if (!line_end) line_end = strchr(req, '\\n');\r\n   146\t    if (!line_end) {\r\n   147\t        send_simple(fd, 400, \"Bad Request\", \"text/plain\", \"Bad Request\");\r\n   148\t        return;\r\n   149\t    }\r\n   150\t    *line_end = '\\0';\r\n   151\t\r\n   152\t    char method[16], target[2048];\r\n   153\t    if (sscanf(req, \"%15s %2047s\", method, target) != 2) {\r\n   154\t        send_simple(fd, 400, \"Bad Request\", \"text/plain\", \"Bad Request\");\r\n   155\t        return;\r\n   156\t    }\r\n   157\t\r\n   158\t    if (strcmp(method, \"GET\") != 0) {\r\n   159\t        send_simple(fd, 405, \"Method Not Allowed\", \"text/plain\", \"Method Not Allowed\");\r\n   160\t        return;\r\n   161\t    }\r\n   162\t\r\n   163\t    char *q = strchr(target, '?');\r\n   164\t    if (q) *q = '\\0';\r\n   165\t\r\n   166\t    if (strcmp(target, \"/api/notes\") == 0) {\r\n   167\t        send_simple(fd, 200, \"OK\", \"application/json\", \"[]\");\r\n   168\t        return;\r\n   169\t    }\r\n   170\t\r\n   171\t    /* If any percent-encoding is present, reject to satisfy traversal constraints.\r\n   172\t       Required assets do not require encoding. */\r\n   173\t    if (strchr(target, '%') != NULL) {\r\n   174\t        send_simple(fd, 403, \"Forbidden\", \"text/plain\", \"Forbidden\");\r\n   175\t        return;\r\n   176\t    }\r\n   177\t\r\n   178\t    char decoded[2048];\r\n   179\t    if (percent_decode(target, decoded, sizeof(decoded)) != 0) {\r\n   180\t        send_simple(fd, 403, \"Forbidden\", \"text/plain\", \"Forbidden\");\r\n   181\t        return;\r\n   182\t    }\r\n   183\t\r\n   184\t    if (strstr(target, \"..\") != NULL || strstr(decoded, \"..\") != NULL ||\r\n   185\t        has_dot_segments_or_backslash(target) || has_dot_segments_or_backslash(decoded)) {\r\n   186\t        send_simple(fd, 403, \"Forbidden\", \"text/plain\", \"Forbidden\");\r\n   187\t        return;\r\n   188\t    }\r\n   189\t\r\n   190\t    const char *url_path = decoded;\r\n   191\t    if (strcmp(url_path, \"/\") == 0) url_path = \"/index.html\";\r\n   192\t\r\n   193\t    char fs_path[512];\r\n   194\t    if (snprintf(fs_path, sizeof(fs_path), \"%s%s\", WWW_DIR, url_path) >= (int)sizeof(fs_path)) {\r\n   195\t        send_simple(fd, 404, \"Not Found\", \"text/plain\", \"Not Found\");\r\n   196\t        return;\r\n   197\t    }\r\n   198\t\r\n"]
