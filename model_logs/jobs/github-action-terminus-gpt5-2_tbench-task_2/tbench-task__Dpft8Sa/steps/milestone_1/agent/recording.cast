[505.0728, "o", "\u001b[?2004h"]
[505.072859, "o", "> "]
[505.072997, "o", "    if (sscanf(req, \"%15s %2047s\", method, target) != 2) {\r\n\u001b[?2004l\r"]
[505.073026, "o", "\u001b[?2004h"]
[505.073046, "o", "> "]
[505.073284, "o", "        send_simple(fd, 400, \"Bad Request\", \"text/plain\", \"Bad Request\");\r\n\u001b[?2004l\r"]
[505.073314, "o", "\u001b[?2004h> "]
[505.073437, "o", "        return;\r\n\u001b[?2004l\r\u001b[?2004h"]
[505.073466, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[505.073495, "o", "> \r\n\u001b[?2004l\r"]
[505.07352, "o", "\u001b[?2004h"]
[505.073577, "o", "> "]
[505.073683, "o", "    if (strcmp(method, \"GET\") != 0) {\r\n\u001b[?2004l\r"]
[505.07371, "o", "\u001b[?2004h"]
[505.073744, "o", "> "]
[505.07401, "o", "        send_simple(fd, 405, \"Method Not Allowed\", \"text/plain\", \"Method Not Allowed\");\r\n\u001b[?2004l\r"]
[505.074067, "o", "\u001b[?2004h> "]
[505.07418, "o", "        return;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[505.074292, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[505.074379, "o", "\u001b[?2004h> "]
[505.074451, "o", "    char *q = strchr(target, '?');\r\n\u001b[?2004l\r\u001b[?2004h> "]
[505.074552, "o", "    if (q) *q = '\\0';\r\n\u001b[?2004l\r"]
[505.074594, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[505.074687, "o", "\u001b[?2004h> "]
[505.074803, "o", "    if (strcmp(target, \"/api/notes\") == 0) {\r\n\u001b[?2004l\r"]
[505.074874, "o", "\u001b[?2004h> "]
