[887.39353, "o", "#include \"auth.h\"\r\n"]
[887.393665, "o", "\r\n#include <ctype.h>\r\n#include <stdio.h>\r\n#include <stdlib.h>\r\n#include <string.h>\r\n\r\n"]
[887.393983, "o", "static char *g_api_key = NULL;\r\n\r\nstatic void rstrip_inplace(char *s) {\r\n    if (!s) return;\r\n    size_t n = strlen(s);\r\n    while (n > 0 && isspace((unsigned char)s[n - 1])) {\r\n        s[n - 1] = '\\0';\r\n        n--;\r\n    }\r\n}\r\n\r\nstatic char *lstrip(char *s) {\r\n    while (s && *s && isspace((unsigned char)*s)) s++;\r\n    return s;\r\n}\r\n\r\nstatic const char *load_api_key(void) {\r\n    if (g_api_key) return g_api_key;\r\n\r\n    FILE *f = fopen(\"/app/config/api.key\", \"rb\");\r\n    if (!f) {\r\n        g_api_key = strdup(\"\");\r\n        return g_api_key;\r\n    }\r\n\r\n    char buf[4096];\r\n"]
[887.394329, "o", "    size_t n = fread(buf, 1, sizeof(buf) - 1, f);\r\n    fclose(f);\r\n    buf[n] = '\\0';\r\n\r\n    char *s = lstrip(buf);\r\n    rstrip_inplace(s);\r\n\r\n    g_api_key = strdup(s);\r\n    if (!g_api_key) g_api_key = strdup(\"\");\r\n    return g_api_key;\r\n}\r\n\r\nint api_key_valid(struct MHD_Connection *connection) {\r\n    const char *want = load_api_key();\r\n    const char *got = MHD_lookup_connection_value(connection, MHD_HEADER_KIND, \"X-API-Key\");\r\n\r\n    if (!want || want[0] == '\\0') return 0;\r\n    if (!got) return 0;\r\n    return strcmp(want, got) == 0;\r\n}\r\n#include \"db.h\"\r\n\r\n#include <sqlite3.h>\r\n\r\n#include <errno.h>\r\n#include <pthread.h>\r\n#include <stdio.h>\r\n#include <stdlib.h>\r\n#include <string.h>\r\n\r\nstatic sqlite3 *g_db = NULL;\r\nstatic pthread_mutex_t g_db_mu = PTHREAD_MUTEX_INITIALIZER;\r\n\r\nstatic int exec_sql(const char *sql) {\r\n    char *err = NULL;\r\n    int rc = sqlite3_exec(g_db, sql, NULL, NULL, &err);\r\n    if (rc != SQLITE_OK) {\r\n        if (err) sqlite3_free(err);\r\n        return -1;\r\n    }\r\n    return 0;\r\n}\r\n\r\nint init_db(const char *path) {\r\n    pthread_mutex_lock(&g_db_mu);\r\n    if (g_db) {\r\n        pthread_mutex_unlock(&g_db_mu);\r\n        return 0;\r\n    }\r\n\r\n    if (sqlite3_open(path, &g_db) != SQLITE_OK) {\r\n        pthread_mutex_unlock(&g_db_mu);\r\n        return -1;\r\n    }\r\n\r\n    sqlite3_busy_timeout(g_db, 5000);\r\n    exec_sql(\"PRAGMA journal_mode=WAL;\");\r\n    exec_sql(\"PRAGMA synchronous=NORMAL;\");\r\n\r\n    const char *schema =\r\n        \"CREATE TABLE IF NOT EXISTS notes (\"\r\n        \"id INTEGER PRIMARY KEY AUTOINCREMENT,\"\r\n        \"title TEXT NOT NULL,\"\r\n        \"content TEXT NOT NULL\"\r\n        \");\";\r\n    if (exec_sql(schema) != 0) {\r\n        sqlite3_close(g_db);\r\n        g_db = NULL;\r\n        pthread_mutex_unlock(&g_db_mu);\r\n        return -1;\r\n    }\r\n\r\n    pthread_mutex_unlock(&g_db_mu);\r\n    return 0;\r\n}\r\n\r\nvoid close_db(void) {\r\n    pthread_mutex_lock(&g_db_mu);\r\n    if (g_db) {\r\n        sqlite3_close(g_db);\r\n        g_db = NULL;\r\n    }\r\n    pthread_mutex_unlock(&g_db_mu);\r\n}\r\n\r\nstatic void sb_append(char **buf, size_t *cap, size_t *len, const char *s) {\r\n    size_t add = strlen(s);\r\n    if (*len + add + 1 > *cap) {\r\n        size_t ncap = (*cap == 0) ? 1024 : *cap;\r\n        while (*len + add + 1 > ncap) ncap *= 2;\r\n        char *nb = realloc(*buf, ncap);\r\n        if (!nb) return;\r\n        *buf = nb;\r\n        *cap = ncap;\r\n    }\r\n    memcpy(*buf + *len, s, add);\r\n    *len += add;\r\n    (*buf)[*len] = '\\0';\r\n}\r\n\r\nstatic char *json_escape(const unsigned char *s) {\r\n    if (!s) return strdup(\"\");\r\n    size_t cap = 64, len = 0;\r\n    char *out = malloc(cap);\r\n    if (!out) return NULL;\r\n    out[0] = '\\0';\r\n\r\n    for (const unsigned char *p = s; *p; p++) {\r\n        char tmp[8];\r\n        if (*p == '\"' || *p == '\\\\') {\r\n            tmp[0] = '\\\\';\r\n            tmp[1] = (char)*p;\r\n            tmp[2] = '\\0';\r\n            sb_append(&out, &cap, &len, tmp);\r\n        } else if (*p == '\\n') {\r\n            sb_append(&out, &cap, &len, \"\\\\n\");\r\n        } else if (*p == '\\r') {\r\n            sb_append(&out, &cap, &len, \"\\\\r\");\r\n        } else if (*p == '\\t') {\r\n            sb_append(&out, &cap, &len, \"\\\\t\");\r\n        } else if (*p < 0x20) {\r\n            snprintf(tmp, sizeof(tmp), \"\\\\u%04x\", (unsigned int)*p);\r\n            sb_append(&out, &cap, &len, tmp);\r\n        } else {\r\n            tmp[0] = (char)*p;\r\n            tmp[1] = '\\0';\r\n            sb_append(&out, &cap, &len, tmp);\r\n        }\r\n    }\r\n    return out;\r\n}\r\n\r\nint create_note(const char *title, const char *content) {\r\n    pthread_mutex_lock(&g_db_mu);\r\n\r\n    sqlite3_exec(g_db, \"BEGIN IMMEDIATE;\", NULL, NULL, NULL);\r\n\r\n    sqlite3_stmt *st = NULL;\r\n    const char *sql = \"INSERT INTO notes(title, content) VALUES(?, ?);\";\r\n    if (sqlite3_prepare_v2(g_db, sql, -1, &st, NULL) != SQLITE_OK) {\r\n        sqlite3_exec(g_db, \"ROLLBACK;\", NULL, NULL, NULL);\r\n        pthread_mutex_unlock(&g_db_mu);\r\n        return -1;\r\n    }\r\n\r\n    sqlite3_bind_text(st, 1, title ? title : \"\", -1, SQLITE_TRANSIENT);\r\n"]
[887.394455, "o", "    sqlite3_bind_text(st, 2, content ? content : \"\", -1, SQLITE_TRANSIENT);\r\n\r\n    int rc = sqlite3_step(st);\r\n    sqlite3_finalize(st);\r\n    if (rc != SQLITE_DONE) {\r\n        sqlite3_exec(g_db, \"ROLLBACK;\", NULL, NULL, NULL);\r\n        pthread_mutex_unlock(&g_db_mu);\r\n        return -1;\r\n    }\r\n\r\n    int id = (int)sqlite3_last_insert_rowid(g_db);\r\n    sqlite3_exec(g_db, \"COMMIT;\", NULL, NULL, NULL);\r\n\r\n    pthread_mutex_unlock(&g_db_mu);\r\n    return id;\r\n}\r\n\r\nint get_total_notes_count(void) {\r\n    pthread_mutex_lock(&g_db_mu);\r\n\r\n    sqlite3_stmt *st = NULL;\r\n"]
