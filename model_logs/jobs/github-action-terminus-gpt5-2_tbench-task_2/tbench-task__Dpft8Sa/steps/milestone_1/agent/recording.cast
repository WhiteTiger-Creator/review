[422.154846, "o", "    const char *p = path;\r\n\u001b[?2004l\r"]
[422.154951, "o", "\u001b[?2004h> "]
[422.155041, "o", "    while (*p) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[422.155071, "o", "> "]
