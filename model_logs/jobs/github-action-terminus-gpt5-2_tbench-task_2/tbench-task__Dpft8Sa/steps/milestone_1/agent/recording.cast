[858.436276, "i", "perl -0777 -i -pe 's/let API_KEY = null;\\n\\n  function getApiKey\\(\\) \\{\\n    if \\(API_KEY\\) return API_KEY;\\n    \\/\\/ Lazy-load key once; trimmed as required\\n    return fetch\\(\\x27\\/config\\/api\\.key\\x27\\)\\.then\\(\\(r\\) => r\\.text\\(\\)\\)\\.then\\(\\(t\\) => \\{\\n      API_KEY = \\(t \\|\\| \\x27\\x27\\)\\.trim\\(\\);\\n      return API_KEY;\\n    \\}\\);\\n  \\}\\n/let API_KEY = '\\''\"$ENV{API_KEY_TRIMMED}\"'\\'';\\n\\n  function getApiKey() {\\n    return Promise.resolve((API_KEY || \"\").trim());\\n  }\\n/sm' /app/www/app.js\n"]
[858.438371, "o", "perl -0777 -i -pe 's/let API_KEY = null;\\n\\n  function getApiKey\\(\\) \\{\\n    if \\(API_KEY\\) return API_KEY;\\n    \\/\\/ Lazy-load key once; trimmed as required\\n    return fetch\\(\\x27\\/config\\/api\\.key\\x27\\)\\.then\\(\\(r\\) => r\\.text\\(\\)\\)\\.then\\(\\(t\\) => \\{\\n      API_KEY = \\(t \\|\\| \\x27\\x27\\)\\.trim\\(\\);\\n      return API_KEY;\\n    \\}\\);\\n  \\}\\n/let API_KEY = '\\''\"$ENV{API_KEY_TRIMMED}\"'\\'';\\n\\n  function getApiKey() {\\n    return Promise.resolve((API_KEY || \"\").trim());\\n  }\\n/sm' /app/www/app.js\r\n\u001b[?2004l\r"]
