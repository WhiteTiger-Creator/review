[901.120321, "o", "/app/src/main.c:80:                     \"Access-Control-Allow-Methods: GET, POST, PUT, DELETE, OPTIONS\\r\\n\"\r\n/app/src/main.c:97:                     \"Access-Control-Allow-Methods: GET, POST, PUT, DELETE, OPTIONS\\r\\n\"\r\n/app/src/main.c:399:    if (is_api && (strcmp(method, \"POST\") == 0 || strcmp(method, \"PUT\") == 0)) {\r\n/app/src/main.c:441:    if (strcmp(path, \"/api/notes\") == 0 && strcmp(method, \"GET\") == 0) {\r\n/app/src/main.c:460:    if (parse_note_id(path, &note_id) && strcmp(method, \"GET\") == 0) {\r\n/app/src/main.c:472:    if (strcmp(path, \"/api/notes\") == 0 && strcmp(method, \"POST\") == 0) {\r\n/app/src/main.c:598:    // Static serving only supports GET\r\n/app/src/main.c:599:    if (strcmp(method, \"GET\") != 0) {\r\n/app/src/main.c:600:        send_simple(fd, 405, \"Method Not Allowed\", \"text/plain\", \"Method Not Allowed\");\r\n/app/src/routes.c:15:                            \"GET, POST, PUT, DELETE, OPTIONS\");\r\n/app/src/routes.c:31:                            \"GET, POST, PUT, DELETE, OPTIONS\");\r\n/app/src/routes.c:66:    if (strcmp(url, \"/api/notes\") == 0 && strcmp(method, \"GET\") == 0) {\r\n"]
