[619.674417, "o", "#define _POSIX_C_SOURCE 200809L\r\n#include <arpa/inet.h>\r\n#include <errno.h>\r\n#include <netinet/in.h>\r\n#include <signal.h>\r\n#include <stdio.h>\r\n#include <stdlib.h>\r\n#include <string.h>\r\n#include <sys/socket.h>\r\n#include <sys/stat.h>\r\n#include <unistd.h>\r\n\r\n#include \"db.h\"\r\n\r\n#define PORT 8080\r\n#define WWW_DIR \"/app/www\"\r\n\r\nstatic volatile sig_atomic_t g_stop = 0;\r\nstatic int g_listen_fd = -1;\r\n\r\nstatic void on_signal(int sig) {\r\n    (void)sig;\r\n    g_stop = 1;\r\n    if (g_listen_fd >= 0) close(g_listen_fd);\r\n    close_db();\r\n}\r\n"]
[619.674458, "o", "\r\nstatic const char *content_type_for_path(const char *path) {\r\n    const char *ext = strrchr(path, '.');\r\n    if (!ext) return \"application/octet-stream\";\r\n    if (strcmp(ext, \".html\") == 0) return \"text/html\";\r\n    if (strcmp(ext, \".css\") == 0) return \"text/css\";\r\n    if (strcmp(ext, \".js\") == 0) return \"application/javascript\";\r\n    return \"application/octet-stream\";\r\n}\r\n\r\nstatic int hexval(char c) {\r\n    if (c >= '0' && c <= '9') return c - '0';\r\n    if (c >= 'a' && c <= 'f') return 10 + (c - 'a');\r\n    if (c >= 'A' && c <= 'F') return 10 + (c - 'A');\r\n    return -1;\r\n}\r\n\r\nstatic int percent_decode(const char *src, char *dst, size_t dstsz) {\r\n    size_t di = 0;\r\n    for (size_t si = 0; src[si] != '\\0'; si++) {\r\n        if (di + 1 >= dstsz) return -1;\r\n        if (src[si] == '%' && src[si + 1] && src[si + 2]) {\r\n            int hi = hexval(src[si + 1]);\r\n            int lo = hexval(src[si + 2]);\r\n            if (hi >= 0 && lo >= 0) {\r\n                dst[di++] = (char)((hi << 4) | lo);\r\n                si += 2;\r\n                continue;\r\n            }\r\n        }\r\n        dst[di++] = src[si];\r\n    }\r\n    dst[di] = '\\0';\r\n    return 0;\r\n}\r\n\r\nstatic int has_dot_segments_or_backslash(const char *path) {\r\n    if (strchr(path, '\\\\') != NULL) return 1;\r\n    const char *p = path;\r\n"]
[619.67448, "o", "    while (*p) {\r\n        while (*p == '/') p++;\r\n        const char *seg = p;\r\n        while (*p && *p != '/') p++;\r\n        size_t len = (size_t)(p - seg);\r\n        if (len == 1 && seg[0] == '.') return 1;\r\n        if (len == 2 && seg[0] == '.' && seg[1] == '.') return 1;\r\n"]
[619.674502, "o", "    }\r\n    return 0;\r\n}\r\n\r\nstatic int write_all(int fd, const void *buf, size_t n) {\r\n    const char *p = (const char *)buf;\r\n    while (n > 0) {\r\n"]
[619.67452, "o", "        ssize_t w = write(fd, p, n);\r\n        if (w < 0) {\r\n            if (errno == EINTR) continue;\r\n            return -1;\r\n        }\r\n"]
[619.674537, "o", "        p += (size_t)w;\r\n        n -= (size_t)w;\r\n    }\r\n    return 0;\r\n}\r\n"]
[619.674555, "o", "\r\nstatic void send_simple(int fd, int code, const char *status, const char *ctype, const char *body) {\r\n    char hdr[512];\r\n    size_t blen = body ? strlen(body) : 0;\r\n    int n = snprintf(hdr, sizeof(hdr),\r\n"]
[619.674573, "o", "                     \"HTTP/1.1 %d %s\\r\\n\"\r\n                     \"Connection: close\\r\\n\"\r\n                     \"Content-Type: %s\\r\\n\"\r\n                     \"Content-Length: %zu\\r\\n\"\r\n                     \"\\r\\n\",\r\n"]
[619.674595, "o", "                     code, status, ctype, blen);\r\n    if (n < 0) return;\r\n    write_all(fd, hdr, (size_t)n);\r\n    if (body) write_all(fd, body, blen);\r\n}\r\n"]
[619.674783, "o", "\r\nstatic void send_file(int fd, const char *fs_path) {\r\n    struct stat st;\r\n    if (stat(fs_path, &st) != 0 || !S_ISREG(st.st_mode)) {\r\n        send_simple(fd, 404, \"Not Found\", \"text/plain\", \"Not Found\");\r\n        return;\r\n"]
[619.674811, "o", "    }\r\n\r\n    FILE *f = fopen(fs_path, \"rb\");\r\n    if (!f) {\r\n        send_simple(fd, 404, \"Not Found\", \"text/plain\", \"Not Found\");\r\n        return;\r\n    }\r\n\r\n    char hdr[512];\r\n    const char *ct = content_type_for_path(fs_path);\r\n    int n = snprintf(hdr, sizeof(hdr),\r\n                     \"HTTP/1.1 200 OK\\r\\n\"\r\n                     \"Connection: close\\r\\n\"\r\n                     \"Content-Type: %s\\r\\n\"\r\n                     \"Content-Length: %zu\\r\\n\"\r\n                     \"\\r\\n\",\r\n                     ct, (size_t)st.st_size);\r\n    if (n > 0) write_all(fd, hdr, (size_t)n);\r\n\r\n    char buf[4096];\r\n    size_t r;\r\n    while ((r = fread(buf, 1, sizeof(buf), f)) > 0) {\r\n        if (write_all(fd, buf, r) != 0) break;\r\n    }\r\n    fclose(f);\r\n}\r\n\r\nstatic void handle_client(int fd) {\r\n    char req[8192];\r\n    ssize_t n = read(fd, req, sizeof(req) - 1);\r\n    if (n <= 0) return;\r\n    req[n] = '\\0';\r\n\r\n    char *line_end = strstr(req, \"\\r\\n\");\r\n    if (!line_end) line_end = strchr(req, '\\n');\r\n    if (!line_end) {\r\n        send_simple(fd, 400, \"Bad Request\", \"text/plain\", \"Bad Request\");\r\n        return;\r\n    }\r\n    *line_end = '\\0';\r\n\r\n    char method[16], target[2048];\r\n    if (sscanf(req, \"%15s %2047s\", method, target) != 2) {\r\n        send_simple(fd, 400, \"Bad Request\", \"text/plain\", \"Bad Request\");\r\n        return;\r\n    }\r\n\r\n    if (strcmp(method, \"GET\") != 0) {\r\n        send_simple(fd, 405, \"Method Not Allowed\", \"text/plain\", \"Method Not Allowed\");\r\n        return;\r\n    }\r\n\r\n    char *q = strchr(target, '?');\r\n    if (q) *q = '\\0';\r\n\r\n    if (strcmp(target, \"/api/notes\") == 0) {\r\n        send_simple(fd, 200, \"OK\", \"application/json\", \"[]\");\r\n        return;\r\n    }\r\n\r\n    /* If any percent-encoding is present, reject to satisfy traversal constraints.\r\n       Required assets do not require encoding. */\r\n    if (strchr(target, '%') != NULL) {\r\n        send_simple(fd, 403, \"Forbidden\", \"text/plain\", \"Forbidden\");\r\n        return;\r\n    }\r\n\r\n    char decoded[2048];\r\n    if (percent_decode(target, decoded, sizeof(decoded)) != 0) {\r\n        send_simple(fd, 403, \"Forbidden\", \"text/plain\", \"Forbidden\");\r\n        return;\r\n    }\r\n\r\n    if (strstr(target, \"..\") != NULL || strstr(decoded, \"..\") != NULL ||\r\n        has_dot_segments_or_backslash(target) || has_dot_segments_or_backslash(decoded)) {\r\n"]
[619.675466, "o", "        send_simple(fd, 403, \"Forbidden\", \"text/plain\", \"Forbidden\");\r\n        return;\r\n    }\r\n\r\n    const char *url_path = decoded;\r\n    if (strcmp(url_path, \"/\") == 0) url_path = \"/index.html\";\r\n\r\n    char fs_path[512];\r\n    if (snprintf(fs_path, sizeof(fs_path), \"%s%s\", WWW_DIR, url_path) >= (int)sizeof(fs_path)) {\r\n        send_simple(fd, 404, \"Not Found\", \"text/plain\", \"Not Found\");\r\n        return;\r\n    }\r\n\r\n    send_file(fd, fs_path);\r\n}\r\n\r\nint main(void) {\r\n    signal(SIGINT, on_signal);\r\n    signal(SIGTERM, on_signal);\r\n\r\n    mkdir(\"/app/data\", 0755);\r\n    if (init_db(\"/app/data/notes.db\") != 0) {\r\n        fprintf(stderr, \"Failed to initialize database\\n\");\r\n        return 1;\r\n    }\r\n\r\n    g_listen_fd = socket(AF_INET, SOCK_STREAM, 0);\r\n    if (g_listen_fd < 0) {\r\n        perror(\"socket\");\r\n        return 1;\r\n    }\r\n\r\n    int one = 1;\r\n    setsockopt(g_listen_fd, SOL_SOCKET, SO_REUSEADDR, &one, sizeof(one));\r\n\r\n    struct sockaddr_in addr;\r\n    memset(&addr, 0, sizeof(addr));\r\n    addr.sin_family = AF_INET;\r\n    addr.sin_port = htons(PORT);\r\n    addr.sin_addr.s_addr = htonl(INADDR_ANY);\r\n\r\n    if (bind(g_listen_fd, (struct sockaddr *)&addr, sizeof(addr)) != 0) {\r\n        perror(\"bind\");\r\n        return 1;\r\n    }\r\n\r\n    if (listen(g_listen_fd, 128) != 0) {\r\n        perror(\"listen\");\r\n        return 1;\r\n    }\r\n\r\n    printf(\"Server running on port %d\\n\", PORT);\r\n\r\n    while (!g_stop) {\r\n        int cfd = accept(g_listen_fd, NULL, NULL);\r\n        if (cfd < 0) {\r\n            if (errno == EINTR) continue;\r\n            break;\r\n        }\r\n        handle_client(cfd);\r\n        close(cfd);\r\n    }\r\n\r\n    if (g_listen_fd >= 0) close(g_listen_fd);\r\n    close_db();\r\n    return 0;\r\n}\r\n\u001b[?2004hroot@972cf0f30065:/app# "]
[619.792072, "i", "apply_patch<<'PATCH'\n*** Begin Patch\n*** Update File: /app/src/auth.c\n@@\n-#include \"auth.h\"\n-\n-int api_key_valid(struct MHD_Connection *connection) {\n-    (void)connection;\n-    return 0;\n-}\n+#include \"auth.h\"\n+\n+#include <ctype.h>\n+#include <stdio.h>\n+#include <stdlib.h>\n+#include <string.h>\n+\n+static char *g_api_key = NULL;\n+\n+static void rstrip_inplace(char *s) {\n+    if (!s) return;\n+    size_t n = strlen(s);\n+    while (n > 0 && isspace((unsigned char)s[n - 1])) {\n+        s[n - 1] = '\\0';\n+        n--;\n+    }\n+}\n+\n+static char *lstrip(char *s) {\n+    while (s && *s && isspace((unsigned char)*s)) s++;\n+    return s;\n+}\n+\n+static const char *load_api_key(void) {\n+    if (g_api_key) return g_api_key;\n+\n+    FILE *f = fopen(\"/app/config/api.key\", \"rb\");\n+    if (!f) {\n+        g_api_key = strdup(\"\");\n+        return g_api_key;\n+    }\n+    char buf[4096];\n+    size_t n = fread(buf, 1, sizeof(buf) - 1, f);\n+    fclose(f);\n+    buf[n] = '\\0';\n+\n+    char *s = lstrip(buf);\n+    rstrip_inplace(s);\n+    g_api_key = strdup(s);\n+    if (!g_api_key) g_api_key = strdup(\"\");\n+    return g_api_key;\n+}\n+\n+int api_key_valid(struct MHD_Connection *connection) {\n+    const char *want = load_api_key();\n+    const char *got = MHD_lookup_connection_value(connection, MHD_HEADER_KIND, \"X-API-Key\");\n+    if (!want || want[0] == '\\0') return 0;\n+    if (!got) return 0;\n+    return strcmp(want, got) == 0;\n+}\n*** End Patch\nPATCH\n"]
