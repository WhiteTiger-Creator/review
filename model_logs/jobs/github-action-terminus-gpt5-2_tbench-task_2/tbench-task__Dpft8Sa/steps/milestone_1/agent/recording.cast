[699.783372, "o", "    10\t#include <sys/stat.h>\r\n    11\t#include <unistd.h>\r\n    12\t\r\n    13\t#include \"db.h\"\r\n    14\t\r\n    15\t#define PORT 8080\r\n    16\t#define WWW_DIR \"/app/www\"\r\n    17\t\r\n    18\tstatic volatile sig_atomic_t g_stop = 0;\r\n    19\tstatic int g_listen_fd = -1;\r\n    20\t\r\n    21\tstatic void on_signal(int sig) {\r\n    22\t    (void)sig;\r\n    23\t    g_stop = 1;\r\n    24\t    if (g_listen_fd >= 0) close(g_listen_fd);\r\n    25\t    close_db();\r\n    26\t}\r\n    27\t\r\n    28\tstatic const char *content_type_for_path(const char *path) {\r\n    29\t    const char *ext = strrchr(path, '.');\r\n    30\t    if (!ext) return \"application/octet-stream\";\r\n    31\t    if (strcmp(ext, \".html\") == 0) return \"text/html\";\r\n    32\t    if (strcmp(ext, \".css\") == 0) return \"text/css\";\r\n    33\t    if (strcmp(ext, \".js\") == 0) return \"application/javascript\";\r\n    34\t    return \"application/octet-stream\";\r\n    35\t}\r\n    36\t\r\n    37\tstatic int hexval(char c) {\r\n    38\t    if (c >= '0' && c <= '9') return c - '0';\r\n    39\t    if (c >= 'a' && c <= 'f') return 10 + (c - 'a');\r\n    40\t    if (c >= 'A' && c <= 'F') return 10 + (c - 'A');\r\n    41\t    return -1;\r\n    42\t}\r\n    43\t\r\n    44\tstatic int percent_decode(const char *src, char *dst, size_t dstsz) {\r\n    45\t    size_t di = 0;\r\n    46\t    for (size_t si = 0; src[si] != '\\0'; si++) {\r\n    47\t        if (di + 1 >= dstsz) return -1;\r\n    48\t        if (src[si] == '%' && src[si + 1] && src[si + 2]) {\r\n    49\t            int hi = hexval(src[si + 1]);\r\n    50\t            int lo = hexval(src[si + 2]);\r\n    51\t            if (hi >= 0 && lo >= 0) {\r\n    52\t                dst[di++] = (char)((hi << 4) | lo);\r\n    53\t                si += 2;\r\n    54\t                continue;\r\n    55\t            }\r\n    56\t        }\r\n    57\t        dst[di++] = src[si];\r\n    58\t    }\r\n    59\t    dst[di] = '\\0';\r\n    60\t    return 0;\r\n    61\t}\r\n    62\t\r\n    63\tstatic int has_dot_segments_or_backslash(const char *path) {\r\n    64\t    if (strchr(path, '\\\\') != NULL) return 1;\r\n    65\t    const char *p = path;\r\n    66\t    while (*p) {\r\n    67\t        while (*p == '/') p++;\r\n    68\t        const char *seg = p;\r\n    69\t        while (*p && *p != '/') p++;\r\n    70\t        size_t len = (size_t)(p - seg);\r\n    71\t        if (len == 1 && seg[0] == '.') return 1;\r\n    72\t        if (len == 2 && seg[0] == '.' && seg[1] == '.') return 1;\r\n    73\t    }\r\n    74\t    return 0;\r\n    75\t}\r\n    76\t\r\n    77\tstatic int write_all(int fd, const void *buf, size_t n) {\r\n    78\t    const char *p = (const char *)buf;\r\n"]
[699.783422, "o", "    79\t    while (n > 0) {\r\n    80\t        ssize_t w = write(fd, p, n);\r\n    81\t        if (w < 0) {\r\n    82\t            if (errno == EINTR) continue;\r\n    83\t            return -1;\r\n    84\t        }\r\n    85\t        p += (size_t)w;\r\n    86\t        n -= (size_t)w;\r\n    87\t    }\r\n    88\t    return 0;\r\n    89\t}\r\n    90\t\r\n    91\tstatic void send_simple(int fd, int code, const char *status, const char *ctype, const char *body) {\r\n    92\t    char hdr[512];\r\n    93\t    size_t blen = body ? strlen(body) : 0;\r\n    94\t    int n = snprintf(hdr, sizeof(hdr),\r\n    95\t                     \"HTTP/1.1 %d %s\\r\\n\"\r\n    96\t                     \"Connection: close\\r\\n\"\r\n    97\t                     \"Content-Type: %s\\r\\n\"\r\n    98\t                     \"Content-Length: %zu\\r\\n\"\r\n    99\t                     \"\\r\\n\",\r\n   100\t                     code, status, ctype, blen);\r\n   101\t    if (n < 0) return;\r\n   102\t    write_all(fd, hdr, (size_t)n);\r\n   103\t    if (body) write_all(fd, body, blen);\r\n   104\t}\r\n   105\t\r\n   106\tstatic void send_file(int fd, const char *fs_path) {\r\n   107\t    struct stat st;\r\n   108\t    if (stat(fs_path, &st) != 0 || !S_ISREG(st.st_mode)) {\r\n   109\t        send_simple(fd, 404, \"Not Found\", \"text/plain\", \"Not Found\");\r\n   110\t        return;\r\n   111\t    }\r\n   112\t\r\n   113\t    FILE *f = fopen(fs_path, \"rb\");\r\n   114\t    if (!f) {\r\n   115\t        send_simple(fd, 404, \"Not Found\", \"text/plain\", \"Not Found\");\r\n   116\t        return;\r\n   117\t    }\r\n   118\t\r\n   119\t    char hdr[512];\r\n   120\t    const char *ct = content_type_for_path(fs_path);\r\n   121\t    int n = snprintf(hdr, sizeof(hdr),\r\n   122\t                     \"HTTP/1.1 200 OK\\r\\n\"\r\n   123\t                     \"Connection: close\\r\\n\"\r\n   124\t                     \"Content-Type: %s\\r\\n\"\r\n   125\t                     \"Con