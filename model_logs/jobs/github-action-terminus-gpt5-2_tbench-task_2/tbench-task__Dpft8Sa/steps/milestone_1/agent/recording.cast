[900.994489, "o", "#include <netinet/in.h>\r\n#include <signal.h>\r\n#include <stdio.h>\r\n#include <stdlib.h>\r\n#include <string.h>\r\n#include <sys/socket.h>\r\n#include <sys/stat.h>\r\n#include <unistd.h>\r\n\r\n#define PORT 8080\r\n#define WWW_DIR \"/app/www\"\r\n#define MAX_BODY 65536\r\n\r\nstatic volatile sig_atomic_t g_stop = 0;\r\nstatic int g_listen_fd = -1;\r\n\r\nstatic void on_signal(int sig) {\r\n    (void)sig;\r\n    g_stop = 1;\r\n"]
[900.994513, "o", "    if (g_listen_fd >= 0) close(g_listen_fd);\r\n}\r\n\r\nstatic int write_all(int fd, const void *buf, size_t len) {\r\n    const char *p = (const char *)buf;\r\n    while (len > 0) {\r\n"]
[900.994534, "o", "        ssize_t n = write(fd, p, len);\r\n        if (n < 0) {\r\n            if (errno == EINTR) continue;\r\n            return -1;\r\n        }\r\n        p += (size_t)n;\r\n        len -= (size_t)n;\r\n"]
[900.994557, "o", "    }\r\n    return 0;\r\n}\r\n\r\nstatic const char *content_type_for_path(const char *path) {\r\n    const char *ext = strrchr(path, '.');\r\n"]
[900.994596, "o", "    if (!ext) return \"application/octet-stream\";\r\n    if (strcmp(ext, \".html\") == 0) return \"text/html\";\r\n    if (strcmp(ext, \".js\") == 0) return \"application/javascript\";\r\n    if (strcmp(ext, \".css\") == 0) return \"text/css\";\r\n"]
[900.994618, "o", "    if (strcmp(ext, \".png\") == 0) return \"image/png\";\r\n    if (strcmp(ext, \".jpg\") == 0 || strcmp(ext, \".jpeg\") == 0) return \"image/jpeg\";\r\n    if (strcmp(ext, \".svg\") == 0) return \"image/svg+xml\";\r\n    return \"application/octet-stream\";\r\n}\r\n\r\nstatic void send_simple(int fd, int code, const char *reason,\r\n                        const char *content_type, const char *body) {\r\n    size_t blen = body ? strlen(body) : 0;\r\n    char hdr[512];\r\n"]
[900.994643, "o", "    int n = snprintf(hdr, sizeof(hdr),\r\n                     \"HTTP/1.1 %d %s\\r\\n\"\r\n                     \"Connection: close\\r\\n\"\r\n                     \"Content-Type: %s\\r\\n\"\r\n                     \"Content-Length: %zu\\r\\n\"\r\n                     \"\\r\\n\",\r\n"]
[900.994664, "o", "                     code, reason, content_type, blen);\r\n    if (n > 0) write_all(fd, hdr, (size_t)n);\r\n    if (body) write_all(fd, body, blen);\r\n}\r\n\r\nstatic void send_json(int fd, int code, const char *reason, const char *body) {\r\n"]
[900.994683, "o", "    size_t blen = body ? strlen(body) : 0;\r\n    char hdr[768];\r\n    int n = snprintf(hdr, sizeof(hdr),\r\n                     \"HTTP/1.1 %d %s\\r\\n\"\r\n                     \"Connection: close\\r\\n\"\r\n                     \"Content-Type: application/json\\r\\n\"\r\n"]
[900.994701, "o", "                     \"Access-Control-Allow-Origin: *\\r\\n\"\r\n                     \"Access-Control-Allow-Methods: GET, POST, PUT, DELETE, OPTIONS\\r\\n\"\r\n                     \"Access-Control-Allow-Headers: Content-Type, X-API-Key\\r\\n\"\r\n                     \"Content-Length: %zu\\r\\n\"\r\n"]
[900.994722, "o", "                     \"\\r\\n\",\r\n                     code, reason, blen);\r\n    if (n > 0) write_all(fd, hdr, (size_t)n);\r\n    if (body) write_all(fd, body, blen);\r\n}\r\n\r\n"]
[900.994754, "o", "static void send_json_total(int fd, int code, const char *reason, const char *body, int total) {\r\n    size_t blen = body ? strlen(body) : 0;\r\n    char hdr[900];\r\n    int n = snprintf(hdr, sizeof(hdr),\r\n                     \"HTTP/1.1 %d %s\\r\\n\"\r\n"]
[900.994776, "o", "                     \"Connection: close\\r\\n\"\r\n                     \"Content-Type: application/json\\r\\n\"\r\n                     \"Access-Control-Allow-Origin: *\\r\\n\"\r\n                     \"Access-Control-Allow-Methods: GET, POST, PUT, DELETE, OPTIONS\\r\\n\"\r\n                     \"Access-Control-Allow-Headers: Content-Type, X-API-Key\\r\\n\"\r\n                     \"X-Total-Count: %d\\r\\n\"\r\n                     \"Content-Length: %zu\\r\\n\"\r\n                     \"\\r\\n\",\r\n"]
[900.994799, "o", "                     code, reason, total, blen);\r\n    if (n > 0) write_all(fd, hdr, (size_t)n);\r\n    if (body) write_all(fd, body, blen);\r\n}\r\n\r\nstatic void send_file(int fd, const char *fs_path) {\r\n    struct stat st;\r\n"]
[900.994818, "o", "    if (stat(fs_path, &st) != 0 || !S_ISREG(st.st_mode)) {\r\n        send_simple(fd, 404, \"Not Found\", \"text/plain\", \"Not Found\");\r\n        return;\r\n    }\r\n\r\n    FILE *f = fopen(fs_path, \"rb\");\r\n    if (!f) {\r\n"]
[900.994837, "o", "        send_simple(fd, 404, \"Not Found\", \"text/plain\", \"Not Found\");\r\n        return;\r\n    }\r\n\r\n    char hdr[512];\r\n"]
[900.994855, "o", "    const char *ct = content_type_for_path(fs_path);\r\n    int n = snprintf(hdr, sizeof(hdr),\r\n                     \"HTTP/1.1 200 OK\\r\\n\"\r\n                     \"Connection: close\\r\\n\"\r\n"]
[900.994874, "o", "                     \"Content-Type: %s\\r\\n\"\r\n                     \"Content-Length: %zu\\r\\n\"\r\n                     \"\\r\\n\",\r\n"]
[900.994892, "o", "                     ct, (size_t)st.st_size);\r\n    if (n > 0) write_all(fd, hdr, (size_t)n);\r\n\r\n    char buf[4096];\r\n    size_t r;\r\n"]
[900.994909, "o", "    while ((r = fread(buf, 1, sizeof(buf), f)) > 0) {\r\n        if (write_all(fd, buf, r) != 0) break;\r\n    }\r\n    fclose(f);\r\n}\r\n\r\nstatic int has_dot_segments_or_backslash(const char *s) {\r\n    if (!s) return 0;\r\n"]
[900.994928, "o", "    if (strchr(s, '\\\\') != NULL) return 1;\r\n    if (strstr(s, \"/./\") != NULL) return 1;\r\n    if (strstr(s, \"/../\") != NULL) return 1;\r\n    size_t n = strlen(s);\r\n"]
[900.994947, "o", "    if (n >= 2 && strcmp(s + n - 2, \"/.\") == 0) return 1;\r\n    if (n >= 3 && strcmp(s + n - 3, \"/..\") == 0) return 1;\r\n    return 0;\r\n}\r\n\r\n"]
[900.994967, "o", "static int percent_decode(const char *in, char *out, size_t out_sz) {\r\n    size_t oi = 0;\r\n    for (size_t i = 0; in[i]; i++) {\r\n        if (oi + 1 >= out_sz) return -1;\r\n        if (in[i] == '%') {\r\n"]
[900.994986, "o", "            if (!isxdigit((unsigned char)in[i + 1]) || !isxdigit((unsigned char)in[i + 2])) return -1;\r\n            char tmp[3] = {in[i + 1], in[i + 2], 0};\r\n            out[oi++] = (char)strtol(tmp, NULL, 16);\r\n            i += 2;\r\n        } else {\r\n            out[oi++] = in[i];\r\n        }\r\n"]
[900.995006, "o", "    }\r\n    out[oi] = 0;\r\n    return 0;\r\n}\r\n\r\nstatic const char *find_header_value(const char *headers, const char *name) {\r\n"]
[900.995025, "o", "    size_t nlen = strlen(name);\r\n    const char *p = headers;\r\n    while (*p) {\r\n        const char *line_end = strstr(p, \"\\r\\n\");\r\n        if (!line_end) break;\r\n"]
[900.995044, "o", "        if (line_end == p) break;\r\n\r\n        if (strncasecmp(p, name, nlen) == 0 && p[nlen] == ':') {\r\n            const char *v = p + nlen + 1;\r\n"]
[900.995065, "o", "            while (*v == ' ' || *v == '\\t') v++;\r\n            return v;\r\n        }\r\n        p = line_end + 2;\r\n    }\r\n    return NULL;\r\n"]
[900.99509, "o", "}\r\n\r\nstatic int parse_content_length(const char *headers) {\r\n    const char *v = find_header_value(headers, \"Content-Length\");\r\n    if (!v) return 0;\r\n"]
[900.995109, "o", "    return atoi(v);\r\n}\r\n\r\nstatic int api_key_ok_from_raw(const char *headers) {\r\n    const char *v = find_header_value(headers, \"X-API-Key\");\r\n    if (!v) return 0;\r\n\r\n"]
[900.99514, "o", "    char key[1024];\r\n    size_t i = 0;\r\n    while (v[i] && v[i] != '\\r' && v[i] != '\\n' && i + 1 < sizeof(key)) {\r\n        key[i] = v[i];\r\n        i++;\r\n"]
[900.995162, "o", "    }\r\n    key[i] = '\\0';\r\n\r\n    struct MHD_Connection *dummy = NULL;\r\n    (void)dummy;\r\n\r\n"]
[900.995181, "o", "    // auth.c expects a MHD_Connection; we can't supply one here. So implement comparison here by\r\n    // reading the trimmed key using the same file and trimming rules.\r\n    FILE *f = fopen(\"/app/config/api.key\", \"rb\");\r\n    if (!f) return 0;\r\n    char buf[4096];\r\n    size_t n = fread(buf, 1, sizeof(buf) - 1, f);\r\n    fclose(f);\r\n"]
[900.995199, "o", "    buf[n] = '\\0';\r\n\r\n    char *s = buf;\r\n    while (*s && isspace((unsigned char)*s)) s++;\r\n"]
[900.995244, "o", "    size_t slen = strlen(s);\r\n    while (slen > 0 && isspace((unsigned char)s[slen - 1])) {\r\n        s[slen - 1] = '\\0';\r\n        slen--;\r\n    }\r\n"]
[900.996432, "o", "\r\n    return (s[0] != '\\0' && strcmp(s, key) == 0);\r\n}\r\n\r\nstatic int parse_qp_int(const char *query, const char *key, int *out) {\r\n    if (!query) return 0;\r\n    size_t klen = strlen(key);\r\n    const char *p = query;\r\n    while (*p) {\r\n        if (strncmp(p, key, klen) == 0 && p[klen] == '=') {\r\n            p += klen + 1;\r\n            *out = atoi(p);\r\n            return 1;\r\n        }\r\n        const char *amp = strchr(p, '&');\r\n        if (!amp) break;\r\n        p = amp + 1;\r\n    }\r\n    return 0;\r\n}\r\n\r\nstatic int is_blank_title(const char *s) {\r\n    if (!s) return 1;\r\n    while (*s) {\r\n        if (!isspace((unsigned char)*s)) return 0;\r\n        s++;\r\n    }\r\n    return 1;\r\n}\r\n\r\nstatic char *json_extract_string(const char *json, const char *field) {\r\n    if (!json || !field) return NULL;\r\n    char pat[128];\r\n    snprintf(pat, sizeof(pat), \"\\\"%s\\\"\", field);\r\n    const char *p = strstr(json, pat);\r\n    if (!p) return NULL;\r\n    p += strlen(pat);\r\n    while (*p && isspace((unsigned char)*p)) p++;\r\n    if (*p != ':') return NULL;\r\n\u001b[?2004hroot@972cf0f30065:/app# "]
