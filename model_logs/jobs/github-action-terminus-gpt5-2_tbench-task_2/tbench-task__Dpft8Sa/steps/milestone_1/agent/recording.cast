[766.94542, "i", ");\n        return;\n    }\n\n    if (parse_note_id(path, &note_id) && strcmp(method, \"PUT\") == 0) {\n        if (!api_key_ok_from_raw(headers)) {\n            send_json(fd, 401, \"Unauthorized\", \"{\\\"error\\\":\\\"unauthorized\\\"}\");\n            free(req);\n            return;\n        }\n\n        if (!note_exists(note_id)) {\n            send_json(fd, 404, \"Not Found\", \"{\\\"error\\\":\\\"not found\\\"}\");\n            free(req);\n            return;\n        }\n\n        int cl = parse_content_length(headers);\n        char *body_copy = strndup(body, (size_t)cl);\n        if (!body_copy) {\n            send_json(fd, 400, \"Bad Request\", \"{\\\"error\\\":\\\"bad request\\\"}\");\n            free(req);\n            return;\n        }\n\n        char *title = json_extract_string(body_copy, \"title\");\n        char *content = json_extract_string(body_copy, \"content\");\n        if (!content) content = strdup(\"\");\n\n        if (!title || is_blank_title(title)) {\n            free(title);\n            free(content);\n            free(body_copy);\n            send_json(fd, 400, \"Bad Request\", \"{\\\"error\\\":\\\"invalid title\\\"}\");\n            free(req);\n            return;\n        }\n\n        if (!update_note(note_id, title, content)) {\n            // if it disappeared, still return not found per contract\n            send_json(fd, 404, \"Not Found\", \"{\\\"error\\\":\\\"not found\\\"}\");\n        } else {\n            char *note_json = get_note_json(note_id);\n            if (!note_json) note_json = strdup(\"{\\\"error\\\":\\\"internal\\\"}\");\n            send_json(fd, 200, \"OK\", note_json);\n            free(note_json);\n        }\n\n        free(title);\n        free(content);\n        free(body_copy);\n        free(req);\n        return;\n    }\n\n    if (parse_note_id(path, &note_id) && strcmp(method, \"DELETE\") == 0) {\n        if (!api_key_ok_from_raw(headers)) {\n            send_json(fd, 401, \"Unauthorized\", \"{\\\"error\\\":\\\"unauthorized\\\"}\");\n            free(req);\n            return;\n        }\n        if (!delete_note(note_id)) {\n            send_json(fd, 404, \"Not Found\", \"{\\\"error\\\":\\\"not found\\\"}\");\n        } else {\n            send_json(fd, 200, \"OK\", \"{\\\"status\\\":\\\"deleted\\\"}\");\n        }\n        free(req);\n        return;\n    }\n\n    if (is_api) {\n        send_json(fd, 404, \"Not Found\", \"{\\\"error\\\":\\\"not found\\\"}\");\n        free(req);\n        return;\n    }\n\n    // Static serving only supports GET\n    if (strcmp(method, \"GET\") != 0) {\n        send_simple(fd, 405, \"Method Not Allowed\", \"text/plain\", \"Method Not Allowed\");\n        free(req);\n        return;\n    }\n\n    // For static, reject percent-encoding to satisfy traversal constraints.\n    if (strchr(target, '%') != NULL) {\n        send_simple(fd, 403, \"Forbidden\", \"text/plain\", \"Forbidden\");\n        free(req);\n        return;\n    }\n\n    char decoded[2048];\n    if (percent_decode(target, decoded, sizeof(decoded)) != 0) {\n        send_simple(fd, 403, \"Forbidden\", \"text/plain\", \"Forbidden\");\n        free(req);\n        return;\n    }\n\n    if (strstr(target, \"..\") != NULL || strstr(decoded, \"..\") != NULL ||\n        has_dot_segments_or_backslash(target) || has_dot_segments_or_backslash(decoded)) {\n        send_simple(fd, 403, \"Forbidden\", \"text/plain\", \"Forbidden\");\n        free(req);\n        return;\n    }\n\n    const char *url_path = decoded;\n    if (strcmp(url_path, \"/\") == 0) url_path = \"/index.html\";\n\n    char fs_path[512];\n    if (snprintf(fs_path, sizeof(fs_path), \"%s%s\", WWW_DIR, url_path) >= (int)sizeof(fs_path)) {\n        send_simple(fd, 404, \"Not Found\", \"text/plain\", \"Not Found\");\n        free(req);\n        return;\n    }\n\n    send_file(fd, fs_path);\n    free(req);\n}\n\nint main(void) {\n    signal(SIGINT, on_signal);\n    signal(SIGTERM, on_signal);\n\n    mkdir(\"/app/data\", 0755);\n    if (init_db(\"/app/data/notes.db\") != 0) {\n        fprintf(stderr, \"Failed to initialize database\\n\");\n        return 1;\n    }\n\n    g_listen_fd = socket(AF_INET, SOCK_STREAM, 0);\n    if (g_listen_fd < 0) {\n        perror(\"socket\");\n        return 1;\n    }\n\n    int one = 1;\n    setsockopt(g_listen_fd, SOL_SOCKET, SO_REUSEADDR, &one, sizeof(one));\n\n    struct sockaddr_in addr;\n    "]
[766.945569, "i", "memset(&addr, 0, sizeof(addr));\n    addr.sin_family = AF_INET;\n    addr.sin_port = htons(PORT);\n    addr.sin_addr.s_addr = htonl(INADDR_ANY);\n\n    if (bind(g_listen_fd, (struct sockaddr *)&addr, sizeof(addr)) != 0) {\n        perror(\"bind\");\n        return 1;\n    }\n\n    if (listen(g_listen_fd, 128) != 0) {\n        perror(\"listen\");\n        return 1;\n    }\n\n    printf(\"Server running on port %d\\n\", PORT);\n\n    while (!g_stop) {\n        int cfd = accept(g_listen_fd, NULL, NULL);\n        if (cfd < 0) {\n            if (errno == EINTR) continue;\n            break;\n        }\n        handle_client(cfd);\n        close(cfd);\n    }\n\n    if (g_listen_fd >= 0) close(g_listen_fd);\n    close_db();\n    return 0;\n}\nEOF\n"]
