[766.773228, "i", "cat >/app/src/main.c <<'EOF'\n#define _GNU_SOURCE\n\n#include \"auth.h\"\n#include \"db.h\"\n\n#include <arpa/inet.h>\n#include <ctype.h>\n#include <errno.h>\n#include <netinet/in.h>\n#include <signal.h>\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <sys/socket.h>\n#include <sys/stat.h>\n#include <unistd.h>\n\n#define PORT 8080\n#define WWW_DIR \"/app/www\"\n#define MAX_BODY 65536\n\nstatic volatile sig_atomic_t g_stop = 0;\nstatic int g_listen_fd = -1;\n\nstatic void on_signal(int sig) {\n    (void)sig;\n    g_stop = 1;\n    if (g_listen_fd >= 0) close(g_listen_fd);\n}\n\nstatic int write_all(int fd, const void *buf, size_t len) {\n    const char *p = (const char *)buf;\n    while (len > 0) {\n        ssize_t n = write(fd, p, len);\n        if (n < 0) {\n            if (errno == EINTR) continue;\n            return -1;\n        }\n        p += (size_t)n;\n        len -= (size_t)n;\n    }\n    return 0;\n}\n\nstatic const char *content_type_for_path(const char *path) {\n    const char *ext = strrchr(path, '.');\n    if (!ext) return \"application/octet-stream\";\n    if (strcmp(ext, \".html\") == 0) return \"text/html\";\n    if (strcmp(ext, \".js\") == 0) return \"application/javascript\";\n    if (strcmp(ext, \".css\") == 0) return \"text/css\";\n    if (strcmp(ext, \".png\") == 0) return \"image/png\";\n    if (strcmp(ext, \".jpg\") == 0 || strcmp(ext, \".jpeg\") == 0) return \"image/jpeg\";\n    if (strcmp(ext, \".svg\") == 0) return \"image/svg+xml\";\n    return \"application/octet-stream\";\n}\n\nstatic void send_simple(int fd, int code, const char *reason,\n                        const char *content_type, const char *body) {\n    size_t blen = body ? strlen(body) : 0;\n    char hdr[512];\n    int n = snprintf(hdr, sizeof(hdr),\n                     \"HTTP/1.1 %d %s\\r\\n\"\n                     \"Connection: close\\r\\n\"\n                     \"Content-Type: %s\\r\\n\"\n                     \"Content-Length: %zu\\r\\n\"\n                     \"\\r\\n\",\n                     code, reason, content_type, blen);\n    if (n > 0) write_all(fd, hdr, (size_t)n);\n    if (body) write_all(fd, body, blen);\n}\n\nstatic void send_json(int fd, int code, const char *reason, const char *body) {\n    size_t blen = body ? strlen(body) : 0;\n    char hdr[768];\n    int n = snprintf(hdr, sizeof(hdr),\n                     \"HTTP/1.1 %d %s\\r\\n\"\n                     \"Connection: close\\r\\n\"\n                     \"Content-Type: application/json\\r\\n\"\n                     \"Access-Control-Allow-Origin: *\\r\\n\"\n                     \"Access-Control-Allow-Methods: GET, POST, PUT, DELETE, OPTIONS\\r\\n\"\n                     \"Access-Control-Allow-Headers: Content-Type, X-API-Key\\r\\n\"\n                     \"Content-Length: %zu\\r\\n\"\n                     \"\\r\\n\",\n                     code, reason, blen);\n    if (n > 0) write_all(fd, hdr, (size_t)n);\n    if (body) write_all(fd, body, blen);\n}\n\nstatic void send_json_total(int fd, int code, const char *reason, const char *body, int total) {\n    size_t blen = body ? strlen(body) : 0;\n    char hdr[900];\n    int n = snprintf(hdr, sizeof(hdr),\n                     \"HTTP/1.1 %d %s\\r\\n\"\n                     \"Connection: close\\r\\n\"\n                     \"Content-Type: application/json\\r\\n\"\n                     \"Access-Control-Allow-Origin: *\\r\\n\"\n                     \"Access-Control-Allow-Methods: GET, POST, PUT, DELETE, OPTIONS\\r\\n\"\n                     \"Access-Control-Allow-Headers: Content-Type, X-API-Key\\r\\n\"\n                     \"X-Total-Count: %d\\r\\n\"\n                     \"Content-Length: %zu\\r\\n\"\n                     \"\\r\\n\",\n                     code, reason, total, blen);\n    if (n > 0) write_all(fd, hdr, (size_t)n);\n    if (body) write_all(fd, body, blen);\n}\n\nstatic void send_file(int fd, const char *fs_path) {\n    struct stat st;\n    if (stat(fs_path, &st) != 0 || !S_ISREG(st.st_mode)) {\n        send_simple(fd, 404, \"Not Found\", \"text/plain\", \"Not Found\");\n        return;\n    }\n\n    FILE *f = fopen(fs_path, \"rb\");\n    if (!f) {\n        send_simple(fd, 404, \"Not Found\", \"text/plain\", \"Not Found\");\n        return;\n    }\n\n    char hdr[512];\n    const char *ct = content_type_for_path(fs_path);\n    int n = sn"]
[766.773404, "i", "printf(hdr, sizeof(hdr),\n                     \"HTTP/1.1 200 OK\\r\\n\"\n                     \"Connection: close\\r\\n\"\n                     \"Content-Type: %s\\r\\n\"\n                     \"Content-Length: %zu\\r\\n\"\n                     \"\\r\\n\",\n                     ct, (size_t)st.st_size);\n    if (n > 0) write_all(fd, hdr, (size_t)n);\n\n    char buf[4096];\n    size_t r;\n    while ((r = fread(buf, 1, sizeof(buf), f)) > 0) {\n        if (write_all(fd, buf, r) != 0) break;\n    }\n    fclose(f);\n}\n\nstatic int has_dot_segments_or_backslash(const char *s) {\n    if (!s) return 0;\n    if (strchr(s, '\\\\') != NULL) return 1;\n    if (strstr(s, \"/./\") != NULL) return 1;\n    if (strstr(s, \"/../\") != NULL) return 1;\n    size_t n = strlen(s);\n    if (n >= 2 && strcmp(s + n - 2, \"/.\") == 0) return 1;\n    if (n >= 3 && strcmp(s + n - 3, \"/..\") == 0) return 1;\n    return 0;\n}\n\nstatic int percent_decode(const char *in, char *out, size_t out_sz) {\n    size_t oi = 0;\n    for (size_t i = 0; in[i]; i++) {\n        if (oi + 1 >= out_sz) return -1;\n        if (in[i] == '%') {\n            if (!isxdigit((unsigned char)in[i + 1]) || !isxdigit((unsigned char)in[i + 2])) return -1;\n            char tmp[3] = {in[i + 1], in[i + 2], 0};\n            out[oi++] = (char)strtol(tmp, NULL, 16);\n            i += 2;\n        } else {\n            out[oi++] = in[i];\n        }\n    }\n    out[oi] = 0;\n    return 0;\n}\n\nstatic const char *find_header_value(const char *headers, const char *name) {\n    size_t nlen = strlen(name);\n    const char *p = headers;\n    while (*p) {\n        const char *line_end = strstr(p, \"\\r\\n\");\n        if (!line_end) break;\n        if (line_end == p) break;\n\n        if (strncasecmp(p, name, nlen) == 0 && p[nlen] == ':') {\n            const char *v = p + nlen + 1;\n            while (*v == ' ' || *v == '\\t') v++;\n            return v;\n        }\n        p = line_end + 2;\n    }\n    return NULL;\n}\n\nstatic int parse_content_length(const char *headers) {\n    const char *v = find_header_value(headers, \"Content-Length\");\n    if (!v) return 0;\n    return atoi(v);\n}\n\nstatic int api_key_ok_from_raw(const char *headers) {\n    const char *v = find_header_value(headers, \"X-API-Key\");\n    if (!v) return 0;\n\n    char key[1024];\n    size_t i = 0;\n    while (v[i] && v[i] != '\\r' && v[i] != '\\n' && i + 1 < sizeof(key)) {\n        key[i] = v[i];\n        i++;\n    }\n    key[i] = '\\0';\n\n    struct MHD_Connection *dummy = NULL;\n    (void)dummy;\n\n    // auth.c expects a MHD_Connection; we can't supply one here. So implement comparison here by\n    // reading the trimmed key using the same file and trimming rules.\n    FILE *f = fopen(\"/app/config/api.key\", \"rb\");\n    if (!f) return 0;\n    char buf[4096];\n    size_t n = fread(buf, 1, sizeof(buf) - 1, f);\n    fclose(f);\n    buf[n] = '\\0';\n\n    char *s = buf;\n    while (*s && isspace((unsigned char)*s)) s++;\n    size_t slen = strlen(s);\n    while (slen > 0 && isspace((unsigned char)s[slen - 1])) {\n        s[slen - 1] = '\\0';\n        slen--;\n    }\n\n    return (s[0] != '\\0' && strcmp(s, key) == 0);\n}\n\nstatic int parse_qp_int(const char *query, const char *key, int *out) {\n    if (!query) return 0;\n    size_t klen = strlen(key);\n    const char *p = query;\n    while (*p) {\n        if (strncmp(p, key, klen) == 0 && p[klen] == '=') {\n            p += klen + 1;\n            *out = atoi(p);\n            return 1;\n        }\n        const char *amp = strchr(p, '&');\n        if (!amp) break;\n        p = amp + 1;\n    }\n    return 0;\n}\n\nstatic int is_blank_title(const char *s) {\n    if (!s) return 1;\n    while (*s) {\n        if (!isspace((unsigned char)*s)) return 0;\n        s++;\n    }\n    return 1;\n}\n\nstatic char *json_extract_string(const char *json, const char *field) {\n    if (!json || !field) return NULL;\n    char pat[128];\n    snprintf(pat, sizeof(pat), \"\\\"%s\\\"\", field);\n    const char *p = strstr(json, pat);\n    if (!p) return NULL;\n    p += strlen(pat);\n    while (*p && isspace((unsigned char)*p)) p++;\n    if (*p != ':') return NULL;\n    p++;\n    while (*p && isspace((unsigned char)*p)) p++;\n    if (*p != '\"') return NULL;\n    p++;\n\n    size_t "]
[766.773495, "i", "cap = 64, len = 0;\n    char *out = malloc(cap);\n    if (!out) return NULL;\n\n    while (*p && *p != '\"') {\n        char c = *p++;\n        if (c == '\\\\') {\n            char e = *p++;\n            if (e == '\"' || e == '\\\\' || e == '/') c = e;\n            else if (e == 'n') c = '\\n';\n            else if (e == 'r') c = '\\r';\n            else if (e == 't') c = '\\t';\n            else {\n                // unsupported escape; treat as invalid\n                free(out);\n                return NULL;\n            }\n        }\n        if (len + 2 > cap) {\n            cap *= 2;\n            char *nb = realloc(out, cap);\n            if (!nb) {\n                free(out);\n                return NULL;\n            }\n            out = nb;\n        }\n        out[len++] = c;\n    }\n    if (*p != '\"') {\n        free(out);\n        return NULL;\n    }\n    out[len] = '\\0';\n    return out;\n}\n\nstatic int parse_note_id(const char *path, int *out_id) {\n    const char *prefix = \"/api/notes/\";\n    size_t plen = strlen(prefix);\n    if (strncmp(path, prefix, plen) != 0) return 0;\n    const char *p = path + plen;\n    if (!*p) return 0;\n    for (const char *q = p; *q; q++) {\n        if (!isdigit((unsigned char)*q)) return 0;\n    }\n    *out_id = atoi(p);\n    return 1;\n}\n\nstatic int read_full_request(int fd, char **out, size_t *out_len) {\n    size_t cap = 16384;\n    size_t len = 0;\n    char *buf = malloc(cap);\n    if (!buf) return -1;\n\n    while (1) {\n        if (len == cap) {\n            cap *= 2;\n            char *nb = realloc(buf, cap);\n            if (!nb) {\n                free(buf);\n                return -1;\n            }\n            buf = nb;\n        }\n        ssize_t n = read(fd, buf + len, cap - len);\n        if (n < 0) {\n            if (errno == EINTR) continue;\n            free(buf);\n            return -1;\n        }\n        if (n == 0) break;\n        len += (size_t)n;\n        if (len >= 4 && strstr(buf, \"\\r\\n\\r\\n\") != NULL) break;\n        if (len > 1024 * 1024) break;\n    }\n\n    *out = buf;\n    *out_len = len;\n    return 0;\n}\n\nstatic void handle_client(int fd) {\n    char *req = NULL;\n    size_t req_len = 0;\n    if (read_full_request(fd, &req, &req_len) != 0) return;\n    req = realloc(req, req_len + 1);\n    if (!req) return;\n    req[req_len] = '\\0';\n\n    char *hdr_end = strstr(req, \"\\r\\n\\r\\n\");\n    if (!hdr_end) {\n        free(req);\n        send_simple(fd, 400, \"Bad Request\", \"text/plain\", \"Bad Request\");\n        return;\n    }\n\n    char *line_end = strstr(req, \"\\r\\n\");\n    if (!line_end) {\n        free(req);\n        send_simple(fd, 400, \"Bad Request\", \"text/plain\", \"Bad Request\");\n        return;\n    }\n    *line_end = '\\0';\n\n    char method[16], target[2048];\n    if (sscanf(req, \"%15s %2047s\", method, target) != 2) {\n        free(req);\n        send_simple(fd, 400, \"Bad Request\", \"text/plain\", \"Bad Request\");\n        return;\n    }\n\n    const char *headers = line_end + 2;\n    char *body = hdr_end + 4;\n    size_t have_body = req_len - (size_t)(body - req);\n\n    // Parse target into path + query\n    char target_copy[2048];\n    strncpy(target_copy, target, sizeof(target_copy) - 1);\n    target_copy[sizeof(target_copy) - 1] = '\\0';\n    char *query = strchr(target_copy, '?');\n    if (query) *query++ = '\\0';\n    const char *path = target_copy;\n\n    int is_api = (strncmp(path, \"/api/\", 5) == 0);\n\n    if (is_api && strcmp(method, \"OPTIONS\") == 0) {\n        send_json(fd, 200, \"OK\", \"\");\n        free(req);\n        return;\n    }\n\n    if (is_api && (strcmp(method, \"POST\") == 0 || strcmp(method, \"PUT\") == 0)) {\n        int cl = parse_content_length(headers);\n        if (cl > MAX_BODY) {\n            send_json(fd, 413, \"Payload Too Large\", \"{\\\"error\\\":\\\"payload too large\\\"}\");\n            free(req);\n            return;\n        }\n\n        // If body not fully read yet, read remainder\n        while ((int)have_body < cl) {\n            char tmp[4096];\n            ssize_t n = read(fd, tmp, sizeof(tmp));\n            if (n < 0) {\n                if (errno == EINTR) continue;\n                break;\n            }\n            if (n == 0) break;\n            size_t need = req_len + "]
[766.773588, "i", "(size_t)n;\n            char *nb = realloc(req, need + 1);\n            if (!nb) break;\n            req = nb;\n            memcpy(req + req_len, tmp, (size_t)n);\n            req_len = need;\n            req[req_len] = '\\0';\n            // body pointer may have moved\n            hdr_end = strstr(req, \"\\r\\n\\r\\n\");\n            body = hdr_end ? hdr_end + 4 : req;\n            have_body = req_len - (size_t)(body - req);\n            if ((int)have_body > MAX_BODY) {\n                send_json(fd, 413, \"Payload Too Large\", \"{\\\"error\\\":\\\"payload too large\\\"}\");\n                free(req);\n                return;\n            }\n        }\n\n        if ((int)have_body > MAX_BODY) {\n            send_json(fd, 413, \"Payload Too Large\", \"{\\\"error\\\":\\\"payload too large\\\"}\");\n            free(req);\n            return;\n        }\n    }\n\n    if (strcmp(path, \"/api/notes\") == 0 && strcmp(method, \"GET\") == 0) {\n        int limit = 50;\n        int offset = 0;\n        parse_qp_int(query, \"limit\", &limit);\n        parse_qp_int(query, \"offset\", &offset);\n        if (limit <= 0) limit = 50;\n        if (limit > 100) limit = 100;\n        if (offset < 0) offset = 0;\n\n        int total = get_total_notes_count();\n        char *json = get_notes_paginated_json(limit, offset);\n        if (!json) json = strdup(\"[]\");\n        send_json_total(fd, 200, \"OK\", json, total);\n        free(json);\n        free(req);\n        return;\n    }\n\n    int note_id = 0;\n    if (parse_note_id(path, &note_id) && strcmp(method, \"GET\") == 0) {\n        char *json = get_note_json(note_id);\n        if (!json) {\n            send_json(fd, 404, \"Not Found\", \"{\\\"error\\\":\\\"not found\\\"}\");\n        } else {\n            send_json(fd, 200, \"OK\", json);\n            free(json);\n        }\n        free(req);\n        return;\n    }\n\n    if (strcmp(path, \"/api/notes\") == 0 && strcmp(method, \"POST\") == 0) {\n        if