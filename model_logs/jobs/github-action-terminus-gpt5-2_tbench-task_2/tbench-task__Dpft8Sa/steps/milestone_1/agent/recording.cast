[657.779735, "o", "\t    signal(SIGTERM, on_signal);\r\n   205\t\r\n   206\t    mkdir(\"/app/data\", 0755);\r\n   207\t    if (init_db(\"/app/data/notes.db\") != 0) {\r\n   208\t        fprintf(stderr, \"Failed to initialize database\\n\");\r\n   209\t        return 1;\r\n   210\t    }\r\n   211\t\r\n   212\t    g_listen_fd = socket(AF_INET, SOCK_STREAM, 0);\r\n   213\t    if (g_listen_fd < 0) {\r\n   214\t        perror(\"socket\");\r\n   215\t        return 1;\r\n   216\t    }\r\n   217\t\r\n   218\t    int one = 1;\r\n   219\t    setsockopt(g_listen_fd, SOL_SOCKET, SO_REUSEADDR, &one, sizeof(one));\r\n   220\t\r\n   221\t    struct sockaddr_in addr;\r\n   222\t    memset(&addr, 0, sizeof(addr));\r\n   223\t    addr.sin_family = AF_INET;\r\n   224\t    addr.sin_port = htons(PORT);\r\n   225\t    addr.sin_addr.s_addr = htonl(INADDR_ANY);\r\n   226\t\r\n   227\t    if (bind(g_listen_fd, (struct sockaddr *)&addr, sizeof(addr)) != 0) {\r\n   228\t        perror(\"bind\");\r\n   229\t        return 1;\r\n   230\t    }\r\n   231\t\r\n   232\t    if (listen(g_listen_fd, 128) != 0) {\r\n   233\t        perror(\"listen\");\r\n   234\t        return 1;\r\n   235\t    }\r\n   236\t\r\n   237\t    printf(\"Server running on port %d\\n\", PORT);\r\n   238\t\r\n   239\t    while (!g_stop) {\r\n   240\t        int cfd = accept(g_listen_fd, NULL, NULL);\r\n   241\t        if (cfd < 0) {\r\n   242\t            if (errno == EINTR) continue;\r\n   243\t            break;\r\n   244\t        }\r\n   245\t        handle_client(cfd);\r\n   246\t        close(cfd);\r\n   247\t    }\r\n   248\t\r\n   249\t    if (g_listen_fd >= 0) close(g_listen_fd);\r\n   250\t    close_db();\r\n   251\t    return 0;\r\n   252\t}\r\n"]
