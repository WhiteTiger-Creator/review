[191.515353, "o", "\u001b[?2004h"]
[191.515374, "o", "> "]
[191.515505, "o", "    if (strcmp(method, \"GET\") == 0) {\r\n\u001b[?2004l\r"]
[191.515533, "o", "\u001b[?2004h> "]
