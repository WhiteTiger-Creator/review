[422.151139, "o", "\u001b[?2004h> "]
[422.151357, "o", "            int hi = hexval(src[si + 1]);\r\n\u001b[?2004l\r"]
[422.151489, "o", "\u001b[?2004h> "]
[422.151667, "o", "            int lo = hexval(src[si + 2]);\r\n\u001b[?2004l\r"]
[422.151794, "o", "\u001b[?2004h> "]
[422.151966, "o", "            if (hi >= 0 && lo >= 0) {\r\n\u001b[?2004l\r"]
[422.15204, "o", "\u001b[?2004h> "]
[422.152361, "o", "                dst[di++] = (char)((hi << 4) | lo);\r\n\u001b[?2004l\r"]
