[505.076721, "o", "\u001b[?2004h"]
[505.076739, "o", "> "]
[505.076977, "o", "    if (percent_decode(target, decoded, sizeof(decoded)) != 0) {\r\n\u001b[?2004l\r"]
[505.077003, "o", "\u001b[?2004h"]
[505.077021, "o", "> "]
[505.077243, "o", "        send_simple(fd, 403, \"Forbidden\", \"text/plain\", \"Forbidden\");\r\n\u001b[?2004l\r"]
[505.077273, "o", "\u001b[?2004h"]
[505.077292, "o", "> "]
[505.077391, "o", "        return;\r\n\u001b[?2004l\r\u001b[?2004h"]
[505.07749, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[505.077525, "o", "\u001b[?2004h> "]
[505.077764, "o", "    if (strstr(target, \"..\") != NULL || strstr(decoded, \"..\") != NULL ||\r\n\u001b[?2004l\r"]
[505.077869, "o", "\u001b[?2004h> "]
[505.078085, "o", "        has_dot_segments_or_backslash(target) || has_dot_segments_or_backslash(decoded)) {\r\n\u001b[?2004l\r"]
[505.078175, "o", "\u001b[?2004h> "]
[505.07836, "o", "        send_simple(fd, 403, \"Forbidden\", \"text/plain\", \"Forbidden\");\r\n\u001b[?2004l\r"]
[505.078457, "o", "\u001b[?2004h> "]
[505.078541, "o", "        return;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
