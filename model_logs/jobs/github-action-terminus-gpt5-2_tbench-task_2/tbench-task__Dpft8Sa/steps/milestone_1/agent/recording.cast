[505.078738, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[505.07884, "o", "    const char *url_path = decoded;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[505.079017, "o", "    if (strcmp(url_path, \"/\") == 0) url_path = \"/index.html\";\r\n\u001b[?2004l\r"]
[505.079096, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
