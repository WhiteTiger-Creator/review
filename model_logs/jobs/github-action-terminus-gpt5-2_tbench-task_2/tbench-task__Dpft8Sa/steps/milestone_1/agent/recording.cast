[468.879188, "o", "\u001b[01m\u001b[Ksrc/main.c:226:9:\u001b[m\u001b[K \u001b[01;31m\u001b[Kerror: \u001b[m\u001b[Kexpected ‘\u001b[01m\u001b[K=\u001b[m\u001b[K’, ‘\u001b[01m\u001b[K,\u001b[m\u001b[K’, ‘\u001b[01m\u001b[K;\u001b[m\u001b[K’, ‘\u001b[01m\u001b[Kasm\u001b[m\u001b[K’ or ‘\u001b[01m\u001b[K__attribute__\u001b[m\u001b[K’ before ‘\u001b[01m\u001b[K.\u001b[m\u001b[K’ token\r\n  226 |     addr\u001b[01;31m\u001b[K.\u001b[m\u001b[Ksin_addr.s_addr = htonl(INADDR_ANY);\r\n      |         \u001b[01;31m\u001b[K^\u001b[m\u001b[K\r\n"]
