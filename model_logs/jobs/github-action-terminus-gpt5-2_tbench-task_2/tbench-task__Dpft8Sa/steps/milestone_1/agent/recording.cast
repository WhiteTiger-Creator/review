[191.511653, "o", "\u001b[?2004h"]
[191.511702, "o", "> "]
[191.511789, "o", "    if (con_cls && *con_cls) {\r\n\u001b[?2004l\r"]
[191.511823, "o", "\u001b[?2004h> "]
