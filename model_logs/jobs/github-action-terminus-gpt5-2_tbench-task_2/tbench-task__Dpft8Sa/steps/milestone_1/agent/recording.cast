[505.057381, "o", "\u001b[?2004h> "]
[505.057575, "o", "        size_t len = (size_t)(p - seg);\r\n\u001b[?2004l\r"]
[505.057608, "o", "\u001b[?2004h> "]
[505.057928, "o", "        if (len == 1 && seg[0] == '.') return 1;\r\n\u001b[?2004l\r"]
[505.058079, "o", "\u001b[?2004h> "]
