[505.069576, "o", "\u001b[?2004h> "]
[505.06968, "o", "    if (n > 0) write_all(fd, hdr, (size_t)n);\r\n\u001b[?2004l\r\u001b[?2004h"]
[505.069747, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[505.069843, "o", ">     char buf[4096];\r\n\u001b[?2004l\r\u001b[?2004h> "]
[505.069943, "o", "    size_t r;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[505.070109, "o", "    while ((r = fread(buf, 1, sizeof(buf), f)) > 0) {\r\n\u001b[?2004l\r"]
[505.070213, "o", "\u001b[?2004h> "]
[505.070311, "o", "        if (write_all(fd, buf, r) != 0) break;\r\n\u001b[?2004l\r"]
[505.070414, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[505.070527, "o", "\u001b[?2004h>     fclose(f);\r\n\u001b[?2004l\r\u001b[?2004h"]
[505.070594, "o", "> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[505.070683, "o", "\u001b[?2004h> "]
[505.070754, "o", "static void handle_client(int fd) {\r\n\u001b[?2004l\r"]
[505.070785, "o", "\u001b[?2004h> "]
[505.070862, "o", "    char req[8192];\r\n\u001b[?2004l\r"]
[505.070928, "o", "\u001b[?2004h> "]
[505.071087, "o", "    ssize_t n = read(fd, req, sizeof(req) - 1);\r\n\u001b[?2004l\r"]
[505.071193, "o", "\u001b[?2004h> "]
[505.071283, "o", "    if (n <= 0) return;\r\n\u001b[?2004l\r"]
[505.071316, "o", "\u001b[?2004h> "]
[505.071387, "o", "    req[n] = '\\0';\r\n\u001b[?2004l\r\u001b[?2004h> "]
[505.071416, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[505.071439, "o", "> "]
