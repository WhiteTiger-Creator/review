[191.508461, "o", "\u001b[?2004h> "]
[191.508622, "o", "    size_t n = fread(buf, 1, (size_t)st.st_size, f);\r\n\u001b[?2004l\r"]
[191.508692, "o", "\u001b[?2004h> "]
[191.508722, "o", "    fclose(f);\r\n\u001b[?2004l\r"]
[191.50881, "o", "\u001b[?2004h> "]
[191.508908, "o", "    if (n != (size_t)st.st_size) {\r\n\u001b[?2004l\r"]
[191.508936, "o", "\u001b[?2004h> "]
