[886.387523, "o", "/app/src/auth.c:8:static char *g_api_key = NULL;\r\n/app/src/auth.c:10:static void rstrip_inplace(char *s) {\r\n/app/src/auth.c:19:static char *lstrip(char *s) {\r\n/app/src/auth.c:24:static const char *load_api_key(void) {\r\n/app/src/auth.c:48:    const char *got = MHD_lookup_connection_value(connection, MHD_HEADER_KIND, \"X-API-Key\");\r\n/app/src/db.c:11:static sqlite3 *g_db = NULL;\r\n/app/src/db.c:12:static pthread_mutex_t g_db_mu = PTHREAD_MUTEX_INITIALIZER;\r\n/app/src/db.c:14:static int exec_sql(const char *sql) {\r\n/app/src/db.c:66:static void sb_append(char **buf, size_t *cap, size_t *len, const char *s) {\r\n/app/src/db.c:81:static char *json_escape(const unsigned char *s) {\r\n/app/src/main.c:19:#define WWW_DIR \"/app/www\"\r\n/app/src/main.c:22:static volatile sig_atomic_t g_stop = 0;\r\n/app/src/main.c:23:static int g_listen_fd = -1;\r\n/app/src/main.c:25:static void on_signal(int sig) {\r\n/app/src/main.c:31:static int write_all(int fd, const void *buf, size_t len) {\r\n/app/src/main.c:45:static const char *content_type_for_path(const char *path) {\r\n/app/src/main.c:57:static void send_simple(int fd, int code, const char *reason,\r\n/app/src/main.c:72:static void send_json(int fd, int code, const char *reason, const char *body) {\r\n/app/src/main.c:89:static void send_json_total(int fd, int code, const char *reason, const char *body, int total) {\r\n/app/src/main.c:107:static void send_file(int fd, const char *fs_path) {\r\n/app/src/main.c:139:static int has_dot_segments_or_backslash(const char *s) {\r\n/app/src/main.c:150:static int percent_decode(const char *in, char *out, size_t out_sz) {\r\n/app/src/main.c:167:static const char *find_header_value(const char *headers, const char *name) {\r\n/app/src/main.c:185:static int parse_content_length(const char *headers) {\r\n/app/src/main.c:191:static int api_key_ok_from_raw(const char *headers) {\r\n/app/src/main.c:226:static int parse_qp_int(const char *query, const char *key, int *out) {\r\n/app/src/main.c:243:static int is_blank_title(const char *s) {\r\n/app/src/main.c:252:static char *json_extract_string(const char *json, const char *field) {\r\n/app/src/main.c:303:static int parse_note_id(const char *path, int *out_id) {\r\n/app/src/main.c:316:static int read_full_request(int fd, char **out, size_t *out_len) {\r\n/app/src/main.c:349:static void handle_client(int fd) {\r\n/app/src/main.c:600:        send_simple(fd, 405, \"Method Not Allowed\", \"text/plain\", \"Method Not Allowed\");\r\n/app/src/main.c:605:    // For static, reject percent-encoding to satisfy traversal constraints.\r\n/app/src/routes.c:8:static enum MHD_Result send_json(struct MHD_Connection *connection,\r\n/app/src/routes.c:23:static enum MHD_Result send_json_total(struct MHD_Connection *connection,\r\n/app/src/routes.c:42:static void request_completed(void *cls, struct MHD_Connection *connection,\r\n/app/src/static.c:1:#include \"static.h\"\r\n/app/src/static.c:3:enum MHD_Result serve_static_file(struct MHD_Connection *connection, const char *url) {\r\n/app/src/static.h:6:enum MHD_Result serve_static_file(struct MHD_Connection *connection, const char *url);\r\n"]
