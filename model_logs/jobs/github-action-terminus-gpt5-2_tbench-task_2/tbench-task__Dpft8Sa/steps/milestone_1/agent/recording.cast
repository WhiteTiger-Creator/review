       const char *seg = p;\r\n    69\t        while (*p && *p != '/') p++;\r\n    70\t        size_t len = (size_t)(p - seg);\r\n    71\t        if (len == 1 && seg[0] == '.') return 1;\r\n    72\t        if (len == 2 && seg[0] == '.' && seg[1] == '.') return 1;\r\n    73\t    }\r\n    74\t    return 0;\r\n    75\t}\r\n    76\t\r\n    77\tstatic int write_all(int fd, const void *buf, size_t n) {\r\n    78\t    const char *p = (const char *)buf;\r\n    79\t    while (n > 0) {\r\n    80\t        ssize_t w = write(fd, p, n);\r\n    81\t        if (w < 0) {\r\n    82\t            if (errno == EINTR) continue;\r\n    83\t            return -1;\r\n    84\t        }\r\n    85\t        p += (size_t)w;\r\n    86\t        n -= (size_t)w;\r\n    87\t    }\r\n    88\t    return 0;\r\n    89\t}\r\n    90\t\r\n"]
