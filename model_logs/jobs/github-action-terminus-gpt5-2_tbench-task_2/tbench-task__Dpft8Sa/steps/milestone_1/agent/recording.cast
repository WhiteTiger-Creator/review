[505.052118, "o", "\u001b[?2004h> "]
[505.052428, "o", "        if (src[si] == '%' && src[si + 1] && src[si + 2]) {\r\n\u001b[?2004l\r"]
[505.052561, "o", "\u001b[?2004h> "]
