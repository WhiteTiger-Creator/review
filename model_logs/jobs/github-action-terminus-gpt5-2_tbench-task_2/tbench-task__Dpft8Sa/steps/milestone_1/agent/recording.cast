[467.734263, "o", "   140\t    ssize_t n = read(fd, req, sizeof(req) - 1);\r\n   141\t    if (n <= 0) return;\r\n"]
[467.736531, "o", "   142\t    req[n] = '\\0';\r\n   143\t\r\n   144\t    char *line_end = strstr(req, \"\\r\\n\");\r\n   145\t    if (!line_end) line_end = strchr(req, '\\n');\r\n   146\t    if (!line_end) {\r\n   147\t        send_simple(fd, 400, \"Bad Request\", \"text/plain\", \"Bad Request\");\r\n   148\t        return;\r\n   149\t    }\r\n   150\t    *line_end = '\\0';\r\n   151\t\r\n   152\t    char method[16], target[2048];\r\n   153\t    if (sscanf(req, \"%15s %2047s\", method, target) != 2) {\r\n   154\t        send_simple(fd, 400, \"Bad Request\", \"text/plain\", \"Bad Request\");\r\n   155\t        return;\r\n   156\t    }\r\n   157\t\r\n   158\t    if (strcmp(method, \"GET\") != 0) {\r\n   159\t        send_simple(fd, 405, \"Method Not Allowed\", \"text/plain\", \"Method Not Allowed\");\r\n   160\t        return;\r\n   161\t    }\r\n   162\t\r\n   163\t    char *q = strchr(target, '?');\r\n   164\t    if (q) *q = '\\0';\r\n   165\t\r\n   166\t    if (strcmp(target, \"/api/notes\") == 0) {\r\n   167\t        send_simple(fd, 200, \"OK\", \"application/json\", \"[]\");\r\n   168\t        return;\r\n   169\t    }\r\n   170\t\r\n   171\t    /* If the client used percent-encoding in the path, treat it as suspicious.\r\n   172\t       We don't need it for required static assets, and it can be used for traversal. */\r\n   173\t    if (strchr(target, '%') != NULL) {\r\n   174\t        send_simple(fd, 403, \"Forbidden\", \"text/plain\", \"Forbidden\");\r\n   175\t        return;\r\n   176\t    }\r\n   177\t\r\n   178\t    char decoded[2048];\r\n   179\t    if (percent_decode(target, decoded, sizeof(decoded)) != 0) {\r\n   180\t        fprintf(stderr, \"DECODE_FAIL\\n\");\r\n   181\t        send_simple(fd, 403, \"Forbidden\", \"text/plain\", \"Forbidden\");\r\n   182\t        return;\r\n   183\t    }\r\n   184\t\r\n   185\t    if (strstr(target, \"..\") != NULL || strstr(decoded, \"..\") != NULL ||\r\n   186\t        has_dot_segments_or_backslash(target) || has_dot_segments_or_backslash(decoded)) {\r\n   187\t        send_simple(fd, 403, \"Forbidden\", \"text/plain\", \"Forbidden\");\r\n   188\t        return;\r\n   189\t    }\r\n   190\t\r\n   191\t    const char *url_path = decoded;\r\n   192\t    if (strcmp(url_path, \"/\") == 0) url_path = \"/index.html\";\r\n   193\t\r\n   194\t    char fs_path[512];\r\n   195\t    if (snprintf(fs_path, sizeof(fs_path), \"%s%s\", WWW_DIR, url_path) >= (int)sizeof(fs_path)) {\r\n   196\t        send_simple(fd, 404, \"Not Found\", \"text/plain\", \"Not Found\");\r\n   197\t        return;\r\n   198\t    }\r\n   199\t\r\n   200\t    send_file(fd, fs_path);\r\n   201\t}\r\n   202\t\r\n   203\tint main(void) {\r\n   204\t    signal(SIGINT, on_signal);\r\n   205\t    signal(SIGTERM, on_signal);\r\n   206\t\r\n   207\t    mkdir(\"/app/data\", 0755);\r\n   208\t    if (init_db(\"/app/data/notes.db\") != 0) {\r\n   209\t        fprintf(stderr, \"Failed to initialize database\\n\");\r\n   210\t        return 1;\r\n   211\t    }\r\n   212\t\r\n   213\t    g_listen_fd = socket(AF_INET, SOCK_STREAM, 0);\r\n   214\t    if (g_listen_fd < 0) {\r\n   215\t        perror(\"socket\");\r\n   216\t        return 1;\r\n   217\t    }\r\n   218\t\r\n   219\t    int one = 1;\r\n   220\t    setsockopt(g_listen_fd, SOL_SOCKET, SO_REUSEADDR, &one, sizeof(one));\r\n   221\t\r\n   222\t    struct sockaddr_in addr;\r\n   223\t    memset(&addr, 0, sizeof(addr));\r\n   224\t    addr.sin_family = AF_INET;\r\n   225\t    addr.sin_port = htons(PORT);\r\n   226\t    addr.sin_addr.s_addr = htonl(INADDR_ANY);\r\n   227\t\r\n   228\t    if (bind(g_listen_fd, (struct sockaddr *)&addr, sizeof(addr)) != 0) {\r\n   229\t        perror(\"bind\");\r\n   230\t        return 1;\r\n   231\t    }\r\n   232\t\r\n   233\t    if (listen(g_listen_fd, 128) != 0) {\r\n   234\t        perror(\"listen\");\r\n   235\t        return 1;\r\n   236\t    }\r\n   237\t\r\n   238\t    printf(\"Server running on port %d\\n\", PORT);\r\n   239\t\r\n   240\t    while (!g_stop) {\r\n"]
