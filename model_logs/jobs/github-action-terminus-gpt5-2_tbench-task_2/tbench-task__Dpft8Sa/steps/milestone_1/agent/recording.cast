[305.635958, "o", "        while (*p == '/') p++;\r\n\u001b[?2004l\r"]
[305.635991, "o", "\u001b[?2004h> "]
[305.636194, "o", "        const char *seg = p;\r\n\u001b[?2004l\r"]
[305.636229, "o", "\u001b[?2004h> "]
[305.636471, "o", "        while (*p && *p != '/') p++;\r\n\u001b[?2004l\r"]
[305.636504, "o", "\u001b[?2004h> "]
[305.636767, "o", "        size_t len = (size_t)(p - seg);\r\n\u001b[?2004l\r"]
[305.6368, "o", "\u001b[?2004h> "]
[305.637156, "o", "        if (len == 1 && seg[0] == '.') return 1;\r\n\u001b[?2004l\r"]
[305.637186, "o", "\u001b[?2004h> "]
[305.637622, "o", "        if (len == 2 && seg[0] == '.' && seg[1] == '.') return 1;\r\n\u001b[?2004l\r"]
[305.637655, "o", "\u001b[?2004h> "]
[305.637761, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[305.637864, "o", "    return 0;\r\n\u001b[?2004l\r"]
[305.637936, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h"]
[305.637975, "o", "> \r\n\u001b[?2004l\r"]
[305.638054, "o", "\u001b[?2004h"]
[305.638083, "o", "> "]
[305.638413, "o", "static int write_all(int fd, const void *buf, size_t n) {\r\n\u001b[?2004l\r"]
[305.638446, "o", "\u001b[?2004h> "]
[305.638693, "o", "    const char *p = (const char *)buf;\r\n\u001b[?2004l\r"]
[305.638724, "o", "\u001b[?2004h> "]
[305.638867, "o", "    while (n > 0) {\r\n\u001b[?2004l\r"]
[305.638936, "o", "\u001b[?2004h> "]
[305.639164, "o", "        ssize_t w = write(fd, p, n);\r\n\u001b[?2004l\r"]
[305.639297, "o", "\u001b[?2004h> "]
[305.639405, "o", "        if (w < 0) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[305.63969, "o", "            if (errno == EINTR) continue;\r\n\u001b[?2004l\r"]
[305.639721, "o", "\u001b[?2004h> "]
[305.639875, "o", "            return -1;\r\n\u001b[?2004l\r"]
[305.639905, "o", "\u001b[?2004h> "]
[305.640004, "o", "        }\r\n\u001b[?2004l\r"]
[305.640109, "o", "\u001b[?2004h> "]
[305.640201, "o", "        p += (size_t)w;\r\n\u001b[?2004l\r"]
[305.640234, "o", "\u001b[?2004h> "]
[305.640397, "o", "        n -= (size_t)w;\r\n\u001b[?2004l\r"]
[305.640426, "o", "\u001b[?2004h"]
[305.640445, "o", "> "]
[305.640507, "o", "    }\r\n\u001b[?2004l\r"]
[305.640614, "o", "\u001b[?2004h"]
[305.640649, "o", ">     return 0;\r\n\u001b[?2004l\r"]
[305.640673, "o", "\u001b[?2004h"]
[305.640699, "o", "> }"]
[305.640827, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r \u001b[?2004h> "]
[305.641428, "o", "static void send_simple(int fd, int code, const char *status, const char *ctype, const char *body) {\r\n\u001b[?2004l\r"]
[305.641488, "o", "\u001b[?2004h> "]
[305.641613, "o", "    char hdr[512];\r\n\u001b[?2004l\r"]
[305.641692, "o", "\u001b[?2004h> "]
[305.641936, "o", "    size_t blen = body ? strlen(body) : 0;\r\n\u001b[?2004l\r"]
[305.641966, "o", "\u001b[?2004h> "]
[305.642244, "o", "    int n = snprintf(hdr, sizeof(hdr),\r\n\u001b[?2004l\r"]
[305.642322, "o", "\u001b[?2004h> "]
[305.642575, "o", "                     \"HTTP/1.1 %d %s\\r\\n\"\r\n\u001b[?2004l\r"]
[305.642603, "o", "\u001b[?2004h> "]
[305.642917, "o", "                     \"Connection: close\\r\\n\"\r\n\u001b[?2004l\r"]
[305.642994, "o", "\u001b[?2004h> "]
[305.64334, "o", "                     \"Content-Type: %s\\r\\n\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[305.64363, "o", "                     \"Content-Length: %zu\\r\\n\"\r\n\u001b[?2004l\r"]
[305.643706, "o", "\u001b[?2004h> "]
[305.643863, "o", "                     \"\\r\\n\",\r\n\u001b[?2004l\r"]
[305.643931, "o", "\u001b[?2004h> "]
[305.644178, "o", "                     code, status, ctype, blen);\r\n\u001b[?2004l\r"]
[305.644206, "o", "\u001b[?2004h> "]
[305.644304, "o", "    if (n < 0) return;\r\n\u001b[?2004l\r"]
[305.644377, "o", "\u001b[?2004h> "]
[305.644471, "o", "    write_all(fd, hdr, (size_t)n);\r\n\u001b[?2004l\r"]
[305.644501, "o", "\u001b[?2004h> "]
[305.644647, "o", "    if (body) write_all(fd, body, blen);\r\n\u001b[?2004l\r"]
[305.644679, "o", "\u001b[?2004h> "]
[305.644699, "o", "}\r\n\u001b[?2004l\r"]
[305.644787, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[305.644955, "o", "static void send_file(int fd, const char *fs_path) {\r\n\u001b[?2004l\r"]
[305.644982, "o", "\u001b[?2004h> "]
[305.645077, "o", "    struct stat st;\r\n\u001b[?2004l\r"]
[305.6451, "o", "\u001b[?2004h> "]
[305.645294, "o", "    if (stat(fs_path, &st) != 0 || !S_ISREG(st.st_mode)) {\r\n\u001b[?2004l\r"]
[305.645368, "o", "\u001b[?2004h> "]
[305.645545, "o", "        send_simple(fd, 404, \"Not Found\", \"text/plain\", \"Not Found\");\r\n\u001b[?2004l\r"]
[305.64557, "o", "\u001b[?2004h"]
[305.64559, "o", "> "]
[305.645668, "o", "        return;\r\n\u001b[?2004l\r"]
[305.645698, "o", "\u001b[?2004h> "]
[305.645719, "o", "    }\r\n\u001b[?2004l\r"]
[305.645738, "o", "\u001b[?2004h"]
[305.645758, "o", "> \r\n\u001b[?2004l\r"]
[305.645867, "o", "\u001b[?2004h> "]
[305.645938, "o", "    FILE *f = fopen(fs_path, \"rb\");\r\n\u001b[?2004l\r"]
[305.645963, "o", "\u001b[?2004h> "]
[305.646032, "o", "    if (!f) {\r\n\u001b[?2004l\r"]
[305.646061, "o", "\u001b[?2004h> "]
[305.646289, "o", "        send_simple(fd, 404, \"Not Found\", \"text/plain\", \"Not Found\");\r\n\u001b[?2004l\r"]
[305.646313, "o", "\u001b[?2004h> "]
[305.646394, "o", "        return;\r\n\u001b[?2004l\r"]
[305.64646, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[305.646485, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[305.646554, "o", "\u001b[?2004h> "]
[305.646653, "o", "    char hdr[512];\r\n\u001b[?2004l\r\u001b[?2004h"]
[305.64678, "o", "> "]
[305.646868, "o", "    const char *ct = content_type_for_path(fs_path);\r\n\u001b[?2004l\r\u001b[?2004h"]
[305.647025, "o", "> "]
[305.647102, "o", "    int n = snprintf(hdr, sizeof(hdr),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[305.647252, "o", "                     \"HTTP/1.1 200 OK\\r\\n\"\r\n\u001b[?2004l\r"]
[305.647286, "o", "\u001b[?2004h> "]
[305.647448, "o", "                     \"Connection: close\\r\\n\"\r\n\u001b[?2004l\r"]
[305.647478, "o", "\u001b[?2004h> "]
[305.64764, "o", "                     \"Content-Type: %s\\r\\n\"\r\n\u001b[?2004l\r"]
[305.647669, "o", "\u001b[?2004h> "]
[305.647835, "o", "                     \"Content-Length: %zu\\r\\n\"\r\n\u001b[?2004l\r"]
[305.647866, "o", "\u001b[?2004h> "]
[305.647978, "o", "                     \"\\r\\n\",\r\n\u001b[?2004l\r"]
[305.64807, "o", "\u001b[?2004h> "]
[305.648173, "o", "                     ct, (size_t)st.st_size);\r\n\u001b[?2004l\r"]
[305.64825, "o", "\u001b[?2004h> "]
[305.648375, "o", "    if (n > 0) write_all(fd, hdr, (size_t)n);\r\n\u001b[?2004l\r"]
[305.648415, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[305.648559, "o", "\u001b[?2004h> "]
[305.648681, "o", "    char buf[4096];\r\n\u001b[?2004l\r\u001b[?2004h>     size_t r;\r\n\u001b[?2004l\r\u001b[?2004h"]
[305.64878, "o", "> "]
[305.648872, "o", "    while ((r = fread(buf, 1, sizeof(buf), f)) > 0) {\r\n\u001b[?2004l\r"]
[305.648947, "o", "\u001b[?2004h> "]
[305.649075, "o", "        if (write_all(fd, buf, r) != 0) break;\r\n\u001b[?2004l\r"]
[305.649187, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[305.649291, "o", "\u001b[?2004h> "]
[305.64941, "o", "    fclose(f);\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[305.649519, "o", "> "]
[305.649616, "o", "static void handle_client(int fd) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[305.64967, "o", "    char req[8192];\r\n\u001b[?2004l\r"]
[305.649806, "o", "\u001b[?2004h> "]
[305.649877, "o", "    ssize_t n = read(fd, req, sizeof(req) - 1);\r\n\u001b[?2004l\r"]
[305.650001, "o", "\u001b[?2004h> "]
[305.650102, "o", "    if (n <= 0) return;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[305.650204, "o", "    req[n] = '\\0';\r\n\u001b[?2004l\r\u001b[?2004h> "]
[305.650319, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[305.650425, "o", "    /* Parse request line */\r\n\u001b[?2004l\r\u001b[?2004h> "]
[305.650531, "o", "    char *line_end = strstr(req, \"\\r\\n\");\r\n\u001b[?2004l\r"]
[305.65061, "o", "\u001b[?2004h> "]
[305.650742, "o", "    if (!line_end) line_end = strchr(req, '\\n');\r\n\u001b[?2004l\r"]
[305.650831, "o", "\u001b[?2004h> "]
[305.650873, "o", "    if (!line_end) {\r\n\u001b[?2004l\r"]
[305.651024, "o", "\u001b[?2004h> "]
[305.651171, "o", "        send_simple(fd, 400, \"Bad Request\", \"text/plain\", \"Bad Request\");\r\n\u001b[?2004l\r"]
[305.651261, "o", "\u001b[?2004h> "]
[305.65136, "o", "        return;\r\n\u001b[?2004l\r\u001b[?2004h"]
[305.651476, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[305.651561, "o", "    *line_end = '\\0';\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[305.651587, "o", "> "]
[305.651698, "o", "    char method[16], target[2048];\r\n\u001b[?2004l\r"]
[305.651775, "o", "\u001b[?2004h> "]
[305.651922, "o", "    if (sscanf(req, \"%15s %2047s\", method, target) != 2) {\r\n\u001b[?2004l\r"]
[305.651949, "o", "\u001b[?2004h"]
[305.651969, "o", "> "]
[305.652193, "o", "        send_simple(fd, 400, \"Bad Request\", \"text/plain\", \"Bad Request\");\r\n\u001b[?2004l\r"]
[305.652222, "o", "\u001b[?2004h> "]
[305.652308, "o", "        return;\r\n\u001b[?2004l\r"]
[305.652337, "o", "\u001b[?2004h> "]
[305.652394, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[305.652453, "o", "> \r\n\u001b[?2004l\r"]
[305.652485, "o", "\u001b[?2004h> "]
[305.652602, "o", "    if (strcmp(method, \"GET\") != 0) {\r\n\u001b[?2004l\r"]
[305.652629, "o", "\u001b[?2004h> "]
[305.652896, "o", "        send_simple(fd, 405, \"Method Not Allowed\", \"text/plain\", \"Method Not Allowed\");\r\n\u001b[?2004l\r"]
[305.652924, "o", "\u001b[?2004h> "]
[305.653014, "o", "        return;\r\n\u001b[?2004l\r"]
[305.653081, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[305.653111, "o", "> \r\n\u001b[?2004l\r"]
[305.653177, "o", "\u001b[?2004h> "]
[305.65332, "o", "    /* Strip query string */\r\n\u001b[?2004l\r"]
[305.65348, "o", "\u001b[?2004h> "]
[305.653629, "o", "    char *q = strchr(target, '?');\r\n\u001b[?2004l\r\u001b[?2004h> "]
[305.653738, "o", "    if (q) *q = '\\0';\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[305.653844, "o", "    /* API: minimal health probe */\r\n\u001b[?2004l\r\u001b[?2004h"]
[305.65392, "o", "> "]
[305.654027, "o", "    if (strcmp(target, \"/api/notes\") == 0) {\r\n\u001b[?2004l\r"]
[305.654056, "o", "\u001b[?2004h"]
[305.654079, "o", "> "]
[305.65429, "o", "        send_simple(fd, 200, \"OK\", \"application/json\", \"[]\");\r\n\u001b[?2004l\r"]
[305.654316, "o", "\u001b[?2004h"]
[305.654333, "o", "> "]
[305.654435, "o", "        return;\r\n\u001b[?2004l\r"]
[305.65454, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[305.654568, "o", "\u001b[?2004h> "]
[305.654775, "o", "    /* Enforce traversal protections on BOTH raw and decoded. */\r\n\u001b[?2004l\r"]
[305.654802, "o", "\u001b[?2004h> "]
[305.654911, "o", "    char decoded[2048];\r\n\u001b[?2004l\r"]
[305.654942, "o", "\u001b[?2004h> "]
[305.655143, "o", "    if (percent_decode(target, decoded, sizeof(decoded)) != 0) {\r\n\u001b[?2004l\r"]
[305.655184, "o", "\u001b[?2004h> "]
[305.655413, "o", "        send_simple(fd, 403, \"Forbidden\", \"text/plain\", \"Forbidden\");\r\n\u001b[?2004l\r"]
[305.655443, "o", "\u001b[?2004h> "]
[305.655592, "o", "        return;\r\n\u001b[?2004l\r"]
[305.655677, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[305.655935, "o", "    if (has_dot_segments_or_backslash(target) || has_dot_segments_or_backslash(decoded)) {\r\n\u001b[?2004l\r"]
[305.655964, "o", "\u001b[?2004h> "]
[305.656191, "o", "        send_simple(fd, 403, \"Forbidden\", \"text/plain\", \"Forbidden\");\r\n\u001b[?2004l\r"]
[305.656223, "o", "\u001b[?2004h> "]
[305.656344, "o", "        return;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[305.656376, "o", "\u001b[?2004h> \r\n"]
[305.6564, "o", "\u001b[?2004l\r\u001b[?2004h"]
[305.656423, "o", "> "]
[305.656568, "o", "    /* Serve static assets from WWW_DIR */\r\n\u001b[?2004l\r"]
[305.656601, "o", "\u001b[?2004h> "]
[305.656743, "o", "    const char *url_path = decoded;\r\n\u001b[?2004l\r"]
[305.656855, "o", "\u001b[?2004h> "]
[305.656978, "o", "    if (strcmp(url_path, \"/\") == 0) url_path = \"/index.html\";\r\n\u001b[?2004l\r"]
[305.657071, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[305.657171, "o", "    char fs_path[512];\r\n\u001b[?2004l\r\u001b[?2004h"]
[305.657203, "o", "> "]
[305.65747, "o", "    if (snprintf(fs_path, sizeof(fs_path), \"%s%s\", WWW_DIR, url_path) >= (int)sizeof(fs_path)) {\r\n\u001b[?2004l\r"]
[305.657502, "o", "\u001b[?2004h> "]
[305.657743, "o", "        send_simple(fd, 404, \"Not Found\", \"text/plain\", \"Not Found\");\r\n\u001b[?2004l\r"]
[305.657775, "o", "\u001b[?2004h> "]
[305.657897, "o", "        return;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[305.657925, "o", "\u001b[?2004h> "]
[305.657946, "o", "\r\n\u001b[?2004l\r"]
[305.65797, "o", "\u001b[?2004h"]
[305.657995, "o", "> "]
[305.6582, "o", "    send_file(fd, fs_path);\r\n\u001b[?2004l\r\u001b[?2004h"]
[305.658369, "o", "> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[305.658517, "o", "int main(void) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[305.658657, "o", "    signal(SIGINT, on_signal);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[305.658807, "o", "    signal(SIGTERM, on_signal);\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[305.658938, "o", "    mkdir(\"/app/data\", 0755);\r\n\u001b[?2004l\r\u001b[?2004h"]
[305.659081, "o", "> "]
[305.659253, "o", "    if (init_db(\"/app/data/notes.db\") != 0) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[305.65937, "o", "        fprintf(stderr, \"Failed to initialize database\\n\");\r\n\u001b[?2004l\r"]
[305.659488, "o", "\u001b[?2004h> "]
[305.659557, "o", "        return 1;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[305.659586, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[305.659662, "o", "\u001b[?2004h> "]
[305.659798, "o", "    g_listen_fd = socket(AF_INET, SOCK_STREAM, 0);\r\n\u001b[?2004l\r"]
[305.659826, "o", "\u001b[?2004h> "]
[305.659941, "o", "    if (g_listen_fd < 0) {\r\n\u001b[?2004l\r"]
[305.659965, "o", "\u001b[?2004h> "]
[305.660075, "o", "        perror(\"socket\");\r\n\u001b[?2004l\r"]
[305.660158, "o", "\u001b[?2004h> "]
[305.660194, "o", "        return 1;\r\n\u001b[?2004l\r"]
[305.660216, "o", "\u001b[?2004h> "]
[305.660304, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[305.660335, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[305.660358, "o", "> "]
[305.660445, "o", "    int one = 1;\r\n\u001b[?2004l\r\u001b[?2004h"]
[305.660477, "o", "> "]
[305.660687, "o", "    setsockopt(g_listen_fd, SOL_SOCKET, SO_REUSEADDR, &one, sizeof(one));\r\n\u001b[?2004l\r"]
