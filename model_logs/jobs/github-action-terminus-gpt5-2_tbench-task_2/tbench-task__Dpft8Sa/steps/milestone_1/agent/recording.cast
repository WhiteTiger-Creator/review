[422.153118, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h"]
[422.153206, "o", "> "]
[422.153349, "o", "        dst[di++] = src[si];\r\n\u001b[?2004l\r"]
[422.153381, "o", "\u001b[?2004h> "]
[422.153403, "o", "    }\r\n\u001b[?2004l\r"]
[422.153503, "o", "\u001b[?2004h> "]
[422.153584, "o", "    dst[di] = '\\0';\r\n\u001b[?2004l\r"]
[422.153613, "o", "\u001b[?2004h"]
[422.153632, "o", "> "]
[422.153737, "o", "    return 0;\r\n\u001b[?2004l\r"]
