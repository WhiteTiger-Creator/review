[847.65735, "o", "\r\n\u001b[?2004l\r"]
[847.659207, "o", "(() => {\r\n  const API_BASE = '/api/notes';\r\n\r\n  const noteForm = document.getElementById('note-form');\r\n  const noteTitle = document.getElementById('note-title');\r\n  const noteContent = document.getElementById('note-content');\r\n  const notesList = document.getElementById('notes-list');\r\n\r\n  let activeId = null;\r\n  let API_KEY = null;\r\n\r\n  function getApiKey() {\r\n    if (API_KEY) return API_KEY;\r\n    // Lazy-load key once; trimmed as required\r\n    return fetch('/config/api.key').then((r) => r.text()).then((t) => {\r\n      API_KEY = (t || '').trim();\r\n      return API_KEY;\r\n    });\r\n  }\r\n\r\n  function clearAndResetForm() {\r\n    activeId = null;\r\n    if (noteTitle) noteTitle.value = '';\r\n    if (noteContent) noteContent.value = '';\r\n  }\r\n\r\n  function fetchNotes() {\r\n    // No API key / Content-Type on GET\r\n    return fetch(API_BASE).then((r) => {\r\n      if (!r.ok) throw new Error('Failed to load notes');\r\n      return r.json();\r\n    });\r\n  }\r\n\r\n  function apiRequest(method, url, bodyObj) {\r\n    return getApiKey().then((key) => {\r\n      const headers = {\r\n        'Content-Type': 'application/json',\r\n        'x-api-key': key\r\n      };\r\n      const opts = { method, headers };\r\n      if (bodyObj !== undefined) opts.body = JSON.stringify(bodyObj);\r\n      return fetch(url, opts).then((r) => {\r\n        if (!r.ok) throw new Error(method + ' failed');\r\n        // API may or may not return JSON; don't assume\r\n        return r.text().then(() => r);\r\n      });\r\n    });\r\n  }\r\n\r\n  function renderNotes(notes) {\r\n    if (!notesList) return;\r\n\r\n    // Clear list\r\n    while (notesList.firstChild) notesList.removeChild(notesList.firstChild);\r\n\r\n    for (let i = 0; i < notes.length; i++) {\r\n"]
[847.659298, "o", "      const n = notes[i];\r\n\r\n      const row = document.createElement('div');\r\n      row.className = 'note-row';\r\n      row.setAttribute('data-id', String(n.id));\r\n\r\n      const titleEl = document.createElement('span');\r\n      titleEl.className = 'note-title';\r\n      titleEl.textContent = n.title;\r\n\r\n      const contentEl = document.createElement('span');\r\n      contentEl.className = 'note-content';\r\n      contentEl.textContent = n.content;\r\n\r\n      const editBtn = document.createElement('button');\r\n      editBtn.type = 'button';\r\n      editBtn.className = 'edit-btn';\r\n"]
[847.659641, "o", "      editBtn.textContent = 'Edit';\r\n      editBtn.addEventListener('click', () => {\r\n        activeId = n.id;\r\n        if (noteTitle) noteTitle.value = n.title || '';\r\n        if (noteContent) noteContent.value = n.content || '';\r\n      });\r\n\r\n      const deleteBtn = document.createElement('button');\r\n      deleteBtn.type = 'button';\r\n      deleteBtn.className = 'delete-btn';\r\n      deleteBtn.textContent = 'Delete';\r\n      deleteBtn.addEventListener('click', () => {\r\n        apiRequest('DELETE', API_BASE + '/' + encodeURIComponent(String(n.id)))\r\n"]
[847.65974, "o", "          .then(() => loadNotes())\r\n          .then(() => {\r\n            if (activeId === n.id) clearAndResetForm();\r\n          })\r\n          .catch(() => {});\r\n      });\r\n\r\n      row.appendChild(titleEl);\r\n      row.appendChild(document.createTextNode(' '));\r\n      row.appendChild(contentEl);\r\n      row.appendChild(document.createTextNode(' '));\r\n      row.appendChild(editBtn);\r\n      row.appendChild(document.createTextNode(' '));\r\n      row.appendChild(deleteBtn);\r\n\r\n      notesList.appendChild(row);\r\n    }\r\n  }\r\n\r\n  function loadNotes() {\r\n    return fetchNotes().then((notes) => {\r\n      renderNotes(Array.isArray(notes) ? notes : []);\r\n      return notes;\r\n    });\r\n  }\r\n\r\n  if (noteForm) {\r\n    noteForm.addEventListener('submit', (e) => {\r\n      if (e && e.preventDefault) e.preventDefault();\r\n\r\n      const title = (noteTitle && noteTitle.value ? noteTitle.value : '').trim();\r\n      const content = (noteContent && noteContent.value ? noteContent.value : '').trim();\r\n\r\n      if (!title && !content) {\r\n        // nothing to save\r\n        return;\r\n      }\r\n\r\n      if (activeId == null) {\r\n        apiRequest('POST', API_BASE, { title, content })\r\n          .then(() => {\r\n            clearAndResetForm();\r\n            return loadNotes();\r\n          })\r\n          .catch(() => {});\r\n      } else {\r\n        apiRequest('PUT', API_BASE + '/' + encodeURIComponent(String(activeId)), { title, content })\r\n          .then(() => {\r\n            clearAndResetForm();\r\n            return loadNotes();\r\n          })\r\n          .catch(() => {});\r\n      }\r\n    });\r\n  }\r\n\r\n  // Initial load\r\n  loadNotes().catch(() => {});\r\n})();\r\n"]
