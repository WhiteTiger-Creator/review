[505.055786, "o", "static int has_dot_segments_or_backslash(const char *path) {\r\n\u001b[?2004l\r"]
[505.055896, "o", "\u001b[?2004h> "]
[505.056117, "o", "    if (strchr(path, '\\\\') != NULL) return 1;\r\n\u001b[?2004l\r"]
[505.056222, "o", "\u001b[?2004h> "]
[505.056331, "o", "    const char *p = path;\r\n\u001b[?2004l\r"]
[505.056474, "o", "\u001b[?2004h> "]
