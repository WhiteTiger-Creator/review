[918.429878, "o", "#define _GNU_SOURCE\r\n\r\n#include \"auth.h\"\r\n#include \"db.h\"\r\n\r\n#include <arpa/inet.h>\r\n"]
[918.43008, "o", "#include <ctype.h>\r\n#include <errno.h>\r\n#include <netinet/in.h>\r\n#include <signal.h>\r\n#include <stdio.h>\r\n#include <stdlib.h>\r\n#include <string.h>\r\n#include <sys/socket.h>\r\n#include <sys/stat.h>\r\n#include <unistd.h>\r\n\r\n#define PORT 8080\r\n#define WWW_DIR \"/app/www\"\r\n#define MAX_BODY 65536\r\n\r\nstatic volatile sig_atomic_t g_stop = 0;\r\nstatic int g_listen_fd = -1;\r\n\r\nstatic void on_signal(int sig) {\r\n    (void)sig;\r\n    g_stop = 1;\r\n    if (g_listen_fd >= 0) close(g_listen_fd);\r\n"]
[918.430116, "o", "}\r\n\r\nstatic int write_all(int fd, const void *buf, size_t len) {\r\n    const char *p = (const char *)buf;\r\n    while (len > 0) {\r\n        ssize_t n = write(fd, p, len);\r\n        if (n < 0) {\r\n            if (errno == EINTR) continue;\r\n            return -1;\r\n        }\r\n        p += (size_t)n;\r\n        len -= (size_t)n;\r\n    }\r\n    return 0;\r\n}\r\n\r\nstatic const char *content_type_for_path(const char *path) {\r\n    const char *ext = strrchr(path, '.');\r\n    if (!ext) return \"application/octet-stream\";\r\n    if (strcmp(ext, \".html\") == 0) return \"text/html\";\r\n    if (strcmp(ext, \".js\") == 0) return \"application/javascript\";\r\n    if (strcmp(ext, \".css\") == 0) return \"text/css\";\r\n    if (strcmp(ext, \".png\") == 0) return \"image/png\";\r\n    if (strcmp(ext, \".jpg\") == 0 || strcmp(ext, \".jpeg\") == 0) return \"image/jpeg\";\r\n    if (strcmp(ext, \".svg\") == 0) return \"image/svg+xml\";\r\n    return \"application/octet-stream\";\r\n}\r\n\r\nstatic void send_simple(int fd, int code, const char *reason,\r\n                        const char *content_type, const char *body) {\r\n    size_t blen = body ? strlen(body) : 0;\r\n    char hdr[512];\r\n    int n = snprintf(hdr, sizeof(hdr),\r\n                     \"HTTP/1.1 %d %s\\r\\n\"\r\n                     \"Connection: close\\r\\n\"\r\n                     \"Content-Type: %s\\r\\n\"\r\n                     \"Content-Length: %zu\\r\\n\"\r\n                     \"\\r\\n\",\r\n                     code, reason, content_type, blen);\r\n    if (n > 0) write_all(fd, hdr, (size_t)n);\r\n    if (body) write_all(fd, body, blen);\r\n}\r\n\r\nstatic void send_json(int fd, int code, const char *reason, const char *body) {\r\n    size_t blen = body ? strlen(body) : 0;\r\n    char hdr[768];\r\n    int n = snprintf(hdr, sizeof(hdr),\r\n                     \"HTTP/1.1 %d %s\\r\\n\"\r\n                     \"Connection: close\\r\\n\"\r\n                     \"Content-Type: application/json\\r\\n\"\r\n                     \"Access-Control-Allow-Origin: *\\r\\n\"\r\n"]
[918.430139, "o", "                     \"Access-Control-Allow-Methods: GET, POST, PUT, DELETE, OPTIONS\\r\\n\"\r\n                     \"Access-Control-Allow-Headers: Content-Type, X-API-Key\\r\\n\"\r\n                     \"Content-Length: %zu\\r\\n\"\r\n                     \"\\r\\n\",\r\n                     code, reason, blen);\r\n    if (n > 0) write_all(fd, hdr, (size_t)n);\r\n"]
[918.430157, "o", "    if (body) write_all(fd, body, blen);\r\n}\r\n\r\nstatic void send_json_total(int fd, int code, const char *reason, const char *body, int total) {\r\n    size_t blen = body ? strlen(body) : 0;\r\n    char hdr[900];\r\n    int n = snprintf(hdr, sizeof(hdr),\r\n                     \"HTTP/1.1 %d %s\\r\\n\"\r\n"]
[918.430181, "o", "                     \"Connection: close\\r\\n\"\r\n                     \"Content-Type: application/json\\r\\n\"\r\n                     \"Access-Control-Allow-Origin: *\\r\\n\"\r\n                     \"Access-Control-Allow-Methods: GET, POST, PUT, DELETE, OPTIONS\\r\\n\"\r\n"]
[918.430225, "o", "                     \"Access-Control-Allow-Headers: Content-Type, X-API-Key\\r\\n\"\r\n                     \"X-Total-Count: %d\\r\\n\"\r\n                     \"Content-Length: %zu\\r\\n\"\r\n                     \"\\r\\n\",\r\n                     code, reason, total, blen);\r\n    if (n > 0) write_all(fd, hdr, (size_t)n);\r\n"]
[918.430245, "o", "    if (body) write_all(fd, body, blen);\r\n}\r\n\r\nstatic void send_file(int fd, const char *fs_path) {\r\n    struct stat st;\r\n    if (stat(fs_path, &st) != 0 || !S_ISREG(st.st_mode)) {\r\n        send_simple(fd, 404, \"Not Found\", \"text/plain\", \"Not Found\");\r\n        return;\r\n    }\r\n\r\n    FILE *f = fopen(fs_path, \"rb\");\r\n"]
[918.430264, "o", "    if (!f) {\r\n        send_simple(fd, 404, \"Not Found\", \"text/plain\", \"Not Found\");\r\n        return;\r\n    }\r\n\r\n    char hdr[512];\r\n"]
[918.430468, "o", "    const char *ct = content_type_for_path(fs_path);\r\n    int n = snprintf(hdr, sizeof(hdr),\r\n                     \"HTTP/1.1 200 OK\\r\\n\"\r\n                     \"Connection: close\\r\\n\"\r\n"]
[918.430689, "o", "                     \"Content-Type: %s\\r\\n\"\r\n                     \"Content-Length: %zu\\r\\n\"\r\n                     \"\\r\\n\",\r\n                     ct, (size_t)st.st_size);\r\n    if (n > 0) write_all(fd, hdr, (size_t)n);\r\n\r\n    char buf[4096];\r\n    size_t r;\r\n    while ((r = fread(buf, 1, sizeof(buf), f)) > 0) {\r\n        if (write_all(fd, buf, r) != 0) break;\r\n    }\r\n    fclose(f);\r\n}\r\n\r\nstatic int has_dot_segments_or_backslash(const char *s) {\r\n    if (!s) return 0;\r\n"]
