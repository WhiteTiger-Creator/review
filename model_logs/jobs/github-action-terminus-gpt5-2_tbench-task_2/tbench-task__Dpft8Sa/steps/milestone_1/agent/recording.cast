[191.51465, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[191.514743, "o", "    if (strncmp(url, \"/api/\", 5) == 0) {\r\n\u001b[?2004l\r"]
[191.514779, "o", "\u001b[?2004h> "]
