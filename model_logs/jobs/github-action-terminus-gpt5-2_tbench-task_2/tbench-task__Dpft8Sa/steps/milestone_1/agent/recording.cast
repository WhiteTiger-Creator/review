[422.155609, "o", "\u001b[?2004h> "]
[422.15586, "o", "        while (*p && *p != '/') p++;\r\n\u001b[?2004l\r"]
[422.155893, "o", "\u001b[?2004h> "]
[422.156153, "o", "        size_t len = (size_t)(p - seg);\r\n\u001b[?2004l\r"]
[422.156184, "o", "\u001b[?2004h> "]
