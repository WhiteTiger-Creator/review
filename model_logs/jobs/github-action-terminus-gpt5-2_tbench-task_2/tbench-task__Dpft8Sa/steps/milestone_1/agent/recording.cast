[908.45604, "i", "apply_patch<<'PATCH'\n*** Begin Patch\n*** Update File: src/main.c\n@@\n-    // Static serving only supports GET\n-    if (strcmp(method, \"GET\") != 0) {\n-        send_simple(fd, 405, \"Method Not Allowed\", \"text/plain\", \"Method Not Allowed\");\n-        goto out;\n-    }\n+    // Static serving supports GET and HEAD\n+    // Some harnesses probe with HEAD; treat it like GET but without a body.\n+    int is_head = (strcmp(method, \"HEAD\") == 0);\n+    if (!(strcmp(method, \"GET\") == 0 || is_head)) {\n+        send_simple(fd, 405, \"Method Not Allowed\", \"text/plain\", \"Method Not Allowed\");\n+        goto out;\n+    }\n@@\n-    serve_static(fd, path);\n+    serve_static(fd, path, is_head);\n     goto out;\n*** End Patch\nPATCH\n"]
