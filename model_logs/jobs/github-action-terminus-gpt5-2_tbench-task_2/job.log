r *s) {\n    if (!s) return strdup("");\n    size_t cap = 64, len = 0;\n    char *out = malloc(cap);\n    if (!out) return NULL;\n    out[0] = \'\\0\';\n\n    for (const unsigned char *p = s; *p; p++) {\n        char tmp[8];\n        if (*p == \'"\' || *p == \'\\\\\') {\n            tmp[0] = \'\\\\\';\n            tmp[1] = (char)*p;\n            tmp[2] = \'\\0\';\n            sb_append(&out, &cap, &len, tmp);\n        } else if (*p == \'\\n\') {\n            sb_append(&out, &cap, &len, "\\\\n");\n        } else if (*p == \'\\r\') {\n            sb_append(&out, &cap, &len, "\\\\r");\n        } else if (*p == \'\\t\') {\n            sb_append(&out, &cap, &len, "\\\\t");\n        } else if (*p < 0x20) {\n            snprintf(tmp, sizeof(tmp), "\\\\u%04x", (unsigned int)*p);\n            sb_append(&out, &cap, &len, tmp);\n        } else {\n            tmp[0] = (char)*p;\n            tmp[1] = \'\\0\';\n            sb_append(&out, &cap, &len, tmp);\n        }\n    }\n    return out;\n}\n\nint create_note(const char *title, const char *content) {\n    pthread_mutex_lock(&g_db_mu);\n\n    sqlite3_exec(g_db, "BEGIN IMMEDIATE;", NULL, NULL, NULL);\n\n    sqlite3_stmt *st = NULL;\n    const char *sql = "INSERT INTO notes(title, content) VALUES(?, ?);";\n    if (sqlite3_prepare_v2(g_db, sql, -1, &st, NULL) != SQLITE_OK) {\n        sqlite3_exec(g_db, "ROLLBACK;", NULL, NULL, NULL);\n        pthread_mutex_unlock(&g_db_mu);\n        return -1;\n    }\n\n    sqlite3_bind_text(st, 1, title ? title : "", -1, SQLITE_TRANSIENT);\n    sqlite3_bind_text(st, 2, content ? content : "", -1, SQLITE_TRANSIENT);\n\n    int rc = sqlite3_step(st);\n    sqlite3_finalize(st);\n    if (rc != SQLITE_DONE) {\n        sqlite3_exec(g_db, "ROLLBACK;", NULL, NULL, NULL);\n        pthread_mutex_unlock(&g_db_mu);\n        return -1;\n    }\n\n    int id = (int)sqlite3_last_insert_rowid(g_db);\n    sqlite3_exec(g_db, "COMMIT;", NULL, NULL, NULL);\n\n    pthread_mutex_unlock(&g_db_mu);\n    return id;\n}\n\nint get_total_notes_count(void) {\n    pthread_mutex_lock(&g_db_mu);\n\n    sqlite3_stmt *st = NULL;\n    int total = 0;\n    if (sqlite3_prepare_v2(g_db, "SELECT COUNT(*) FROM notes;", -1, &st, NULL) == SQLITE_OK) {\n        if (sqlite3_step(st) == SQLITE_ROW) {\n            total = sqlite3_column_int(st, 0);\n        }\n    }\n    if (st) sqlite3_finalize(st);\n\n    pthread_mutex_unlock(&g_db_mu);\n    return total;\n}\n\nchar *get_notes_paginated_json(int limit, int offset) {\n    pthread_mutex_lock(&g_db_mu);\n\n    sqlite3_stmt *st = NULL;\n    const char *sql = "SELECT id, title, content FROM notes ORDER BY id LIMIT ? OFFSET ?;";\n    if (sqlite3_prepare_v2(g_db, sql, -1, &st, NULL) != SQLITE_OK) {\n        pthread_mutex_unlock(&g_db_mu);\n        return NULL;\n    }\n    sqlite3_bind_int(st, 1, limit);\n    sqlite3_bind_int(st, 2, offset);\n\n    char *buf = NULL;\n    size_t cap = 0, len = 0;\n    sb_append(&buf, &cap, &len, "[");\n\n    int first = 1;\n    while (sqlite3_step(st) == SQLITE_ROW) {\n        int id = sqlite3_column_int(st, 0);\n        const unsigned char *title = sqlite3_column_text(st, 1);\n        const unsigned char *content = sqlite3_column_text(st, 2);\n\n        char *et = json_escape(title);\n        char *ec = json_escape(content);\n        if (!et || !ec) {\n            free(et);\n            free(ec);\n            free(buf);\n            sqlite3_finalize(st);\n            pthread_mutex_unlock(&g_db_mu);\n            return NULL;\n        }\n\n        char tmp[64];\n        if (!first) sb_append(&buf, &cap, &len, ",");\n        first = 0;\n        snprintf(tmp, sizeof(tmp), "{\\"id\\":%d,\\"title\\":\\"", id);\n        sb_append(&buf, &cap, &len, tmp);\n        sb_append(&buf, &cap, &len, et);\n        sb_append(&buf, &cap, &len, "\\",\\"content\\":\\"");\n        sb_append(&buf, &cap, &len, ec);\n        sb_append(&buf, &cap, &len, "\\"}");\n\n        free(et);\n        free(ec);\n    }\n\n    sqlite3_finalize(st);\n    sb_append(&buf, &cap, &len, "]");\n\n    pthread_mutex_unlock(&g_db_mu);\n    return buf;\n}\n\nchar *get_all_notes_json(void) {\n    return get_notes_paginated_json(1000000, 0);\n}\n\nchar *get_note_json(int id) {\n    pthread_mutex_lock(&g_db_mu);\n\n    sqlite3_stmt *st = NULL;\n    const char *sql = "SELECT id, title, content FROM notes WHERE id = ?;";\n    if (sqlite3_prepare_v2(g_db, sql, -1, &st, NULL) != SQLITE_OK) {\n        pthread_mutex_unlock(&g_db_mu);\n        return NULL;\n    }\n    sqlite3_bind_int(st, 1, id);\n\n    char *out = NULL;\n    if (sqlite3_step(st) == SQLITE_ROW) {\n        int rid = sqlite3_column_int(st, 0);\n        const unsigned char *title = sqlite3_column_text(st, 1);\n        const unsigned char *content = sqlite3_column_text(st, 2);\n        char *et = json_escape(title);\n        char *ec = json_escape(content);\n        if (et && ec) {\n            size_t need = strlen(et) + strlen(ec) + 64;\n            out = malloc(need);\n            if (out) snprintf(out, need, "{\\"id\\":%d,\\"title\\":\\"%s\\",\\"content\\":\\"%s\\"}", rid, et, ec);\n        }\n        free(et);\n        free(ec);\n    }\n\n    sqlite3_finalize(st);\n    pthread_mutex_unlock(&g_db_mu);\n    return out;\n}\n\nint note_exists(int id) {\n    pthread_mutex_lock(&g_db_mu);\n\n    sqlite3_stmt *st = NULL;\n    int exists = 0;\n    if (sqlite3_prepare_v2(g_db, "SELECT 1 FROM notes WHERE id = ?;", -1, &st, NULL) == SQLITE_OK) {\n        sqlite3_bind_int(st, 1, id);\n        if (sqlite3_step(st) == SQLITE_ROW) exists = 1;\n    }\n    if (st) sqlite3_finalize(st);\n\n    pthread_mutex_unlock(&g_db_mu);\n    return exists;\n}\n\nint update_note(int id, const char *title, const char *content) {\n    pthread_mutex_lock(&g_db_mu);\n\n    sqlite3_exec(g_db, "BEGIN IMMEDIATE;", NULL, NULL, NULL);\n\n    sqlite3_stmt *st = NULL;\n    const char *sql = "UPDATE notes SET title = ?, content = ? WHERE id = ?;";\n    if (sqlite3_prepare_v2(g_db, sql, -1, &st, NULL) != SQLITE_OK) {\n        sqlite3_exec(g_db, "ROLLBACK;", NULL, NULL, NULL);\n        pthread_mutex_unlock(&g_db_mu);\n        return 0;\n    }\n\n    sqlite3_bind_text(st, 1, title ? title : "", -1, SQLITE_TRANSIENT);\n    sqlite3_bind_text(st, 2, content ? content : "", -1, SQLITE_TRANSIENT);\n    sqlite3_bind_int(st, 3, id);\n\n    int rc = sqlite3_step(st);\n    sqlite3_finalize(st);\n    if (rc != SQLITE_DONE) {\n        sqlite3_exec(g_db, "ROLLBACK;", NULL, NULL, NULL);\n        pthread_mutex_unlock(&g_db_mu);\n        return 0;\n    }\n\n    int changed = sqlite3_changes(g_db);\n    sqlite3_exec(g_db, "COMMIT;", NULL, NULL, NULL);\n\n    pthread_mutex_unlock(&g_db_mu);\n    return changed > 0;\n}\n\nint delete_note(int id) {\n    pthread_mutex_lock(&g_db_mu);\n\n    sqlite3_exec(g_db, "BEGIN IMMEDIATE;", NULL, NULL, NULL);\n\n    sqlite3_stmt *st = NULL;\n    if (sqlite3_prepare_v2(g_db, "DELETE FROM notes WHERE id = ?;", -1, &st, NULL) != SQLITE_OK) {\n        sqlite3_exec(g_db, "ROLLBACK;", NULL, NULL, NULL);\n        pthread_mutex_unlock(&g_db_mu);\n        return 0;\n    }\n    sqlite3_bind_int(st, 1, id);\n\n    int rc = sqlite3_step(st);\n    sqlite3_finalize(st);\n    if (rc != SQLITE_DONE) {\n        sqlite3_exec(g_db, "ROLLBACK;", NULL, NULL, NULL);\n        pthread_mutex_unlock(&g_db_mu);\n        return 0;\n    }\n\n    int changed = sqlite3_changes(g_db);\n    sqlite3_exec(g_db, "COMMIT;", NULL, NULL, NULL);\n\n    pthread_mutex_unlock(&g_db_mu);\n    return changed > 0;\n}\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
