[172.718435, "o", "#pragma once\r\n\r\n#include \"core/ev.h\"\r\n\r\n#include <stdbool.h>\r\n#include <stddef.h>\r\n\r\ntypedef struct {\r\n  tb_event *v;\r\n  size_t len;\r\n  size_t cap;\r\n} tb_vec_ev;\r\n\r\nbool tb_vec_ev_init(tb_vec_ev *a, size_t cap);\r\nvoid tb_vec_ev_free(tb_vec_ev *a);\r\nbool tb_vec_ev_push(tb_vec_ev *a, tb_event ev);\r\nvoid tb_vec_ev_clear(tb_vec_ev *a);\r\n\r\n"]
