[378.680769, "i", "python3 -c '\nimport json\nwith open(\"/app/output/stress2.json\") as f:\n    d = json.load(f)\nevents = d[\"events\"]\nsubmits = [e for e in events if e[\"kind\"]==\"submit\"]\ncompletes = [e for e in events if e[\"kind\"]==\"complete\"]\nnotifies = [e for e in events if e[\"kind\"]==\"notify\"]\nprint(\"Submits:\", len(submits), \"Completes:\", len(completes), \"Notifies:\", len(notifies))\nsub_ids = [e[\"id\"] for e in submits]\nprint(\"IDs contiguous 1..N:\", sub_ids == list(range(1, len(submits)+1)))\nprint(\"All completed:\", sorted(e[\"id\"] for e in completes) == sorted(sub_ids))\nprint(\"All notified:\", sorted(e[\"id\"] for e in notifies) == sorted(sub_ids))\n'\n"]
