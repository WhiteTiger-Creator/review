[438.924686, "i", "python3 -c '\nimport json\n# Check interleaving - submits and completes should be spread across the log\nwith open(\"/app/output/report.json\") as f:\n    d = json.load(f)\nevents = d[\"events\"]\nkinds = [e[\"kind\"] for e in events]\n# Find first complete and check it is not after all submits\nfirst_complete_idx = kinds.index(\"complete\")\nlast_submit_idx = len(kinds) - 1 - kinds[::-1].index(\"submit\")\nprint(f\"First complete at index {first_complete_idx}, last submit at {last_submit_idx}\")\nprint(f\"Interleaved: {first_complete_idx < last_submit_idx}\")\n'\n"]
[438.924903, "o", "python3 -c '\r\n\u001b[?2004l\r\u001b[?2004h"]
