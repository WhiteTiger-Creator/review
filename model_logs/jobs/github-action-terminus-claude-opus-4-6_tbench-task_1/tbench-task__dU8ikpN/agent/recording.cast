[363.181088, "i", "python3 -c \"\nimport json\nwith open('/app/output/stress_a.json') as f:\n    a = json.load(f)\nwith open('/app/output/stress_b.json') as f:\n    b = json.load(f)\nprint(f'stress a_then_b events: {len(a[\"events\"])}')\nprint(f'stress b_then_a events: {len(b[\"events\"])}')\n\na_sub = [e['id'] for e in a['events'] if e['kind']=='submit']\nb_sub = [e['id'] for e in b['events'] if e['kind']=='submit']\nprint(f'Same submits: {a_sub == b_sub}')\n\na_comp = [e['id'] for e in a['events'] if e['kind']=='complete']\nb_comp = [e['id'] for e in b['events'] if e['kind']=='complete']\nprint(f'Same complete coverage: {sorted(a_comp) == sorted(b_comp)}')\nprint(f'Different complete sequence: {a_comp != b_comp}')\nprint(f'Submit IDs contiguous 1..N: {a_sub == list(range(1, len(a_sub)+1))}')\n\"\n"]
