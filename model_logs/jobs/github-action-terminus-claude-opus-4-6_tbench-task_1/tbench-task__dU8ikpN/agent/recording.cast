[498.859629, "i", "python3 -c '\nimport json\n# Check no duplicate (kind, id) pairs\nfor fname in [\"/app/output/report.json\", \"/app/output/stress_a.json\", \"/app/output/stress2.json\", \"/app/output/steady.json\"]:\n    with open(fname) as f:\n        d = json.load(f)\n    events = d[\"events\"]\n    seen = set()\n    dups = 0\n    for e in events:\n        key = (e[\"kind\"], e[\"id\"])\n        if key in seen:\n            dups += 1\n            print(f\"DUPLICATE in {fname}: {key}\")\n        seen.add(key)\n    if dups == 0:\n        print(f\"{fname}: No duplicates\")\n'\n"]
