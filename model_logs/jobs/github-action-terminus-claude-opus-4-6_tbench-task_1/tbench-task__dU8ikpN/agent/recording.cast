[360.173395, "i", "python3 -c \"\nimport json\nwith open('/app/output/report.json') as f:\n    d = json.load(f)\nevents = d['events']\n# Check ordering: for each id, submit must come before complete, complete before notify\nfirst_submit = {}\nfirst_complete = {}\nfirst_notify = {}\nfor i, ev in enumerate(events):\n    eid = ev['id']\n    kind = ev['kind']\n    if kind == 'submit':\n        if eid in first_submit:\n            print(f'DUPLICATE submit for {eid}')\n        else:\n            first_submit[eid] = i\n    elif kind == 'complete':\n        if eid in first_complete:\n            print(f'DUPLICATE complete for {eid}')\n        else:\n            first_complete[eid] = i\n    elif kind == 'notify':\n        if eid in first_notify:\n            print(f'DUPLICATE notify for {eid}')\n        else:\n            first_notify[eid] = i\n\nok = True\nfor eid in first_submit:\n    si = first_submit[eid]\n    ci = first_complete.get(eid)\n    ni = first_notify.get(eid)\n    if ci is None:\n        print(f'Missing complete for {eid}')\n        ok = False\n    elif si >"]
[360.175221, "i", "= ci:\n        print(f'Order violation submit/complete for {eid}: {si} >= {ci}')\n        ok = False\n    if ni is None:\n        print(f'Missing notify for {eid}')\n        ok = False\n    elif ci is not None and ci >= ni:\n        print(f'Order violation complete/notify for {eid}: {ci} >= {ni}')\n        ok = False\nif ok:\n    print('All ordering invariants OK')\n\"\n"]
[360.175443, "o", "python3 -c \"\r\n\u001b[?2004l\r\u001b[?2004h> import json\r\n\u001b[?2004l\r\u001b[?2004h> with open('/app/output/report.json') as f:\r\n\u001b[?2004l\r\u001b[?2004h>     d = json.load(f)\r\n\u001b[?2004l\r\u001b[?2004h> events = d['events']\r\n\u001b[?2004l\r\u001b[?2004h> # Check ordering: for each id, submit must come before complete, complete before notify\r\n\u001b[?2004l\r\u001b[?2004h> first_submit = {}\r\n\u001b[?2004l\r\u001b[?2004h> first_complete = {}\r\n\u001b[?2004l\r\u001b[?2004h> first_notify = {}\r\n\u001b[?2004l\r\u001b[?2004h> for i, ev in enumerate(events):\r\n\u001b[?2004l\r= ci:\r\n        print(f'Order violation submit/complete for {eid}: {si} >= {ci}')\r\n        ok = False\r\n    if ni is None:\r\n        print(f'Missing notify for {eid}')\r\n        ok = False\r\n    elif ci is not None and ci >= ni:\r\n        print(f'Order violation complete/notify for {eid}: {ci} >= {ni}')\r\n        ok = False\r\nif ok:\r\n    print('All ordering invariants OK')\r\n\"\r\n\u001b[?2004h>     eid = ev['id']\r\n"]
