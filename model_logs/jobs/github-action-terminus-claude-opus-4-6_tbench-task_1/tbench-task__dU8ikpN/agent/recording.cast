[612.561676, "o", "scenarios = ['basic', 'stress', 'stress2']\r\n\u001b[?2004l\r\u001b[?2004h> profiles = ['burst', 'steady']\r\n\u001b[?2004l\r\u001b[?2004h> orders = ['a_then_b', 'b_then_a']\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def check_report(path, scenario, profile):\r\n\u001b[?2004l\r\u001b[?2004h>     with open(path) as f:\r\n\u001b[?2004l\r\u001b[?2004h>         d = json.load(f)\r\n\u001b[?2004l\r\u001b[?2004h>     assert d['scenario'] == scenario, f\"Bad scenario: {d['scenario']}\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
