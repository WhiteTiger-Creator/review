[180.559905, "o", "\r\n"]
[180.559948, "o", "\u001b[?2004l\r"]
[180.562382, "o", "#pragma once\r\n\r\n#include <stdbool.h>\r\n#include <stdint.h>\r\n#include <stdio.h>\r\n\r\nbool fs_write_u32(FILE *f, uint32_t v);\r\nbool fs_read_u32(FILE *f, uint32_t *out);\r\n\r\nbool fs_write_u64(FILE *f, uint64_t v);\r\nbool fs_read_u64(FILE *f, uint64_t *out);\r\n\r\n"]
