[179.972126, "i", "cat /app/src/core/vec_ev.c\n"]
[179.972829, "o", "cat /app/src/core/vec_ev.c\r\n\u001b[?2004l\r"]
[179.97417, "o", "#include \"core/vec_ev.h\"\r\n\r\n#include <stdlib.h>\r\n\r\nbool tb_vec_ev_init(tb_vec_ev *a, size_t cap) {\r\n  if (!a)\r\n    return false;\r\n  if (cap == 0)\r\n    cap = 16;\r\n  a->v = (tb_event *)malloc(sizeof(tb_event) * cap);\r\n  if (!a->v)\r\n    return false;\r\n  a->len = 0;\r\n  a->cap = cap;\r\n  return true;\r\n}\r\n\r\nvoid tb_vec_ev_free(tb_vec_ev *a) {\r\n  if (!a)\r\n    return;\r\n  free(a->v);\r\n  a->v = NULL;\r\n  a->len = 0;\r\n  a->cap = 0;\r\n}\r\n\r\nbool tb_vec_ev_push(tb_vec_ev *a, tb_event ev) {\r\n  if (!a || !a->v)\r\n    return false;\r\n  if (a->len == a->cap) {\r\n    size_t ncap = a->cap * 2;\r\n    tb_event *nv = (tb_event *)realloc(a->v, ncap * sizeof(tb_event));\r\n    if (!nv)\r\n      return false;\r\n    a->v = nv;\r\n    a->cap = ncap;\r\n  }\r\n  a->v[a->len++] = ev;\r\n  return true;\r\n}\r\n\r\nvoid tb_vec_ev_clear(tb_vec_ev *a) {\r\n  if (!a)\r\n    return;\r\n  a->len = 0;\r\n}\r\n\r\n"]
[179.974263, "o", "\u001b[?2004hroot@ddb910b7e5ab:/app# "]
[180.265742, "i", "cat /app/src/io/fs.c\n"]
[180.26628, "o", "cat /app/src/io/fs.c\r\n\u001b[?2004l\r"]
[180.267207, "o", "#include \"io/fs.h\"\r\n\r\nbool fs_write_u32(FILE *f, uint32_t v) { return fwrite(&v, sizeof(v), 1, f) == 1; }\r\nbool fs_read_u32(FILE *f, uint32_t *out) { return fread(out, sizeof(*out), 1, f) == 1; }\r\n\r\nbool fs_write_u64(FILE *f, uint64_t v) { return fwrite(&v, sizeof(v), 1, f) == 1; }\r\nbool fs_read_u64(FILE *f, uint64_t *out) { return fread(out, sizeof(*out), 1, f) == 1; }\r\n\r\n"]
[180.267376, "o", "\u001b[?2004h"]
[180.267552, "o", "root@ddb910b7e5ab:/app# "]
