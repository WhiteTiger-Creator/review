[376.685083, "i", "cat > /tmp/check.py << 'PYEOF'\nimport json\n\nwith open('/app/output/stress_a.json') as f:\n    a = json.load(f)\nwith open('/app/output/stress_b.json') as f:\n    b = json.load(f)\n\nprint('stress a_then_b events:', len(a['events']))\nprint('stress b_then_a events:', len(b['events']))\n\na_sub = [e['id'] for e in a['events'] if e['kind']=='submit']\nb_sub = [e['id'] for e in b['events'] if e['kind']=='submit']\nprint('Same submits:', a_sub == b_sub)\n\na_comp = [e['id'] for e in a['events'] if e['kind']=='complete']\nb_comp = [e['id'] for e in b['events'] if e['kind']=='complete']\nprint('Same complete coverage:', sorted(a_comp) == sorted(b_comp))\nprint('Different complete sequence:', a_comp != b_comp)\nprint('Submit IDs contiguous 1..N:', a_sub == list(range(1, len(a_sub)+1)))\n\n# Check ordering for stress_a\nevents = a['events']\nfirst_submit = {}\nfirst_complete = {}\nfirst_notify = {}\nfor i, ev in enumerate(events):\n    eid = ev['id']\n    kind = ev['kind']\n    if kind == 'submit':\n        first_submit.setdefault(eid, i)\n    e"]
[376.686869, "i", "lif kind == 'complete':\n        first_complete.setdefault(eid, i)\n    elif kind == 'notify':\n        first_notify.setdefault(eid, i)\n\nok = True\nfor eid in first_submit:\n    si = first_submit[eid]\n    ci = first_complete.get(eid)\n    ni = first_notify.get(eid)\n    if ci is None:\n        print(f'Missing complete for {eid}')\n        ok = False\n    elif si >= ci:\n        print(f'Order violation submit/complete for {eid}: {si} >= {ci}')\n        ok = False\n    if ni is None:\n        print(f'Missing notify for {eid}')\n        ok = False\n    elif ci is not None and ci >= ni:\n        print(f'Order violation complete/notify for {eid}: {ci} >= {ni}')\n        ok = False\n\nif ok:\n    print('Stress ordering invariants OK')\nelse:\n    print('ORDERING FAILED')\nPYEOF\npython3 /tmp/check.py\n"]
