[612.561916, "o", "    events = d['events']\r\n\u001b[?2004l\r"]
[612.561974, "o", "\u001b[?2004h> "]
[612.562211, "o", "    submits = [e for e in events if e['kind'] == 'submit']\r\n\u001b[?2004l\r"]
[612.562279, "o", "\u001b[?2004h"]
[612.562324, "o", "> "]
[612.562499, "o", "    completes = [e for e in events if e['kind'] == 'complete']\r\n\u001b[?2004l\r"]
[612.562576, "o", "\u001b[?2004h> "]
[612.56292, "o", "    notifies = [e for e in events if e['kind'] == 'notify']\r\n\u001b[?2004l\r\u001b[?2004h"]
[612.563012, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[612.56304, "o", "    # IDs contiguous 1..N\r\n\u001b[?2004l\r\u001b[?2004h> "]
[612.563205, "o", "    sub_ids = [e['id'] for e in submits]\r\n\u001b[?2004l\r"]
[612.563268, "o", "\u001b[?2004h> "]
[612.563492, "o", "    assert sub_ids == list(range(1, len(submits)+1)), \"IDs not contiguous\"\r\n\u001b[?2004l\r"]
[612.563553, "o", "\u001b[?2004h> "]
[612.563607, "o", "    \r\n\u001b[?2004l\r"]
[612.563629, "o", "\u001b[?2004h> "]
[612.563797, "o", "    # Every submit completed and notified exactly once\r\n\u001b[?2004l\r"]
[612.563818, "o", "\u001b[?2004h"]
[612.563838, "o", "> "]
[612.564162, "o", "    assert len(completes) == len(submits), f\"Complete count mismatch: {len(completes)} vs {len(submits)}\"\r\n\u001b[?2004l\r"]
[612.564213, "o", "\u001b[?2004h"]
[612.564238, "o", "> "]
[612.564549, "o", "    assert len(notifies) == len(submits), f\"Notify count mismatch: {len(notifies)} vs {len(submits)}\"\r\n\u001b[?2004l\r"]
[612.564573, "o", "\u001b[?2004h"]
[612.564588, "o", "> "]
[612.564863, "o", "    assert sorted(e['id'] for e in completes) == sorted(sub_ids), \"Complete IDs mismatch\"\r\n\u001b[?2004l\r"]
[612.564928, "o", "\u001b[?2004h> "]
[612.56519, "o", "    assert sorted(e['id'] for e in notifies) == sorted(sub_ids), \"Notify IDs mismatch\"\r\n\u001b[?2004l\r"]
[612.565241, "o", "\u001b[?2004h> "]
[612.565296, "o", "    "]
[612.565316, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[612.565425, "o", "    # No duplicate (kind, id)\r\n\u001b[?2004l\r"]
[612.56549, "o", "\u001b[?2004h> "]
[612.565566, "o", "    seen = set()\r\n\u001b[?2004l\r"]
[612.565668, "o", "\u001b[?2004h> "]
[612.56569, "o", "    for e in events:\r\n\u001b[?2004l\r"]
[612.565758, "o", "\u001b[?2004h> "]
[612.565851, "o", "        key = (e['kind'], e['id'])\r\n\u001b[?2004l\r"]
[612.565901, "o", "\u001b[?2004h"]
[612.566008, "o", "> "]
[612.566111, "o", "        assert key not in seen, f\"Duplicate: {key}\"\r\n\u001b[?2004l\r"]
[612.566179, "o", "\u001b[?2004h> "]
[612.566259, "o", "        seen.add(key)\r\n\u001b[?2004l\r\u001b[?2004h"]
[612.566331, "o", "> "]
[612.566391, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[612.566525, "o", "    # Ordering: submit < complete < notify for each id\r\n\u001b[?2004l\r"]
[612.566542, "o", "\u001b[?2004h"]
[612.566646, "o", "> "]
[612.566691, "o", "    positions = {}\r\n\u001b[?2004l\r\u001b[?2004h> "]
[612.566809, "o", "    for i, e in enumerate(events):\r\n\u001b[?2004l\r"]
[612.566911, "o", "\u001b[?2004h> "]
[612.567063, "o", "        positions.setdefault(e['id'], {})[e['kind']] = i\r\n\u001b[?2004l\r"]
[612.567085, "o", "\u001b[?2004h"]
[612.567102, "o", "> "]
[612.56724, "o", "    for eid, pos in positions.items():\r\n\u001b[?2004l\r"]
[612.567308, "o", "\u001b[?2004h> "]
[612.567537, "o", "        assert pos['submit'] < pos['complete'], f\"Order: submit >= complete for {eid}\"\r\n\u001b[?2004l\r"]
[612.567603, "o", "\u001b[?2004h> "]
[612.567858, "o", "        assert pos['complete'] < pos['notify'], f\"Order: complete >= notify for {eid}\"\r\n\u001b[?2004l\r"]
[612.56798, "o", "\u001b[?2004h> "]
[612.568064, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[612.568211, "o", "    # Interleaving: first complete before last submit\r\n\u001b[?2004l\r"]
[612.568271, "o", "\u001b[?2004h"]
[612.568293, "o", "> "]
[612.568405, "o", "    kinds = [e['kind'] for e in events]\r\n\u001b[?2004l\r"]
[612.568466, "o", "\u001b[?2004h> "]
[612.568553, "o", "    if len(submits) > 1:\r\n\u001b[?2004l\r"]
[612.568628, "o", "\u001b[?2004h> "]
[612.568765, "o", "        first_comp = kinds.index('complete')\r\n\u001b[?2004l\r"]
[612.568812, "o", "\u001b[?2004h"]
[612.56883, "o", "> "]
[612.569024, "o", "        last_sub = len(kinds) - 1 - kinds[::-1].index('submit')\r\n\u001b[?2004l\r"]
[612.569125, "o", "\u001b[?2004h> "]
[612.569274, "o", "        assert first_comp < last_sub, \"Not interleaved\"\r\n\u001b[?2004l\r"]
[612.569344, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[612.569361, "o", "\u001b[?2004h"]
[612.569376, "o", "> "]
[612.569457, "o", "    return events\r\n\u001b[?2004l\r"]
[612.569527, "o", "\u001b[?2004h"]
[612.569566, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[612.569679, "o", "all_ok = True\r\n\u001b[?2004l\r"]
[612.569707, "o", "\u001b[?2004h> "]
[612.569755, "o", "results = {}\r\n\u001b[?2004l\r"]
[612.569773, "o", "\u001b[?2004h"]
[612.569824, "o", "> \r\n\u001b[?2004l\r"]
[612.569926, "o", "\u001b[?2004h> "]
[612.570003, "o", "for scn in scenarios:\r\n\u001b[?2004l\r"]
[612.570039, "o", "\u001b[?2004h"]
[612.570108, "o", "> "]
[612.570146, "o", "    for prof in profiles:\r\n"]
[612.570219, "o", "\u001b[?2004l\r\u001b[?2004h"]
[612.570241, "o", "> "]
[612.570308, "o", "        for ord in orders:\r\n\u001b[?2004l\r"]
[612.570338, "o", "\u001b[?2004h"]
[612.570355, "o", "> "]
[612.570555, "o", "            out = f'/app/output/test_{scn}_{prof}_{ord}.json'\r\n\u001b[?2004l\r"]
[612.570592, "o", "\u001b[?2004h"]
[612.570659, "o", "> "]
[612.570911, "o", "            cmd = ['arena', '--scenario', scn, '--profile', prof, '--order', ord, '--out', out]\r\n\u001b[?2004l\r"]
[612.570932, "o", "\u001b[?2004h"]
[612.570954, "o", "> "]
[612.571146, "o", "            r = subprocess.run(cmd, capture_output=True)\r\n\u001b[?2004l\r"]
[612.571174, "o", "\u001b[?2004h"]
[612.571184, "o", "> "]
[612.571315, "o", "            if r.returncode != 0:\r\n\u001b[?2004l\r"]
[612.571378, "o", "\u001b[?2004h"]
[612.571432, "o", "> "]
[612.57163, "o", "                print(f'FAIL: {\" \".join(cmd)} -> exit {r.returncode}')\r\n\u001b[?2004l\r"]
[612.57166, "o", "\u001b[?2004h> "]
[612.571804, "o", "                print(r.stderr.decode())\r\n\u001b[?2004l\r"]
[612.571871, "o", "\u001b[?2004h> "]
[612.571963, "o", "                all_ok = False\r\n\u001b[?2004l\r"]
[612.572047, "o", "\u001b[?2004h"]
[612.572145, "o", ">                 continue\r\n\u001b[?2004l\r"]
[612.572205, "o", "\u001b[?2004h>             try:\r\n\u001b[?2004l\r"]
[612.57228, "o", "\u001b[?2004h> "]
[612.572423, "o", "                evts = check_report(out, scn, prof)\r\n\u001b[?2004l\r"]
[612.572491, "o", "\u001b[?2004h> "]
[612.572619, "o", "                results[(scn, prof, ord)] = evts\r\n\u001b[?2004l\r"]
[612.572662, "o", "\u001b[?2004h"]
[612.572681, "o", "> "]
[612.57288, "o", "                print(f'OK: {scn}/{prof}/{ord} -> {len(evts)} events')\r\n\u001b[?2004l\r"]
[612.572952, "o", "\u001b[?2004h> "]
[612.573061, "o", "            except Exception as ex:\r\n\u001b[?2004l\r"]
[612.573128, "o", "\u001b[?2004h> "]
[612.573288, "o", "                print(f'FAIL: {scn}/{prof}/{ord}: {ex}')\r\n\u001b[?2004l\r"]
[612.573354, "o", "\u001b[?2004h> "]
[612.573446, "o", "                all_ok = False\r\n\u001b[?2004l\r"]
[612.573504, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[612.573685, "o", "\u001b[?2004h> "]
[612.573749, "o", "# Check reconciliation order changes sequence\r\n\u001b[?2004l\r\u001b[?2004h"]
[612.573763, "o", "> "]
[612.573849, "o", "for scn in scenarios:\r\n\u001b[?2004l\r"]
[612.573917, "o", "\u001b[?2004h> "]
[612.573991, "o", "    for prof in profiles:\r\n\u001b[?2004l\r"]
[612.574011, "o", "\u001b[?2004h"]
[612.574023, "o", "> "]
[612.574213, "o", "        a_evts = results.get((scn, prof, 'a_then_b'))\r\n\u001b[?2004l\r"]
[612.574245, "o", "\u001b[?2004h"]
[612.574301, "o", "> "]
[612.574449, "o", "        b_evts = results.get((scn, prof, 'b_then_a'))\r\n\u001b[?2004l\r"]
[612.574501, "o", "\u001b[?2004h> "]
[612.574607, "o", "        if a_evts and b_evts:\r\n"]
[612.574656, "o", "\u001b[?2004l\r\u001b[?2004h"]
[612.574695, "o", "> "]
[612.57491, "o", "            a_comp = [e['id'] for e in a_evts if e['kind'] == 'complete']\r\n\u001b[?2004l\r"]
[612.574968, "o", "\u001b[?2004h> "]
[612.575185, "o", "            b_comp = [e['id'] for e in b_evts if e['kind'] == 'complete']\r\n\u001b[?2004l\r"]
[612.575202, "o", "\u001b[?2004h"]
[612.57523, "o", "> "]
[612.575436, "o", "            if sorted(a_comp) == sorted(b_comp) and a_comp != b_comp:\r\n\u001b[?2004l\r"]
[612.575456, "o", "\u001b[?2004h"]
[612.575481, "o", "> "]
[612.575652, "o", "                print(f'  Order diff OK: {scn}/{prof}')\r\n\u001b[?2004l\r"]
[612.575732, "o", "\u001b[?2004h"]
[612.575816, "o", "> "]
[612.575901, "o", "            elif a_comp == b_comp:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[612.57609, "o", "                print(f'  WARNING: same sequence for {scn}/{prof}')\r\n\u001b[?2004l\r"]
[612.57611, "o", "\u001b[?2004h"]
[612.576122, "o", "> "]
[612.576296, "o", "            else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[612.576468, "o", "                print(f'  ERROR: different coverage for {scn}/{prof}')\r\n\u001b[?2004l\r"]
[612.576534, "o", "\u001b[?2004h> "]
[612.576633, "o", "                all_ok = False\r\n\u001b[?2004l\r"]
[612.576696, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[612.576761, "o", "\u001b[?2004h> "]
[612.576879, "o", "# Check reproducibility\r\n\u001b[?2004l\r\u001b[?2004h"]
[612.576898, "o", "> "]
[612.577019, "o", "for scn in scenarios:\r\n\u001b[?2004l\r"]
[612.577081, "o", "\u001b[?2004h> "]
[612.577156, "o", "    for prof in profiles:\r\n\u001b[?2004l\r"]
[612.577227, "o", "\u001b[?2004h> "]
[612.57729, "o", "        for ord in orders:\r\n\u001b[?2004l\r"]
[612.577369, "o", "\u001b[?2004h> "]
[612.577534, "o", "            out1 = f'/app/output/test_{scn}_{prof}_{ord}.json'\r\n\u001b[?2004l\r"]
[612.577626, "o", "\u001b[?2004h> "]
[612.577804, "o", "            out2 = f'/app/output/test_{scn}_{prof}_{ord}_2.json'\r\n\u001b[?2004l\r"]
[612.577861, "o", "\u001b[?2004h> "]
[612.578246, "o", "            subprocess.run(['arena', '--scenario', scn, '--profile', prof, '--order', ord, '--out', out2], capture_output=True)\r\n\u001b[?2004l\r"]
[612.578272, "o", "\u001b[?2004h"]
[612.578363, "o", "> "]
[612.578506, "o", "            with open(out1) as f1, open(out2) as f2:\r\n\u001b[?2004l\r"]
[612.57853, "o", "\u001b[?2004h> "]
[612.578679, "o", "                if f1.read() == f2.read():\r\n\u001b[?2004l\r"]
[612.578763, "o", "\u001b[?2004h> "]
[612.57888, "o", "                    pass  # good\r\n\u001b[?2004l\r"]
[612.578902, "o", "\u001b[?2004h> "]
[612.57897, "o", "                else:\r\n\u001b[?2004l\r"]
[612.578999, "o", "\u001b[?2004h"]
[612.57901, "o", "> "]
[612.579216, "o", "                    print(f'FAIL REPRO: {scn}/{prof}/{ord}')\r\n\u001b[?2004l\r"]
[612.579251, "o", "\u001b[?2004h"]
[612.579332, "o", "> "]
[612.579421, "o", "                    all_ok = False\r\n\u001b[?2004l\r"]
[612.579438, "o", "\u001b[?2004h"]
[612.579447, "o", "> "]
[612.579457, "o", "\r\n\u001b[?2004l\r"]
[612.579486, "o", "\u001b[?2004h"]
[612.579506, "o", "> "]
[612.579623, "o", "if all_ok:\r\n\u001b[?2004l\r"]
[612.57965, "o", "\u001b[?2004h> "]
[612.579747, "o", "    print('\\nALL TESTS PASSED')\r\n\u001b[?2004l\r"]
[612.579772, "o", "\u001b[?2004h> "]
[612.579811, "o", "else:\r\n\u001b[?2004l\r"]
[612.579839, "o", "\u001b[?2004h"]
[612.579938, "o", "> "]
[612.580013, "o", "    print('\\nSOME TESTS FAILED')\r\n\u001b[?2004l\r"]
[612.580029, "o", "\u001b[?2004h"]
[612.58004, "o", "> "]
[612.580102, "o", "PYEOF\r\n\u001b[?2004l\r"]
[612.581206, "o", "\u001b[?2004hroot@ddb910b7e5ab:/app# "]
