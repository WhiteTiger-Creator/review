[285.594503, "i", "cat > /app/src/auth.c << 'EOF'\n#include \"auth.h\"\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <ctype.h>\n\nstatic char api_key[256] = {0};\nstatic int key_loaded = 0;\n\nstatic void load_api_key(void) {\n    if (key_loaded) return;\n    FILE *f = fopen(\"/app/config/api.key\", \"r\");\n    if (!f) {\n        key_loaded = 1;\n        return;\n    }\n    if (fgets(api_key, sizeof(api_key), f)) {\n        /* trim whitespace from both ends */\n        char *start = api_key;\n        while (*start && isspace((unsigned char)*start)) start++;\n        char *end = start + strlen(start) - 1;\n        while (end >= start && isspace((unsigned char)*end)) *end-- = '\\0';\n        if (start != api_key) memmove(api_key, start, strlen(start) + 1);\n    }\n    fclose(f);\n    key_loaded = 1;\n}\n\nint api_key_valid(struct MHD_Connection *connection) {\n    load_api_key();\n    const char *provided = MHD_lookup_connection_value(connection, MHD_HEADER_KIND, \"X-API-Key\");\n    if (!provided || strlen(api_key) == 0) return 0;\n    return strcmp(provided, api_key) == 0 ? 1 : 0;\n}\nEOF\n"]
[285.595913, "o", "cat > /app/src/auth.c << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> #include \"auth.h\"\r\n\u001b[?2004l\r\u001b[?2004h> #include <stdio.h>\r\n\u001b[?2004l\r\u001b[?2004h> "]
