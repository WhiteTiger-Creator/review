[286.127834, "o", "/* Check if a key exists in JSON (even if value is empty string) */\r\n\u001b[?2004l\r"]
[286.127977, "o", "\u001b[?2004h> "]
[286.12823, "o", "static int json_has_key(const char *json, const char *key) {\r\n\u001b[?2004l\r"]
[286.128323, "o", "\u001b[?2004h> "]
[286.128434, "o", "    char search[256];\r\n\u001b[?2004l\r"]
[286.128521, "o", "\u001b[?2004h> "]
[286.128805, "o", "    snprintf(search, sizeof(search), \"\\\"%s\\\"\", key);\r\n\u001b[?2004l\r"]
[286.128832, "o", "\u001b[?2004h> "]
[286.129087, "o", "    return strstr(json, search) != NULL;\r\n\u001b[?2004l\r"]
[286.12911, "o", "\u001b[?2004h"]
[286.129129, "o", "> }\r\n\u001b[?2004l\r"]
[286.129255, "o", "\u001b[?2004h> "]
[286.129356, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[286.129517, "o", "static int parse_id_from_url(const char *url) {\r\n\u001b[?2004l\r"]
[286.129613, "o", "\u001b[?2004h> "]
[286.129777, "o", "    /* url is /api/notes/{id} */\r\n\u001b[?2004l\r"]
[286.129893, "o", "\u001b[?2004h> "]
[286.130108, "o", "    const char *p = url + strlen(\"/api/notes/\");\r\n\u001b[?2004l\r"]
[286.130132, "o", "\u001b[?2004h"]
[286.130153, "o", "> "]
[286.130413, "o", "    if (*p == '\\0' || *p == '?') return -1;\r\n\u001b[?2004l\r"]
[286.130478, "o", "\u001b[?2004h> "]
[286.130636, "o", "    /* check all digits */\r\n\u001b[?2004l\r"]
[286.130691, "o", "\u001b[?2004h> "]
[286.130855, "o", "    const char *check = p;\r\n\u001b[?2004l\r"]
[286.130943, "o", "\u001b[?2004h> "]
[286.131048, "o", "    while (*check) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[286.131405, "o", "        if (!isdigit((unsigned char)*check)) return -1;\r\n\u001b[?2004l\r"]
[286.13155, "o", "\u001b[?2004h> "]
[286.131622, "o", "        check++;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[286.131666, "o", "    }\r\n\u001b[?2004l\r"]
[286.131706, "o", "\u001b[?2004h> "]
[286.131869, "o", "    return atoi(p);\r\n\u001b[?2004l\r\u001b[?2004h"]
[286.131908, "o", "> }\r\n\u001b[?2004l\r"]
[286.131933, "o", "\u001b[?2004h"]
[286.131956, "o", "> \r\n\u001b[?2004l\r"]
[286.132079, "o", "\u001b[?2004h> "]
