[286.109813, "o", "/* Simple JSON string value extractor - finds \"key\":\"value\" and returns allocated string */\r\n\u001b[?2004l\r"]
[286.109871, "o", "\u001b[?2004h> "]
[286.110246, "o", "static char *json_get_string(const char *json, const char *key) {\r\n\u001b[?2004l\r"]
[286.110285, "o", "\u001b[?2004h> "]
[286.11043, "o", "    char search[256];\r\n\u001b[?2004l\r"]
[286.110476, "o", "\u001b[?2004h> "]
[286.110792, "o", "    snprintf(search, sizeof(search), \"\\\"%s\\\"\", key);\r\n\u001b[?2004l\r"]
[286.110911, "o", "\u001b[?2004h> "]
[286.111096, "o", "    const char *pos = strstr(json, search);\r\n\u001b[?2004l\r"]
[286.111147, "o", "\u001b[?2004h> "]
[286.111301, "o", "    if (!pos) return NULL;\r\n\u001b[?2004l\r"]
[286.11133, "o", "\u001b[?2004h> "]
[286.11161, "o", "    pos += strlen(search);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[286.11178, "o", "    /* skip whitespace and colon */\r\n\u001b[?2004l\r"]
[286.111806, "o", "\u001b[?2004h> "]
[286.112244, "o", "    while (*pos && (isspace((unsigned char)*pos) || *pos == ':')) pos++;\r\n\u001b[?2004l\r"]
[286.112267, "o", "\u001b[?2004h"]
[286.112285, "o", "> "]
[286.112693, "o", "    if (*pos == 'n' && strncmp(pos, \"null\", 4) == 0) return NULL;\r\n\u001b[?2004l\r"]
[286.112719, "o", "\u001b[?2004h> "]
[286.112946, "o", "    if (*pos != '\"') return NULL;\r\n\u001b[?2004l\r"]
[286.112968, "o", "\u001b[?2004h"]
[286.112986, "o", "> "]
[286.1132, "o", "    pos++; /* skip opening quote */\r\n\u001b[?2004l\r"]
[286.113223, "o", "\u001b[?2004h"]
[286.113243, "o", "> "]
[286.113526, "o", "    /* find end of string, handling escapes */\r\n\u001b[?2004l\r"]
[286.113549, "o", "\u001b[?2004h"]
[286.11357, "o", "> "]
[286.113717, "o", "    size_t cap = 1024;\r\n\u001b[?2004l\r"]
[286.113785, "o", "\u001b[?2004h> "]
[286.113955, "o", "    char *result = malloc(cap);\r\n\u001b[?2004l\r"]
[286.113977, "o", "\u001b[?2004h"]
[286.113995, "o", "> "]
[286.114124, "o", "    size_t len = 0;\r\n\u001b[?2004l\r"]
[286.11415, "o", "\u001b[?2004h"]
[286.114171, "o", "> "]
[286.114384, "o", "    while (*pos && *pos != '\"') {\r\n\u001b[?2004l\r"]
[286.114472, "o", "\u001b[?2004h> "]
[286.114615, "o", "        if (len + 8 >= cap) {\r\n\u001b[?2004l\r"]
[286.114643, "o", "\u001b[?2004h> "]
[286.114791, "o", "            cap *= 2;\r\n\u001b[?2004l\r"]
[286.11482, "o", "\u001b[?2004h> "]
[286.115085, "o", "            result = realloc(result, cap);\r\n\u001b[?2004l\r"]
[286.115157, "o", "\u001b[?2004h> "]
[286.115219, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h"]
[286.115243, "o", "> "]
[286.115458, "o", "        if (*pos == '\\\\') {\r\n\u001b[?2004l\r"]
[286.115484, "o", "\u001b[?2004h> "]
[286.115612, "o", "            pos++;\r\n\u001b[?2004l\r"]
[286.11564, "o", "\u001b[?2004h> "]
[286.11584, "o", "            switch (*pos) {\r\n\u001b[?2004l\r"]
[286.115921, "o", "\u001b[?2004h> "]
[286.11621, "o", "                case '\"': result[len++] = '\"'; break;\r\n\u001b[?2004l\r"]
[286.116278, "o", "\u001b[?2004h> "]
[286.116582, "o", "                case '\\\\': result[len++] = '\\\\'; break;\r\n\u001b[?2004l\r"]
[286.116671, "o", "\u001b[?2004h> "]
[286.116946, "o", "                case '/': result[len++] = '/'; break;\r\n\u001b[?2004l\r"]
[286.117039, "o", "\u001b[?2004h> "]
[286.117308, "o", "                case 'n': result[len++] = '\\n'; break;\r\n\u001b[?2004l\r"]
[286.117417, "o", "\u001b[?2004h> "]
[286.117677, "o", "                case 'r': result[len++] = '\\r'; break;\r\n\u001b[?2004l\r"]
[286.117747, "o", "\u001b[?2004h> "]
[286.118039, "o", "                case 't': result[len++] = '\\t'; break;\r\n\u001b[?2004l\r"]
[286.118068, "o", "\u001b[?2004h> "]
[286.118396, "o", "                case 'b': result[len++] = '\\b'; break;\r\n\u001b[?2004l\r"]
[286.118455, "o", "\u001b[?2004h> "]
[286.118758, "o", "                case 'f': result[len++] = '\\f'; break;\r\n\u001b[?2004l\r"]
[286.11879, "o", "\u001b[?2004h> "]
[286.118969, "o", "                case 'u': {\r\n\u001b[?2004l\r"]
[286.119093, "o", "\u001b[?2004h> "]
[286.119491, "o", "                    /* basic unicode escape - just copy as-is for ASCII range */\r\n\u001b[?2004l\r"]
[286.119571, "o", "\u001b[?2004h> "]
[286.119881, "o", "                    if (pos[1] && pos[2] && pos[3] && pos[4]) {\r\n\u001b[?2004l\r"]
[286.119906, "o", "\u001b[?2004h> "]
[286.120329, "o", "                        char hex[5] = {pos[1], pos[2], pos[3], pos[4], 0};\r\n\u001b[?2004l\r"]
[286.120353, "o", "\u001b[?2004h> "]
[286.12086, "o", "                        unsigned int codepoint = (unsigned int)strtoul(hex, NULL, 16);\r\n\u001b[?2004l\r"]
[286.120888, "o", "\u001b[?2004h> "]
[286.121173, "o", "                        if (codepoint < 0x80) {\r\n\u001b[?2004l\r"]
[286.121294, "o", "\u001b[?2004h> "]
[286.121574, "o", "                            result[len++] = (char)codepoint;\r\n\u001b[?2004l\r"]
[286.121599, "o", "\u001b[?2004h> "]
[286.121934, "o", "                        } else if (codepoint < 0x800) {\r\n\u001b[?2004l\r"]
[286.121963, "o", "\u001b[?2004h> "]
[286.122444, "o", "                            result[len++] = (char)(0xC0 | (codepoint >> 6));\r\n\u001b[?2004l\r"]
[286.122551, "o", "\u001b[?2004h> "]
[286.122922, "o", "                            result[len++] = (char)(0x80 | (codepoint & 0x3F));\r\n\u001b[?2004l\r"]
[286.122957, "o", "\u001b[?2004h> "]
[286.123164, "o", "                        } else {\r\n\u001b[?2004l\r"]
[286.12319, "o", "\u001b[?2004h> "]
[286.123632, "o", "                            result[len++] = (char)(0xE0 | (codepoint >> 12));\r\n\u001b[?2004l\r"]
[286.123667, "o", "\u001b[?2004h> "]
[286.124178, "o", "                            result[len++] = (char)(0x80 | ((codepoint >> 6) & 0x3F));\r\n\u001b[?2004l\r"]
[286.124221, "o", "\u001b[?2004h> "]
[286.124674, "o", "                            result[len++] = (char)(0x80 | (codepoint & 0x3F));\r\n\u001b[?2004l\r"]
[286.124764, "o", "\u001b[?2004h> "]
[286.124888, "o", "                        }\r\n\u001b[?2004l\r"]
[286.124934, "o", "\u001b[?2004h> "]
[286.125129, "o", "                        pos += 4;\r\n\u001b[?2004l\r"]
[286.125229, "o", "\u001b[?2004h> "]
[286.125318, "o", "                    }\r\n\u001b[?2004l\r"]
[286.12535, "o", "\u001b[?2004h> "]
[286.125512, "o", "                    break;\r\n\u001b[?2004l\r"]
[286.12554, "o", "\u001b[?2004h> "]
[286.125667, "o", "                }\r\n\u001b[?2004l\r"]
[286.12574, "o", "\u001b[?2004h> "]
[286.12605, "o", "                default: result[len++] = *pos; break;\r\n\u001b[?2004l\r"]
[286.126137, "o", "\u001b[?2004h> "]
[286.126168, "o", "            }\r\n"]
[286.126193, "o", "\u001b[?2004l\r"]
[286.126214, "o", "\u001b[?2004h> "]
[286.126342, "o", "        } else {\r\n\u001b[?2004l\r"]
[286.126369, "o", "\u001b[?2004h> "]
[286.12658, "o", "            result[len++] = *pos;\r\n\u001b[?2004l\r"]
[286.126604, "o", "\u001b[?2004h> "]
[286.126707, "o", "        }\r\n\u001b[?2004l\r"]
[286.126838, "o", "\u001b[?2004h>         pos++;\r\n\u001b[?2004l\rt"]
[286.126873, "o", "\u001b[?2004h> "]
[286.126948, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[286.127044, "o", "> "]
[286.127125, "o", "    result[len] = '\\0';\r\n\u001b[?2004l\r"]
[286.127165, "o", "\u001b[?2004h> "]
[286.127292, "o", "    return result;\r\n\u001b[?2004l\r"]
