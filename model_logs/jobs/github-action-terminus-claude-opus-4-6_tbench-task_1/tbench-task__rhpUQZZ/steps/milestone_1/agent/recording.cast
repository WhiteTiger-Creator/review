[286.137217, "o", "\u001b[?2004h>         }\r\n"]
[286.137331, "o", "\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r \u001b[?2004h> "]
[286.137525, "o", "        struct connection_info *ci = *con_cls;\r\n\u001b[?2004l\r"]
[286.13755, "o", "\u001b[?2004h> "]
[286.137568, "o", "\r\n\u001b[?2004l\re"]
[286.137588, "o", "\u001b[?2004h"]
[286.137611, "o", "> "]
[286.137826, "o", "        if (*upload_data_size > 0) {\r\n\u001b[?2004l\r"]
[286.137853, "o", "\u001b[?2004h> "]
