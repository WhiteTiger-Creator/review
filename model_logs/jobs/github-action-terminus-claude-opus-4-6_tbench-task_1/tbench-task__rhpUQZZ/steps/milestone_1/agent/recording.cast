[286.141431, "o", "\u001b[?2004h> "]
[286.141657, "o", "            *upload_data_size = 0;\r\n\u001b[?2004l\r"]
[286.141756, "o", "\u001b[?2004h> "]
[286.141859, "o", "            return MHD_YES;\r\n\u001b[?2004l\r"]
[286.141886, "o", "\u001b[?2004h> "]
