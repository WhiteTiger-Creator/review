[318.836023, "o", "\u001b[?2004h"]
[318.836046, "o", "> "]
[318.836142, "o", "    if (!f) return MHD_NO;\r\n\u001b[?2004l\r"]
[318.836166, "o", "\u001b[?2004h> "]
[318.836189, "o", "\r\n\u001b[?2004l\r"]
[318.836213, "o", "\u001b[?2004h"]
[318.836238, "o", "> "]
[318.836373, "o", "    char *buf = malloc(st.st_size);\r\n\u001b[?2004l\r"]
[318.836444, "o", "\u001b[?2004h> "]
[318.836527, "o", "    fread(buf, 1, st.st_size, f);\r\n\u001b[?2004l\r"]
[318.836626, "o", "\u001b[?2004h>     fclose(f);\r\n\u001b[?2004l\r"]
