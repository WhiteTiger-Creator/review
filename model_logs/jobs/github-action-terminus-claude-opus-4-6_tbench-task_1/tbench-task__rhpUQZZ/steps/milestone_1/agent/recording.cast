[286.093778, "i", "cat > /app/src/routes.c << 'EOF'\n#include \"routes.h\"\n#include \"db.h\"\n#include \"auth.h\"\n#include <microhttpd.h>\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <ctype.h>\n\n#define MAX_BODY_SIZE 65536\n\nstatic enum MHD_Result send_json(struct MHD_Connection *connection,\n                                  const char *body, unsigned int status_code) {\n    struct MHD_Response *response = MHD_create_response_from_buffer(\n        strlen(body), (void *)body, MHD_RESPMEM_MUST_COPY);\n    MHD_add_response_header(response, \"Content-Type\", \"application/json\");\n    MHD_add_response_header(response, \"Access-Control-Allow-Origin\", \"*\");\n    MHD_add_response_header(response, \"Access-Control-Allow-Methods\",\n                            \"GET, POST, PUT, DELETE, OPTIONS\");\n    MHD_add_response_header(response, \"Access-Control-Allow-Headers\",\n                            \"Content-Type, X-API-Key\");\n    enum MHD_Result ret = MHD_queue_response(connection, status_code, response);\n    MHD_destroy_response(response);\n    return ret;\n}\n\nstatic enum MHD_Result send_json_with_total(struct MHD_Connection *connection,\n                                             const char *body, unsigned int status_code, int total) {\n    struct MHD_Response *response = MHD_create_response_from_buffer(\n        strlen(body), (void *)body, MHD_RESPMEM_MUST_COPY);\n    MHD_add_response_header(response, \"Content-Type\", \"application/json\");\n    MHD_add_response_header(response, \"Access-Control-Allow-Origin\", \"*\");\n    MHD_add_response_header(response, \"Access-Control-Allow-Methods\",\n                            \"GET, POST, PUT, DELETE, OPTIONS\");\n    MHD_add_response_header(response, \"Access-Control-Allow-Headers\",\n                            \"Content-Type, X-API-Key\");\n    char total_str[32];\n    snprintf(total_str, sizeof(total_str), \"%d\", total);\n    MHD_add_response_header(response, \"X-Total-Count\", total_str);\n    enum MHD_Result ret = MHD_queue_response(connection, status_code, response);\n    MHD_destroy_response(response);\n    return ret;\n}\n\n/* Simple JSON string value extractor - finds \"key\":\"value\" and returns allocated string */\nstatic char *json_get_string(const char *json, const char *key) {\n    char search[256];\n    snprintf(search, sizeof(search), \"\\\"%s\\\"\", key);\n    const char *pos = strstr(json, search);\n    if (!pos) return NULL;\n    pos += strlen(search);\n    /* skip whitespace and colon */\n    while (*pos && (isspace((unsigned char)*pos) || *pos == ':')) pos++;\n    if (*pos == 'n' && strncmp(pos, \"null\", 4) == 0) return NULL;\n    if (*pos != '\"') return NULL;\n    pos++; /* skip opening quote */\n    /* find end of string, handling escapes */\n    size_t cap = 1024;\n    char *result = malloc(cap);\n    size_t len = 0;\n    while (*pos && *pos != '\"') {\n        if (len + 8 >= cap) {\n            cap *= 2;\n            result = realloc(result, cap);\n        }\n        if (*pos == '\\\\') {\n            pos++;\n            switch (*pos) {\n                case '\"': result[len++] = '\"'; break;\n                case '\\\\': result[len++] = '\\\\'; break;\n                case '/': result[len++] = '/'; break;\n                case 'n': result[len++] = '\\n'; break;\n                case 'r': result[len++] = '\\r'; break;\n                case 't': result[len++] = '\\t'; break;\n                case 'b': result[len++] = '\\b'; break;\n                case 'f': result[len++] = '\\f'; break;\n                case 'u': {\n                    /* basic unicode escape - just copy as-is for ASCII range */\n                    if (pos[1] && pos[2] && pos[3] && pos[4]) {\n                        char hex[5] = {pos[1], pos[2], pos[3], pos[4], 0};\n                        unsigned int codepoint = (unsigned int)strtoul(hex, NULL, 16);\n                        if (codepoint < 0x80) {\n                            result[len++] = (char)codepoint;\n                        } else if (codepoint < 0x800) {\n                            result[len++] = (char)(0xC0 | (codepoint >> 6));\n                            result[len++] = (char)(0x80 | (codepoint & 0x3F));\n                        } else {\n         "]
[286.093976, "i", "                   result[len++] = (char)(0xE0 | (codepoint >> 12));\n                            result[len++] = (char)(0x80 | ((codepoint >> 6) & 0x3F));\n                            result[len++] = (char)(0x80 | (codepoint & 0x3F));\n                        }\n                        pos += 4;\n                    }\n                    break;\n                }\n                default: result[len++] = *pos; break;\n            }\n        } else {\n            result[len++] = *pos;\n        }\n        pos++;\n    }\n    result[len] = '\\0';\n    return result;\n}\n\n/* Check if a key exists in JSON (even if value is empty string) */\nstatic int json_has_key(const char *json, const char *key) {\n    char search[256];\n    snprintf(search, sizeof(search), \"\\\"%s\\\"\", key);\n    return strstr(json, search) != NULL;\n}\n\nstatic int parse_id_from_url(const char *url) {\n    /* url is /api/notes/{id} */\n    const char *p = url + strlen(\"/api/notes/\");\n    if (*p == '\\0' || *p == '?') return -1;\n    /* check all digits */\n    const char *check = p;\n    while (*check) {\n        if (!isdigit((unsigned char)*check)) return -1;\n        check++;\n    }\n    return atoi(p);\n}\n\nenum MHD_Result route_request(struct MHD_Connection *connection, const char *url,\n                              const char *method, const char *upload_data,\n                              size_t *upload_data_size, void **con_cls) {\n\n    /* OPTIONS preflight */\n    if (strcmp(method, \"OPTIONS\") == 0) {\n        return send_json(connection, \"\", 200);\n    }\n\n    /* For POST/PUT, we need to accumulate the body across multiple calls */\n    if (strcmp(method, \"POST\") == 0 || strcmp(method, \"PUT\") == 0) {\n        if (*con_cls == NULL) {\n            struct connection_info *ci = calloc(1, sizeof(struct connection_info));\n            ci->data = NULL;\n            ci->data_size = 0;\n            *con_cls = ci;\n            return MHD_YES;\n        }\n\n        struct connection_info *ci = *con_cls;\n\n        if (*upload_data_size > 0) {\n            /* Check body size limit */\n            if (ci->data_size + *upload_data_size > MAX_BODY_SIZE) {\n                *upload_data_size = 0;\n                ci->data_size = MAX_BODY_SIZE + 1; /* mark as too large */\n                return MHD_YES;\n            }\n            ci->data = realloc(ci->data, ci->data_size + *upload_data_size + 1);\n            memcpy(ci->data + ci->data_size, upload_data, *upload_data_size);\n            ci->data_size += *upload_data_size;\n            ci->data[ci->data_size] = '\\0';\n            *upload_data_size = 0;\n            return MHD_YES;\n        }\n\n        /* All data received - process the request */\n        if (ci->data_size > MAX_BODY_SIZE) {\n            return send_json(connection, \"{\\\"error\\\":\\\"payload too large\\\"}\", 413);\n        }\n\n        const char *body = ci->data ? ci->data : \"\";\n\n        if (strcmp(method, \"POST\") == 0 && strcmp(url, \"/api/notes\") == 0) {\n            /* Auth check */\n            if (!api_key_valid(connection)) {\n                return send_json(connection, \"{\\\"error\\\":\\\"unauthorized\\\"}\", 401);\n            }\n\n            /* Parse title and content */\n            char *title = json_get_string(body, \"title\");\n            char *content = json_get_string(body, \"content\");\n\n            /* Validate title */\n            if (!title || strlen(title) == 0) {\n                if (title) free(title);\n                if (content) free(content);\n                return send_json(connection, \"{\\\"error\\\":\\\"title is required\\\"}\", 400);\n            }\n\n            int id = create_note(title, content ? content : \"\");\n            if (id < 0) {\n                free(title);\n                if (content) free(content);\n                return send_json(connection, \"{\\\"error\\\":\\\"database error\\\"}\", 500);\n            }\n\n            /* Build response */\n            char *note_json = get_note_json(id);\n            enum MHD_Result r;\n            if (note_json) {\n                r = send_json(connection, note_json, 201);\n                free(note_json);\n            } else {\n                /* fallback - shouldn't happen */\n                ch"]
[286.094082, "i", "ar resp[65536];\n                char *etitle = malloc(strlen(title) * 6 + 1);\n                char *econtent = malloc((content ? strlen(content) : 0) * 6 + 1);\n                /* simple fallback */\n                snprintf(resp, sizeof(resp), \"{\\\"id\\\":%d,\\\"title\\\":\\\"%s\\\",\\\"content\\\":\\\"%s\\\"}\",\n                         id, title, content ? content : \"\");\n                free(etitle);\n                free(econtent);\n                r = send_json(connection, resp, 201);\n            }\n            free(title);\n            if (content) free(content);\n            return r;\n        }\n\n        if (strcmp(method, \"PUT\") == 0 && strncmp(url, \"/api/notes/\", 11) == 0) {\n            /* Auth check */\n            if (!api_key_valid(connection)) {\n                return send_json(connection, \"{\\\"error\\\":\\\"unauthorized\\\"}\", 401);\n            }\n\n            int id = parse_id_from_url(url);\n            if (id < 0) {\n                return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", 404);\n            }\n\n            /* Parse title and content */\n            char *title = json_get_string(body, \"title\");\n            char *content = json_get_string(body, \"content\");\n\n            /* Validate title - same rules as POST */\n            if (!title || strlen(title) == 0) {\n                if (title) free(title);\n                if (content) free(content);\n                return send_json(connection, \"{\\\"error\\\":\\\"title is required\\\"}\", 400);\n            }\n\n            int result = update_note(id, title, content ? content : \"\");\n            free(title);\n            if (content) free(content);\n\n            if (result == 1) {\n                return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", 404);\n            } else if (result < 0) {\n                return send_json(connection, \"{\\\"error\\\":\\\"database error\\\"}\", 500);\n            }\n\n            char *note_json = get_note_json(id);\n            if (note_json) {\n                enum MHD_Result r = send_json(connection, note_json, 200);\n                free(note_json);\n                return r;\n            }\n            return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", 404);\n        }\n\n        /* POST/PUT to unknown URL */\n        return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", 404);\n    }\n\n    /* DELETE needs body accumulation handling too (though typically no body) */\n    if (strcmp(method, \"DELETE\") == 0) {\n        if (*con_cls == NULL) {\n            struct connection_info *ci = calloc(1, sizeof(struct connection_info));\n            *con_cls = ci;\n            return MHD_YES;\n        }\n        if (*upload_data_size > 0) {\n            *upload_data_size = 0;\n            return MHD_YES;\n        }\n\n        if (strncmp(url, \"/api/notes/\", 11) != 0) {\n            return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", 404);\n        }\n\n        /* Auth check */\n        if (!api_key_valid(connection)) {\n            return send_json(connection, \"{\\\"error\\\":\\\"unauthorized\\\"}\", 401);\n        }\n\n        int id = parse_id_from_url(url);\n        if (id < 0) {\n            return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", 404);\n        }\n\n        int result = delete_note(id);\n        if (result == 1) {\n            return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", 404);\n        } else if (result < 0) {\n            return send_json(connection, \"{\\\"error\\\":\\\"database error\\\"}\", 500);\n        }\n        return send_json(connection, \"{\\\"status\\\":\\\"deleted\\\"}\", 200);\n    }\n\n    /* GET requests */\n    if (strcmp(method, \"GET\") == 0) {\n        /* GET /api/notes */\n        if (strcmp(url, \"/api/notes\") == 0) {\n            const char *limit_str = MHD_lookup_connection_value(connection, MHD_GET_ARGUMENT_KIND, \"limit\");\n            const char *offset_str = MHD_lookup_connection_value(connection, MHD_GET_ARGUMENT_KIND, \"offset\");\n\n            int limit = 50;\n            int offset = 0;\n            if (limit_str) limit = atoi(limit_str);\n            if (offset_str) offset = atoi(offset_str);\n            if (limit <= 0) limit = 50;\n            if (limit > 100) limit = 100;\n            if (o"]
[286.09412, "i", "ffset < 0) offset = 0;\n\n            int total = get_total_notes_count();\n            char *json = get_notes_paginated_json(limit, offset);\n            if (!json) {\n                return send_json_with_total(connection, \"[]\", 200, total);\n            }\n            enum MHD_Result r = send_json_with_total(connection, json, 200, total);\n            free(json);\n            return r;\n        }\n\n        /* GET /api/notes/{id} */\n        if (strncmp(url, \"/api/notes/\", 11) == 0) {\n            int id = parse_id_from_url(url);\n            if (id < 0) {\n                return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", 404);\n            }\n            char *json = get_note_json(id);\n            if (!json) {\n                return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", 404);\n            }\n            enum MHD_Result r = send_json(connection, json, 200);\n            free(json);\n            return r;\n        }\n\n        return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", 404);\n    }\n\n    return send_json(connection, \"{\\\"error\\\":\\\"not found\\\"}\", 404);\n}\nEOF\n"]
