[286.135026, "o", "\u001b[?2004h> "]
[286.135392, "o", "    if (strcmp(method, \"POST\") == 0 || strcmp(method, \"PUT\") == 0) {\r\n\u001b[?2004l\r"]
[286.135488, "o", "\u001b[?2004h> "]
[286.13564, "o", "        if (*con_cls == NULL) {\r\n\u001b[?2004l\r"]
[286.135731, "o", "\u001b[?2004h> "]
[286.136163, "o", "            struct connection_info *ci = calloc(1, sizeof(struct connection_info));\r\n\u001b[?2004l\r"]
