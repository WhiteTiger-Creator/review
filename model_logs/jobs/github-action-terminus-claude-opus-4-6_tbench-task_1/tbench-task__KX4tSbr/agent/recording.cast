[98.964258, "o", "cat /app/environment/m14/extra_m1.cpp\r\n\u001b[?2004l\r#include \"types.h\"\r\n#include <sstream>\r\n#include <string>\r\n#include <vector>\r\n\r\nnamespace forge {\r\n\r\nstd::string m14_token_manifest_order(const std::vector<UnitSpec> &units) {\r\n    std::ostringstream joined;\r\n    for (size_t i = 0; i < units.size(); ++i) {\r\n        if (i) {\r\n            joined << '\\n';\r\n        }\r\n        joined << units[i].name << '|' << units[i].mode << '|' << units[i].record << '|'\r\n               << units[i].manifest_bytes << '|' << units[i].start_pass;\r\n    }\r\n    return joined.str();\r\n}\r\n\r\n}\r\n\u001b[?2004hroot@607b4f5bd756:/app# "]
[99.090266, "i", "cat /app/environment/m14/shadow_m2.c\n"]
[99.090651, "o", "cat /app/environment/m14/shadow_m2.c\r\n\u001b[?2004l\r"]
[99.092544, "o", "#include \"types.h\"\r\n#include <stdlib.h>\r\n\r\nint64_t m14_shadow_carry(int64_t base, int64_t carry) {\r\n    if (carry < 0) {\r\n        return base;\r\n    }\r\n    return base + carry / 2;\r\n}\r\n\u001b[?2004hroot@607b4f5bd756:/app# "]
