[366.659516, "o", "    for (const auto &block : split_object_blocks(arr)) {\r\n\u001b[?2004l\r"]
[366.659539, "o", "\u001b[?2004h> "]
[366.659716, "o", "        UnitSpec spec;\r\n\u001b[?2004l\r"]
[366.659801, "o", "\u001b[?2004h> "]
[366.660094, "o", "        spec.name = pick_string(block, \"name\");\r\n\u001b[?2004l\r"]
[366.660118, "o", "\u001b[?2004h"]
[366.660139, "o", "> "]
[366.660469, "o", "        spec.mode = pick_string(block, \"mode\");\r\n\u001b[?2004l\r"]
[366.660579, "o", "\u001b[?2004h> "]
[366.660838, "o", "        spec.record = pick_string(block, \"record\");\r\n\u001b[?2004l\r"]
[366.66086, "o", "\u001b[?2004h"]
[366.660913, "o", "> "]
[366.661332, "o", "        spec.manifest_bytes = pick_int(block, \"manifest_bytes\");\r\n\u001b[?2004l\r"]
[366.661425, "o", "\u001b[?2004h> "]
[366.66174, "o", "        spec.start_pass = pick_int(block, \"start_pass\");\r\n\u001b[?2004l\r"]
[366.661763, "o", "\u001b[?2004h"]
[366.661843, "o", "> "]
[366.662029, "o", "        if (!spec.name.empty()) {\r\n\u001b[?2004l\r"]
[366.662115, "o", "\u001b[?2004h> "]
[366.662387, "o", "            manifest.units.push_back(spec);\r\n\u001b[?2004l\r"]
[366.662514, "o", "\u001b[?2004h>         }\r\n\u001b[?2004l\r"]
[366.662538, "o", "\u001b[?2004h> "]
[366.662661, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[366.662802, "o", "    return manifest;\r\n\u001b[?2004l\r"]
[366.662826, "o", "\u001b[?2004h> "]
[366.662913, "o", "}\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[366.662935, "o", "\u001b[?2004l\r"]
[366.662951, "o", "\u001b[?2004h"]
[366.663007, "o", "> "]
[366.663291, "o", "std::string digest_hex(const std::string &text) {\r\n\u001b[?2004l\r"]
[366.663419, "o", "\u001b[?2004h> "]
[366.663708, "o", "    std::uint64_t h = digest_update(kDigestSeed, text);\r\n\u001b[?2004l\r"]
[366.663732, "o", "\u001b[?2004h> "]
[366.663923, "o", "    std::ostringstream os;\r\n\u001b[?2004l\r"]
[366.663944, "o", "\u001b[?2004h"]
[366.664011, "o", "> "]
[366.664497, "o", "    os << std::hex << std::nouppercase << std::setfill('0') << std::setw(16) << h;\r\n\u001b[?2004l\r"]
[366.664618, "o", "\u001b[?2004h> "]
[366.664705, "o", "    return os.str();\r\n\u001b[?2004l\r\u001b[?2004h"]
[366.664804, "o", "> }\r\n\u001b[?2004l\r"]
[366.664907, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[366.66497, "o", "> "]
[366.665438, "o", "UnitRun analyze_unit(const UnitSpec &spec, int order_rank, int order_weight_base, int pass_epoch,\r\n\u001b[?2004l\r"]
[366.665592, "o", "\u001b[?2004h> "]
[366.666059, "o", "                     const fs::path &manifest_dir, const char *const *names, size_t name_count,\r\n\u001b[?2004l\r"]
[366.666079, "o", "\u001b[?2004h"]
[366.66609, "o", "> "]
[366.666599, "o", "                     const LaneCheckpoint *checkpoint, int64_t carry_weight) {\r\n\u001b[?2004l\r"]
[366.666684, "o", "\u001b[?2004h> "]
[366.666834, "o", "    (void)carry_weight;\r\n\u001b[?2004l\r"]
[366.666883, "o", "\u001b[?2004h> "]
[366.667271, "o", "    fs::path record_path = manifest_dir / spec.record;\r\n\u001b[?2004l\r"]
[366.667296, "o", "\u001b[?2004h"]
[366.667307, "o", "> "]
[366.667467, "o", "    UnitRun run{};\r\n\u001b[?2004l\r"]
[366.667547, "o", "\u001b[?2004h> "]
[366.66768, "o", "    run.name = spec.name;\r\n\u001b[?2004l\r"]
[366.667745, "o", "\u001b[?2004h"]
[366.667803, "o", "> "]
[366.668296, "o", "    run.mode = forge_lane_mode(spec.mode.c_str(), spec.name.c_str(), pass_epoch);\r\n\u001b[?2004l\r"]
[366.66832, "o", "\u001b[?2004h"]
[366.668349, "o", "> "]
[366.668622, "o", "    run.manifest_bytes = spec.manifest_bytes;\r\n\u001b[?2004l\r"]
[366.668658, "o", "\u001b[?2004h"]
[366.668671, "o", "> "]
[366.669021, "o", "    run.record_bytes = read_record_bytes(record_path);\r\n\u001b[?2004l\r"]
[366.669045, "o", "\u001b[?2004h"]
[366.669065, "o", "> "]
[366.669602, "o", "    run.drift_bytes = run.record_bytes - static_cast<int64_t>(run.manifest_bytes);\r\n\u001b[?2004l\r"]
[366.66962, "o", "\u001b[?2004h"]
[366.669633, "o", "> "]
[366.669864, "o", "    run.order_rank = order_rank;\r\n\u001b[?2004l\r"]
[366.670028, "o", "\u001b[?2004h> \r\n\u001b[?2004l\rl\u001b[?2004h> "]
[366.670237, "o", "    int pass_index = spec.start_pass;\r\n\u001b[?2004l\r"]
[366.670371, "o", "\u001b[?2004h> "]
[366.670506, "o", "    bool has_checkpoint_entry = false;\r\n\u001b[?2004l\r\u001b[?2004h"]
[366.67053, "o", "> "]
[366.670725, "o", "    int64_t cp_carry_weight = 0;\r\n\u001b[?2004l\r"]
[366.670801, "o", "\u001b[?2004h> "]
[366.671183, "o", "    if (run.mode == \"resume\" && checkpoint != nullptr && checkpoint->valid) {\r\n\u001b[?2004l\r"]
[366.671259, "o", "\u001b[?2004h> "]
[366.671513, "o", "        auto it = checkpoint->units.find(spec.name);\r\n\u001b[?2004l\r"]
[366.671622, "o", "\u001b[?2004h> "]
[366.671846, "o", "        if (it != checkpoint->units.end()) {\r\n\u001b[?2004l\r"]
[366.671949, "o", "\u001b[?2004h> "]
[366.672151, "o", "            pass_index = it->second.next_pass;\r\n\u001b[?2004l\r"]
[366.672172, "o", "\u001b[?2004h"]
[366.672214, "o", "> "]
[366.672557, "o", "            cp_carry_weight = it->second.carry_weight;\r\n\u001b[?2004l\r"]
[366.672599, "o", "\u001b[?2004h> "]
[366.672855, "o", "            has_checkpoint_entry = true;\r\n\u001b[?2004l\r"]
[366.672988, "o", "\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[366.67312, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\rt\u001b[?2004h> "]
[366.673424, "o", "    if (run.mode == \"resume\" && has_checkpoint_entry) {\r\n\u001b[?2004l\r"]
[366.673545, "o", "\u001b[?2004h> "]
[366.673972, "o", "        run.order_weight = cp_carry_weight + static_cast<int64_t>(order_weight_base) + run.record_bytes;\r\n\u001b[?2004l\r"]
[366.674032, "o", "\u001b[?2004h> "]
[366.674194, "o", "    } else {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[366.674679, "o", "        // Fresh formula: order_weight_base * (order_rank + 1) + record_bytes\r\n\u001b[?2004l\r\u001b[?2004h"]
[366.674699, "o", "> "]
[366.675498, "o", "        run.order_weight = static_cast<int64_t>(order_weight_base) * (static_cast<int64_t>(order_rank) + 1) + run.record_bytes;\r\n\u001b[?2004l\r"]
[366.675523, "o", "\u001b[?2004h"]
[366.675667, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[366.67586, "o", "    run.pass_index = pass_index;\r\n\u001b[?2004l\r"]
[366.675878, "o", "\u001b[?2004h"]
[366.675893, "o", "> "]
[366.676197, "o", "    run.row_serial = forge_lane_row_text(run);\r\n\u001b[?2004l\r"]
[366.676251, "o", "\u001b[?2004h> "]
[366.676556, "o", "    run.row_digest = digest_hex(run.row_serial);\r\n\u001b[?2004l\r"]
[366.676645, "o", "\u001b[?2004h> \r\n\u001b[?2004l\ro\u001b[?2004h"]
[366.67666, "o", "> "]
[366.676825, "o", "    std::ostringstream js;\r\n\u001b[?2004l\r"]
[366.676897, "o", "\u001b[?2004h> "]
[366.677448, "o", "    js << \"{\\\"name\\\":\\\"\" << json_escape(run.name) << \"\\\",\\\"mode\\\":\\\"\" << json_escape(run.mode)\r\n\u001b[?2004l\r"]
[366.677498, "o", "\u001b[?2004h> "]
[366.677984, "o", "       << \"\\\",\\\"pass_index\\\":\" << run.pass_index << \",\\\"manifest_bytes\\\":\" << run.manifest_bytes\r\n\u001b[?2004l\r"]
[366.678157, "o", "\u001b[?2004h> "]
[366.67851, "o", "       << \",\\\"record_bytes\\\":\" << run.record_bytes << \",\\\"drift_bytes\\\":\" << run.drift_bytes\r\n\u001b[?2004l\r"]
[366.678539, "o", "\u001b[?2004h> "]
[366.679015, "o", "       << \",\\\"order_rank\\\":\" << run.order_rank << \",\\\"order_weight\\\":\" << run.order_weight\r\n\u001b[?2004l\r"]
[366.679131, "o", "\u001b[?2004h> "]
[366.679354, "o", "       << \",\\\"row_digest\\\":\\\"\" << run.row_digest << \"\\\"}\";\r\n\u001b[?2004l\r"]
[366.679379, "o", "\u001b[?2004h"]
[366.679452, "o", "> "]
[366.679554, "o", "    run.json = js.str();\r\n\u001b[?2004l\r"]
[366.679607, "o", "\u001b[?2004h"]
[366.679623, "o", "> "]
[366.679711, "o", "    return run;\r\n\u001b[?2004l\r"]
[366.679792, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r"]
[366.679883, "o", "\u001b[?2004h> \r\n\u001b[?2004l\rh\u001b[?2004h> "]
[366.680033, "o", "}  // namespace forge\r\n\u001b[?2004l\r"]
[366.680069, "o", "\u001b[?2004h> \r\n"]
[366.680233, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[366.680392, "o", "int forge_run_emit(int argc, char **argv) {\r\n\u001b[?2004l\r"]
[366.680414, "o", "\u001b[?2004h> "]
[366.680553, "o", "    if (argc != 4) {\r\n\u001b[?2004l\r"]
[366.680637, "o", "\u001b[?2004h> "]
[366.681016, "o", "        std::cerr << \"usage: forge_emit <manifest-json> <output-json> <units-csv>\\n\";\r\n\u001b[?2004l\r"]
[366.681042, "o", "\u001b[?2004h"]
[366.681058, "o", "> "]
[366.681181, "o", "        return 2;\r\n\u001b[?2004l\r\u001b[?2004h"]
[366.6812, "o", "> "]
[366.681302, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[366.681485, "o", "    fs::path manifest_path = argv[1];\r\n\u001b[?2004l\r"]
[366.68151, "o", "\u001b[?2004h"]
[366.68161, "o", "> "]
[366.681743, "o", "    fs::path output_path = argv[2];\r\n\u001b[?2004l\r"]
[366.681762, "o", "\u001b[?2004h"]
[366.681775, "o", "> "]
[366.682179, "o", "    std::vector<std::string> requested = forge::split_units_csv(argv[3]);\r\n\u001b[?2004l\r"]
[366.682203, "o", "\u001b[?2004h"]
[366.682215, "o", "> "]
[366.682564, "o", "    forge::Manifest manifest = forge::load_manifest(manifest_path);\r\n\u001b[?2004l\r"]
[366.682588, "o", "\u001b[?2004h"]
[366.6826, "o", "> "]
[366.682906, "o", "    fs::path manifest_dir = manifest_path.parent_path();\r\n\u001b[?2004l\r"]
[366.682927, "o", "\u001b[?2004h"]
[366.682939, "o", "> \r\n"]
[366.682955, "o", "\u001b[?2004l\r"]
[366.683003, "o", "\u001b[?2004h> "]
[366.683468, "o", "    const char *lane_token = forge_lane_fingerprint(manifest.units.data(), manifest.units.size());\r\n\u001b[?2004l\r"]
[366.683493, "o", "\u001b[?2004h> "]
[366.683732, "o", "    std::string lane_token_str(lane_token);\r\n\u001b[?2004l\r"]
[366.683753, "o", "\u001b[?2004h"]
[366.683779, "o", "> "]
[366.684053, "o", "    fs::path checkpoint_path = forge::kCheckpointPath;\r\n\u001b[?2004l\r"]
[366.684074, "o", "\u001b[?2004h"]
[366.684087, "o", "> "]
[366.684476, "o", "    int pass_epoch = forge::read_pass_epoch(checkpoint_path, lane_token_str);\r\n\u001b[?2004l\r"]
[366.684502, "o", "\u001b[?2004h"]
[366.684515, "o", "> "]
[366.684866, "o", "    forge::LaneCheckpoint checkpoint = forge_lane_load_checkpoint(checkpoint_path, lane_token_str);\r\n\u001b[?2004l\r"]
[366.684889, "o", "\u001b[?2004h"]
[366.684902, "o", "> "]
[366.684914, "o", "\r\n\u001b[?2004l\r"]
[366.684955, "o", "\u001b[?2004h"]
[366.685087, "o", "> "]
[366.685164, "o", "    std::vector<const char *> name_ptrs;\r\n\u001b[?2004l\r"]
[366.685218, "o", "\u001b[?2004h> "]
[366.685348, "o", "    for (const auto &unit : manifest.units) {\r\n\u001b[?2004l\r"]
[366.685374, "o", "\u001b[?2004h"]
[366.685389, "o", "> "]
[366.685553, "o", "        name_ptrs.push_back(unit.name.c_str());\r\n\u001b[?2004l\r"]
[366.685572, "o", "\u001b[?2004h"]
[366.685587, "o", "> "]
[366.68565, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[366.68567, "o", "> \r\n\u001b[?2004l\r"]
[366.685724, "o", "\u001b[?2004h> "]
[366.685906, "o", "    std::map<std::string, forge::UnitSpec> spec_by_name;\r\n\u001b[?2004l\r"]
[366.685925, "o", "\u001b[?2004h"]
[366.685941, "o", "> "]
[366.686122, "o", "    for (const auto &unit : manifest.units) {\r\n\u001b[?2004l\r"]
[366.68614, "o", "\u001b[?2004h"]
[366.686156, "o", "> "]
[366.686299, "o", "        spec_by_name[unit.name] = unit;\r\n\u001b[?2004l\r"]
[366.686319, "o", "\u001b[?2004h"]
[366.686337, "o", "> "]
[366.686397, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[366.686417, "o", "> \r\n\u001b[?2004l\r"]
[366.68647, "o", "\u001b[?2004h> "]
[366.686599, "o", "    std::vector<forge::UnitRun> units;\r\n\u001b[?2004l\r"]
[366.686618, "o", "\u001b[?2004h"]
[366.686633, "o", "> "]
[366.686827, "o", "    std::vector<forge::UnitCheckpoint> updated_entries;\r\n\u001b[?2004l\r"]
[366.686846, "o", "\u001b[?2004h"]
[366.686863, "o", "> "]
[366.687023, "o", "    std::vector<std::string> requested_resume;\r\n\u001b[?2004l\r"]
[366.687042, "o", "\u001b[?2004h"]
[366.687058, "o", "> "]
[366.687202, "o", "    for (const auto &name : requested) {\r\n\u001b[?2004l\r"]
[366.687222, "o", "\u001b[?2004h"]
[366.687235, "o", "> "]
[366.687388, "o", "        auto it = spec_by_name.find(name);\r\n\u001b[?2004l\r"]
[366.687406, "o", "\u001b[?2004h"]
[366.687423, "o", "> "]
[366.687563, "o", "        if (it == spec_by_name.end()) {\r\n\u001b[?2004l\r"]
[366.687583, "o", "\u001b[?2004h"]
[366.687641, "o", "> "]
[366.68769, "o", "            continue;\r\n\u001b[?2004l\r"]
[366.687742, "o", "\u001b[?2004h> "]
[366.687789, "o", "        }\r\n\u001b[?2004l\r"]
[366.687808, "o", "\u001b[?2004h"]
[366.687856, "o", "> "]
[366.688014, "o", "        int order_rank = static_cast<int>(std::distance(\r\n\u001b[?2004l\r"]
[366.688036, "o", "\u001b[?2004h"]
[366.688092, "o", "> "]
[366.688186, "o", "            manifest.units.begin(),\r\n\u001b[?2004l\r"]
[366.688205, "o", "\u001b[?2004h"]
[366.688221, "o", "> "]
[366.688449, "o", "            std::find_if(manifest.units.begin(), manifest.units.end(),\r\n\u001b[?2004l\r"]
[366.688468, "o", "\u001b[?2004h"]
[366.688483, "o", "> "]
[366.688755, "o", "                         [&](const forge::UnitSpec &u) { return u.name == name; })));\r\n\u001b[?2004l\r"]
[366.688774, "o", "\u001b[?2004h"]
[366.688833, "o", "> "]
[366.688891, "o", "        int64_t cw = 0;\r\n\u001b[?2004l\r"]
[366.688909, "o", "\u001b[?2004h"]
[366.688922, "o", "> "]
[366.689043, "o", "        if (checkpoint.valid) {\r\n\u001b[?2004l\r"]
[366.689062, "o", "\u001b[?2004h"]
[366.689073, "o", "> "]
[366.689268, "o", "            auto cp = checkpoint.units.find(name);\r\n\u001b[?2004l\r"]
[366.689294, "o", "\u001b[?2004h"]
[366.689309, "o", "> "]
[366.689472, "o", "            if (cp != checkpoint.units.end()) {\r\n\u001b[?2004l\r"]
[366.689491, "o", "\u001b[?2004h"]
[366.689506, "o", "> "]
[366.689669, "o", "                cw = cp->second.carry_weight;\r\n\u001b[?2004l\r"]
[366.68969, "o", "\u001b[?2004h"]
[366.689746, "o", "> "]
[366.689767, "o", "            }\r\n\u001b[?2004l\r"]
[366.689823, "o", "\u001b[?2004h> "]
[366.689876, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h"]
[366.689919, "o", "> "]
[366.690223, "o", "        forge::UnitRun run = forge::analyze_unit(it->second, order_rank, manifest.order_weight_base,\r\n\u001b[?2004l\r"]
[366.690241, "o", "\u001b[?2004h"]
[366.690257, "o", "> "]
[366.690552, "o", "                                                 pass_epoch, manifest_dir, name_ptrs.data(),\r\n\u001b[?2004l\r"]
[366.690573, "o", "\u001b[?2004h"]
[366.690632, "o", "> "]
[366.690881, "o", "                                                 name_ptrs.size(), &checkpoint, cw);\r\n\u001b[?2004l\r"]
[366.690899, "o", "\u001b[?2004h"]
[366.690914, "o", "> "]
[366.691034, "o", "        units.push_back(run);\r\n\u001b[?2004l\r"]
[366.691055, "o", "\u001b[?2004h"]
[366.691109, "o", "> "]
[366.691209, "o", "        if (run.mode == \"resume\") {\r\n\u001b[?2004l\r"]
[366.691227, "o", "\u001b[?2004h"]
[366.691239, "o", "> "]
[366.691405, "o", "            requested_resume.push_back(name);\r\n\u001b[?2004l\r"]
[366.691424, "o", "\u001b[?2004h"]
[366.691438, "o", "> "]
[366.691588, "o", "            forge::UnitCheckpoint entry;\r\n\u001b[?2004l\r"]
[366.691606, "o", "\u001b[?2004h"]
[366.69162, "o", "> "]
[366.691754, "o", "            entry.name = run.name;\r\n\u001b[?2004l\r"]
[366.691773, "o", "\u001b[?2004h"]
[366.691787, "o", "> "]
[366.691959, "o", "            entry.next_pass = run.pass_index + 1;\r\n\u001b[?2004l\r"]
[366.691978, "o", "\u001b[?2004h"]
[366.691992, "o", "> "]
[366.692167, "o", "            entry.carry_weight = run.order_weight;\r\n\u001b[?2004l\r"]
[366.692186, "o", "\u001b[?2004h"]
[366.692201, "o", "> "]
[366.692372, "o", "            entry.carry_drift = run.drift_bytes;\r\n\u001b[?2004l\r"]
[366.69239, "o", "\u001b[?2004h"]
[366.692406, "o", "> "]
[366.692569, "o", "            updated_entries.push_back(entry);\r\n\u001b[?2004l\r"]
[366.692587, "o", "\u001b[?2004h"]
[366.692602, "o", "> "]
[366.692663, "o", "        }\r\n\u001b[?2004l\r"]
[366.692682, "o", "\u001b[?2004h"]
[366.692697, "o", "> "]
[366.692759, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[366.692777, "o", "> \r\n\u001b[?2004l\r"]
[366.692825, "o", "\u001b[?2004h> "]
[366.693071, "o", "    int64_t drift_total = forge_lane_drift_total(units.data(), units.size());\r\n\u001b[?2004l\r"]
[366.693089, "o", "\u001b[?2004h"]
[366.693103, "o", "> "]
[366.693356, "o", "    int64_t weight_total = forge_lane_score_total(units.data(), units.size());\r\n\u001b[?2004l\r"]
[366.693374, "o", "\u001b[?2004h"]
[366.693429, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[366.693448, "o", "> "]
[366.693557, "o", "    std::ostringstream serial;\r\n\u001b[?2004l\r"]
[366.693632, "o", "\u001b[?2004h> "]
[366.693893, "o", "    serial << forge_lane_header_text(forge::kSchemaVersion, manifest.release_id,\r\n\u001b[?2004l\r"]
[366.693912, "o", "\u001b[?2004h"]
[366.693927, "o", "> "]
[366.694229, "o", "                                     manifest.order_weight_base, pass_epoch, drift_total,\r\n\u001b[?2004l\r"]
[366.694248, "o", "\u001b[?2004h"]
[366.694262, "o", "> "]
[366.694446, "o", "                                     weight_total);\r\n\u001b[?2004l\r"]
[366.694467, "o", "\u001b[?2004h"]
[366.694482, "o", "> "]
[366.694622, "o", "    for (const auto &unit : units) {\r\n\u001b[?2004l\r"]
[366.694681, "o", "\u001b[?2004h> "]
[366.694828, "o", "        serial << '\\n' << unit.row_serial;\r\n\u001b[?2004l\r"]
[366.694849, "o", "\u001b[?2004h"]
[366.694863, "o", "> "]
[366.694924, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[366.694944, "o", "> "]
[366.695145, "o", "    std::string top_digest = forge::digest_hex(serial.str());\r\n\u001b[?2004l\r"]
[366.695166, "o", "\u001b[?2004h"]
[366.695266, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[366.695428, "o", "    fs::create_directories(output_path.parent_path());\r\n\u001b[?2004l\r"]
[366.695486, "o", "\u001b[?2004h"]
[366.695509, "o", "> "]
[366.695595, "o", "    std::ostringstream out;\r\n\u001b[?2004l\r"]
[366.695648, "o", "\u001b[?2004h> "]
[366.695894, "o", "    out << \"{\\\"schema_version\\\":\" << forge::kSchemaVersion << \",\\\"release_id\\\":\\\"\"\r\n\u001b[?2004l\r"]
[366.695967, "o", "\u001b[?2004h> "]
[366.696236, "o", "        << manifest.release_id << \"\\\",\\\"order_weight_base\\\":\" << manifest.order_weight_base\r\n\u001b[?2004l\r"]
[366.696279, "o", "\u001b[?2004h"]
[366.696301, "o", "> "]
[366.696503, "o", "        << \",\\\"pass_epoch\\\":\" << pass_epoch << \",\\\"units\\\":[\";\r\n\u001b[?2004l\r"]
[366.696532, "o", "\u001b[?2004h> "]
[366.69673, "o", "    for (std::size_t i = 0; i < units.size(); ++i) {\r\n\u001b[?2004l\r"]
[366.696756, "o", "\u001b[?2004h> "]
[366.696865, "o", "        if (i) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[366.696887, "o", "> "]
[366.696991, "o", "            out << ',';\r\n\u001b[?2004l\r"]
[366.697016, "o", "\u001b[?2004h"]
[366.69703, "o", "> "]
[366.697092, "o", "        }\r\n\u001b[?2004l\r"]
[366.697109, "o", "\u001b[?2004h"]
[366.697124, "o", "> "]
[366.697246, "o", "        out << units[i].json;\r\n\u001b[?2004l\r"]
[366.697267, "o", "\u001b[?2004h"]
[366.697325, "o", ">     }\r\n\u001b[?2004l\r"]
[366.697344, "o", "\u001b[?2004h"]
[366.697359, "o", "> "]
[366.697648, "o", "    out << \"],\\\"total_drift_bytes\\\":\" << drift_total << \",\\\"order_score\\\":\" << weight_total\r\n\u001b[?2004l\r"]
[366.697665, "o", "\u001b[?2004h"]
[366.69768, "o", "> "]
[366.697864, "o", "        << \",\\\"digest\\\":\\\"\" << top_digest << \"\\\"}\\n\";\r\n\u001b[?2004l\r"]
[366.697882, "o", "\u001b[?2004h"]
[366.697894, "o", "> "]
[366.698096, "o", "    std::ofstream file(output_path, std::ios::binary);\r\n\u001b[?2004l\r"]
[366.698114, "o", "\u001b[?2004h"]
[366.698128, "o", "> "]
[366.698238, "o", "    file << out.str();\r\n\u001b[?2004l\r"]
[366.698314, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[366.698383, "o", "\u001b[?2004h> "]
[366.698608, "o", "    // Merge checkpoint entries: preserve existing valid entries, update requested ones\r\n\u001b[?2004l\r"]
[366.698673, "o", "\u001b[?2004h"]
[366.698694, "o", "> "]
[366.698841, "o", "    std::vector<forge::UnitCheckpoint> merged =\r\n\u001b[?2004l\r"]
[366.69887, "o", "\u001b[?2004h> "]
[366.699148, "o", "        forge_lane_merge_checkpoint(checkpoint, updated_entries, requested_resume);\r\n\u001b[?2004l\r"]
[366.699171, "o", "\u001b[?2004h"]
[366.699285, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[366.699415, "o", "    // Write checkpoint file with pass_epoch\r\n\u001b[?2004l\r"]
[366.699444, "o", "\u001b[?2004h> "]
[366.699681, "o", "    fs::create_directories(fs::path(checkpoint_path).parent_path());\r\n\u001b[?2004l\r"]
[366.699711, "o", "\u001b[?2004h"]
[366.699725, "o", "> "]
[366.699843, "o", "    std::ostringstream cp_out;\r\n\u001b[?2004l\r"]
[366.6999, "o", "\u001b[?2004h> "]
[366.700156, "o", "    cp_out << \"{\\\"schema_version\\\":\" << forge::kSchemaVersion << \",\\\"lane_token\\\":\\\"\"\r\n\u001b[?2004l\r"]
[366.700208, "o", "\u001b[?2004h> "]
[366.700483, "o", "           << lane_token_str << \"\\\",\\\"pass_epoch\\\":\" << (pass_epoch + 1) << \",\\\"units\\\":[\";\r\n\u001b[?2004l\r"]
[366.700534, "o", "\u001b[?2004h> "]
[366.700695, "o", "    for (size_t i = 0; i < merged.size(); ++i) {\r\n\u001b[?2004l\r"]
[366.700748, "o", "\u001b[?2004h> "]
[366.700816, "o", "        if (i) {\r\n\u001b[?2004l\r"]
[366.700866, "o", "\u001b[?2004h> "]
[366.700962, "o", "            cp_out << ',';\r\n\u001b[?2004l\r"]
[366.701011, "o", "\u001b[?2004h> "]
[366.701064, "o", "        }\r\n\u001b[?2004l\r"]
[366.701083, "o", "\u001b[?2004h"]
[366.701138, "o", "> "]
[366.701407, "o", "        cp_out << \"{\\\"name\\\":\\\"\" << merged[i].name << \"\\\",\\\"next_pass\\\":\" << merged[i].next_pass\r\n\u001b[?2004l\r"]
[366.701428, "o", "\u001b[?2004h"]
[366.701483, "o", "> "]
[366.701724, "o", "               << \",\\\"carry_weight\\\":\" << merged[i].carry_weight << \",\\\"carry_drift\\\":\"\r\n\u001b[?2004l\r"]
[366.701744, "o", "\u001b[?2004h"]
[366.701827, "o", "> "]
[366.701938, "o", "               << merged[i].carry_drift << '}';\r\n\u001b[?2004l\r"]
[366.702014, "o", "\u001b[?2004h"]
[366.702085, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[366.702172, "o", "> "]
[366.70227, "o", "    cp_out << \"]}\\n\";\r\n\u001b[?2004l\r\u001b[?2004h> "]
[366.702414, "o", "    std::ofstream cp_file(checkpoint_path, std::ios::binary);\r\n\u001b[?2004l\r"]
[366.702476, "o", "\u001b[?2004h"]
[366.702568, "o", ">     cp_file << cp_out.str();\r\n\u001b[?2004l\r"]
[366.702593, "o", "\u001b[?2004h"]
[366.702609, "o", "> \r\n\u001b[?2004l\r"]
[366.702685, "o", "\u001b[?2004h> "]
[366.702702, "o", "    return 0;"]
[366.702717, "o", "\r\n\u001b[?2004l\r"]
[366.702786, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r"]
[366.702834, "o", "\u001b[?2004h> "]
[366.702877, "o", "ENDOFFILE\r\n\u001b[?2004l\r"]
