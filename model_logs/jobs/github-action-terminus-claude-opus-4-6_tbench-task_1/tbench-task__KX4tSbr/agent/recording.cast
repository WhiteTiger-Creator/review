[285.92628, "o", "\u001b[?2004h> "]
[285.926549, "o", "extern \"C\" const char *m14_lane_token(const forge::UnitSpec *units, size_t count) {\r\n\u001b[?2004l\r"]
[285.926571, "o", "\u001b[?2004h> "]
[285.926685, "o", "    static std::string cached;\r\n\u001b[?2004l\r"]
[285.926704, "o", "\u001b[?2004h"]
[285.926717, "o", "> "]
[285.926949, "o", "    // Build descriptor lines and sort alphabetically by unit name\r\n\u001b[?2004l\r"]
[285.926976, "o", "\u001b[?2004h"]
[285.926989, "o", "> "]
[285.927254, "o", "    std::vector<std::pair<std::string, std::string>> descriptors;\r\n\u001b[?2004l\r"]
[285.927357, "o", "\u001b[?2004h> "]
[285.927398, "o", "    for (size_t i = 0; i < count; ++i) {\r\n\u001b[?2004l\r"]
[285.927423, "o", "\u001b[?2004h"]
[285.927438, "o", "> "]
[285.927684, "o", "        descriptors.push_back({units[i].name, descriptor_line(units[i])});\r\n\u001b[?2004l\r"]
[285.927727, "o", "\u001b[?2004h"]
[285.92775, "o", ">     }\r\n\u001b[?2004l\r"]
[285.92788, "o", "\u001b[?2004h> "]
[285.927999, "o", "    std::sort(descriptors.begin(), descriptors.end(),\r\n\u001b[?2004l\r"]
[285.928027, "o", "\u001b[?2004h"]
[285.928041, "o", "> "]
[285.928302, "o", "              [](const auto &a, const auto &b) { return a.first < b.first; });\r\n\u001b[?2004l\r"]
[285.928324, "o", "\u001b[?2004h> "]
[285.928462, "o", "    std::ostringstream joined;\r\n\u001b[?2004l\r"]
[285.928498, "o", "\u001b[?2004h> "]
[285.928666, "o", "    for (size_t i = 0; i < descriptors.size(); ++i) {\r\n\u001b[?2004l\r"]
[285.928691, "o", "\u001b[?2004h"]
[285.928719, "o", "> "]
[285.92878, "o", "        if (i) {\r\n\u001b[?2004l\r"]
[285.928857, "o", "\u001b[?2004h> "]
[285.928965, "o", "            joined << '\\n';\r\n\u001b[?2004l\r\u001b[?2004h> "]
[285.929081, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h"]
[285.9291, "o", "> "]
[285.929221, "o", "        joined << descriptors[i].second;\r\n\u001b[?2004l\r"]
[285.929249, "o", "\u001b[?2004h> "]
[285.929302, "o", "    }\r\n\u001b[?2004l\r"]
[285.930112, "o", "\u001b[?2004h> "]
[285.93033, "o", "    cached = digest_hex(joined.str());\r\n\u001b[?2004l\r"]
[285.930438, "o", "\u001b[?2004h> "]
[285.930576, "o", "    return cached.c_str();\r\n\u001b[?2004l\r"]
[285.930649, "o", "\u001b[?2004h"]
[285.930748, "o", "> }\r\n\u001b[?2004l\r"]
[285.930837, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[285.930912, "o", "\u001b[?2004h"]
