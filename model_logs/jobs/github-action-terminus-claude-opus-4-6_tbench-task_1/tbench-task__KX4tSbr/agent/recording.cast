[285.931316, "o", "extern \"C\" int m14_checkpoint_valid(const char *on_disk_token, const char *expected_token) {\r\n\u001b[?2004l\r"]
[285.931406, "o", "\u001b[?2004h> "]
[285.931595, "o", "    if (on_disk_token == nullptr || expected_token == nullptr) {\r\n\u001b[?2004l\r"]
[285.931666, "o", "\u001b[?2004h> "]
[285.931719, "o", "        return 0;\r\n\u001b[?2004l\r"]
[285.931773, "o", "\u001b[?2004h"]
[285.931839, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[285.931892, "o", "> "]
[285.932161, "o", "    return std::string(on_disk_token) == std::string(expected_token) ? 1 : 0;\r\n\u001b[?2004l\r"]
[285.932235, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h"]
[285.932315, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[285.93258, "o", "forge::LaneCheckpoint m14_read_checkpoint(const std::filesystem::path &path,\r\n\u001b[?2004l\r"]
[285.932663, "o", "\u001b[?2004h> "]
[285.932911, "o", "                                                   const std::string &expected_token) {\r\n"]
[285.932977, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[285.933108, "o", "    forge::LaneCheckpoint state;\r\n\u001b[?2004l\r"]
[285.93319, "o", "\u001b[?2004h> "]
[285.933259, "o", "    std::ifstream in(path);\r\n\u001b[?2004l\r"]
[285.933329, "o", "\u001b[?2004h> "]
[285.933407, "o", "    if (!in) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[285.933465, "o", "> "]
[285.93354, "o", "        return state;\r\n\u001b[?2004l\r\u001b[?2004h"]
[285.933624, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[285.933743, "o", "    std::ostringstream buffer;\r\n\u001b[?2004l\r"]
[285.933805, "o", "\u001b[?2004h> "]
[285.933914, "o", "    buffer << in.rdbuf();\r\n\u001b[?2004l\r"]
[285.934092, "o", "\u001b[?2004h> "]
[285.934234, "o", "    const std::string doc = buffer.str();\r\n\u001b[?2004l\r\u001b[?2004h> "]
[285.934419, "o", "    if (doc.find(\"\\\"schema_version\\\"\") == std::string::npos) {\r\n\u001b[?2004l\r"]
[285.934642, "o", "\u001b[?2004h> "]
[285.934724, "o", "        return state;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[285.934927, "o", "    state.lane_token = pick_string(doc, \"lane_token\");\r\n\u001b[?2004l\r\u001b[?2004h> "]
[285.935215, "o", "    if (!m14_checkpoint_valid(state.lane_token.c_str(), expected_token.c_str())) {\r\n\u001b[?2004l\r"]
[285.935362, "o", "\u001b[?2004h>         return state;\r\n\u001b[?2004l\r\u001b[?2004h"]
[285.935512, "o", ">     }\r\n"]
[285.935601, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[285.935676, "o", "    size_t units_pos = doc.find(\"\\\"units\\\"\");\r\n\u001b[?2004l\r\u001b[?2004h> "]
[285.935847, "o", "    if (units_pos == std::string::npos) {\r\n\u001b[?2004l\r"]
[285.935915, "o", "\u001b[?2004h> "]
[285.936, "o", "        return state;\r\n\u001b[?2004l\r"]
[285.936061, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[285.936116, "o", "\u001b[?2004h> "]
[285.936318, "o", "    size_t arr_start = doc.find('[', units_pos);\r\n\u001b[?2004l\r"]
[285.936397, "o", "\u001b[?2004h> "]
[285.936527, "o", "    size_t arr_end = doc.find(']', arr_start);\r\n"]
[285.936598, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[285.936843, "o", "    if (arr_start == std::string::npos || arr_end == std::string::npos) {\r\n\u001b[?2004l\r"]
[285.93687, "o", "\u001b[?2004h"]
[285.936884, "o", "> "]
[285.93704, "o", "        return state;\r\n\u001b[?2004l\r"]
[285.937194, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[285.937336, "o", "    const std::string arr = doc.substr(arr_start, arr_end - arr_start + 1);\r\n\u001b[?2004l\r"]
[285.937446, "o", "\u001b[?2004h> "]
[285.937572, "o", "    for (const auto &block : split_object_blocks(arr)) {\r\n\u001b[?2004l\r"]
[285.937647, "o", "\u001b[?2004h> "]
[285.937801, "o", "        forge::UnitCheckpoint entry;\r\n\u001b[?2004l\r"]
[285.937817, "o", "\u001b[?2004h> "]
[285.938017, "o", "        entry.name = pick_string(block, \"name\");\r\n\u001b[?2004l\r"]
[285.938059, "o", "\u001b[?2004h"]
[285.938095, "o", "> "]
[285.938285, "o", "        entry.next_pass = pick_int(block, \"next_pass\");\r\n"]
[285.938331, "o", "\u001b[?2004l\r"]
[285.938363, "o", "\u001b[?2004h"]
[285.938397, "o", "> "]
[285.93862, "o", "        entry.carry_weight = pick_int64(block, \"carry_weight\");\r\n\u001b[?2004l\r"]
[285.938667, "o", "\u001b[?2004h> "]
[285.938919, "o", "        entry.carry_drift = pick_int64(block, \"carry_drift\");\r\n\u001b[?2004l\r"]
[285.938974, "o", "\u001b[?2004h"]
[285.939016, "o", "> "]
[285.939147, "o", "        if (!entry.name.empty()) {\r\n\u001b[?2004l\r"]
[285.939192, "o", "\u001b[?2004h> "]
[285.939364, "o", "            state.units[entry.name] = entry;\r\n\u001b[?2004l\r"]
[285.939412, "o", "\u001b[?2004h"]
[285.939458, "o", "> "]
[285.939498, "o", "        }\r\n\u001b[?2004l\r"]
[285.939534, "o", "\u001b[?2004h"]
[285.939568, "o", ">     }\r\n\u001b[?2004l\r"]
[285.939612, "o", "\u001b[?2004h"]
[285.939634, "o", "> "]
[285.939708, "o", "    state.valid = true;\r\n\u001b[?2004l\r"]
[285.93975, "o", "\u001b[?2004h> "]
[285.939833, "o", "    return state;\r\n\u001b[?2004l\r"]
[285.939879, "o", "\u001b[?2004h"]
[285.939927, "o", "> "]
[285.939939, "o", "}\r\n\u001b[?2004l\r"]
[285.93995, "o", "\u001b[?2004h"]
[285.939976, "o", "> "]
[285.93999, "o", "\r\n\u001b[?2004l\r"]
[285.940028, "o", "\u001b[?2004h"]
[285.94004, "o", "> "]
[285.940246, "o", "std::vector<forge::UnitCheckpoint> m14_merge_entries(\r\n"]
[285.940259, "o", "\u001b[?2004l\r"]
[285.940304, "o", "\u001b[?2004h"]
[285.940343, "o", "> "]
[285.94067, "o", "    const forge::LaneCheckpoint &existing, const std::vector<forge::UnitCheckpoint> &updated,\r\n\u001b[?2004l\r"]
[285.940707, "o", "\u001b[?2004h"]
[285.94074, "o", "> "]
[285.940935, "o", "    const std::vector<std::string> &requested_resume) {\r\n\u001b[?2004l\r"]
[285.940975, "o", "\u001b[?2004h> "]
[285.941181, "o", "    // Start with existing valid checkpoint entries\r\n\u001b[?2004l\r"]
[285.941219, "o", "\u001b[?2004h"]
[285.941254, "o", "> "]
[285.941449, "o", "    std::map<std::string, forge::UnitCheckpoint> merged;\r\n\u001b[?2004l\r"]
[285.941493, "o", "\u001b[?2004h> "]
[285.941602, "o", "    if (existing.valid) {\r\n\u001b[?2004l\r"]
[285.941643, "o", "\u001b[?2004h> "]
[285.941841, "o", "        for (const auto &pair : existing.units) {\r\n\u001b[?2004l\r"]
[285.941878, "o", "\u001b[?2004h"]
[285.941911, "o", "> "]
[285.942977, "o", "            merged[pair.first] = pair.second;\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h>     // Update with newly computed entries\r\n\u001b[?2004l\r\u001b[?2004h>     for (const auto &entry : updated) {\r\n\u001b[?2004l\r\u001b[?2004h>         merged[entry.name] = entry;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[285.943114, "o", "    // Convert to sorted vector\r\n\u001b[?2004l\r"]
[285.943245, "o", "\u001b[?2004h> "]
[285.943378, "o", "    std::vector<forge::UnitCheckpoint> out;\r\n\u001b[?2004l\r"]
[285.943462, "o", "\u001b[?2004h> "]
[285.943611, "o", "    for (const auto &pair : merged) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[285.943687, "o", "        out.push_back(pair.second);\r\n\u001b[?2004l\r"]
[285.943803, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[285.9439, "o", "\u001b[?2004h> "]
[285.944021, "o", "    std::sort(out.begin(), out.end(),\r\n\u001b[?2004l\r"]
[285.944102, "o", "\u001b[?2004h> "]
[285.944297, "o", "              [](const forge::UnitCheckpoint &a, const forge::UnitCheckpoint &b) {\r\n\u001b[?2004l\r"]
[285.944392, "o", "\u001b[?2004h> "]
[285.944512, "o", "                  return a.name < b.name;\r\n\u001b[?2004l\r"]
[285.944605, "o", "\u001b[?2004h> "]
[285.944679, "o", "              });\r\n\u001b[?2004l\r\u001b[?2004h> "]
[285.944852, "o", "    return out;\r\n\u001b[?2004l\r"]
[285.944901, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[285.945198, "o", "void m14_write_checkpoint(const std::filesystem::path &path, const char *lane_token,\r\n\u001b[?2004l\r"]
[285.945282, "o", "\u001b[?2004h> "]
[285.945586, "o", "                                     const std::vector<forge::UnitCheckpoint> &entries) {\r\n\u001b[?2004l\r"]
[285.945678, "o", "\u001b[?2004h> "]
[285.947249, "o", "    // This is now a no-op; checkpoint writing is handled in emit_pipeline\r\n\u001b[?2004l\r\u001b[?2004h>     (void)path;\r\n\u001b[?2004l\r\u001b[?2004h>     (void)lane_token;\r\n\u001b[?2004l\r\u001b[?2004h>     (void)entries;\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[285.948287, "o", "\u001b[?2004h"]
[285.948391, "o", "root@607b4f5bd756:/app# "]
[366.610038, "i", "cat > /app/environment/runner/emit_pipeline.cpp << 'ENDOFFILE'\n#include \"emit_pipeline.h\"\n#include \"lane_bridge.h\"\n#include \"scan_bridge.h\"\n#include \"store_bridge.h\"\n#include \"constants.h\"\n#include \"types.h\"\n#include <algorithm>\n#include <cctype>\n#include <filesystem>\n#include <fstream>\n#include <iomanip>\n#include <iostream>\n#include <map>\n#include <sstream>\n#include <stdexcept>\n#include <string>\n#include <vector>\n\nnamespace fs = std::filesystem;\n\nnamespace forge {\n\nconstexpr const char *kCheckpointPath = \"/app/output/forge_checkpoint.json\";\n\nnamespace {\n\nstd::string read_file(const fs::path &path) {\n    std::ifstream in(path, std::ios::binary);\n    if (!in) {\n        throw std::runtime_error(\"could not open fixture\");\n    }\n    std::ostringstream ss;\n    ss << in.rdbuf();\n    return ss.str();\n}\n\nstd::string pick_string(const std::string &block, const std::string &key) {\n    std::string needle = \"\\\"\" + key + \"\\\"\";\n    size_t k = block.find(needle);\n    if (k == std::string::npos) {\n        return \"\";\n    }\n  "]
[366.610181, "i", "  size_t q = block.find('\"', block.find(':', k) + 1);\n    size_t e = block.find('\"', q + 1);\n    if (q == std::string::npos || e == std::string::npos) {\n        return \"\";\n    }\n    return block.substr(q + 1, e - q - 1);\n}\n\nint pick_int(const std::string &block, const std::string &key) {\n    std::string needle = \"\\\"\" + key + \"\\\"\";\n    size_t k = block.find(needle);\n    if (k == std::string::npos) {\n        return 0;\n    }\n    size_t colon = block.find(':', k);\n    if (colon == std::string::npos) {\n        return 0;\n    }\n    size_t start = colon + 1;\n    while (start < block.size() && std::isspace(static_cast<unsigned char>(block[start]))) {\n        ++start;\n    }\n    size_t end = start;\n    if (end < block.size() && block[end] == '-') ++end;\n    while (end < block.size() && std::isdigit(static_cast<unsigned char>(block[end]))) {\n        ++end;\n    }\n    return std::stoi(block.substr(start, end - start));\n}\n\nstd::string extract_array(const std::string &doc, const std::string &key) {\n    std::string needle = \""]
[366.610233, "i", "\\\"\" + key + \"\\\"\";\n    size_t k = doc.find(needle);\n    if (k == std::string::npos) {\n        return \"\";\n    }\n    size_t p = doc.find('[', k);\n    if (p == std::string::npos) {\n        return \"\";\n    }\n    int depth = 0;\n    size_t start = p;\n    for (size_t i = p; i < doc.size(); ++i) {\n        if (doc[i] == '[') {\n            ++depth;\n        }\n        if (doc[i] == ']') {\n            --depth;\n            if (depth == 0) {\n                return doc.substr(start, i - start + 1);\n            }\n        }\n    }\n    return \"\";\n}\n\nstd::vector<std::string> split_object_blocks(const std::string &array_text) {\n    std::vector<std::string> out;\n    int depth = 0;\n    size_t start = std::string::npos;\n    for (size_t i = 0; i < array_text.size(); ++i) {\n        if (array_text[i] == '{') {\n            if (depth == 0) {\n                start = i;\n            }\n            ++depth;\n        } else if (array_text[i] == '}') {\n            --depth;\n            if (depth == 0 && start != std::string::npos) {\n                "]
[366.610288, "i", "out.push_back(array_text.substr(start, i - start + 1));\n                start = std::string::npos;\n            }\n        }\n    }\n    return out;\n}\n\nint64_t read_record_bytes(const fs::path &path) {\n    std::string blob = read_file(path);\n    size_t offset = 0;\n    while (offset < blob.size()) {\n        size_t end = blob.find('\\n', offset);\n        if (end == std::string::npos) {\n            end = blob.size();\n        }\n        if (end > offset) {\n            const char *line = blob.data() + offset;\n            size_t len = end - offset;\n            if (forge_scan_has_key(line, len, \"size_bytes=\")) {\n                return forge_scan_record_bytes(line, len);\n            }\n        }\n        if (end >= blob.size()) {\n            break;\n        }\n        offset = end + 1;\n    }\n    return 0;\n}\n\nstd::uint64_t digest_update(std::uint64_t h, const std::string &text) {\n    for (unsigned char ch : text) {\n        h ^= static_cast<std::uint64_t>(ch);\n        h = (h * kDigestStep) & kDigestMask;\n    }\n    return h;\n}\n\ns"]
