[285.925136, "o", "            if (depth == 0 && start != std::string::npos) {\r\n\u001b[?2004l\r"]
[285.925159, "o", "\u001b[?2004h"]
[285.925174, "o", "> "]
[285.925414, "o", "                out.push_back(array_text.substr(start, i - start + 1));\r\n\u001b[?2004l\r"]
[285.925444, "o", "\u001b[?2004h> "]
[285.925593, "o", "                start = std::string::npos;\r\n\u001b[?2004l\r"]
[285.925611, "o", "\u001b[?2004h> "]
[285.925687, "o", "            }\r\n\u001b[?2004l\r"]
[285.925709, "o", "\u001b[?2004h> "]
[285.925757, "o", "        }\r\n\u001b[?2004l\r"]
[285.925796, "o", "\u001b[?2004h> "]
[285.925835, "o", "    }\r\n\u001b[?2004l\r"]
[285.92587, "o", "\u001b[?2004h"]
[285.925885, "o", "> "]
[285.92595, "o", "    return out;\r\n\u001b[?2004l\r"]
[285.925967, "o", "\u001b[?2004h"]
[285.925977, "o", "> "]
[285.926008, "o", "}\r\n\u001b[?2004l\r"]
