ts]\n    if len(submits) > 1:\n        first_comp = kinds.index(\'complete\')\n        last_sub = len(kinds) - 1 - kinds[::-1].index(\'submit\')\n        assert first_comp < last_sub, "Not interleaved"\n    \n    return events\n\nall_ok = True\nresults = {}\n\nfor scn in scenarios:\n    for prof in profiles:\n        for ord in orders:\n            out = f\'/app/output/test_{scn}_{prof}_{ord}.json\'\n            cmd = [\'arena\', \'--scenario\', scn, \'--profile\', prof, \'--order\', ord, \'--out\', out]\n            r = subprocess.run(cmd, capture_output=True)\n            if r.returncode != 0:\n                print(f\'FAIL: {" ".join(cmd)} -> exit {r.returncode}\')\n                print(r.stderr.decode())\n                all_ok = False\n                continue\n            try:\n                evts = check_report(out, scn, prof)\n                results[(scn, prof, ord)] = evts\n                print(f\'OK: {scn}/{prof}/{ord} -> {len(evts)} events\')\n            except Exception as ex:\n                print(f\'FAIL: {scn}/{prof}/{ord}: {ex}\')\n                all_ok = False\n\n# Check reconciliation order changes sequence\nfor scn in scenarios:\n    for prof in profiles:\n        a_evts = results.get((scn, prof, \'a_then_b\'))\n        b_evts = results.get((scn, prof, \'b_then_a\'))\n        if a_evts and b_evts:\n            a_comp = [e[\'id\'] for e in a_evts if e[\'kind\'] == \'complete\']\n            b_comp = [e[\'id\'] for e in b_evts if e[\'kind\'] == \'complete\']\n            if sorted(a_comp) == sorted(b_comp) and a_comp != b_comp:\n                print(f\'  Order diff OK: {scn}/{prof}\')\n            elif a_comp == b_comp:\n                print(f\'  WARNING: same sequence for {scn}/{prof}\')\n            else:\n                print(f\'  ERROR: different coverage for {scn}/{prof}\')\n                all_ok = False\n\n# Check reproducibility\nfor scn in scenarios:\n    for prof in profiles:\n        for ord in orders:\n            out1 = f\'/ap