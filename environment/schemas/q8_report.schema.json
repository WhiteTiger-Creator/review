{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["case_id", "run_mode", "witness_rows", "barrier_margins", "replay_deltas", "merge_token"],
  "properties": {
    "case_id": { "type": "integer" },
    "run_mode": { "type": "string", "enum": ["direct", "held", "stress"] },
    "witness_rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["arm_id", "cluster_id", "margin", "ref"],
        "properties": {
          "arm_id": { "type": "integer" },
          "cluster_id": { "type": "string" },
          "margin": { "type": "integer" },
          "ref": { "type": "string", "pattern": "^w-[0-9a-f]{12}$" }
        }
      }
    },
    "barrier_margins": {
      "type": "array",
      "items": { "type": "integer", "minimum": 0 }
    },
    "replay_deltas": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step", "arm_id", "cluster_id", "delta"],
        "properties": {
          "step": { "type": "integer" },
          "arm_id": { "type": "integer" },
          "cluster_id": { "type": "string" },
          "delta": { "type": "integer" }
        }
      }
    },
    "merge_token": { "type": "string", "pattern": "^[0-9a-f]{16}$" }
  }
}
