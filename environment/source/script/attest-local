#!/usr/bin/env bash
set -euo pipefail
ARCHIVE="${1:?archive path required}"
REF="${2:-}"
URL="http://127.0.0.1:${PORT:-3000}/api/v1/attestations"
if [ -n "$REF" ]; then
  curl -sS -X POST "$URL" -F "archive=@${ARCHIVE}" -F "release_ref=${REF}"
else
  curl -sS -X POST "$URL" -F "archive=@${ARCHIVE}"
fi
echo
