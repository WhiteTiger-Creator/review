set(CMAKE_SYSTEM_NAME Linux)
find_program(TERMATRIX_MUSL_CC musl-gcc)
if(TERMATRIX_MUSL_CC)
  set(CMAKE_C_COMPILER "${TERMATRIX_MUSL_CC}" CACHE FILEPATH "")
else()
  set(CMAKE_C_COMPILER gcc CACHE FILEPATH "")
endif()
set(TERMATRIX_TARGET_NAME "musl-x86_64" CACHE STRING "")
set(TERMATRIX_ABI_FAMILY "musl" CACHE STRING "")
set(TERMATRIX_ABI_DEFINE "TERMATRIX_ABI_MUSL" CACHE STRING "")
set(TERMATRIX_TARGET_DEFINE "TERMATRIX_TARGET_MUSL_X86_64" CACHE STRING "")
set(TERMATRIX_COMPILER_PROFILE "musl-gcc" CACHE STRING "")
