{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Advisory risk report",
  "type": "object",
  "required": ["schema_version", "packages"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "4"
    },
    "packages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "assessed_version",
          "pages_referenced",
          "advisory_count",
          "max_severity",
          "risk_score",
          "advisories"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9_.-]+$"
          },
          "assessed_version": {
            "type": "string",
            "pattern": "^[0-9]+(\\.[0-9]+)*$"
          },
          "pages_referenced": {
            "type": "integer",
            "minimum": 1
          },
          "advisory_count": {
            "type": "integer",
            "minimum": 1
          },
          "max_severity": {
            "type": "number",
            "minimum": 0,
            "maximum": 10
          },
          "risk_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 10
          },
          "advisories": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
