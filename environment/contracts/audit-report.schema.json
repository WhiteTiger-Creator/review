{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifacts": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "input_digest": {
      "pattern": "^[a-f0-9]{64}$",
      "type": "string"
    },
    "issue_count": {
      "minimum": 0,
      "type": "integer"
    },
    "issues": {
      "items": {
        "properties": {
          "artifact": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "pointer": {
            "type": "string"
          }
        },
        "required": [
          "artifact",
          "pointer",
          "code",
          "message"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "registry_digest": {
      "type": "string"
    },
    "success": {
      "type": "boolean"
    }
  },
  "required": [
    "input_digest",
    "registry_digest",
    "issue_count",
    "success",
    "issues",
    "artifacts"
  ],
  "type": "object"
}
