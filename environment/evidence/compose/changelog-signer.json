{
  "name": "nimbusvault-release",
  "services": {
    "nimbus-changelog": {
      "image": "registry.local/nimbus/changelog:2024.12",
      "environment": {
        "SIGNING_BACKEND": "sigstore"
      }
    }
  },
  "x-nimbus-exceptions": [
    {
      "id": "NV-EX-004",
      "service": "nimbus-changelog",
      "rule": "SIGNED_RELEASE_PIPELINE",
      "bundle": "rekor"
    }
  ]
}
