{
  "name": "nimbusvault-prod",
  "services": {
    "nimbus-worker": {
      "image": "registry.local/nimbus/worker:2024.12",
      "secrets": [
        {
          "source": "legacy_token",
          "target": "/run/secrets/legacy_token",
          "mode": 292
        }
      ]
    }
  },
  "secrets": {
    "legacy_token": {
      "file": "/vault/rotated/legacy_token"
    }
  },
  "x-nimbus-exceptions": [
    {
      "id": "NV-EX-002",
      "service": "nimbus-worker",
      "rule": "SECRET_MOUNT_LEGACY",
      "read_only": true
    }
  ]
}
