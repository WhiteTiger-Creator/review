{
  "name": "nimbusvault-stage",
  "services": {
    "nimbus-preview": {
      "image": "registry.local/nimbus/preview:2024.10",
      "environment": {
        "NV_MTLS_MODE": "exception-bound"
      }
    }
  },
  "x-nimbus-exceptions": [
    {
      "id": "NV-EX-005",
      "service": "nimbus-preview",
      "rule": "MTLS_REMOTE_DEBUG",
      "network": "stage-vpn-only"
    }
  ]
}
