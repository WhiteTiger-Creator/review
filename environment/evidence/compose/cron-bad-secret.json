{
  "name": "nimbusvault-prod",
  "services": {
    "nimbus-cron": {
      "image": "registry.local/nimbus/cron:2024.12",
      "secrets": [
        {
          "source": "legacy_token",
          "target": "/run/secrets/legacy_token",
          "mode": 384
        }
      ]
    }
  },
  "secrets": {
    "legacy_token": {
      "file": "/vault/rotated/legacy_token"
    }
  },
  "x-nimbus-exceptions": [
    {
      "id": "NV-EX-003",
      "service": "nimbus-cron",
      "rule": "SECRET_MOUNT_LEGACY",
      "read_only": false
    }
  ]
}
