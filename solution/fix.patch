+            const t1 = (tt - x0) / x1x0;
+            const t11 = 1.0 - t1;
+            out[i] = t11 * y0 + t1 * y1 + t1 * t11 * (a1 * t11 + b1 * t1);
+        } else {
+            const t2 = (tt - x1) / x2x1;
+            const t22 = 1.0 - t2;
+            out[i] = t22 * y1 + t2 * y2 + t2 * t22 * (a2 * t22 + b2 * t2);
+        }
+    }
+    return out;
+}
+
+function solve3(r0: number[], r1: number[], r2: number[], b: number[]): number[] {
+    const a = [r0.slice(), r1.slice(), r2.slice()];
+    const v = b.slice();
+    // Gaussian elimination with partial pivoting
+    for (let col = 0; col < 3; col++) {
+        let piv = col;
+        for (let r = col + 1; r < 3; r++) if (Math.abs(a[r][col]) > Math.abs(a[piv][col])) piv = r;
+        if (piv !== col) {
+            const t = a[piv];
+            a[piv] = a[col];
+            a[col] = t;
+            const tv = v[piv];
+            v[piv] = v[col];
+            v[col] = tv;
+        }
+        for (let r = col + 1; r < 3; r++) {
+            const f = a[r][col] / a[col][col];
+            for (let c = col; c < 3; c++) a[r][c] -= f * a[col][c];
+            v[r] -= f * v[col];
+        }
+    }
+    const x = new Array<number>(3);
+    for (let i = 2; i >= 0; i--) {
+        let s = v[i];
+        for (let c = i + 1; c < 3; c++) s -= a[i][c] * x[c];
+        x[i] = s / a[i][i];
+    }
+    return x;
+}
+
+// ---- helpers for slicing/mirroring ----
+function revSub(arr: number[], from: number, toExcl: number): number[] {
+    // arr[from:toExcl][::-1]
+    const f = Math.max(0, from);
+    const t = Math.min(arr.length, toExcl);
+    if (t <= f) return [];
+    const out = new Array<number>(t - f);
+    let j = 0;
+    for (let i = t - 1; i >= f; i--) out[j++] = arr[i];
+    return out;
+}
+function subFrom(arr: number[], from: number): number[] {
+    const f = Math.max(0, from);
+    return arr.slice(f, arr.length);
+}
+function revFrom(arr: number[], from: number): number[] {
+    // arr[from:][::-1]
+    return revArr(subFrom(arr, from));
+}
+function revRange(arr: number[], from: number, toExcl: number): number[] {
+    // arr[from:toExcl][::-1]  (toExcl may be arr.length-1 for a[:-1])
+    return revSub(arr, from, toExcl);
+}
+function revArr(arr: number[]): number[] {
+    const out = new Array<number>(arr.length);
+    for (let i = 0; i < arr.length; i++) out[i] = arr[arr.length - 1 - i];
+    return out;
+}
+function appendVal(arr: number[], v: number): number[] {
+    // np.append(arr, v)  -> arr followed by v
+    const out = arr.slice();
+    out.push(v);
+    return out;
+}
+function concat(a: number[], b: number[], c: number[]): number[] {
+    const out = new Array<number>(a.length + b.length + c.length);
+    for (let i = 0; i < a.length; i++) out[i] = a[i];
+    for (let i = 0; i < b.length; i++) out[a.length + i] = b[i];
+    for (let i = 0; i < c.length; i++) out[a.length + b.length + i] = c[i];
+    return out;
+}
+
+/*
+ * Not-a-knot cubic spline, matching scipy.interpolate.CubicSpline default
+ * boundary conditions. Solves for first derivatives (Hermite form).
+ */
+class CubicSplineNotAKnot {
+    private x: number[];
+    private y: number[];
+    private nseg: number;
+    private c1: number[];
+
+    constructor(xIn: number[], yIn: number[]) {
+        this.x = xIn;
+        this.y = yIn;
+        this.nseg = xIn.length - 1;
+        const x = this.x;
+        const y = this.y;
+        const nseg = this.nseg;
+        const n = x.length;
+        const h = new Array<number>(nseg);
+        for (let i = 0; i < nseg; i++) h[i] = x[i + 1] - x[i];
+        const slope = new Array<number>(nseg);
+        for (let i = 0; i < nseg; i++) slope[i] = (y[i + 1] - y[i]) / h[i];
+
+        const a = new Array<number>(n).fill(0);
+        const b = new Array<number>(n).fill(0);
+        const c = new Array<number>(n).fill(0);
+        const rhs = new Array<number>(n).fill(0);
+
+        if (n === 2) {
+            b[0] = 1.0;
+            c[0] = 0.0;
+            rhs[0] = slope[0];
+            a[1] = 0.0;
+            b[1] = 1.0;
+            rhs[1] = slope[0];
+        } else {
+            for (let i = 1; i < n - 1; i++) {
+                a[i] = h[i];
+                b[i] = 2.0 * (h[i - 1] + h[i]);
+                c[i] = h[i - 1];
+                rhs[i] = 3.0 * (h[i] * slope[i - 1] + h[i - 1] * slope[i]);
+            }
+            const h0 = h[0];
+            const h1 = h[1];
+            b[0] = h1;
+            c[0] = h0 + h1;
+            rhs[0] = ((h0 + 2.0 * (h0 + h1)) * h1 * slope[0] + h0 * h0 * slope[1]) / (h0 + h1);
+            const hn2 = h[nseg - 2];
+            const hn1 = h[nseg - 1];
+            a[n - 1] = hn2 + hn1;
+            b[n - 1] = hn2;
+            rhs[n - 1] = (hn1 * hn1 * slope[nseg - 2] + (2.0 * (hn2 + hn1) + hn1) * hn2 * slope[nseg - 1]) / (hn2 + hn1);
+        }
+
+        this.c1 = this.solveTridiag(a, b, c, rhs);
+    }
+
+    private solveTridiag(aIn: number[], bIn: number[], cIn: number[], dIn: number[]): number[] {
+        const n = bIn.length;
+        const a = aIn.slice();
+        const b = bIn.slice();
+        const c = cIn.slice();
+        const d = dIn.slice();
+        for (let i = 1; i < n; i++) {
+            const m = a[i] / b[i - 1];
+            b[i] -= m * c[i - 1];
+            d[i] -= m * d[i - 1];
+        }
+        const xr = new Array<number>(n);
+        xr[n - 1] = d[n - 1] / b[n - 1];
+        for (let i = n - 2; i >= 0; i--) xr[i] = (d[i] - c[i] * xr[i + 1]) / b[i];
+        return xr;
+    }
+
+    eval(t: number): number {
+        const x = this.x;
+        const y = this.y;
+        const nseg = this.nseg;
+        let seg: number;
+        if (t <= x[0]) seg = 0;
+        else if (t >= x[x.length - 1]) seg = nseg - 1;
+        else {
+            let lo = 0;
+            let hi = nseg - 1;
+            seg = 0;
+            while (lo <= hi) {
+                const mid = (lo + hi) >>> 1;
+                if (t < x[mid]) hi = mid - 1;
+                else if (t >= x[mid + 1]) lo = mid + 1;
+                else {
+                    seg = mid;
+                    break;
+                }
+            }
+        }
+        const h = x[seg + 1] - x[seg];
+        const slope = (y[seg + 1] - y[seg]) / h;
+        const d0 = this.c1[seg];
+        const d1 = this.c1[seg + 1];
+        const ttt = t - x[seg];
+        const cc = (3.0 * slope - 2.0 * d0 - d1) / h;
+        const dd = (d0 + d1 - 2.0 * slope) / (h * h);
+        return y[seg] + d0 * ttt + cc * ttt * ttt + dd * ttt * ttt * ttt;
+    }
 }
