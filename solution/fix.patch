+// cubic_spline_3pts port
+function cubicSpline3pts(x: number[], y: number[], T: number[]): number[] {
+    const x0 = x[0];
+    const x1 = x[1];
+    const x2 = x[2];
+    const y0 = y[0];
+    const y1 = y[1];
+    const y2 = y[2];
+    const x1x0 = x1 - x0;
+    const x2x1 = x2 - x1;
+    const y1y0 = y1 - y0;
+    const y2y1 = y2 - y1;
+    const _x1x0 = 1.0 / x1x0;
+    const _x2x1 = 1.0 / x2x1;
+    const m11 = 2 * _x1x0;
+    const m12 = _x1x0;
+    const m13 = 0.0;
+    const m21 = _x1x0;
+    const m22 = 2.0 * (_x1x0 + _x2x1);
+    const m23 = _x2x1;
+    const m31 = 0.0;
+    const m32 = _x2x1;
+    const m33 = 2.0 * _x2x1;
+    const v1 = 3 * y1y0 * _x1x0 * _x1x0;
+    const v3 = 3 * y2y1 * _x2x1 * _x2x1;
+    const v2 = v1 + v3;
+    // solve 3x3
+    const k = solve3(
+        [m11, m12, m13],
+        [m21, m22, m23],
+        [m31, m32, m33],
+        [v1, v2, v3],
