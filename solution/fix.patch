+// spline_points: choose cubic (not-a-knot) or 3pt spline; crop to T within support.
+function splinePoints(T: number[], extrema: number[][]): number[] | null {
+    const n = T.length;
+    const ex = extrema[0];
+    const ey = extrema[1];
+    const out = new Array<number>(n);
+    if (ex.length > 3) {
+        const spline = new CubicSplineNotAKnot(ex, ey);
+        for (let i = 0; i < n; i++) out[i] = spline.eval(T[i]);
+    } else {
+        // cubic_spline_3pts requires exactly 3 points
+        if (ex.length !== 3) return null;
+        const q = cubicSpline3pts(ex, ey, T);
+        for (let i = 0; i < n; i++) out[i] = q[i];
+    }
+    return out;
