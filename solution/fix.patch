+void write_interface_ledger(
+    const fs::path &root,
+    const fs::path &stage,
+    const Descriptor &descriptor) {
+    fs::path ledger_tmp = stage / ("interface_ledger.json.tmp." + std::to_string(static_cast<long long>(getpid())));
