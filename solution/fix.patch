+    out << "    \"cmake_targets\": \"lib/cmake/Termatrix/TermatrixTargets.cmake\",\n";
+    out << "    \"imported_target\": \"Termatrix::termatrix\",\n";
+    out << "    \"include_dir\": \"include\",\n";
+    out << "    \"library\": \"lib/libtermatrix.a\",\n";
+    out << "    \"compile_definitions\": [";
