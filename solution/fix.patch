+void write_cmake_package(
+    const fs::path &root,
+    const fs::path &stage,
+    const Descriptor &descriptor) {
+    std::string fragment_sha = sha256_file(root / descriptor.interface_fragment_file);
+    fs::path cmake_dir = stage / "lib/cmake/Termatrix";
+    fs::create_directories(cmake_dir);
+
+    fs::path config = cmake_dir / "TermatrixConfig.cmake";
+    std::ofstream cfg(config);
+    cfg << "# Generated by " << kGenerator << "\n";
+    cfg << "# interface-fragment-sha256=" << fragment_sha << "\n";
+    cfg << "include(\"${CMAKE_CURRENT_LIST_DIR}/TermatrixTargets.cmake\")\n";
+    cfg << "set(Termatrix_FOUND TRUE)\n";
+    cfg << "set(TERMATRIX_TARGET_NAME \"" << descriptor.target_name << "\")\n";
+    cfg << "set(TERMATRIX_ABI_FAMILY \"" << descriptor.abi_family << "\")\n";
+    cfg << "set(TERMATRIX_INTERFACE_IDENTITY \"termatrix-interface|abi="
+        << descriptor.abi_family << "|target=" << descriptor.target_name << "\")\n";
+    cfg.close();
+
+    fs::path targets = cmake_dir / "TermatrixTargets.cmake";
+    std::ofstream tgt(targets);
+    tgt << "# Generated by " << kGenerator << "\n";
+    tgt << "# interface-fragment-sha256=" << fragment_sha << "\n";
+    tgt << "if(NOT TARGET Termatrix::termatrix)\n";
+    tgt << "  add_library(Termatrix::termatrix STATIC IMPORTED)\n";
+    tgt << "  get_filename_component(_termatrix_prefix \"${CMAKE_CURRENT_LIST_DIR}/../../..\" ABSOLUTE)\n";
+    tgt << "  set_target_properties(Termatrix::termatrix PROPERTIES\n";
+    tgt << "    IMPORTED_LOCATION \"${_termatrix_prefix}/lib/libtermatrix.a\"\n";
+    tgt << "    INTERFACE_INCLUDE_DIRECTORIES \"${_termatrix_prefix}/include\"\n";
+    tgt << "    INTERFACE_COMPILE_DEFINITIONS \""
+        << descriptor.abi_define << "=1;" << descriptor.target_define << "=1\"\n";
+    tgt << "  )\n";
+    tgt << "endif()\n";
+}
