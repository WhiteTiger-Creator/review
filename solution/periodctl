#!/bin/bash
# periodctl — entrypoint for fiscal-window balance snapshot materialization.
set -euo pipefail

LOCKFILE="/tmp/periodctl.lock"

# Acquire lock and ensure it is cleaned up on exit.
acquire_lock() {
    if [ -f "$LOCKFILE" ]; then
        local pid
        pid=$(cat "$LOCKFILE" 2>/dev/null || echo "")
        if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
            echo "Error: Another reconciliation is in progress (PID: $pid)." >&2
            exit 1
        fi
    fi
    echo "$$" > "$LOCKFILE"
}

acquire_lock
trap 'rm -f "$LOCKFILE"' EXIT

JOURNALS_DIR=""
ACCOUNTS_FILE=""
PERIOD_FILE=""
OUTPUT_FILE=""

usage() {
    echo "Usage: periodctl --postings <dir> --accounts <tsv> --window <json> --snapshot <file>" >&2
    exit 2
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --postings) JOURNALS_DIR="$2"; shift 2 ;;
        --accounts) ACCOUNTS_FILE="$2"; shift 2 ;;
        --window) PERIOD_FILE="$2"; shift 2 ;;
        --snapshot) OUTPUT_FILE="$2"; shift 2 ;;
        *) usage ;;
    esac
done

if [[ -z "$JOURNALS_DIR" || -z "$ACCOUNTS_FILE" || -z "$PERIOD_FILE" || -z "$OUTPUT_FILE" ]]; then
    usage
fi

# Exit with 2 if files/directories are missing or unreadable.
# Root bypasses POSIX read checks on mode 000, so also require a read bit in the mode.
lacks_read_bits() {
    local mode oct
    mode=$(stat -c '%a' "$1" 2>/dev/null) || return 0
    oct=$((8#$mode))
    (( (oct & 0444) == 0 ))
}

if [[ ! -d "$JOURNALS_DIR" ]]; then
    exit 2
fi
if [[ ! -e "$ACCOUNTS_FILE" || ! -e "$PERIOD_FILE" ]]; then
    exit 2
fi
if [[ ! -r "$ACCOUNTS_FILE" || ! -r "$PERIOD_FILE" ]] \
    || lacks_read_bits "$ACCOUNTS_FILE" \
    || lacks_read_bits "$PERIOD_FILE"; then
    exit 2
fi

# Invoke the python reconciler passing arguments safely with quotes.
python3 /app/src/reconciler.py \
    --postings "$JOURNALS_DIR" \
    --accounts "$ACCOUNTS_FILE" \
    --window "$PERIOD_FILE" \
    --snapshot "$OUTPUT_FILE"
