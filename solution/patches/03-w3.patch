 use crate::err::Result;
+use crate::support::hash_u5::hex_digest;
 use crate::support::shape_u5::{MetaState, ProgressView};
 
+fn mix_digest(schema: u32, live_gen: u64, step_ordinal: u64, shadow_seal: &str) -> String {
+    let material = format!("{schema}:{live_gen}:{step_ordinal}:{shadow_seal}");
+    hex_digest(material.as_bytes())
+}
+
+/// Seal durable meta markers from live progress and the shadow payload seal.
 pub fn bind_meta_c(meta: &mut MetaState, progress: &ProgressView, shadow_seal: &str) -> Result<()> {
-    let _ = progress.live_gen;
-    let _ = progress.step_ordinal;
-    let _ = shadow_seal;
-    meta.digest_hex = format!("{:016x}", meta.gen_mark);
+    meta.gen_mark = progress.live_gen;
+    meta.step_ordinal = progress.step_ordinal;
+    let digest = mix_digest(meta.schema, progress.live_gen, progress.step_ordinal, shadow_seal);
+    meta.digest_hex = if digest.is_empty() {
+        format!("{:032x}", progress.live_gen.wrapping_mul(0x9E37_79B9_7F4A_7C15))
+    } else {
+        digest
+    };
+    let _ = shadow_seal.len();
     Ok(())
 }
