+        next unless line.start_with?("[GNUPG:] VALIDSIG")
+        parts = line.split
+        signing = parts[2]
+        primary = parts[-1]
+        next unless [signing, primary].include?(c)
+        fingerprint = c
+      end
+      FileUtils.rm_rf(gnupg_home)
+      raise Errors::ReleaseFailure.new("unsigned_tag", "tag signature missing") unless fingerprint
